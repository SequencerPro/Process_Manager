    private async Task MoveBlock(StepTemplateContentResponseDto block, int direction)
    {
        _contentError = null;
        try
        {
            var ordered = _contentBlocks.OrderBy(b => b.SortOrder).ToList();
            var idx = ordered.IndexOf(block);
            var newIdx = idx + direction;
            if (newIdx < 0 || newIdx >= ordered.Count) return;
            ordered.RemoveAt(idx);
            ordered.Insert(newIdx, block);
            var dto = new ReorderStepTemplateContentBlocksDto(ordered.Select(b => b.Id).ToList());
            await Api.ReorderStepTemplateContentAsync(Id, dto);
            await ReloadAfterContentChange();
        }
        catch (Exception ex) { _contentError = ex.Message; }
    }

