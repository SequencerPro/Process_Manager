@page "/vocabulary"
@rendermode InteractiveServer
@inject ApiClient Api
@inject IJSRuntime JS

<PageTitle>Domain Vocabulary</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Domain Vocabulary</h3>
    <button class="btn btn-primary btn-sm" @onclick="ShowCreate">
        <i class="bi bi-plus-lg me-1"></i> New Vocabulary
    </button>
</div>

<div class="mb-3">
    <SearchBox Value="@_search" ValueChanged="OnSearch" Placeholder="Search vocabularies..." />
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_data is not null)
{
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Kind</th>
                    <th>Grade</th>
                    <th>Item</th>
                    <th>Batch</th>
                    <th>Job</th>
                    <th>Process</th>
                    <th>Step</th>
                    <th style="width:140px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!_data.Items.Any())
                {
                    <tr><td colspan="9" class="text-center text-muted py-3">No vocabularies found.</td></tr>
                }
                else
                {
                @foreach (var v in _data.Items)
                {
                    <tr>
                        <td><strong>@v.Name</strong></td>
                        <td>@v.TermKind</td>
                        <td>@v.TermGrade</td>
                        <td>@v.TermItem</td>
                        <td>@v.TermBatch</td>
                        <td>@v.TermJob</td>
                        <td>@v.TermProcess</td>
                        <td>@v.TermStep</td>
                        <td>
                            <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => ShowEdit(v)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(v.Id)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
                }
            </tbody>
        </table>
    </div>

    <Pager Page="_page" PageSize="_pageSize" TotalCount="_data.TotalCount"
           OnPageChanged="OnPageChanged" />
}

@if (_showForm)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editId.HasValue ? "Edit" : "New") Vocabulary</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input class="form-control" @bind="_formName"
                               title="A label for this vocabulary set. e.g. Manufacturing, Lab, Warehouse" />
                    </div>
                    <div class="row g-3">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Term: Kind</label>
                            <input class="form-control" @bind="_formTermKind"
                                   title="The category or type of thing. e.g. Part Type, Material, Component" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Term: Kind Code</label>
                            <input class="form-control" @bind="_formTermKindCode"
                                   title="The short identifier for a Kind. e.g. Part Number, SKU, Material ID" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Term: Grade</label>
                            <input class="form-control" @bind="_formTermGrade"
                                   title="The quality or disposition state of an item. e.g. Disposition, Quality Level, Condition" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Term: Item</label>
                            <input class="form-control" @bind="_formTermItem"
                                   title="A single trackable unit. e.g. Unit, Asset, Serial Number" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Term: Item ID</label>
                            <input class="form-control" @bind="_formTermItemId"
                                   title="The unique identifier for an individual item. e.g. Serial Number, Asset Tag, VIN" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Term: Batch</label>
                            <input class="form-control" @bind="_formTermBatch"
                                   title="A group of items produced or processed together. e.g. Lot, Run, Spool, Heat" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Term: Batch ID</label>
                            <input class="form-control" @bind="_formTermBatchId"
                                   title="The unique identifier for a batch. e.g. Lot Number, Heat Number, Run Code" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Term: Job</label>
                            <input class="form-control" @bind="_formTermJob"
                                   title="A production execution instance. e.g. Work Order, Production Run, Campaign" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Term: Workflow</label>
                            <input class="form-control" @bind="_formTermWorkflow"
                                   title="A directed graph of processes. e.g. Routing, Value Stream, Product Flow" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Term: Process</label>
                            <input class="form-control" @bind="_formTermProcess"
                                   title="An ordered sequence of steps. e.g. Operation, Stage, Phase" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Term: Step</label>
                            <input class="form-control" @bind="_formTermStep"
                                   title="A single unit of work within a process. e.g. Activity, Task, Operation" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                    <button class="btn btn-primary" @onclick="Save">Save</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PaginatedResponse<DomainVocabularyResponseDto>? _data;
    private bool _loading = true;
    private string _search = "";
    private int _page = 1;
    private int _pageSize = 25;

    // Form
    private bool _showForm;
    private Guid? _editId;
    private string _formName = "";
    private string _formTermKind = "Kind";
    private string _formTermKindCode = "Kind Code";
    private string _formTermGrade = "Grade";
    private string _formTermItem = "Item";
    private string _formTermItemId = "Serial Number";
    private string _formTermBatch = "Batch";
    private string _formTermBatchId = "Batch Code";
    private string _formTermJob = "Job";
    private string _formTermWorkflow = "Workflow";
    private string _formTermProcess = "Process";
    private string _formTermStep = "Step";

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _data = await Api.GetVocabulariesAsync(_search, _page, _pageSize);
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearch(string v) { _search = v; _page = 1; await LoadData(); }
    private async Task OnPageChanged(int p) { _page = p; await LoadData(); }

    private void ShowCreate()
    {
        _editId = null;
        _formName = "";
        _formTermKind = "Kind"; _formTermKindCode = "Kind Code"; _formTermGrade = "Grade";
        _formTermItem = "Item"; _formTermItemId = "Serial Number";
        _formTermBatch = "Batch"; _formTermBatchId = "Batch Code";
        _formTermJob = "Job"; _formTermWorkflow = "Workflow";
        _formTermProcess = "Process"; _formTermStep = "Step";
        _showForm = true;
    }

    private void ShowEdit(DomainVocabularyResponseDto v)
    {
        _editId = v.Id; _formName = v.Name;
        _formTermKind = v.TermKind; _formTermKindCode = v.TermKindCode; _formTermGrade = v.TermGrade;
        _formTermItem = v.TermItem; _formTermItemId = v.TermItemId;
        _formTermBatch = v.TermBatch; _formTermBatchId = v.TermBatchId;
        _formTermJob = v.TermJob; _formTermWorkflow = v.TermWorkflow;
        _formTermProcess = v.TermProcess; _formTermStep = v.TermStep;
        _showForm = true;
    }

    private void CloseForm() { _showForm = false; }

    private async Task Save()
    {
        try
        {
            if (_editId.HasValue)
                await Api.UpdateVocabularyAsync(_editId.Value, new DomainVocabularyUpdateDto(
                    _formName, _formTermKind, _formTermKindCode, _formTermGrade,
                    _formTermItem, _formTermItemId, _formTermBatch, _formTermBatchId,
                    _formTermJob, _formTermWorkflow, _formTermProcess, _formTermStep));
            else
                await Api.CreateVocabularyAsync(new DomainVocabularyCreateDto(
                    _formName, _formTermKind, _formTermKindCode, _formTermGrade,
                    _formTermItem, _formTermItemId, _formTermBatch, _formTermBatchId,
                    _formTermJob, _formTermWorkflow, _formTermProcess, _formTermStep));
            _showForm = false;
            await LoadData();
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

    private async Task Delete(Guid id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this vocabulary entry?")) return;
        try { await Api.DeleteVocabularyAsync(id); await LoadData(); }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }
}
