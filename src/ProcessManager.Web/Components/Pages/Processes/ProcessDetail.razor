    }

    private async Task SubmitForApproval()
    {
        if (string.IsNullOrWhiteSpace(_lifecycleUser)) { Toast.ShowError("Submitted By is required."); return; }
        try
        {
            _proc = await Api.SubmitProcessForApprovalAsync(Id, new SubmitForApprovalDto(_lifecycleUser, _lifecycleNotes));
            _showSubmitModal = false; _lifecycleUser = ""; _lifecycleNotes = "";
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

    private async Task ApproveProcess()
    {
        if (string.IsNullOrWhiteSpace(_lifecycleUser)) { Toast.ShowError("Approved By is required."); return; }
        try
        {
            _proc = await Api.ApproveProcessAsync(Id, new ApproveDto(_lifecycleUser, _lifecycleNotes));
            _showApproveModal = false; _lifecycleUser = ""; _lifecycleNotes = "";
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

    private async Task RejectProcess()
    {
        if (string.IsNullOrWhiteSpace(_lifecycleUser)) { Toast.ShowError("Rejected By is required."); return; }
        try
        {
            _proc = await Api.RejectProcessAsync(Id, new RejectDto(_lifecycleUser, _lifecycleNotes ?? ""));
            _showRejectModal = false; _lifecycleUser = ""; _lifecycleNotes = "";
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

    private async Task NewRevision()
    {
        if (string.IsNullOrWhiteSpace(_lifecycleUser)) { Toast.ShowError("Requested By is required."); return; }
        try
        {
            var newProc = await Api.NewProcessRevisionAsync(Id, new NewRevisionDto(_lifecycleUser));
