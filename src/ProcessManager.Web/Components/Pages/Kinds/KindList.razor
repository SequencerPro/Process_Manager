@page "/kinds"
@rendermode InteractiveServer
@inject ApiClient Api
@inject IJSRuntime JS

<PageTitle>Kinds & Grades</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Kinds & Grades</h3>
    <button class="btn btn-primary btn-sm" @onclick="ShowCreateForm">
        <i class="bi bi-plus-lg me-1"></i> New Kind
    </button>
</div>

<div class="d-flex gap-3 mb-3">
    <SearchBox Value="@_search" ValueChanged="OnSearch" Placeholder="Search kinds..." />
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_data is not null)
{
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Serialized</th>
                    <th>Batchable</th>
                    <th>Grades</th>
                    <th style="width:120px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!_data.Items.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-3">No kinds found.</td></tr>
                }
                else
                {
                @foreach (var kind in _data.Items)
                {
                    <tr>
                        <td><code>@kind.Code</code></td>
                        <td>
                            <a href="kinds/@kind.Id">@kind.Name</a>
                        </td>
                        <td>@(kind.IsSerialized ? "Yes" : "No")</td>
                        <td>@(kind.IsBatchable ? "Yes" : "No")</td>
                        <td>
                            @foreach (var g in kind.Grades)
                            {
                                <span class="badge bg-light text-dark border me-1">@g.Code</span>
                            }
                        </td>
                        <td>
                            <button class="btn btn-outline-secondary btn-sm me-1" title="Edit"
                                    @onclick="() => ShowEditForm(kind)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-outline-danger btn-sm" title="Delete"
                                    @onclick="() => DeleteKind(kind)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
                }
            </tbody>
        </table>
    </div>

    <Pager Page="_page" PageSize="_pageSize" TotalCount="_data.TotalCount"
           OnPageChanged="OnPageChanged" />
}

@if (_showForm)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editingId.HasValue ? "Edit Kind" : "New Kind")</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <EditForm Model="_form" OnValidSubmit="SaveKind">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Code</label>
                            <InputText class="form-control" @bind-Value="_form.Code" disabled="@_editingId.HasValue" />
                            <ValidationMessage For="() => _form.Code" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <InputText class="form-control" @bind-Value="_form.Name" />
                            <ValidationMessage For="() => _form.Name" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <InputTextArea class="form-control" @bind-Value="_form.Description" rows="2" />
                        </div>
                        <div class="form-check mb-2">
                            <InputCheckbox class="form-check-input" @bind-Value="_form.IsSerialized" />
                            <label class="form-check-label">Serialized</label>
                        </div>
                        <div class="form-check mb-2">
                            <InputCheckbox class="form-check-input" @bind-Value="_form.IsBatchable" />
                            <label class="form-check-label">Batchable</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    private PaginatedResponse<KindResponseDto>? _data;
    private bool _loading = true;
    private string _search = "";
    private int _page = 1;
    private int _pageSize = 25;

    // Form state
    private bool _showForm;
    private Guid? _editingId;
    private KindFormModel _form = new();

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _data = await Api.GetKindsAsync(_search, _page, _pageSize);
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearch(string value) { _search = value; _page = 1; await LoadData(); }
    private async Task OnPageChanged(int page) { _page = page; await LoadData(); }

    private void ShowCreateForm()
    {
        _editingId = null;
        _form = new();
        _showForm = true;
    }

    private void ShowEditForm(KindResponseDto kind)
    {
        _editingId = kind.Id;
        _form = new() { Code = kind.Code, Name = kind.Name, Description = kind.Description ?? "",
                         IsSerialized = kind.IsSerialized, IsBatchable = kind.IsBatchable };
        _showForm = true;
    }

    private void CloseForm() => _showForm = false;

    private async Task SaveKind()
    {
        try
        {
            if (_editingId.HasValue)
                await Api.UpdateKindAsync(_editingId.Value,
                    new KindUpdateDto(_form.Name, _form.Description, _form.IsSerialized, _form.IsBatchable));
            else
                await Api.CreateKindAsync(
                    new KindCreateDto(_form.Code, _form.Name, _form.Description, _form.IsSerialized, _form.IsBatchable));

            _showForm = false;
            await LoadData();
        }
        catch (HttpRequestException ex)
        {
            Toast.ShowError(ex.Message);
        }
    }

    private async Task DeleteKind(KindResponseDto kind)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Delete kind '{kind.Name}'?")) return;
        try
        {
            await Api.DeleteKindAsync(kind.Id);
            await LoadData();
        }
        catch (HttpRequestException ex)
        {
            Toast.ShowError(ex.Message);
        }
    }

    private class KindFormModel
    {
        public string Code { get; set; } = "";
        public string Name { get; set; } = "";
        public string? Description { get; set; }
        public bool IsSerialized { get; set; }
        public bool IsBatchable { get; set; }
    }
}
