@page "/picklists/{Id:guid}"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin,Engineer")]
@inject ApiClient Api
@inject NavigationManager Nav
@inject TokenService TokenService
@using Microsoft.AspNetCore.Authorization
@using ProcessManager.Api.DTOs
@using ProcessManager.Web.Services

<PageTitle>Pick List Detail</PageTitle>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div></div>
}
else if (_pickList is null)
{
    <div class="alert alert-danger">Pick list not found.</div>
}
else
{
    @* ── Header ── *@
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-1">
                Pick List for <a href="/jobs/@_pickList.JobId">@_pickList.JobCode</a>
            </h3>
            <span class="badge fs-6 @GetStatusBadgeClass(_pickList.Status)">@_pickList.Status</span>
            <span class="text-muted ms-3">Generated @_pickList.GeneratedAt.ToString("g")</span>
        </div>
        <div>
            @if (_pickList.Status is not "Completed" and not "ShortShipped")
            {
                <button class="btn btn-warning" @onclick="ShortShipAsync" disabled="@_saving">
                    <i class="bi bi-exclamation-triangle me-1"></i>Short-Ship Remaining
                </button>
            }
        </div>
    </div>

    @if (_error is not null)
    {
        <div class="alert alert-danger alert-dismissible">
            @_error
            <button type="button" class="btn-close" @onclick="() => _error = null"></button>
        </div>
    }

    @* ── Lines Table ── *@
    <div class="card">
        <div class="card-header"><i class="bi bi-list-ul me-2"></i>Lines (@_pickList.LineCount)</div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Kind Code</th>
                            <th>Kind Name</th>
                            <th>UoM</th>
                            <th>Source Location</th>
                            <th>Required Qty</th>
                            <th>Picked Qty</th>
                            <th>Consumed Qty</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_pickList.Lines is { Count: > 0 })
                        {
                            @foreach (var line in _pickList.Lines)
                            {
                                <tr>
                                    <td>@line.KindCode</td>
                                    <td>@line.KindName</td>
                                    <td>@line.UnitOfMeasure</td>
                                    <td>@line.SourceLocationCode</td>
                                    <td>@line.RequiredQuantity</td>
                                    <td>@line.PickedQuantity</td>
                                    <td>@line.ConsumedQuantity</td>
                                    <td><span class="badge @GetLineBadgeClass(line.Status)">@line.Status</span></td>
                                    <td>
                                        @if (line.Status == "Pending")
                                        {
                                            <button class="btn btn-sm btn-outline-primary" @onclick="() => OpenPickModal(line)">
                                                <i class="bi bi-check2 me-1"></i>Pick
                                            </button>
                                        }
                                        @if (line.Status == "Picked")
                                        {
                                            <button class="btn btn-sm btn-outline-success" @onclick="() => OpenConsumeModal(line)">
                                                <i class="bi bi-check2-all me-1"></i>Consume
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="9" class="text-muted text-center py-3">No lines.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@* ── Confirm Pick Modal ── *@
@if (_showPickModal && _selectedLine is not null)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Pick: @_selectedLine.KindCode</h5>
                    <button type="button" class="btn-close" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Item ID</label>
                        <input class="form-control" @bind="_pickItemId" placeholder="GUID" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Source Location ID</label>
                        <input class="form-control" @bind="_pickSourceLocationId" placeholder="GUID" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Picked Quantity</label>
                        <input type="number" class="form-control" @bind="_pickQuantity" />
                    </div>
                    @if (_modalError is not null)
                    {
                        <div class="alert alert-danger">@_modalError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModals">Cancel</button>
                    <button class="btn btn-primary" @onclick="SubmitPickAsync" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Confirm Pick
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Consume Modal ── *@
@if (_showConsumeModal && _selectedLine is not null)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Consume: @_selectedLine.KindCode</h5>
                    <button type="button" class="btn-close" @onclick="CloseModals"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Consumed Quantity</label>
                        <input type="number" class="form-control" @bind="_consumeQuantity" />
                    </div>
                    @if (_modalError is not null)
                    {
                        <div class="alert alert-danger">@_modalError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModals">Cancel</button>
                    <button class="btn btn-success" @onclick="SubmitConsumeAsync" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Consume
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool _loading = true;
    private bool _saving;
    private string? _error;
    private string? _modalError;
    private PickListResponseDto? _pickList;

    // Pick modal
    private bool _showPickModal;
    private PickListLineResponseDto? _selectedLine;
    private string _pickItemId = "";
    private string _pickSourceLocationId = "";
    private decimal _pickQuantity;

    // Consume modal
    private bool _showConsumeModal;
    private decimal _consumeQuantity;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _pickList = await Api.GetPickListAsync(Id);
        }
        catch { /* handled by null check */ }
        finally { _loading = false; }
    }

    private void OpenPickModal(PickListLineResponseDto line)
    {
        _selectedLine = line;
        _pickItemId = "";
        _pickSourceLocationId = "";
        _pickQuantity = line.RequiredQuantity;
        _modalError = null;
        _showPickModal = true;
    }

    private void OpenConsumeModal(PickListLineResponseDto line)
    {
        _selectedLine = line;
        _consumeQuantity = line.PickedQuantity;
        _modalError = null;
        _showConsumeModal = true;
    }

    private void CloseModals()
    {
        _showPickModal = false;
        _showConsumeModal = false;
        _selectedLine = null;
        _modalError = null;
    }

    private async Task SubmitPickAsync()
    {
        if (_selectedLine is null) return;
        _saving = true;
        _modalError = null;
        try
        {
            Guid? itemId = Guid.TryParse(_pickItemId, out var iid) ? iid : null;
            Guid? srcLocId = Guid.TryParse(_pickSourceLocationId, out var sl) ? sl : null;

            await Api.PickLineAsync(_pickList!.Id, _selectedLine.Id,
                new PickLineDto(itemId!.Value, srcLocId!.Value, _pickQuantity));

            CloseModals();
            await LoadAsync();
        }
        catch (Exception ex) { _modalError = ex.Message; }
        finally { _saving = false; }
    }

    private async Task SubmitConsumeAsync()
    {
        if (_selectedLine is null) return;
        _saving = true;
        _modalError = null;
        try
        {
            await Api.ConsumeLineAsync(_pickList!.Id, _selectedLine.Id,
                new ConsumeLineDto(_consumeQuantity));

            CloseModals();
            await LoadAsync();
        }
        catch (Exception ex) { _modalError = ex.Message; }
        finally { _saving = false; }
    }

    private async Task ShortShipAsync()
    {
        _saving = true;
        _error = null;
        try
        {
            await Api.ShortShipPickListAsync(_pickList!.Id);
            await LoadAsync();
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private static string GetStatusBadgeClass(string? status) => status switch
    {
        "Pending" => "bg-warning text-dark",
        "InProgress" => "bg-info",
        "Completed" => "bg-success",
        "ShortShipped" => "bg-danger",
        _ => "bg-secondary"
    };

    private static string GetLineBadgeClass(string? status) => status switch
    {
        "Pending" => "bg-warning text-dark",
        "Picked" => "bg-info",
        "Consumed" => "bg-success",
        "ShortShipped" => "bg-danger",
        _ => "bg-secondary"
    };
}
