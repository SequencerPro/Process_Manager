    private static string FileIcon(string mimeType) => mimeType switch
    {
        var m when m.StartsWith("image/") => "bi-file-earmark-image",
        "application/pdf" => "bi-file-earmark-pdf",
        var m when m.Contains("spreadsheet") || m.Contains("excel") => "bi-file-earmark-spreadsheet",
        var m when m.Contains("word") || m.Contains("document") => "bi-file-earmark-word",
        _ => "bi-file-earmark"
    };

    private static string FormatSourceType(string st) => st switch
    {
        "ReferenceDocument" => "Reference Document",
        _ => st
    };

    private static string SourceBadgeClass(string st) => st switch
    {
        "Make" => "bg-success-subtle text-success",
        "Buy" => "bg-primary-subtle text-primary",
        "ReferenceDocument" => "bg-info-subtle text-info",
        "Phantom" => "bg-warning-subtle text-warning",
        "Consumable" => "bg-secondary-subtle text-secondary",
        _ => "bg-light text-dark"
    };

