@page "/jobs"
@attribute [Authorize(Roles = "Admin,Engineer")]
@rendermode InteractiveServer
@inject ApiClient Api
@inject IJSRuntime JS
@inject VocabularyService Vocab
@implements IDisposable

<PageTitle>@Vocab.Jobs</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3 page-heading-row">
    <h3 class="mb-0">@Vocab.Jobs</h3>
    <button class="btn btn-primary btn-sm" @onclick="ShowCreate">
        <i class="bi bi-plus-lg me-1"></i> New @Vocab.Job
    </button>
</div>

<div class="d-flex gap-3 mb-3 flex-wrap">
    <SearchBox Value="@_search" ValueChanged="OnSearch" Placeholder="@($"Search {Vocab.Jobs.ToLower()}...")" />
    <select class="form-select form-select-sm" style="width:auto" @onchange="OnStatusFilter">
        <option value="" selected="@(_status is null)">All Statuses</option>
        <option value="Created"    selected="@(_status == "Created")">Created</option>
        <option value="InProgress" selected="@(_status == "InProgress")">In Progress</option>
        <option value="OnHold"     selected="@(_status == "OnHold")">On Hold</option>
        <option value="Completed"  selected="@(_status == "Completed")">Completed</option>
        <option value="Cancelled"  selected="@(_status == "Cancelled")">Cancelled</option>
    </select>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_data is not null)
{
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th class="col-hide-mobile">Process</th>
                    <th>Status</th>
                    <th class="col-hide-mobile">Priority</th>
                    <th class="col-hide-mobile">Created</th>
                    <th style="width:140px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!_data.Items.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-3">No jobs found.</td></tr>
                }
                else
                {
                @foreach (var j in _data.Items)
                {
                    <tr>
                        <td><code>@j.Code</code></td>
                        <td><a href="jobs/@j.Id">@j.Name</a></td>
                        <td class="col-hide-mobile">@j.ProcessName</td>
                        <td><StatusBadge Status="@j.Status" /></td>
                        <td class="col-hide-mobile">@j.Priority</td>
                        <td class="col-hide-mobile">@j.CreatedAt.ToString("g")</td>
                        <td>
                            <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => ShowEdit(j)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(j.Id)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
                }
            </tbody>
        </table>
    </div>

    <Pager Page="_page" PageSize="_pageSize" TotalCount="_data.TotalCount"
           OnPageChanged="OnPageChanged" />
}

@if (_showForm)
{
    <div class="modal show d-block pm-modal" tabindex="-1" style="background: rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <div class="pm-modal-icon pm-modal-icon-blue">
                        <i class="bi @(_editId.HasValue ? "bi-pencil-square" : "bi-plus-circle")"></i>
                    </div>
                    <div>
                        <h5 class="modal-title">@(_editId.HasValue ? "Edit" : "New") @Vocab.Job</h5>
                        <div class="pm-modal-subtitle">@(_editId.HasValue ? "Update job details" : "Select a process and configure your job")</div>
                    </div>
                    <button type="button" class="btn-close ms-auto" @onclick="CloseForm"></button>
                </div>
                <div class="modal-body">
                    @if (!_editId.HasValue)
                    {
                        <div class="pm-input-group">
                            <label><i class="bi bi-gear"></i> Process</label>
                            <div class="d-flex gap-2">
                                <select class="form-select" @bind="_formProcessId">
                                    <option value="">Select a process...</option>
                                    @if (_processes is not null)
                                    {
                                        @foreach (var p in _processes.Items)
                                        {
                                            <option value="@p.Id">@p.Name (@p.Code)</option>
                                        }
                                    }
                                </select>
                                <button type="button" class="pm-browse-btn" title="Browse processes" @onclick="() => _showPicker = true">
                                    <i class="bi bi-grid-3x3-gap"></i>
                                </button>
                            </div>
                        </div>
                        <div class="pm-input-group">
                            <label><i class="bi bi-upc-scan"></i> Code</label>
                            <input class="form-control" @bind="_formCode" />
                        </div>
                        <div class="pm-modal-divider">Details</div>
                    }
                    <div class="pm-input-group">
                        <label><i class="bi bi-type"></i> Name</label>
                        <input class="form-control" @bind="_formName" />
                    </div>
                    <div class="pm-input-group">
                        <label><i class="bi bi-card-text"></i> Description</label>
                        <textarea class="form-control" rows="2" @bind="_formDesc"></textarea>
                    </div>
                    <div class="pm-input-group">
                        <label><i class="bi bi-flag"></i> Priority</label>
                        <input type="number" class="form-control" @bind="_formPriority" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                    <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm"></span> }
                        <i class="bi @(_editId.HasValue ? "bi-check-lg" : "bi-plus-lg")"></i>
                        @(_editId.HasValue ? "Save Changes" : "Create Job")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showPicker && _processes is not null)
{
    <div class="modal show d-block pm-modal pm-picker" tabindex="-1" style="background: rgba(0,0,0,.55); z-index: 1060">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <div class="pm-modal-icon pm-modal-icon-blue">
                        <i class="bi bi-gear"></i>
                    </div>
                    <div>
                        <h5 class="modal-title">Select Process</h5>
                        <div class="pm-modal-subtitle">Browse and choose a process for your job</div>
                    </div>
                    <button type="button" class="btn-close ms-auto" @onclick="() => _showPicker = false"></button>
                </div>
                <div class="modal-body">
                    <div class="pm-picker-search">
                        <input type="text" placeholder="Search processes..." @bind="_pickerSearch" @bind:event="oninput" />
                    </div>
                    <div class="pm-picker-grid">
                        @{ var filtered = _processes.Items.Where(p =>
                            string.IsNullOrEmpty(_pickerSearch)
                            || p.Name.Contains(_pickerSearch, StringComparison.OrdinalIgnoreCase)
                            || p.Code.Contains(_pickerSearch, StringComparison.OrdinalIgnoreCase)).ToList(); }
                        @if (!filtered.Any())
                        {
                            <div class="pm-picker-empty">
                                <i class="bi bi-search d-block mb-2" style="font-size: 1.5rem"></i>
                                No processes match your search
                            </div>
                        }
                        @foreach (var p in filtered)
                        {
                            <div class="pm-picker-tile" @onclick="() => SelectProcessFromPicker(p)">
                                <div class="pm-picker-tile-code">@p.Code</div>
                                <div class="pm-picker-tile-name">@p.Name</div>
                                @if (!string.IsNullOrEmpty(p.Description))
                                {
                                    <div class="pm-picker-tile-desc">@p.Description</div>
                                }
                                <div class="pm-picker-tile-meta">
                                    <span class="pm-picker-tile-badge">v@(p.Version)</span>
                                    <span class="pm-picker-tile-badge">@p.StepCount steps</span>
                                    <span class="pm-picker-tile-badge" style="@(p.Status == "Released" ? "background: #d1e7dd; color: #0f5132" : "")">@p.Status</span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter][SupplyParameterFromQuery(Name = "status")] public string? StatusQuery { get; set; }

    private PaginatedResponse<JobResponseDto>? _data;
    private bool _loading = true;
    private string _search = "";
    private string? _status;
    private int _page = 1;
    private int _pageSize = 25;

    // Form
    private bool _showForm;
    private bool _saving;
    private Guid? _editId;
    private string _formCode = "";
    private string _formName = "";
    private string _formDesc = "";
    private string _formProcessId = "";
    private int _formPriority;
    private PaginatedResponse<ProcessSummaryResponseDto>? _processes;

    // Tile picker
    private bool _showPicker;
    private string _pickerSearch = "";

    protected override void OnInitialized() => Vocab.OnChange += OnVocabChanged;

    protected override async Task OnInitializedAsync()
    {
        _status = StatusQuery;
        await LoadData();
    }

    private void OnVocabChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Vocab.OnChange -= OnVocabChanged;

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _data = await Api.GetJobsAsync(_search, _status, null, _page, _pageSize);
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearch(string v) { _search = v; _page = 1; await LoadData(); }
    private async Task OnPageChanged(int p) { _page = p; await LoadData(); }

    private async Task OnStatusFilter(ChangeEventArgs e)
    {
        _status = string.IsNullOrEmpty(e.Value?.ToString()) ? null : e.Value.ToString();
        _page = 1; await LoadData();
    }

    private async Task ShowCreate()
    {
        _editId = null; _formCode = ""; _formName = ""; _formDesc = ""; _formProcessId = ""; _formPriority = 0;
        _showForm = true;
        _processes = await Api.GetProcessesAsync("", true, excludeDocumentRoles: true, pageSize: 100);
        StateHasChanged();
    }

    private void SelectProcessFromPicker(ProcessSummaryResponseDto p)
    {
        _formProcessId = p.Id.ToString();
        _formName = p.Name;
        _showPicker = false;
        _pickerSearch = "";
    }

    private void ShowEdit(JobResponseDto j)
    {
        _editId = j.Id; _formName = j.Name; _formDesc = j.Description ?? ""; _formPriority = j.Priority;
        _showForm = true;
    }

    private void CloseForm() { _showForm = false; }

    private async Task Save()
    {
        _saving = true;
        try
        {
            if (_editId.HasValue)
                await Api.UpdateJobAsync(_editId.Value, new UpdateJobDto(_formName, _formDesc, _formPriority));
            else
            {
                if (!Guid.TryParse(_formProcessId, out var pid)) { Toast.ShowError("Select a process."); return; }
                await Api.CreateJobAsync(new CreateJobDto(_formCode, _formName, _formDesc, pid, _formPriority));
            }
            _showForm = false;
            await LoadData();
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
        finally { _saving = false; }
    }

    private async Task Delete(Guid id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this job?")) return;
        try { await Api.DeleteJobAsync(id); await LoadData(); }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }
}
