@using Blazor.Diagrams.Components.Renderers
@using ProcessManager.Web.Components.Pages.Workflows

<div class="workflow-node @(Node.IsEntryPoint ? "entry-point" : "") @(Node.Selected ? "selected" : "")"
     style="min-width:180px; max-width:260px; background:#fff; border:2px solid @(Node.IsEntryPoint ? "#198754" : "#0d6efd"); border-radius:0.5rem; box-shadow:0 2px 8px rgba(0,0,0,.12); user-select:none; position:relative;">

    @* ── Top port (input) ── *@
    @foreach (var port in Node.Ports.Where(p => p.Alignment == PortAlignment.Top))
    {
        <PortRenderer Port="port" Class="workflow-port workflow-port-top" />
    }

    <div style="padding:0.5rem 0.75rem; font-weight:600; font-size:0.85rem; border-bottom:1px solid #e9ecef; background:@(Node.IsEntryPoint ? "#d1e7dd" : "#f0f5ff"); border-radius:0.375rem 0.375rem 0 0;"
         class="d-flex align-items-center gap-1">
        @if (Node.IsEntryPoint)
        {
            <i class="bi bi-flag-fill text-success" style="font-size:.7rem"></i>
        }
        <span class="text-truncate">@Node.ProcessName</span>
    </div>
    <div style="padding:0.4rem 0.75rem; font-size:0.75rem; color:#6c757d;">
        <code>@Node.ProcessCode</code>
    </div>

    @* ── Bottom port (output) ── *@
    @foreach (var port in Node.Ports.Where(p => p.Alignment == PortAlignment.Bottom))
    {
        <PortRenderer Port="port" Class="workflow-port workflow-port-bottom" />
    }
</div>

@code {
    [Parameter] public WorkflowProcessNodeModel Node { get; set; } = null!;
}
