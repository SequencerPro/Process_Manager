@page "/workorders"
@rendermode InteractiveServer
@inject ApiClient Api
@inject IJSRuntime JS
@inject VocabularyService Vocab
@implements IDisposable

<PageTitle>@Vocab.Workorders</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">@Vocab.Workorders</h3>
    <button class="btn btn-primary btn-sm" @onclick="ShowCreate">
        <i class="bi bi-plus-lg me-1"></i> New @Vocab.Workorder
    </button>
</div>

<div class="d-flex gap-3 mb-3 flex-wrap">
    <SearchBox Value="@_search" ValueChanged="OnSearch" Placeholder="@($"Search {Vocab.Workorders.ToLower()}...")" />
    <select class="form-select form-select-sm" style="width:auto" @onchange="OnStatusFilter">
        <option value="" selected="@(_status is null)">All Statuses</option>
        <option value="Created"    selected="@(_status == "Created")">Created</option>
        <option value="InProgress" selected="@(_status == "InProgress")">In Progress</option>
        <option value="Completed"  selected="@(_status == "Completed")">Completed</option>
        <option value="Cancelled"  selected="@(_status == "Cancelled")">Cancelled</option>
    </select>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_data is not null)
{
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Workflow</th>
                    <th>Status</th>
                    <th>Priority</th>
                    <th>Created</th>
                    <th style="width:140px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!_data.Items.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-3">No workorders found.</td></tr>
                }
                else
                {
                @foreach (var w in _data.Items)
                {
                    <tr>
                        <td><code>@w.Code</code></td>
                        <td><a href="workorders/@w.Id">@w.Name</a></td>
                        <td>@w.WorkflowName</td>
                        <td><StatusBadge Status="@w.Status" /></td>
                        <td>@w.Priority</td>
                        <td>@w.CreatedAt.ToString("g")</td>
                        <td>
                            <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => ShowEdit(w)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(w.Id)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
                }
            </tbody>
        </table>
    </div>

    <Pager Page="_page" PageSize="_pageSize" TotalCount="_data.TotalCount"
           OnPageChanged="OnPageChanged" />
}

@if (_showForm)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editId.HasValue ? "Edit" : "New") Workorder</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <div class="modal-body">
                    @if (!_editId.HasValue)
                    {
                        <div class="mb-3">
                            <label class="form-label">Workflow</label>
                            <select class="form-select" value="@_formWorkflowId" @onchange="OnWorkflowChanged">
                                <option value="">Select a workflow...</option>
                                @if (_workflows is not null)
                                {
                                    @foreach (var wf in _workflows.Items)
                                    {
                                        <option value="@wf.Id">@wf.Name (@wf.Code)</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Code</label>
                            <input class="form-control" @bind="_formCode" />
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input class="form-control" @bind="_formName" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" rows="2" @bind="_formDesc"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Priority</label>
                        <input type="number" class="form-control" @bind="_formPriority" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                    <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Save
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter][SupplyParameterFromQuery(Name = "status")] public string? StatusQuery { get; set; }

    private PaginatedResponse<WorkorderResponseDto>? _data;
    private bool _loading = true;
    private string _search = "";
    private string? _status;
    private int _page = 1;
    private int _pageSize = 25;

    // Form
    private bool _showForm;
    private bool _saving;
    private Guid? _editId;
    private string _formCode = "";
    private string _formName = "";
    private string _formDesc = "";
    private string _formWorkflowId = "";
    private int _formPriority;
    private PaginatedResponse<WorkflowResponseDto>? _workflows;

    protected override void OnInitialized() => Vocab.OnChange += OnVocabChanged;

    protected override async Task OnInitializedAsync()
    {
        _status = StatusQuery;
        await LoadData();
    }

    private void OnVocabChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Vocab.OnChange -= OnVocabChanged;

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _data = await Api.GetWorkordersAsync(_search, _status, null, _page, _pageSize);
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearch(string v) { _search = v; _page = 1; await LoadData(); }
    private async Task OnPageChanged(int p) { _page = p; await LoadData(); }

    private async Task OnStatusFilter(ChangeEventArgs e)
    {
        _status = string.IsNullOrEmpty(e.Value?.ToString()) ? null : e.Value.ToString();
        _page = 1; await LoadData();
    }

    private async Task ShowCreate()
    {
        _editId = null;
        _formCode = $"WO-{Guid.NewGuid().ToString("N")[..8].ToUpper()}";
        _formName = ""; _formDesc = ""; _formWorkflowId = ""; _formPriority = 0;
        _showForm = true;
        _workflows = await Api.GetWorkflowsAsync(pageSize: 100);
        StateHasChanged();
    }

    private void OnWorkflowChanged(ChangeEventArgs e)
    {
        _formWorkflowId = e.Value?.ToString() ?? "";
        if (_workflows is not null && Guid.TryParse(_formWorkflowId, out var wfId))
        {
            var wf = _workflows.Items.FirstOrDefault(w => w.Id == wfId);
            if (wf is not null)
                _formName = wf.Name;
        }
    }

    private void ShowEdit(WorkorderResponseDto w)
    {
        _editId = w.Id; _formName = w.Name; _formDesc = w.Description ?? ""; _formPriority = w.Priority;
        _showForm = true;
    }

    private void CloseForm() { _showForm = false; }

    private async Task Save()
    {
        _saving = true;
        try
        {
            if (_editId.HasValue)
                await Api.UpdateWorkorderAsync(_editId.Value, new UpdateWorkorderDto(_formName, _formDesc, _formPriority));
            else
            {
                if (!Guid.TryParse(_formWorkflowId, out var wfId)) { Toast.ShowError("Select a workflow."); return; }
                await Api.CreateWorkorderAsync(new CreateWorkorderDto(_formCode, _formName, _formDesc, wfId, _formPriority));
            }
            _showForm = false;
            await LoadData();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
        finally { _saving = false; }
    }

    private async Task Delete(Guid id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this workorder?")) return;
        try { await Api.DeleteWorkorderAsync(id); await LoadData(); }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }
}
