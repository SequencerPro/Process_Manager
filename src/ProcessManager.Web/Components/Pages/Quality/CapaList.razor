@page "/capas"
@attribute [Authorize(Roles = "Admin,Engineer")]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using ProcessManager.Api.DTOs
@inject ApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>CAPA — Process Manager</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4 page-heading-row">
    <div>
        <h3 class="mb-0"><i class="bi bi-shield-check me-2 text-primary"></i>Corrective & Preventive Actions</h3>
        <p class="text-muted small mb-0 d-none d-md-block">Track CAPAs from identification through effectiveness verification</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenCreateModal">
        <i class="bi bi-plus-lg me-1"></i> New CAPA
    </button>
</div>

@* ── KPI cards ── *@
@if (_dashboard is not null)
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card shadow-sm text-center p-3">
                <div class="fs-3 fw-bold text-primary">@_dashboard.TotalOpen</div>
                <div class="small text-muted">Open</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm text-center p-3">
                <div class="fs-3 fw-bold text-danger">@_dashboard.TotalOverdue</div>
                <div class="small text-muted">Overdue</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm text-center p-3">
                <div class="fs-3 fw-bold text-success">@_dashboard.TotalClosed</div>
                <div class="small text-muted">Closed</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm text-center p-3">
                <div class="fs-3 fw-bold text-info">@(_dashboard.AvgDaysToClose.ToString("F0"))d</div>
                <div class="small text-muted">Avg Days to Close</div>
            </div>
        </div>
    </div>
}

@* ── Filters ── *@
<div class="row g-2 mb-3">
    <div class="col-md-4">
        <div class="input-group input-group-sm">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text" class="form-control" placeholder="Search by code or problem…"
                   @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
        </div>
    </div>
    <div class="col-md-2">
        <select class="form-select form-select-sm" @bind="_statusFilter" @bind:after="LoadData">
            <option value="">All statuses</option>
            <option value="Open">Open</option>
            <option value="Containment">Containment</option>
            <option value="RootCauseAnalysis">Root Cause Analysis</option>
            <option value="Implementation">Implementation</option>
            <option value="Verification">Verification</option>
            <option value="EffectivenessReview">Effectiveness Review</option>
            <option value="Closed">Closed</option>
        </select>
    </div>
    <div class="col-md-2">
        <select class="form-select form-select-sm" @bind="_typeFilter" @bind:after="LoadData">
            <option value="">All types</option>
            <option value="Corrective">Corrective</option>
            <option value="Preventive">Preventive</option>
        </select>
    </div>
    <div class="col-md-2">
        <select class="form-select form-select-sm" @bind="_sourceFilter" @bind:after="LoadData">
            <option value="">All sources</option>
            <option value="Manual">Manual</option>
            <option value="CustomerComplaint">Customer Complaint</option>
            <option value="InternalAudit">Internal Audit</option>
            <option value="SupplierIssue">Supplier Issue</option>
            <option value="SpcOutOfControl">SPC Out of Control</option>
            <option value="NonConformance">Non-Conformance</option>
            <option value="ManagementReview">Management Review</option>
        </select>
    </div>
</div>

@* ── Table ── *@
<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Code</th>
                    <th>Problem Statement</th>
                    <th class="text-center">Type</th>
                    <th class="text-center">Status</th>
                    <th class="col-hide-mobile">Owner</th>
                    <th class="text-center col-hide-mobile">Due</th>
                    <th class="text-end" style="width:140px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (_loading)
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">
                        <div class="spinner-border spinner-border-sm me-2"></div>Loading…
                    </td></tr>
                }
                else if (_result is null || !_result.Items.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">No CAPA records found.</td></tr>
                }
                else
                {
                    @foreach (var capa in _result.Items)
                    {
                        <tr>
                            <td class="align-middle"><code>@capa.Code</code></td>
                            <td class="align-middle">
                                <span class="d-inline-block text-truncate" style="max-width: 300px;">
                                    @capa.ProblemStatement
                                </span>
                            </td>
                            <td class="align-middle text-center">
                                <span class="badge @(capa.Type == "Corrective" ? "bg-info text-dark" : "bg-purple")">@capa.Type</span>
                            </td>
                            <td class="align-middle text-center">
                                <span class="badge @CapaStatusBadge(capa.Status)">@FormatStatus(capa.Status)</span>
                            </td>
                            <td class="align-middle col-hide-mobile small">@capa.OwnerDisplayName</td>
                            <td class="align-middle text-center col-hide-mobile small">
                                @if (capa.VerificationDueDate.HasValue)
                                {
                                    var isOverdue = capa.VerificationDueDate.Value < DateTime.UtcNow && capa.ClosedAt is null;
                                    <span class="@(isOverdue ? "text-danger fw-bold" : "text-muted")">
                                        @capa.VerificationDueDate.Value.ToString("MMM d, yyyy")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="align-middle text-end">
                                @if (capa.Status == "Open")
                                {
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteCapa(capa)" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@* ── Pager ── *@
@if (_result is not null && _result.TotalPages > 1)
{
    <nav class="mt-3 d-flex justify-content-center">
        <ul class="pagination pagination-sm">
            <li class="page-item @(!_result.HasPreviousPage ? "disabled" : "")">
                <button class="page-link" @onclick="() => GoToPage(_page - 1)">&laquo;</button>
            </li>
            @for (var p = 1; p <= _result.TotalPages; p++)
            {
                var pg = p;
                <li class="page-item @(pg == _page ? "active" : "")">
                    <button class="page-link" @onclick="() => GoToPage(pg)">@pg</button>
                </li>
            }
            <li class="page-item @(!_result.HasNextPage ? "disabled" : "")">
                <button class="page-link" @onclick="() => GoToPage(_page + 1)">&raquo;</button>
            </li>
        </ul>
    </nav>
}

@* ── Create modal ── *@
@if (_showCreateModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">New CAPA</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <div class="alert alert-danger py-2 small">@_error</div>
                    }
                    <div class="row g-2">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Type <span class="text-danger">*</span></label>
                            <select class="form-select" @bind="_createType">
                                <option value="Corrective">Corrective</option>
                                <option value="Preventive">Preventive</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Source</label>
                            <select class="form-select" @bind="_createSourceType">
                                <option value="Manual">Manual</option>
                                <option value="CustomerComplaint">Customer Complaint</option>
                                <option value="InternalAudit">Internal Audit</option>
                                <option value="SupplierIssue">Supplier Issue</option>
                                <option value="SpcOutOfControl">SPC Out of Control</option>
                                <option value="NonConformance">Non-Conformance</option>
                                <option value="ManagementReview">Management Review</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Problem Statement <span class="text-danger">*</span></label>
                        <textarea class="form-control" rows="3" @bind="_createProblem"
                                  placeholder="Describe the problem or potential issue…"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Containment Action</label>
                        <textarea class="form-control" rows="2" @bind="_createContainment"
                                  placeholder="Immediate containment steps taken…"></textarea>
                    </div>
                    <div class="row g-2">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Owner Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="_createOwnerName" placeholder="Display name" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Owner User ID <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="_createOwnerUserId" placeholder="User ID" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button class="btn btn-primary" @onclick="SubmitCreate" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Create
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PaginatedResponse<CapaRecordSummaryDto>? _result;
    private CapaDashboardDto? _dashboard;
    private bool _loading = true;
    private string _search = "";
    private string _statusFilter = "";
    private string _typeFilter = "";
    private string _sourceFilter = "";
    private int _page = 1;

    // Create modal
    private bool _showCreateModal;
    private bool _saving;
    private string? _error;
    private string _createType = "Corrective";
    private string _createSourceType = "Manual";
    private string _createProblem = "";
    private string? _createContainment;
    private string _createOwnerName = "";
    private string _createOwnerUserId = "";

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var searchParam = string.IsNullOrWhiteSpace(_search) ? null : _search;
            var statusParam = string.IsNullOrEmpty(_statusFilter) ? null : _statusFilter;
            var typeParam = string.IsNullOrEmpty(_typeFilter) ? null : _typeFilter;
            var sourceParam = string.IsNullOrEmpty(_sourceFilter) ? null : _sourceFilter;

            _result = await Api.GetCapasAsync(searchParam, statusParam, typeParam, sourceParam, _page);
            _dashboard = await Api.GetCapaDashboardAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e) { if (e.Key == "Enter") { _page = 1; await LoadData(); } }
    private async Task GoToPage(int p) { _page = p; await LoadData(); }

    private void OpenCreateModal()
    {
        _showCreateModal = true;
        _error = null;
        _createType = "Corrective";
        _createSourceType = "Manual";
        _createProblem = "";
        _createContainment = null;
        _createOwnerName = "";
        _createOwnerUserId = "";
    }

    private void CloseModal() => _showCreateModal = false;

    private async Task SubmitCreate()
    {
        if (string.IsNullOrWhiteSpace(_createProblem) || string.IsNullOrWhiteSpace(_createOwnerUserId) || string.IsNullOrWhiteSpace(_createOwnerName))
        {
            _error = "Problem statement, owner name, and owner user ID are required.";
            return;
        }

        _saving = true;
        _error = null;

        try
        {
            var dto = new CreateCapaRecordDto
            {
                Type = _createType,
                SourceType = _createSourceType,
                ProblemStatement = _createProblem,
                ContainmentAction = _createContainment,
                OwnerUserId = _createOwnerUserId,
                OwnerDisplayName = _createOwnerName
            };
            await Api.CreateCapaAsync(dto);
            _showCreateModal = false;
            await LoadData();
        }
        catch (HttpRequestException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteCapa(CapaRecordSummaryDto capa)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Delete CAPA '{capa.Code}'? Only Open CAPAs can be deleted."))
            return;
        try
        {
            await Api.DeleteCapaAsync(capa.Id);
            await LoadData();
        }
        catch (HttpRequestException ex)
        {
            await JS.InvokeVoidAsync("alert", $"Delete failed: {ex.Message}");
        }
    }

    private static string CapaStatusBadge(string status) => status switch
    {
        "Open" => "bg-info text-dark",
        "Containment" => "bg-warning text-dark",
        "RootCauseAnalysis" => "bg-orange text-dark",
        "Implementation" => "bg-primary",
        "Verification" => "bg-purple",
        "EffectivenessReview" => "bg-secondary",
        "Closed" => "bg-success",
        _ => "bg-secondary"
    };

    private static string FormatStatus(string status) => status switch
    {
        "RootCauseAnalysis" => "Root Cause",
        "EffectivenessReview" => "Effectiveness",
        _ => status
    };
}
