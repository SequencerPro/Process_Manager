@page "/step-templates"
@rendermode InteractiveServer
@inject ApiClient Api
@inject IJSRuntime JS

<PageTitle>Step Templates</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Step Templates</h3>
    <button class="btn btn-primary btn-sm" @onclick="ShowCreateForm">
        <i class="bi bi-plus-lg me-1"></i> New Template
    </button>
</div>

<div class="d-flex gap-3 mb-3 flex-wrap">
    <SearchBox Value="@_search" ValueChanged="OnSearch" Placeholder="Search templates..." />
    <select class="form-select form-select-sm" style="width:auto" @onchange="OnActiveFilter">
        <option value="">All</option>
        <option value="true">Active</option>
        <option value="false">Inactive</option>
    </select>
    <select class="form-select form-select-sm" style="width:auto" @onchange="OnStatusFilter">
        <option value="">Any Status</option>
        <option value="Draft">Draft</option>
        <option value="PendingApproval">Pending Approval</option>
        <option value="Released">Released</option>
        <option value="Superseded">Superseded</option>
        <option value="Retired">Retired</option>
    </select>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_data is not null)
{
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Pattern</th>
                    <th>Ports</th>
                    <th>Maturity</th>
                    <th>Version</th>
                    <th>Status</th>
                    <th>Active</th>
                    <th style="width:120px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!_data.Items.Any())
                {
                    <tr><td colspan="9" class="text-center text-muted py-3">No step templates found.</td></tr>
                }
                else
                {
                @foreach (var st in _data.Items)
                {
                    <tr>
                        <td><code>@st.Code</code></td>
                        <td><a href="step-templates/@st.Id">@st.Name</a></td>
                        <td><span class="badge bg-info text-dark">@st.Pattern</span></td>
                        <td>
                            <span class="text-success small">@st.Ports?.Count(p => p.Direction == PortDirection.Input) in</span>
                            /
                            <span class="text-primary small">@st.Ports?.Count(p => p.Direction == PortDirection.Output) out</span>
                        </td>
                        <td>v@st.Version</td>
                        <td><span class="badge @StatusBadgeClass(st.Status)">@st.Status</span></td>
                        <td>
                            @if (st.Maturity is not null)
                            {
                                <span class="badge @MaturityBadgeClass(st.Maturity.Level)" title="Score @st.Maturity.Score/100">
                                    @st.Maturity.Level
                                </span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            @if (st.IsActive)
                            {
                                <i class="bi bi-check-circle-fill text-success"></i>
                            }
                            else
                            {
                                <i class="bi bi-x-circle text-danger"></i>
                            }
                        </td>
                        <td>
                            <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => ShowEditForm(st)" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(st)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
                }
            </tbody>
        </table>
    </div>

    <Pager Page="_page" PageSize="_pageSize" TotalCount="_data.TotalCount"
           OnPageChanged="OnPageChanged" />
}

@* Create / Edit Modal *@
@if (_showForm)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_isEdit ? "Edit Step Template" : "New Step Template")</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <div class="modal-body">
                    @if (!_isEdit)
                    {
                        <div class="mb-3">
                            <label class="form-label">Code</label>
                            <input class="form-control" @bind="_formCode" />
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input class="form-control" @bind="_formName" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" rows="2" @bind="_formDescription"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Pattern</label>
                        <select class="form-select" @bind="_formPattern">
                            @foreach (var p in Enum.GetValues<StepPattern>())
                            {
                                <option value="@p">@p</option>
                            }
                        </select>
                        <div class="step-pattern-hint mt-2">
                            @switch (_formPattern)
                            {
                                case StepPattern.Transform:
                                    <span class="step-pattern-hint-label">
                                        <i class="bi bi-arrow-right text-success"></i>
                                        <span class="step-pattern-hint-box">Step</span>
                                        <i class="bi bi-arrow-right text-primary"></i>
                                    </span>
                                    <span class="text-muted small ms-2">1 input, 1 output</span>
                                    break;
                                case StepPattern.Assembly:
                                    <span class="step-pattern-hint-label">
                                        <span class="d-inline-flex flex-column" style="line-height:1">
                                            <i class="bi bi-arrow-right text-success" style="font-size:.7rem"></i>
                                            <i class="bi bi-arrow-right text-success" style="font-size:.7rem"></i>
                                        </span>
                                        <span class="step-pattern-hint-box">Step</span>
                                        <i class="bi bi-arrow-right text-primary"></i>
                                    </span>
                                    <span class="text-muted small ms-2">2+ inputs, 1 output</span>
                                    break;
                                case StepPattern.Division:
                                    <span class="step-pattern-hint-label">
                                        <i class="bi bi-arrow-right text-success"></i>
                                        <span class="step-pattern-hint-box">Step</span>
                                        <span class="d-inline-flex flex-column" style="line-height:1">
                                            <i class="bi bi-arrow-right text-primary" style="font-size:.7rem"></i>
                                            <i class="bi bi-arrow-right text-primary" style="font-size:.7rem"></i>
                                        </span>
                                    </span>
                                    <span class="text-muted small ms-2">1 input, 2+ outputs</span>
                                    break;
                                case StepPattern.General:
                                    <span class="step-pattern-hint-label">
                                        <span class="d-inline-flex flex-column" style="line-height:1">
                                            <i class="bi bi-arrow-right text-success" style="font-size:.7rem"></i>
                                            <i class="bi bi-arrow-right text-success" style="font-size:.7rem"></i>
                                        </span>
                                        <span class="step-pattern-hint-box">Step</span>
                                        <span class="d-inline-flex flex-column" style="line-height:1">
                                            <i class="bi bi-arrow-right text-primary" style="font-size:.7rem"></i>
                                            <i class="bi bi-arrow-right text-primary" style="font-size:.7rem"></i>
                                        </span>
                                    </span>
                                    <span class="text-muted small ms-2">any inputs, any outputs</span>
                                    break;
                            }
                        </div>
                    </div>
                    @if (_isEdit)
                    {
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="formIsActive" @bind="_formIsActive" />
                            <label class="form-check-label" for="formIsActive">Active</label>
                        </div>
                    }

                    @* Inline port builder for create only *@
                    @if (!_isEdit)
                    {
                        <div class="step-ports-section">
                            <div class="step-ports-header">
                                <i class="bi bi-diagram-3 me-1"></i>
                                Ports <span class="text-muted small fw-normal">(at least one required)</span>
                            </div>

                            @* ── Dynamic Port Diagram ── *@
                            <div class="step-diagram">
                                @{
                                    var inputs = _formPorts.Where(p => p.Direction == PortDirection.Input).ToList();
                                    var outputs = _formPorts.Where(p => p.Direction == PortDirection.Output).ToList();
                                    var showPlaceholders = !_formPorts.Any();
                                    var placeholderInputs = _formPattern switch
                                    {
                                        StepPattern.Transform => 1,
                                        StepPattern.Assembly => 2,
                                        StepPattern.Division => 1,
                                        _ => 1
                                    };
                                    var placeholderOutputs = _formPattern switch
                                    {
                                        StepPattern.Transform => 1,
                                        StepPattern.Assembly => 1,
                                        StepPattern.Division => 2,
                                        _ => 1
                                    };
                                    var maxInCount = showPlaceholders ? placeholderInputs : inputs.Count;
                                    var maxOutCount = showPlaceholders ? placeholderOutputs : outputs.Count;
                                    var maxPorts = Math.Max(maxInCount, maxOutCount);
                                    var svgHeight = Math.Max(120, maxPorts * 40 + 40);
                                    var blockH = Math.Max(60, maxPorts * 36 + 16);
                                    var blockY = (svgHeight - blockH) / 2.0;
                                    var stepLabel = string.IsNullOrWhiteSpace(_formName) ? "Step" : (_formName.Length > 14 ? _formName[..14] + "..." : _formName);
                                }
                                <svg width="100%" height="@svgHeight" viewBox="0 0 600 @svgHeight" class="step-diagram-svg">
                                    @* Central step block *@
                                    <rect x="220" y="@blockY" width="160" height="@blockH" rx="8" ry="8"
                                          fill="#f8f9fa" stroke="#6c757d" stroke-width="2" />
                                    @((MarkupString)SvgText(300, blockY + blockH / 2.0 + 5, "middle", 14, "600", "#495057", 1, stepLabel))

                                    @if (showPlaceholders)
                                    {
                                        @* Placeholder input arrows (dashed) *@
                                        @for (int i = 0; i < placeholderInputs; i++)
                                        {
                                            var yPos = blockY + (blockH / (placeholderInputs + 1.0)) * (i + 1);
                                            <line x1="60" y1="@yPos" x2="215" y2="@yPos"
                                                  stroke="#198754" stroke-width="2" stroke-dasharray="6,4" opacity="0.4" />
                                            <polygon points="@($"{215},{yPos - 5} {215},{yPos + 5} {220},{yPos}")"
                                                     fill="#198754" opacity="0.4" />
                                            @((MarkupString)SvgText(40, yPos + 4, "end", 11, "400", "#198754", 0.5, _formPattern == StepPattern.General ? "input +" : "input"))
                                        }
                                        @* Placeholder output arrows (dashed) *@
                                        @for (int i = 0; i < placeholderOutputs; i++)
                                        {
                                            var yPos = blockY + (blockH / (placeholderOutputs + 1.0)) * (i + 1);
                                            <line x1="380" y1="@yPos" x2="535" y2="@yPos"
                                                  stroke="#0d6efd" stroke-width="2" stroke-dasharray="6,4" opacity="0.4" />
                                            <polygon points="@($"{535},{yPos - 5} {535},{yPos + 5} {540},{yPos}")"
                                                     fill="#0d6efd" opacity="0.4" />
                                            @((MarkupString)SvgText(560, yPos + 4, "start", 11, "400", "#0d6efd", 0.5, _formPattern == StepPattern.General ? "output +" : "output"))
                                        }
                                    }
                                    else
                                    {
                                        @* Actual input port arrows *@
                                        @for (int i = 0; i < inputs.Count; i++)
                                        {
                                            var port = inputs[i];
                                            var yPos = blockY + (blockH / (inputs.Count + 1.0)) * (i + 1);
                                            <line x1="60" y1="@yPos" x2="215" y2="@yPos"
                                                  stroke="#198754" stroke-width="2" class="step-diagram-arrow" />
                                            <polygon points="@($"{215},{yPos - 5} {215},{yPos + 5} {220},{yPos}")"
                                                     fill="#198754" class="step-diagram-arrow" />
                                            <circle cx="60" cy="@yPos" r="4" fill="#198754" class="step-diagram-arrow" />
                                            @((MarkupString)SvgText(55, yPos + 4, "end", 11, "500", "#198754", 1, port.Name.Length > 12 ? port.Name[..12] + ".." : port.Name))
                                        }
                                        @* Actual output port arrows *@
                                        @for (int i = 0; i < outputs.Count; i++)
                                        {
                                            var port = outputs[i];
                                            var yPos = blockY + (blockH / (outputs.Count + 1.0)) * (i + 1);
                                            <line x1="380" y1="@yPos" x2="535" y2="@yPos"
                                                  stroke="#0d6efd" stroke-width="2" class="step-diagram-arrow" />
                                            <polygon points="@($"{535},{yPos - 5} {535},{yPos + 5} {540},{yPos}")"
                                                     fill="#0d6efd" class="step-diagram-arrow" />
                                            <circle cx="540" cy="@yPos" r="4" fill="#0d6efd" class="step-diagram-arrow" />
                                            @((MarkupString)SvgText(545, yPos + 4, "start", 11, "500", "#0d6efd", 1, port.Name.Length > 12 ? port.Name[..12] + ".." : port.Name))
                                        }
                                    }
                                </svg>
                            </div>

                            @* ── Port Cards ── *@
                            @if (_formPorts.Any())
                            {
                                <div class="step-port-cards mb-3">
                                    @foreach (var fp in _formPorts)
                                    {
                                        var isInput = fp.Direction == PortDirection.Input;
                                        <div class="step-port-card @(isInput ? "step-port-card-input" : "step-port-card-output")">
                                            <div class="d-flex align-items-center gap-2 flex-grow-1">
                                                <i class="bi @(isInput ? "bi-box-arrow-in-right text-success" : "bi-box-arrow-right text-primary")" style="font-size:1.1rem"></i>
                                                <div class="flex-grow-1">
                                                    <div class="fw-semibold small">@fp.Name</div>
                                                    <div class="text-muted" style="font-size:.7rem">
                                                        @(_kinds?.Items.FirstOrDefault(k => k.Id == fp.KindId)?.Name ?? "Kind") / @fp.GradeCode
                                                        <span class="ms-1 badge bg-light text-dark border" style="font-size:.6rem">@fp.QtyRuleMode</span>
                                                    </div>
                                                </div>
                                            </div>
                                            <button class="btn btn-outline-danger btn-sm py-0 px-1" @onclick="() => _formPorts.Remove(fp)" title="Remove port">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </div>
                                    }
                                </div>
                            }

                            @* ── Add Port Form ── *@
                            <div class="step-port-add-form @(_ipDirection == PortDirection.Input ? "step-port-add-input" : "step-port-add-output")">
                                <div class="step-port-add-form-header">
                                    <i class="bi @(_ipDirection == PortDirection.Input ? "bi-box-arrow-in-right" : "bi-box-arrow-right") me-1"></i>
                                    Add Port
                                </div>
                                <div class="row g-2">
                                    <div class="col-md-4">
                                        <label class="form-label form-label-sm">Port Name</label>
                                        <input class="form-control form-control-sm" @bind="_ipName" placeholder="e.g. Part In" />
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label form-label-sm">Direction</label>
                                        <select class="form-select form-select-sm" @bind="_ipDirection">
                                            <option value="@PortDirection.Input">Input</option>
                                            <option value="@PortDirection.Output">Output</option>
                                        </select>
                                    </div>
                                    <div class="col-md-5">
                                        <label class="form-label form-label-sm">Kind</label>
                                        <select class="form-select form-select-sm" @bind="_ipKindId" @bind:after="OnInlineKindChanged">
                                            <option value="">Select kind...</option>
                                            @if (_kinds is not null)
                                            {
                                                @foreach (var k in _kinds.Items)
                                                {
                                                    <option value="@k.Id">@k.Name (@k.Code)</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                </div>
                                <div class="row g-2 mt-1">
                                    <div class="col-md-4">
                                        <label class="form-label form-label-sm">Grade</label>
                                        <select class="form-select form-select-sm" @bind="_ipGradeId">
                                            <option value="">Select grade...</option>
                                            @if (_ipGrades is not null)
                                            {
                                                @foreach (var g in _ipGrades)
                                                {
                                                    <option value="@g.Id">@g.Name (@g.Code)</option>
                                                }
                                            }
                                        </select>
                                    </div>
                                    <div class="col-md-3">
                                        <label class="form-label form-label-sm">Qty Mode</label>
                                        <select class="form-select form-select-sm" @bind="_ipQtyMode">
                                            @foreach (var m in Enum.GetValues<QuantityRuleMode>())
                                            {
                                                <option value="@m">@m</option>
                                            }
                                        </select>
                                    </div>
                                    @if (_ipQtyMode == QuantityRuleMode.Exactly || _ipQtyMode == QuantityRuleMode.ZeroOrN)
                                    {
                                        <div class="col-md-3">
                                            <label class="form-label form-label-sm">N</label>
                                            <input type="number" class="form-control form-control-sm" @bind="_ipQtyN" min="1" />
                                        </div>
                                    }
                                    else if (_ipQtyMode == QuantityRuleMode.Range)
                                    {
                                        <div class="col-md-2">
                                            <label class="form-label form-label-sm">Min</label>
                                            <input type="number" class="form-control form-control-sm" @bind="_ipQtyMin" min="0" />
                                        </div>
                                        <div class="col-md-2">
                                            <label class="form-label form-label-sm">Max</label>
                                            <input type="number" class="form-control form-control-sm" @bind="_ipQtyMax" min="0" />
                                        </div>
                                    }
                                    else if (_ipQtyMode == QuantityRuleMode.Unbounded)
                                    {
                                        <div class="col-md-3">
                                            <label class="form-label form-label-sm">Min</label>
                                            <input type="number" class="form-control form-control-sm" @bind="_ipQtyMin" min="0" />
                                        </div>
                                    }
                                    <div class="col-md-3">
                                        <label class="form-label form-label-sm">Sort Order</label>
                                        <input type="number" class="form-control form-control-sm" @bind="_ipSortOrder" />
                                    </div>
                                    <div class="col-md-2 d-flex align-items-end">
                                        <button class="btn btn-sm @(_ipDirection == PortDirection.Input ? "btn-success" : "btn-primary") w-100" @onclick="AddInlinePort">
                                            <i class="bi bi-plus-lg"></i> Add
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveForm">
                        @(_isEdit ? "Update" : "Create")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PaginatedResponse<StepTemplateResponseDto>? _data;
    private bool _loading = true;
    private string _search = "";
    private bool? _active;
    private string? _status;
    private int _page = 1;
    private int _pageSize = 25;

    // Form state
    private bool _showForm;
    private bool _isEdit;
    private Guid? _editId;
    private string _formCode = "";
    private string _formName = "";
    private string? _formDescription;
    private StepPattern _formPattern = StepPattern.Transform;
    private bool _formIsActive = true;

    // Inline port builder (create mode only)
    private List<InlinePort> _formPorts = new();
    private string _ipName = "";
    private PortDirection _ipDirection = PortDirection.Input;
    private string _ipKindId = "";
    private string _ipGradeId = "";
    private QuantityRuleMode _ipQtyMode = QuantityRuleMode.Exactly;
    private int? _ipQtyN;
    private int? _ipQtyMin;
    private int? _ipQtyMax;
    private int _ipSortOrder;

    // Lookups
    private PaginatedResponse<KindResponseDto>? _kinds;
    private List<GradeResponseDto>? _ipGrades;

    private record InlinePort(string Name, PortDirection Direction, Guid KindId, Guid GradeId, string GradeCode, QuantityRuleMode QtyRuleMode, int? QtyRuleN, int? QtyRuleMin, int? QtyRuleMax, int SortOrder)
    {
        public PortType PortType => PortType.Material;
    }

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _data = await Api.GetStepTemplatesAsync(_search, _active, _status, page: _page, pageSize: _pageSize);
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearch(string value) { _search = value; _page = 1; await LoadData(); }
    private async Task OnPageChanged(int page) { _page = page; await LoadData(); }

    private async Task OnActiveFilter(ChangeEventArgs e)
    {
        _active = string.IsNullOrEmpty(e.Value?.ToString()) ? null : bool.Parse(e.Value.ToString()!);
        _page = 1;
        await LoadData();
    }

    private async Task OnStatusFilter(ChangeEventArgs e)
    {
        _status = string.IsNullOrEmpty(e.Value?.ToString()) ? null : e.Value.ToString();
        _page = 1;
        await LoadData();
    }

    private async Task ShowCreateForm()
    {
        _isEdit = false; _editId = null;
        _formCode = ""; _formName = ""; _formDescription = null;
        _formPattern = StepPattern.Transform; _formIsActive = true;
        _formPorts.Clear();
        ResetInlinePort();
        _showForm = true;
        _kinds = await Api.GetKindsAsync("", 1, 100);
        StateHasChanged();
    }

    private void ShowEditForm(StepTemplateResponseDto st)
    {
        _isEdit = true; _editId = st.Id;
        _formName = st.Name;
        _formDescription = st.Description;
        _formPattern = st.Pattern;
        _formIsActive = st.IsActive;
        _showForm = true;
    }

    private void CloseForm() { _showForm = false; }

    private async Task OnInlineKindChanged()
    {
        _ipGrades = null;
        _ipGradeId = "";
        if (Guid.TryParse(_ipKindId, out var kindId))
        {
            var kind = await Api.GetKindAsync(kindId);
            _ipGrades = kind?.Grades?.ToList();
        }
    }

    private void AddInlinePort()
    {
        if (string.IsNullOrWhiteSpace(_ipName) || !Guid.TryParse(_ipKindId, out var kid) || !Guid.TryParse(_ipGradeId, out var gid))
        {
            Toast.ShowError("Port name, kind, and grade are required."); return;
        }
        if ((_ipQtyMode == QuantityRuleMode.Exactly || _ipQtyMode == QuantityRuleMode.ZeroOrN) && (_ipQtyN is null or <= 0))
        {
            Toast.ShowError($"{_ipQtyMode} mode requires N > 0."); return;
        }
        if (_ipQtyMode == QuantityRuleMode.Range && (_ipQtyMin is null || _ipQtyMax is null))
        {
            Toast.ShowError("Range mode requires both Min and Max."); return;
        }
        if (_ipQtyMode == QuantityRuleMode.Unbounded && _ipQtyMin is null)
        {
            Toast.ShowError("Unbounded mode requires Min."); return;
        }
        var gradeCode = _ipGrades?.FirstOrDefault(g => g.Id == gid)?.Code ?? gid.ToString()[..8];
        _formPorts.Add(new InlinePort(_ipName, _ipDirection, kid, gid, gradeCode, _ipQtyMode, _ipQtyN, _ipQtyMin, _ipQtyMax, _ipSortOrder));
        _ipSortOrder++;
        _ipName = "";
    }

    private void ResetInlinePort()
    {
        _ipName = ""; _ipDirection = PortDirection.Input; _ipKindId = ""; _ipGradeId = "";
        _ipQtyMode = QuantityRuleMode.Exactly; _ipQtyN = null; _ipQtyMin = null; _ipQtyMax = null;
        _ipSortOrder = 0; _ipGrades = null;
    }

    private async Task SaveForm()
    {
        try
        {
            if (_isEdit)
            {
                await Api.UpdateStepTemplateAsync(_editId!.Value,
                    new StepTemplateUpdateDto(_formName, _formDescription, _formPattern, _formIsActive));
            }
            else
            {
                if (!_formPorts.Any()) { Toast.ShowError("Add at least one port."); return; }
                var ports = _formPorts.Select(p =>
                    new PortCreateDto(p.Name, p.Direction, PortType.Material,
                        p.KindId, p.GradeId, p.QtyRuleMode, p.QtyRuleN, p.QtyRuleMin, p.QtyRuleMax,
                        null, null, null, null, null, p.SortOrder)).ToList();
                await Api.CreateStepTemplateAsync(new StepTemplateCreateDto(_formCode, _formName, _formDescription, _formPattern, ports));
            }
            _showForm = false;
            await LoadData();
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

    private async Task Delete(StepTemplateResponseDto st)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Delete step template '{st.Name}'?")) return;
        try { await Api.DeleteStepTemplateAsync(st.Id); await LoadData(); }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

    private string MaturityBadgeClass(MaturityLevel level) => level switch
    {
        MaturityLevel.Optimised  => "bg-success",
        MaturityLevel.Defined    => "bg-primary",
        MaturityLevel.Developing => "bg-warning text-dark",
        _                        => "bg-secondary"
    };

    private static string SvgText(double x, double y, string anchor, int fontSize, string fontWeight, string fill, double opacity, string content)
    {
        var escaped = System.Web.HttpUtility.HtmlEncode(content);
        return $"<text x=\"{x}\" y=\"{y}\" text-anchor=\"{anchor}\" font-size=\"{fontSize}\" font-weight=\"{fontWeight}\" fill=\"{fill}\" opacity=\"{opacity}\">{escaped}</text>";
    }

    private static string StatusBadgeClass(string? status) => status switch
    {
        "Draft"           => "bg-secondary",
        "PendingApproval" => "bg-warning text-dark",
        "Released"        => "bg-success",
        "Superseded"      => "bg-dark",
        "Retired"         => "bg-danger",
        _                 => "bg-light text-dark"
    };
}
