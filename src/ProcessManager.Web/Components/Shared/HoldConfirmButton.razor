@* Hold-to-confirm button: requires sustained press (default 500ms) to fire OnConfirmed *@

<button class="@CssClass"
        disabled="@Disabled"
        @onpointerdown="StartHold"
        @onpointerup="CancelHold"
        @onpointerleave="CancelHold"
        @oncontextmenu:preventDefault="true"
        style="position:relative;overflow:hidden;user-select:none;-webkit-user-select:none;touch-action:manipulation;@Style">
    @if (_holding)
    {
        <span class="hold-progress" style="animation-duration:@(HoldDurationMs)ms"></span>
    }
    @ChildContent
</button>

<style>
    .hold-progress {
        position: absolute;
        inset: 0;
        background: rgba(255,255,255,0.25);
        transform-origin: left;
        animation: hold-fill linear forwards;
        pointer-events: none;
    }

    @@keyframes hold-fill {
        from { transform: scaleX(0); }
        to   { transform: scaleX(1); }
    }
</style>

@code {
    [Parameter] public EventCallback OnConfirmed { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public string CssClass { get; set; } = "btn btn-primary btn-lg";
    [Parameter] public string? Style { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public int HoldDurationMs { get; set; } = 500;

    private bool _holding;
    private CancellationTokenSource? _cts;

    private async Task StartHold()
    {
        if (Disabled) return;
        _holding = true;
        _cts = new CancellationTokenSource();
        StateHasChanged();

        try
        {
            await Task.Delay(HoldDurationMs, _cts.Token);
            _holding = false;
            await OnConfirmed.InvokeAsync();
        }
        catch (TaskCanceledException)
        {
            _holding = false;
        }
    }

    private void CancelHold()
    {
        if (!_holding) return;
        _cts?.Cancel();
        _holding = false;
    }
}
