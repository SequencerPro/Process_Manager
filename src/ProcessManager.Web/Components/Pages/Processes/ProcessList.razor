@page "/processes"
@attribute [Authorize(Roles = "Admin,Engineer")]
@rendermode InteractiveServer
@inject ApiClient Api
@inject IJSRuntime JS
@inject VocabularyService Vocab
@implements IDisposable

<PageTitle>@Vocab.Processes</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3 page-heading-row">
    <h3 class="mb-0">@Vocab.Processes</h3>
    <a href="processes/builder" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-lg me-1"></i> New @Vocab.Process
    </a>
</div>

<div class="d-flex gap-3 mb-3 flex-wrap">
    <SearchBox Value="@_search" ValueChanged="OnSearch" Placeholder="@($"Search {Vocab.Processes.ToLower()}...")" />
    <select class="form-select form-select-sm" style="width:auto" @onchange="OnRoleFilter">
        <option value="">All Types</option>
        <option value="ManufacturingProcess">Manufacturing Process</option>
        <option value="ApprovalProcess">Approval Process</option>
        <option value="Training">Training</option>
    </select>
    <select class="form-select form-select-sm" style="width:auto" @onchange="OnActiveFilter">
        <option value="">All</option>
        <option value="true">Active</option>
        <option value="false">Inactive</option>
    </select>
    <select class="form-select form-select-sm" style="width:auto" @onchange="OnStatusFilter">
        <option value="">Any Status</option>
        <option value="Draft">Draft</option>
        <option value="PendingApproval">Pending Approval</option>
        <option value="Released">Released</option>
        <option value="Superseded">Superseded</option>
        <option value="Retired">Retired</option>
    </select>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_data is not null)
{
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th class="col-hide-mobile">Steps</th>
                    <th class="col-hide-mobile">Version</th>
                    <th>Status</th>
                    <th class="col-hide-mobile">Active</th>
                    <th style="width:140px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!_data.Items.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-3">No processes found.</td></tr>
                }
                else
                {
                @foreach (var p in _data.Items)
                {
                    <tr>
                        <td><code>@p.Code</code></td>
                        <td>
                            <a href="processes/@p.Id">@p.Name</a>
                            @if (p.IsSystemContent)
                            {
                                <span class="badge bg-info text-dark ms-1" title="System content — read only">Library</span>
                            }
                        </td>
                        <td class="col-hide-mobile"><span class="badge bg-secondary">@p.StepCount</span></td>
                        <td class="col-hide-mobile">v@p.Version</td>
                        <td><span class="badge @StatusBadgeClass(p.Status)">@p.Status</span></td>
                        <td class="col-hide-mobile">
                            @if (p.IsActive)
                            {
                                <i class="bi bi-check-circle-fill text-success"></i>
                            }
                            else
                            {
                                <i class="bi bi-x-circle text-danger"></i>
                            }
                        </td>
                        <td>
                            <a href="processes/@p.Id/builder" class="btn btn-outline-primary btn-sm me-1" title="Open in Builder">
                                <i class="bi bi-diagram-3"></i>
                            </a>
                            @if (p.IsSystemContent)
                            {
                                <button class="btn btn-outline-success btn-sm" @onclick="() => ShowCopyModal(p)" title="Copy to My Library">
                                    <i class="bi bi-copy"></i>
                                </button>
                            }
                            else
                            {
                                <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => ShowEdit(p)" title="Quick Edit">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(p.Id)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            }
                        </td>
                    </tr>
                }
                }
            </tbody>
        </table>
    </div>

    <Pager Page="_page" PageSize="_pageSize" TotalCount="_data.TotalCount"
           OnPageChanged="OnPageChanged" />
}

@if (_showForm)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editId.HasValue ? "Edit" : "New") Process</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <div class="modal-body">
                    @if (!_editId.HasValue)
                    {
                        <div class="mb-3">
                            <label class="form-label">Code</label>
                            <input class="form-control" @bind="_formCode" />
                        </div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input class="form-control" @bind="_formName" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" rows="3" @bind="_formDesc"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                    <button class="btn btn-primary" @onclick="Save">Save</button>
                </div>
            </div>
        </div>
    </div>
}

@* ── Copy to My Library Modal ─────────────────────────────────────────── *@
@if (_copySource is not null)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-copy me-2"></i>Copy to My Library</h5>
                    <button type="button" class="btn-close" @onclick="() => _copySource = null"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted">Create an editable copy of <strong>@_copySource.Name</strong> (@_copySource.Code).</p>
                    <div class="mb-3">
                        <label class="form-label fw-medium">New Code <span class="text-danger">*</span></label>
                        <input class="form-control" @bind="_copyCode" placeholder="e.g. MY-PROC-001" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">New Name</label>
                        <input class="form-control" @bind="_copyName" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _copySource = null">Cancel</button>
                    <button class="btn btn-primary" @onclick="HandleCopy"
                            disabled="@(string.IsNullOrWhiteSpace(_copyCode) || _copySaving)">
                        @if (_copySaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        <i class="bi bi-copy me-1"></i> Copy
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PaginatedResponse<ProcessSummaryResponseDto>? _data;
    private bool _loading = true;
    private string _search = "";
    private bool? _active;
    private string? _status;
    private string _roleFilter = "";
    private int _page = 1;
    private int _pageSize = 25;

    // Form
    private bool _showForm;
    private Guid? _editId;
    private string _formCode = "";
    private string _formName = "";
    private string _formDesc = "";

    // Copy modal
    private ProcessSummaryResponseDto? _copySource;
    private string _copyCode = "";
    private string _copyName = "";
    private bool _copySaving;

    protected override void OnInitialized() => Vocab.OnChange += OnVocabChanged;
    protected override async Task OnInitializedAsync() => await LoadData();
    private void OnVocabChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Vocab.OnChange -= OnVocabChanged;

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _data = await Api.GetProcessesAsync(_search, _active, _status,
                processRole: string.IsNullOrEmpty(_roleFilter) ? null : _roleFilter,
                excludeDocumentRoles: string.IsNullOrEmpty(_roleFilter),
                page: _page, pageSize: _pageSize);
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearch(string v) { _search = v; _page = 1; await LoadData(); }
    private async Task OnPageChanged(int p) { _page = p; await LoadData(); }

    private async Task OnRoleFilter(ChangeEventArgs e)
    {
        _roleFilter = e.Value?.ToString() ?? "";
        _page = 1;
        await LoadData();
    }

    private async Task OnActiveFilter(ChangeEventArgs e)
    {
        _active = string.IsNullOrEmpty(e.Value?.ToString()) ? null : bool.Parse(e.Value.ToString()!);
        _page = 1;
        await LoadData();
    }

    private async Task OnStatusFilter(ChangeEventArgs e)
    {
        _status = string.IsNullOrEmpty(e.Value?.ToString()) ? null : e.Value.ToString();
        _page = 1;
        await LoadData();
    }

    private void ShowCreate() { _editId = null; _formCode = ""; _formName = ""; _formDesc = ""; _showForm = true; }

    private void ShowEdit(ProcessSummaryResponseDto p)
    {
        _editId = p.Id; _formName = p.Name; _formDesc = p.Description ?? ""; _showForm = true;
    }

    private void CloseForm() => _showForm = false;

    private async Task Save()
    {
        try
        {
            if (_editId.HasValue)
                await Api.UpdateProcessAsync(_editId.Value, new ProcessUpdateDto(_formName, _formDesc));
            else
                await Api.CreateProcessAsync(new ProcessCreateDto(_formCode, _formName, _formDesc));
            _showForm = false;
            await LoadData();
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

    private async Task Delete(Guid id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this process?")) return;
        try { await Api.DeleteProcessAsync(id); await LoadData(); }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

    private void ShowCopyModal(ProcessSummaryResponseDto p)
    {
        _copySource = p;
        _copyCode = "";
        _copyName = $"{p.Name} (Copy)";
    }

    private async Task HandleCopy()
    {
        if (_copySource is null) return;
        _copySaving = true;
        try
        {
            await Api.CopyProcessToMyLibraryAsync(_copySource.Id,
                new ProcessCopyDto(_copyCode, _copyName));
            Toast.ShowSuccess($"Copied '{_copySource.Name}' as '{_copyCode}'.");
            _copySource = null;
            await LoadData();
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
        finally { _copySaving = false; }
    }

    private static string StatusBadgeClass(string? status) => status switch
    {
        "Draft"          => "bg-secondary",
        "PendingApproval" => "bg-warning text-dark",
        "Released"       => "bg-success",
        "Superseded"     => "bg-dark",
        "Retired"        => "bg-danger",
        _                => "bg-light text-dark"
    };
}
