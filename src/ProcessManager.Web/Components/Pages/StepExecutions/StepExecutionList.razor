@page "/step-executions"
@rendermode InteractiveServer
@inject ApiClient Api

<PageTitle>Step Executions</PageTitle>

<h3 class="mb-3">Step Executions</h3>

<div class="d-flex gap-3 mb-3 flex-wrap">
    <select class="form-select form-select-sm" style="width:auto" @onchange="OnStatusFilter">
        <option value=""           selected="@(_status is null)">All Statuses</option>
        <option value="Pending"    selected="@(_status == "Pending")">Pending</option>
        <option value="InProgress" selected="@(_status == "InProgress")">In Progress</option>
        <option value="Completed"  selected="@(_status == "Completed")">Completed</option>
        <option value="Skipped"    selected="@(_status == "Skipped")">Skipped</option>
        <option value="Failed"     selected="@(_status == "Failed")">Failed</option>
    </select>
    <select class="form-select form-select-sm" style="width:auto" @onchange="OnJobFilter">
        <option value="">All Jobs</option>
        @if (_jobs is not null)
        {
            @foreach (var j in _jobs)
            {
                <option value="@j.Id">@j.Name (@j.Code)</option>
            }
        }
    </select>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_data is not null)
{
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Step Name</th>
                    <th>Job</th>
                    <th>Status</th>
                    <th>Started</th>
                    <th>Completed</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @if (!_data.Items.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-3">No step executions found.</td></tr>
                }
                else
                {
                @foreach (var se in _data.Items)
                {
                    <tr>
                        <td><a href="step-executions/@se.Id">@se.Sequence</a></td>
                        <td><a href="step-executions/@se.Id">@se.StepName</a></td>
                        <td><a href="jobs/@se.JobId">View Job</a></td>
                        <td><StatusBadge Status="@se.Status" /></td>
                        <td>@(se.StartedAt?.ToString("g") ?? "—")</td>
                        <td>@(se.CompletedAt?.ToString("g") ?? "—")</td>
                        <td class="small text-truncate" style="max-width:200px">@(se.Notes ?? "")</td>
                    </tr>
                }
                }
            </tbody>
        </table>
    </div>

    <Pager Page="_page" PageSize="_pageSize" TotalCount="_data.TotalCount"
           OnPageChanged="OnPageChanged" />
}

@code {
    private PaginatedResponse<StepExecutionResponseDto>? _data;
    private bool _loading = true;
    [Parameter][SupplyParameterFromQuery(Name = "status")] public string? StatusQuery { get; set; }

    private string? _status;
    private Guid? _jobId;
    private int _page = 1;
    private int _pageSize = 25;
    private List<JobResponseDto>? _jobs;

    protected override async Task OnInitializedAsync()
    {
        _status = StatusQuery;
        var jobResult = await Api.GetJobsAsync(page: 1, pageSize: 200);
        _jobs = jobResult?.Items?.ToList();
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _data = await Api.GetStepExecutionsAsync(jobId: _jobId, status: _status, page: _page, pageSize: _pageSize);
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnPageChanged(int p) { _page = p; await LoadData(); }

    private async Task OnStatusFilter(ChangeEventArgs e)
    {
        _status = string.IsNullOrEmpty(e.Value?.ToString()) ? null : e.Value.ToString();
        _page = 1; await LoadData();
    }

    private async Task OnJobFilter(ChangeEventArgs e)
    {
        _jobId = Guid.TryParse(e.Value?.ToString(), out var id) ? id : null;
        _page = 1; await LoadData();
    }
}
