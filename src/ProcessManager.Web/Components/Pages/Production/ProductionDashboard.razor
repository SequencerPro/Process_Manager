@page "/production"
@rendermode InteractiveServer
@attribute [Authorize]
@inject ApiClient Api

<PageTitle>Production Dashboard — Process Manager</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-0"><i class="bi bi-speedometer me-2 text-primary"></i>Production Dashboard</h3>
        <p class="text-muted small mb-0">Live WIP status, bottlenecks and maintenance schedule</p>
    </div>
    <button class="btn btn-sm btn-outline-secondary" @onclick="Load" disabled="@_loading">
        <i class="bi bi-arrow-clockwise @(_loading ? "spin" : "") me-1"></i>Refresh
    </button>
</div>

@if (_loading)
{
    <div class="text-center py-5 text-muted">
        <div class="spinner-border spinner-border-sm me-2"></div>Loading…
    </div>
}
else if (_dash is null)
{
    <div class="alert alert-warning small">Could not load production data.</div>
}
else
{
    <!-- KPI Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md col-6">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <span class="fs-2 text-primary"><i class="bi bi-play-circle-fill"></i></span>
                    <div>
                        <div class="fw-bold fs-4 lh-1 mb-1">@_dash.TotalActiveJobs</div>
                        <div class="text-muted" style="font-size:.78rem">Active Jobs</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md col-6">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <span class="fs-2 @(_dash.LateJobCount > 0 ? "text-danger" : "text-success")">
                        <i class="bi bi-clock-history"></i>
                    </span>
                    <div>
                        <div class="fw-bold fs-4 lh-1 mb-1">@_dash.LateJobCount</div>
                        <div class="text-muted" style="font-size:.78rem">Late Jobs</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md col-6">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <span class="fs-2 @(_dash.EquipmentDownCount > 0 ? "text-warning" : "text-success")">
                        <i class="bi bi-tools"></i>
                    </span>
                    <div>
                        <div class="fw-bold fs-4 lh-1 mb-1">@_dash.EquipmentDownCount</div>
                        <div class="text-muted" style="font-size:.78rem">Equipment Down</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md col-6">
            <div class="card h-100 border-0 shadow-sm">
                <div class="card-body d-flex align-items-center gap-3 py-3">
                    <span class="fs-2 @(_dash.MaintenanceDue.Any() ? "text-warning" : "text-success")">
                        <i class="bi bi-wrench-adjustable"></i>
                    </span>
                    <div>
                        <div class="fw-bold fs-4 lh-1 mb-1">@_dash.MaintenanceDue.Count</div>
                        <div class="text-muted" style="font-size:.78rem">Maintenance Due</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Late Jobs -->
        @if (_dash.LateJobs.Any())
        {
            <div class="col-12">
                <div class="card shadow-sm border-danger">
                    <div class="card-header bg-danger bg-opacity-10 d-flex justify-content-between align-items-center">
                        <span class="fw-semibold text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Late Jobs (@_dash.LateJobs.Count)</span>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Job</th>
                                    <th>Process</th>
                                    <th>Current Step</th>
                                    <th>Due Date</th>
                                    <th>Days Late</th>
                                    <th>Equipment</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var j in _dash.LateJobs.OrderByDescending(x => x.DaysLate))
                                {
                                    <tr>
                                        <td>
                                            <a href="jobs/@j.JobId" class="text-decoration-none fw-semibold">@j.JobCode</a>
                                            <div class="text-muted small">@j.JobName</div>
                                        </td>
                                        <td class="text-muted small">@j.ProcessName</td>
                                        <td class="small">@j.CurrentStepName</td>
                                        <td class="small">@j.DueDate?.ToString("MMM d, yyyy")</td>
                                        <td><span class="badge bg-danger">@j.DaysLate d</span></td>
                                        <td>
                                            @if (j.CurrentEquipmentCode is not null)
                                            {
                                                <span class="badge @(j.CurrentEquipmentDown ? "bg-warning text-dark" : "bg-secondary")">
                                                    @if (j.CurrentEquipmentDown) { <i class="bi bi-exclamation me-1"></i> }
                                                    @j.CurrentEquipmentCode
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        }

        <!-- WIP Board -->
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span class="fw-semibold"><i class="bi bi-kanban me-2"></i>Active WIP (@_dash.TotalActiveJobs jobs)</span>
                </div>
                @if (_dash.ActiveJobs.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Job</th>
                                    <th>Current Step</th>
                                    <th>Step Time</th>
                                    <th>Expected Done</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var j in _dash.ActiveJobs)
                                {
                                    <tr class="@(j.IsLate ? "table-danger" : "")">
                                        <td>
                                            <a href="jobs/@j.JobId" class="text-decoration-none fw-semibold">@j.JobCode</a>
                                            <div class="text-muted" style="font-size:.78rem">@j.JobName</div>
                                        </td>
                                        <td class="small">
                                            @j.CurrentStepName
                                            @if (j.CurrentEquipmentCode is not null)
                                            {
                                                <div>
                                                    <span class="badge @(j.CurrentEquipmentDown ? "bg-warning text-dark" : "bg-light text-dark border") badge-sm">
                                                        @if (j.CurrentEquipmentDown) { <i class="bi bi-exclamation me-1"></i> }
                                                        @j.CurrentEquipmentCode
                                                    </span>
                                                </div>
                                            }
                                        </td>
                                        <td class="small text-muted">
                                            @if (j.CurrentStepRunningMinutes.HasValue)
                                            {
                                                @FormatMinutes(j.CurrentStepRunningMinutes.Value)
                                                @if (j.CurrentStepExpectedMinutes.HasValue)
                                                {
                                                    <span class="text-muted"> / @FormatMinutes(j.CurrentStepExpectedMinutes.Value)</span>
                                                }
                                            }
                                            else { <span>—</span> }
                                        </td>
                                        <td class="small">@j.ExpectedCompletionDate?.ToString("MMM d")</td>
                                        <td>
                                            @if (j.IsLate)
                                            {
                                                <span class="badge bg-danger">@j.DaysLate d late</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">On time</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="card-body text-muted small text-center py-4">No active jobs.</div>
                }
            </div>
        </div>

        <!-- Right column: Bottlenecks + Maintenance -->
        <div class="col-lg-4">
            <!-- Bottlenecks -->
            <div class="card shadow-sm mb-3">
                <div class="card-header fw-semibold">
                    <i class="bi bi-funnel me-2"></i>Bottlenecks
                </div>
                @if (_dash.Bottlenecks.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var b in _dash.Bottlenecks.Take(5))
                        {
                            <li class="list-group-item py-2 px-3">
                                <div class="d-flex justify-content-between">
                                    <span class="small fw-semibold">@b.StepName</span>
                                    <span class="badge bg-warning text-dark">@b.PendingCount pending</span>
                                </div>
                                <div class="text-muted" style="font-size:.75rem">@FormatMinutes(b.BacklogMinutes) backlog</div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="card-body text-muted small text-center py-3">No bottlenecks detected.</div>
                }
            </div>

            <!-- Maintenance Due -->
            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span class="fw-semibold"><i class="bi bi-wrench-adjustable me-2"></i>Maintenance Due</span>
                    <a href="maintenance" class="btn btn-sm btn-outline-secondary py-0">View all</a>
                </div>
                @if (_dash.MaintenanceDue.Any())
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var t in _dash.MaintenanceDue.Take(8))
                        {
                            <li class="list-group-item py-2 px-3">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="small fw-semibold">@t.Title</div>
                                        <div class="text-muted" style="font-size:.75rem">@t.EquipmentCode — @t.EquipmentName</div>
                                    </div>
                                    <span class="badge @TaskStatusBadge(t.Status) ms-2">@t.Status</span>
                                </div>
                                <div class="text-muted" style="font-size:.75rem">Due: @t.DueDate.ToString("MMM d, yyyy")</div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <div class="card-body text-muted small text-center py-3">No maintenance due.</div>
                }
            </div>
        </div>
    </div>
}

@code {
    private ProductionDashboardDto? _dash;
    private bool _loading = true;

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _loading = true;
        try
        {
            _dash = await Api.GetProductionDashboardAsync();
        }
        finally { _loading = false; }
    }

    private static string FormatMinutes(double mins)
    {
        if (mins < 60) return $"{(int)mins}m";
        return $"{(int)(mins / 60)}h {(int)(mins % 60)}m";
    }

    private static string FormatMinutes(int mins) => FormatMinutes((double)mins);

    private static string TaskStatusBadge(string status) => status switch
    {
        "Overdue" => "bg-danger",
        "Due" => "bg-warning text-dark",
        "InProgress" => "bg-primary",
        "Upcoming" => "bg-secondary",
        "Completed" => "bg-success",
        "Cancelled" => "bg-light text-dark border",
        _ => "bg-secondary"
    };
}
