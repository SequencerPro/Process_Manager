@page "/suppliers"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin,Engineer")]
@using Microsoft.AspNetCore.Authorization
@using ProcessManager.Api.DTOs
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Suppliers — Process Manager</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4 page-heading-row">
    <div>
        <h3 class="mb-0"><i class="bi bi-building me-2 text-primary"></i>Approved Supplier List</h3>
        <p class="text-muted small mb-0 d-none d-md-block">Manage suppliers, evaluations, and approval status</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenCreateModal">
        <i class="bi bi-plus-lg me-1"></i> New Supplier
    </button>
</div>

@* ── KPI cards ── *@
@if (_dashboard is not null)
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card shadow-sm text-center p-3">
                <div class="fs-3 fw-bold text-primary">@_dashboard.TotalSuppliers</div>
                <div class="small text-muted">Total Suppliers</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm text-center p-3">
                <div class="fs-3 fw-bold text-success">@_dashboard.ApprovedSuppliers</div>
                <div class="small text-muted">Approved</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm text-center p-3">
                <div class="fs-3 fw-bold text-warning">@_dashboard.ConditionalSuppliers</div>
                <div class="small text-muted">Conditional</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm text-center p-3">
                <div class="fs-3 fw-bold text-danger">@_dashboard.SuspendedSuppliers</div>
                <div class="small text-muted">Suspended</div>
            </div>
        </div>
    </div>
}

@* ── Filters ── *@
<div class="row g-2 mb-3">
    <div class="col-md-4">
        <div class="input-group input-group-sm">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text" class="form-control" placeholder="Search by code, name, or contact…"
                   @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
        </div>
    </div>
    <div class="col-md-3">
        <select class="form-select form-select-sm" @bind="_statusFilter" @bind:after="LoadData">
            <option value="">All statuses</option>
            <option value="Pending">Pending</option>
            <option value="Approved">Approved</option>
            <option value="Conditional">Conditional</option>
            <option value="Suspended">Suspended</option>
            <option value="Inactive">Inactive</option>
        </select>
    </div>
</div>

@* ── Table ── *@
<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th class="text-center">Status</th>
                    <th class="text-center col-hide-mobile">Score</th>
                    <th class="text-center col-hide-mobile">Evaluations</th>
                    <th class="text-end" style="width:140px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (_loading)
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">
                        <div class="spinner-border spinner-border-sm me-2"></div>Loading…
                    </td></tr>
                }
                else if (_result is null || !_result.Items.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No suppliers found.</td></tr>
                }
                else
                {
                    @foreach (var sup in _result.Items)
                    {
                        <tr>
                            <td class="align-middle"><code>@sup.Code</code></td>
                            <td class="align-middle">
                                <a href="/suppliers/@sup.Id" class="text-decoration-none">@sup.Name</a>
                            </td>
                            <td class="align-middle text-center">
                                <span class="badge @StatusBadge(sup.Status)">@sup.Status</span>
                            </td>
                            <td class="align-middle text-center col-hide-mobile">
                                @if (sup.LatestOverallScore.HasValue)
                                {
                                    <span class="badge @ScoreBadge(sup.LatestOverallScore.Value)">@sup.LatestOverallScore / 100</span>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                            <td class="align-middle text-center col-hide-mobile">@sup.EvaluationCount</td>
                            <td class="align-middle text-end">
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick='() => Nav.NavigateTo($"/suppliers/{sup.Id}")' title="View details">
                                    <i class="bi bi-eye"></i>
                                </button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteSupplier(sup)" title="Deactivate">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@* ── Pager ── *@
@if (_result is not null && _result.TotalPages > 1)
{
    <nav class="mt-3 d-flex justify-content-center">
        <ul class="pagination pagination-sm">
            <li class="page-item @(!_result.HasPreviousPage ? "disabled" : "")">
                <button class="page-link" @onclick="() => GoToPage(_page - 1)">&laquo;</button>
            </li>
            @for (var p = 1; p <= _result.TotalPages; p++)
            {
                var pg = p;
                <li class="page-item @(pg == _page ? "active" : "")">
                    <button class="page-link" @onclick="() => GoToPage(pg)">@pg</button>
                </li>
            }
            <li class="page-item @(!_result.HasNextPage ? "disabled" : "")">
                <button class="page-link" @onclick="() => GoToPage(_page + 1)">&raquo;</button>
            </li>
        </ul>
    </nav>
}

@* ── Create modal ── *@
@if (_showCreateModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">New Supplier</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <div class="alert alert-danger py-2 small">@_error</div>
                    }
                    <div class="mb-3">
                        <label class="form-label">Code <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" @bind="_createCode" placeholder="e.g. SUP-001" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Name <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" @bind="_createName" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Contact Name</label>
                        <input type="text" class="form-control" @bind="_createContactName" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Contact Email</label>
                        <input type="email" class="form-control" @bind="_createContactEmail" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Contact Phone</label>
                        <input type="text" class="form-control" @bind="_createContactPhone" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Address</label>
                        <textarea class="form-control" rows="2" @bind="_createAddress"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notes</label>
                        <textarea class="form-control" rows="2" @bind="_createNotes"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button class="btn btn-primary" @onclick="SubmitCreate" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Create
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PaginatedResponse<SupplierSummaryDto>? _result;
    private SupplierQualityDashboardDto? _dashboard;
    private bool _loading = true;
    private string _search = "";
    private string _statusFilter = "";
    private int _page = 1;

    // Create modal
    private bool _showCreateModal;
    private bool _saving;
    private string? _error;
    private string _createCode = "";
    private string _createName = "";
    private string? _createContactName;
    private string? _createContactEmail;
    private string? _createContactPhone;
    private string? _createAddress;
    private string? _createNotes;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();

        bool? activeFilter = null;
        if (_statusFilter == "Inactive") activeFilter = false;
        else if (!string.IsNullOrEmpty(_statusFilter)) activeFilter = null;

        _result = await Api.GetSuppliersAsync(_search, _statusFilter, activeFilter, _page);
        _dashboard = await Api.GetSupplierQualityDashboardAsync();
        _loading = false;
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e) { if (e.Key == "Enter") { _page = 1; await LoadData(); } }
    private async Task GoToPage(int p) { _page = p; await LoadData(); }

    private void OpenCreateModal()
    {
        _showCreateModal = true;
        _error = null;
        _createCode = "";
        _createName = "";
        _createContactName = null;
        _createContactEmail = null;
        _createContactPhone = null;
        _createAddress = null;
        _createNotes = null;
    }

    private void CloseModal() => _showCreateModal = false;

    private async Task SubmitCreate()
    {
        if (string.IsNullOrWhiteSpace(_createCode) || string.IsNullOrWhiteSpace(_createName))
        {
            _error = "Code and Name are required.";
            return;
        }

        _saving = true;
        _error = null;

        try
        {
            var dto = new CreateSupplierDto
            {
                Code = _createCode,
                Name = _createName,
                ContactName = _createContactName,
                ContactEmail = _createContactEmail,
                ContactPhone = _createContactPhone,
                Address = _createAddress,
                Notes = _createNotes
            };
            var created = await Api.CreateSupplierAsync(dto);
            _showCreateModal = false;
            if (created != null) Nav.NavigateTo($"/suppliers/{created.Id}");
        }
        catch (HttpRequestException ex)
        {
            _error = ex.Message.Contains("409") ? $"A supplier with code '{_createCode}' already exists." : ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteSupplier(SupplierSummaryDto sup)
    {
        await Api.DeleteSupplierAsync(sup.Id);
        await LoadData();
    }

    private static string StatusBadge(string status) => status switch
    {
        "Approved" => "bg-success",
        "Conditional" => "bg-warning text-dark",
        "Suspended" => "bg-danger",
        "Pending" => "bg-info text-dark",
        "Inactive" => "bg-secondary",
        _ => "bg-secondary"
    };

    private static string ScoreBadge(int score) => score switch
    {
        >= 80 => "bg-success",
        >= 60 => "bg-warning text-dark",
        _ => "bg-danger"
    };
}
