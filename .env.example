# ─────────────────────────────────────────────────────────────────────────────
# Process Manager — on-premises environment configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env, fill in the required values, then run:
#   docker compose up -d
#
# .env is git-ignored. Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────


# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Random secret used to sign JWT tokens. Must be at least 32 characters.
# Generate a value with:  openssl rand -base64 32
JWT_KEY=REPLACE_WITH_A_RANDOM_32_CHARACTER_SECRET

# Password for the PostgreSQL database.
POSTGRES_PASSWORD=REPLACE_WITH_A_SECURE_DATABASE_PASSWORD


# ── OPTIONAL ─────────────────────────────────────────────────────────────────

# Password to protect the Swagger UI at /swagger.
# Leave blank to disable the basic-auth gate entirely.
SWAGGER_PASSWORD=

# Initial admin account password.
# Only applied on first startup when the database has no users.
# Default value (Admin1234!) is used if this is left blank or omitted.
SEED_ADMIN_PASSWORD=Admin1234!

# JWT token lifetime in minutes. Default: 480 (8 hours).
# JWT_EXPIRY_MINUTES=480
