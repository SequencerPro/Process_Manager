@page "/workflows"
@attribute [Authorize(Roles = "Admin,Engineer")]
@rendermode InteractiveServer
@inject ApiClient Api
@inject IJSRuntime JS
@inject VocabularyService Vocab
@implements IDisposable

<PageTitle>@Vocab.Workflows</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3 page-heading-row">
    <h3 class="mb-0">@Vocab.Workflows</h3>
    <button class="btn btn-primary btn-sm" @onclick="ShowCreate">
        <i class="bi bi-plus-lg me-1"></i> New @Vocab.Workflow
    </button>
</div>

<div class="d-flex flex-wrap gap-2 mb-3">
    <SearchBox Value="@_search" ValueChanged="OnSearch" Placeholder="@($"Search {Vocab.Workflows.ToLower()}...")" />
    <select class="form-select form-select-sm" style="width:auto" @onchange="OnActiveFilter">
        <option value="">All</option>
        <option value="true">Active</option>
        <option value="false">Inactive</option>
    </select>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_data is not null)
{
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th class="col-hide-mobile">Version</th>
                    <th>Processes</th>
                    <th class="col-hide-mobile">Links</th>
                    <th>Active</th>
                    <th style="width:140px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!_data.Items.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-3">No workflows found.</td></tr>
                }
                else
                {
                @foreach (var w in _data.Items)
                {
                    <tr>
                        <td><code>@w.Code</code></td>
                        <td><a href="workflows/@w.Id">@w.Name</a></td>
                        <td class="col-hide-mobile">v@w.Version</td>
                        <td><span class="badge bg-secondary">@(w.Processes?.Count ?? 0)</span></td>
                        <td class="col-hide-mobile"><span class="badge bg-secondary">@(w.Links?.Count ?? 0)</span></td>
                        <td>
                            @if (w.IsActive)
                            {
                                <i class="bi bi-check-circle-fill text-success"></i>
                            }
                            else
                            {
                                <i class="bi bi-x-circle text-danger"></i>
                            }
                        </td>
                        <td>
                            <a href="workflows/@w.Id/builder" class="btn btn-outline-primary btn-sm me-1" title="Open in Builder">
                                <i class="bi bi-diagram-3"></i>
                            </a>
                            <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => ShowEdit(w)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(w.Id)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
                }
            </tbody>
        </table>
    </div>

    <Pager Page="_page" PageSize="_pageSize" TotalCount="_data.TotalCount"
           OnPageChanged="OnPageChanged" />
}

@if (_showForm)
{
    <div class="modal show d-block pm-modal" tabindex="-1" style="background: rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <div class="pm-modal-icon pm-modal-icon-orange">
                        <i class="bi @(_editId.HasValue ? "bi-pencil-square" : "bi-plus-circle")"></i>
                    </div>
                    <div>
                        <h5 class="modal-title">@(_editId.HasValue ? "Edit" : "New") @Vocab.Workflow</h5>
                        <div class="pm-modal-subtitle">@(_editId.HasValue ? "Update workflow details" : "Create a new workflow to orchestrate processes")</div>
                    </div>
                    <button type="button" class="btn-close ms-auto" @onclick="CloseForm"></button>
                </div>
                <div class="modal-body">
                    @if (!_editId.HasValue)
                    {
                        <div class="pm-input-group">
                            <label><i class="bi bi-upc-scan"></i> Code</label>
                            <input class="form-control" @bind="_formCode" placeholder="e.g. WRKFLW-001" />
                        </div>
                        <div class="pm-modal-divider">Details</div>
                    }
                    <div class="pm-input-group">
                        <label><i class="bi bi-type"></i> Name</label>
                        <input class="form-control" @bind="_formName" placeholder="e.g. PC Build Workflow" />
                    </div>
                    <div class="pm-input-group">
                        <label><i class="bi bi-card-text"></i> Description</label>
                        <textarea class="form-control" rows="3" @bind="_formDesc" placeholder="Optional description..."></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                    <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm"></span> }
                        <i class="bi @(_editId.HasValue ? "bi-check-lg" : "bi-plus-lg")"></i>
                        @(_editId.HasValue ? "Save Changes" : "Create Workflow")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PaginatedResponse<WorkflowResponseDto>? _data;
    private bool _loading = true;
    private string _search = "";
    private bool? _active;
    private int _page = 1;
    private int _pageSize = 25;

    private bool _showForm;
    private bool _saving;
    private Guid? _editId;
    private string _formCode = "";
    private string _formName = "";
    private string _formDesc = "";

    protected override void OnInitialized() => Vocab.OnChange += OnVocabChanged;
    protected override async Task OnInitializedAsync() => await LoadData();
    private void OnVocabChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Vocab.OnChange -= OnVocabChanged;

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _data = await Api.GetWorkflowsAsync(_search, _active, _page, _pageSize);
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearch(string v) { _search = v; _page = 1; await LoadData(); }
    private async Task OnPageChanged(int p) { _page = p; await LoadData(); }

    private async Task OnActiveFilter(ChangeEventArgs e)
    {
        _active = string.IsNullOrEmpty(e.Value?.ToString()) ? null : bool.Parse(e.Value.ToString()!);
        _page = 1; await LoadData();
    }

    private void ShowCreate() { _editId = null; _formCode = ""; _formName = ""; _formDesc = ""; _showForm = true; }

    private void ShowEdit(WorkflowResponseDto w)
    {
        _editId = w.Id; _formName = w.Name; _formDesc = w.Description ?? ""; _showForm = true;
    }

    private void CloseForm() { _showForm = false; }

    private async Task Save()
    {
        _saving = true;
        try
        {
            if (_editId.HasValue)
                await Api.UpdateWorkflowAsync(_editId.Value, new UpdateWorkflowDto(_formName, _formDesc));
            else
                await Api.CreateWorkflowAsync(new CreateWorkflowDto(_formCode, _formName, _formDesc));
            _showForm = false;
            await LoadData();
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
        finally { _saving = false; }
    }

    private async Task Delete(Guid id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this workflow?")) return;
        try { await Api.DeleteWorkflowAsync(id); await LoadData(); }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }
}
