@page "/onboarding"
@rendermode InteractiveServer
@using ProcessManager.Domain.Entities
@inject ApiClient Api
@inject NavigationManager Nav

<PageTitle>Welcome — Process Manager</PageTitle>

@if (_state is null)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary"></div>
        <div class="text-muted small mt-2">Loading your workspace…</div>
    </div>
}
else
{
    <div class="container" style="max-width: 820px;">
        <div class="mb-4">
            <h3 class="mb-1">Welcome to Process Manager</h3>
            <p class="text-muted mb-0">A short tour so your team can hit the ground running.</p>
        </div>

        @* Progress bar *@
        <div class="mb-4">
            <div class="d-flex justify-content-between small text-muted mb-1">
                <span>Step @(_step + 1) of 5</span>
                <span>@((_step * 20) + (_state.IsCompleted ? 20 : 0))%</span>
            </div>
            <div class="progress" style="height: 6px;">
                <div class="progress-bar" role="progressbar"
                     style="width: @((_state.IsCompleted ? 100 : _step * 20))%;"></div>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-body p-4">
                @if (_errorMessage is not null)
                {
                    <div class="alert alert-danger py-2">
                        <i class="bi bi-exclamation-triangle me-2"></i>@_errorMessage
                    </div>
                }

                @switch (_step)
                {
                    case 0:
                        @StepWelcome();
                        break;
                    case 1:
                        @StepCreateKind();
                        break;
                    case 2:
                        @StepCreateStepTemplate();
                        break;
                    case 3:
                        @StepCreateProcess();
                        break;
                    case 4:
                        @StepFinish();
                        break;
                }
            </div>
        </div>

        <div class="d-flex justify-content-between mt-3">
            <button class="btn btn-link text-muted" @onclick="SkipAsync" disabled="@_busy">
                <i class="bi bi-fast-forward me-1"></i>Skip &amp; seed sample
            </button>
            <div>
                @if (_step > 0)
                {
                    <button class="btn btn-outline-secondary me-2" @onclick="Back" disabled="@_busy">
                        <i class="bi bi-arrow-left me-1"></i>Back
                    </button>
                }
                @if (_step < 4)
                {
                    <button class="btn btn-primary" @onclick="Next" disabled="@_busy">
                        @if (_busy) { <span class="spinner-border spinner-border-sm me-2"></span> }
                        Next <i class="bi bi-arrow-right ms-1"></i>
                    </button>
                }
                else
                {
                    <button class="btn btn-success" @onclick="FinishAsync" disabled="@_busy">
                        @if (_busy) { <span class="spinner-border spinner-border-sm me-2"></span> }
                        <i class="bi bi-check2-circle me-1"></i>Finish
                    </button>
                }
            </div>
        </div>
    </div>
}

@code {
    private OnboardingStateDto? _state;
    private int _step;
    private bool _busy;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _state = await Api.GetOnboardingStateAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Could not load onboarding state: {ex.Message}";
            return;
        }

        if (_state is null)
        {
            _errorMessage = "Onboarding state is not available for your tenant.";
            return;
        }

        if (_state.IsCompleted || _state.IsSkipped)
        {
            // Already finished — bounce to the dashboard.
            Nav.NavigateTo("/", forceLoad: false);
            return;
        }

        _step = Math.Clamp(_state.CurrentStep, 0, 4);
    }

    private async Task Next()
    {
        if (_state is null) return;
        _busy = true;
        _errorMessage = null;
        try
        {
            _step = Math.Min(_step + 1, 4);
            var updated = await Api.UpdateOnboardingStateAsync(new UpdateOnboardingStepDto(
                _step, _state.FirstKindId, _state.FirstStepTemplateId, _state.FirstProcessId, _state.FirstJobId));
            if (updated is not null) _state = updated;
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task Back()
    {
        if (_state is null) return;
        _step = Math.Max(_step - 1, 0);
        try
        {
            var updated = await Api.UpdateOnboardingStateAsync(new UpdateOnboardingStepDto(
                _step, _state.FirstKindId, _state.FirstStepTemplateId, _state.FirstProcessId, _state.FirstJobId));
            if (updated is not null) _state = updated;
        }
        catch { /* non-fatal */ }
    }

    private async Task FinishAsync()
    {
        if (_state is null) return;
        _busy = true;
        _errorMessage = null;
        try
        {
            var updated = await Api.UpdateOnboardingStateAsync(new UpdateOnboardingStepDto(
                5, _state.FirstKindId, _state.FirstStepTemplateId, _state.FirstProcessId, _state.FirstJobId));
            if (updated is not null) _state = updated;
            Nav.NavigateTo("/", forceLoad: true);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private async Task SkipAsync()
    {
        _busy = true;
        _errorMessage = null;
        try
        {
            await Api.SkipOnboardingAsync(seedSample: true);
            Nav.NavigateTo("/", forceLoad: true);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    // ── Step renderers ───────────────────────────────────────────────────────

    private RenderFragment StepWelcome() => __builder =>
    {
        <h5 class="mb-2"><i class="bi bi-stars me-2 text-primary"></i>Welcome</h5>
        <p class="text-muted">
            Process Manager helps you design and run repeatable manufacturing processes.
            We've pre-configured a starter vocabulary based on your industry
            (<strong>@IndustryLabel(_state!.Industry)</strong>) — you can change it later in
            <a href="/vocabulary">Vocabulary</a>.
        </p>
        <p class="text-muted">
            In the next four steps you'll:
        </p>
        <ol class="text-muted">
            <li>Create your first <strong>Kind</strong> — the thing you make.</li>
            <li>Create your first <strong>Step Template</strong> — a reusable operation.</li>
            <li>Create your first <strong>Process</strong> — a sequence of steps.</li>
            <li>Review and finish.</li>
        </ol>
        <p class="text-muted small mb-0">
            In a hurry? Click <em>Skip &amp; seed sample</em> and we'll generate a working example for you.
        </p>
    };

    private RenderFragment StepCreateKind() => __builder =>
    {
        <h5 class="mb-2"><i class="bi bi-box me-2 text-primary"></i>Create your first Kind</h5>
        <p class="text-muted">
            A <strong>Kind</strong> is the thing you make — a part, a board, a device.
            Each Kind can have one or more <strong>Grades</strong> (e.g. "NEW", "PASS", "REWORK").
        </p>
        <div class="alert alert-info py-2 small mb-0">
            <i class="bi bi-info-circle me-2"></i>
            Head to <a href="/kinds" target="_blank">Kinds &amp; Grades</a> in another tab to set one up,
            then come back and click Next. Or click <em>Skip &amp; seed sample</em> to get a ready-made example.
        </div>
    };

    private RenderFragment StepCreateStepTemplate() => __builder =>
    {
        <h5 class="mb-2"><i class="bi bi-puzzle me-2 text-primary"></i>Create a Step Template</h5>
        <p class="text-muted">
            A <strong>Step Template</strong> describes a single operation — for example "Mill Feature A",
            "Solder SMT", "Final Inspection". Each template has inputs, outputs and prompts.
        </p>
        <div class="alert alert-info py-2 small mb-0">
            <i class="bi bi-info-circle me-2"></i>
            Go to <a href="/step-templates" target="_blank">Step Templates</a> and create one, or skip
            and we'll seed a representative example for your industry.
        </div>
    };

    private RenderFragment StepCreateProcess() => __builder =>
    {
        <h5 class="mb-2"><i class="bi bi-diagram-3 me-2 text-primary"></i>Assemble your Process</h5>
        <p class="text-muted">
            A <strong>Process</strong> is a sequence of Step Templates that produces a Kind.
            You can have multiple revisions of a Process as it evolves.
        </p>
        <div class="alert alert-info py-2 small mb-0">
            <i class="bi bi-info-circle me-2"></i>
            Visit <a href="/processes" target="_blank">Processes</a> and create one, or skip and
            we'll assemble the sample.
        </div>
    };

    private RenderFragment StepFinish() => __builder =>
    {
        <h5 class="mb-2"><i class="bi bi-check2-circle me-2 text-success"></i>You're ready</h5>
        <p class="text-muted">
            That's the tour. From the dashboard you can:
        </p>
        <ul class="text-muted">
            <li>Create a <strong>Work Order</strong> for a Kind and release <strong>Jobs</strong> to the floor.</li>
            <li>Invite teammates from <a href="/admin/users">Admin → Users</a>.</li>
            <li>Turn advanced modules on or off from <a href="/settings/modules">Settings → Modules</a>.</li>
        </ul>
        <p class="text-muted small mb-0">
            Click Finish to open your dashboard.
        </p>
    };

    private static string IndustryLabel(OnboardingIndustry industry) => industry switch
    {
        OnboardingIndustry.CNC     => "CNC machining",
        OnboardingIndustry.PCBA    => "PCB assembly",
        OnboardingIndustry.Medical => "medical device",
        _                          => "general manufacturing"
    };
}
