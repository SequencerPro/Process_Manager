    private static string SerializeChoices(string raw) =>
        System.Text.Json.JsonSerializer.Serialize(
            raw.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries));

    private static string DeserializeChoices(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return string.Empty;
        try
        {
            var arr = System.Text.Json.JsonSerializer.Deserialize<string[]>(json);
            return arr is null ? string.Empty : string.Join("\n", arr);
        }
        catch { return json; }
    }

