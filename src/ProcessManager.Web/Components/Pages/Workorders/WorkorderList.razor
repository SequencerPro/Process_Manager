@page "/workorders"
@rendermode InteractiveServer
@inject ApiClient Api
@inject IJSRuntime JS
@inject VocabularyService Vocab
@implements IDisposable

<PageTitle>@Vocab.Workorders</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">@Vocab.Workorders</h3>
    <button class="btn btn-primary btn-sm" @onclick="ShowCreate">
        <i class="bi bi-plus-lg me-1"></i> New @Vocab.Workorder
    </button>
</div>

<div class="d-flex gap-3 mb-3 flex-wrap">
    <SearchBox Value="@_search" ValueChanged="OnSearch" Placeholder="@($"Search {Vocab.Workorders.ToLower()}...")" />
    <select class="form-select form-select-sm" style="width:auto" @onchange="OnStatusFilter">
        <option value="" selected="@(_status is null)">All Statuses</option>
        <option value="Created"    selected="@(_status == "Created")">Created</option>
        <option value="InProgress" selected="@(_status == "InProgress")">In Progress</option>
        <option value="Completed"  selected="@(_status == "Completed")">Completed</option>
        <option value="Cancelled"  selected="@(_status == "Cancelled")">Cancelled</option>
    </select>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_data is not null)
{
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Workflow</th>
                    <th>Status</th>
                    <th>Priority</th>
                    <th>Created</th>
                    <th style="width:140px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!_data.Items.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-3">No workorders found.</td></tr>
                }
                else
                {
                @foreach (var w in _data.Items)
                {
                    <tr>
                        <td><code>@w.Code</code></td>
                        <td><a href="workorders/@w.Id">@w.Name</a></td>
                        <td>@w.WorkflowName</td>
                        <td><StatusBadge Status="@w.Status" /></td>
                        <td>@w.Priority</td>
                        <td>@w.CreatedAt.ToString("g")</td>
                        <td>
                            <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => ShowEdit(w)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(w.Id)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
                }
            </tbody>
        </table>
    </div>

    <Pager Page="_page" PageSize="_pageSize" TotalCount="_data.TotalCount"
           OnPageChanged="OnPageChanged" />
}

@if (_showForm)
{
    <div class="modal show d-block pm-modal" tabindex="-1" style="background: rgba(0,0,0,.45)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <div class="pm-modal-icon pm-modal-icon-orange">
                        <i class="bi @(_editId.HasValue ? "bi-pencil-square" : "bi-plus-circle")"></i>
                    </div>
                    <div>
                        <h5 class="modal-title">@(_editId.HasValue ? "Edit" : "New") @Vocab.Workorder</h5>
                        <div class="pm-modal-subtitle">@(_editId.HasValue ? "Update workorder details" : "Select a workflow and configure your workorder")</div>
                    </div>
                    <button type="button" class="btn-close ms-auto" @onclick="CloseForm"></button>
                </div>
                <div class="modal-body">
                    @if (!_editId.HasValue)
                    {
                        <div class="pm-input-group">
                            <label><i class="bi bi-diagram-3"></i> Workflow</label>
                            <div class="d-flex gap-2">
                                <select class="form-select" value="@_formWorkflowId" @onchange="OnWorkflowChanged">
                                    <option value="">Select a workflow...</option>
                                    @if (_workflows is not null)
                                    {
                                        @foreach (var wf in _workflows.Items)
                                        {
                                            <option value="@wf.Id">@wf.Name (@wf.Code)</option>
                                        }
                                    }
                                </select>
                                <button type="button" class="pm-browse-btn" title="Browse workflows" @onclick="() => _showPicker = true">
                                    <i class="bi bi-grid-3x3-gap"></i>
                                </button>
                            </div>
                        </div>
                        <div class="pm-input-group">
                            <label><i class="bi bi-upc-scan"></i> Code</label>
                            <input class="form-control" @bind="_formCode" />
                        </div>
                        <div class="pm-modal-divider">Details</div>
                    }
                    <div class="pm-input-group">
                        <label><i class="bi bi-type"></i> Name</label>
                        <input class="form-control" @bind="_formName" />
                    </div>
                    <div class="pm-input-group">
                        <label><i class="bi bi-card-text"></i> Description</label>
                        <textarea class="form-control" rows="2" @bind="_formDesc"></textarea>
                    </div>
                    <div class="pm-input-group">
                        <label><i class="bi bi-flag"></i> Priority</label>
                        <input type="number" class="form-control" @bind="_formPriority" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                    <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm"></span> }
                        <i class="bi @(_editId.HasValue ? "bi-check-lg" : "bi-plus-lg")"></i>
                        @(_editId.HasValue ? "Save Changes" : "Create Workorder")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@if (_showPicker && _workflows is not null)
{
    <div class="modal show d-block pm-modal pm-picker" tabindex="-1" style="background: rgba(0,0,0,.55); z-index: 1060">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <div class="pm-modal-icon pm-modal-icon-orange">
                        <i class="bi bi-diagram-3"></i>
                    </div>
                    <div>
                        <h5 class="modal-title">Select Workflow</h5>
                        <div class="pm-modal-subtitle">Browse and choose a workflow for your workorder</div>
                    </div>
                    <button type="button" class="btn-close ms-auto" @onclick="() => _showPicker = false"></button>
                </div>
                <div class="modal-body">
                    <div class="pm-picker-search">
                        <input type="text" placeholder="Search workflows..." @bind="_pickerSearch" @bind:event="oninput" />
                    </div>
                    <div class="pm-picker-grid">
                        @{ var filtered = _workflows.Items.Where(wf =>
                            string.IsNullOrEmpty(_pickerSearch)
                            || wf.Name.Contains(_pickerSearch, StringComparison.OrdinalIgnoreCase)
                            || wf.Code.Contains(_pickerSearch, StringComparison.OrdinalIgnoreCase)).ToList(); }
                        @if (!filtered.Any())
                        {
                            <div class="pm-picker-empty">
                                <i class="bi bi-search d-block mb-2" style="font-size: 1.5rem"></i>
                                No workflows match your search
                            </div>
                        }
                        @foreach (var wf in filtered)
                        {
                            <div class="pm-picker-tile" @onclick="() => SelectWorkflowFromPicker(wf)">
                                <div class="pm-picker-tile-code">@wf.Code</div>
                                <div class="pm-picker-tile-name">@wf.Name</div>
                                @if (!string.IsNullOrEmpty(wf.Description))
                                {
                                    <div class="pm-picker-tile-desc">@wf.Description</div>
                                }
                                <div class="pm-picker-tile-meta">
                                    <span class="pm-picker-tile-badge">v@(wf.Version)</span>
                                    @if (wf.IsActive)
                                    {
                                        <span class="pm-picker-tile-badge" style="background: #d1e7dd; color: #0f5132">Active</span>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter][SupplyParameterFromQuery(Name = "status")] public string? StatusQuery { get; set; }

    private PaginatedResponse<WorkorderResponseDto>? _data;
    private bool _loading = true;
    private string _search = "";
    private string? _status;
    private int _page = 1;
    private int _pageSize = 25;

    // Form
    private bool _showForm;
    private bool _saving;
    private Guid? _editId;
    private string _formCode = "";
    private string _formName = "";
    private string _formDesc = "";
    private string _formWorkflowId = "";
    private int _formPriority;
    private PaginatedResponse<WorkflowResponseDto>? _workflows;

    // Tile picker
    private bool _showPicker;
    private string _pickerSearch = "";

    protected override void OnInitialized() => Vocab.OnChange += OnVocabChanged;

    protected override async Task OnInitializedAsync()
    {
        _status = StatusQuery;
        await LoadData();
    }

    private void OnVocabChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Vocab.OnChange -= OnVocabChanged;

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _data = await Api.GetWorkordersAsync(_search, _status, null, _page, _pageSize);
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearch(string v) { _search = v; _page = 1; await LoadData(); }
    private async Task OnPageChanged(int p) { _page = p; await LoadData(); }

    private async Task OnStatusFilter(ChangeEventArgs e)
    {
        _status = string.IsNullOrEmpty(e.Value?.ToString()) ? null : e.Value.ToString();
        _page = 1; await LoadData();
    }

    private async Task ShowCreate()
    {
        _editId = null;
        _formCode = $"WO-{Guid.NewGuid().ToString("N")[..8].ToUpper()}";
        _formName = ""; _formDesc = ""; _formWorkflowId = ""; _formPriority = 0;
        _showForm = true;
        _workflows = await Api.GetWorkflowsAsync(pageSize: 100);
        StateHasChanged();
    }

    private void OnWorkflowChanged(ChangeEventArgs e)
    {
        _formWorkflowId = e.Value?.ToString() ?? "";
        if (_workflows is not null && Guid.TryParse(_formWorkflowId, out var wfId))
        {
            var wf = _workflows.Items.FirstOrDefault(w => w.Id == wfId);
            if (wf is not null)
                _formName = wf.Name;
        }
    }

    private void SelectWorkflowFromPicker(WorkflowResponseDto wf)
    {
        _formWorkflowId = wf.Id.ToString();
        _formName = wf.Name;
        _showPicker = false;
        _pickerSearch = "";
    }

    private void ShowEdit(WorkorderResponseDto w)
    {
        _editId = w.Id; _formName = w.Name; _formDesc = w.Description ?? ""; _formPriority = w.Priority;
        _showForm = true;
    }

    private void CloseForm() { _showForm = false; }

    private async Task Save()
    {
        _saving = true;
        try
        {
            if (_editId.HasValue)
                await Api.UpdateWorkorderAsync(_editId.Value, new UpdateWorkorderDto(_formName, _formDesc, _formPriority));
            else
            {
                if (!Guid.TryParse(_formWorkflowId, out var wfId)) { Toast.ShowError("Select a workflow."); return; }
                await Api.CreateWorkorderAsync(new CreateWorkorderDto(_formCode, _formName, _formDesc, wfId, _formPriority));
            }
            _showForm = false;
            await LoadData();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
        finally { _saving = false; }
    }

    private async Task Delete(Guid id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this workorder?")) return;
        try { await Api.DeleteWorkorderAsync(id); await LoadData(); }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }
}
