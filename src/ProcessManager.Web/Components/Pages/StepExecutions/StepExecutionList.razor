@page "/step-executions"
@rendermode InteractiveServer
@inject ApiClient Api

<PageTitle>Step Executions</PageTitle>

<h3 class="mb-3">Step Executions</h3>

<div class="d-flex gap-3 mb-3 flex-wrap">
    <select class="form-select form-select-sm" style="width:auto" @onchange="OnStatusFilter">
        <option value="">All Statuses</option>
        <option value="Pending">Pending</option>
        <option value="Running">Running</option>
        <option value="Completed">Completed</option>
        <option value="Skipped">Skipped</option>
        <option value="Failed">Failed</option>
    </select>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_data is not null)
{
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Step Name</th>
                    <th>Job</th>
                    <th>Status</th>
                    <th>Started</th>
                    <th>Completed</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var se in _data.Items)
                {
                    <tr>
                        <td><a href="step-executions/@se.Id">@se.Sequence</a></td>
                        <td><a href="step-executions/@se.Id">@se.StepName</a></td>
                        <td><a href="jobs/@se.JobId">View Job</a></td>
                        <td><StatusBadge Status="@se.Status" /></td>
                        <td>@(se.StartedAt?.ToString("g") ?? "—")</td>
                        <td>@(se.CompletedAt?.ToString("g") ?? "—")</td>
                        <td class="small text-truncate" style="max-width:200px">@(se.Notes ?? "")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <Pager Page="_page" PageSize="_pageSize" TotalCount="_data.TotalCount"
           OnPageChanged="OnPageChanged" />
}

@if (_error is not null)
{
    <div class="alert alert-danger mt-3 py-2">@_error</div>
}

@code {
    private PaginatedResponse<StepExecutionResponseDto>? _data;
    private bool _loading = true;
    private string? _status;
    private int _page = 1;
    private int _pageSize = 25;
    private string? _error;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true; _error = null;
        _data = await Api.GetStepExecutionsAsync(status: _status, page: _page, pageSize: _pageSize);
        _loading = false;
    }

    private async Task OnPageChanged(int p) { _page = p; await LoadData(); }

    private async Task OnStatusFilter(ChangeEventArgs e)
    {
        _status = string.IsNullOrEmpty(e.Value?.ToString()) ? null : e.Value.ToString();
        _page = 1; await LoadData();
    }
}
