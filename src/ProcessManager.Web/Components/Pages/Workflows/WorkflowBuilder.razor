    /// <summary>
    /// Pick the best source/target port pair based on relative node positions.
    /// Prefers vertical connections (bottom→top) when nodes are stacked,
    /// and horizontal (right→left) when side by side.
    /// </summary>
    private (PortModel? src, PortModel? tgt) GetBestPortPair(
        WorkflowProcessNodeModel srcNode, WorkflowProcessNodeModel tgtNode)
    {
        double dx = (tgtNode.Position?.X ?? 0) - (srcNode.Position?.X ?? 0);
        double dy = (tgtNode.Position?.Y ?? 0) - (srcNode.Position?.Y ?? 0);

        PortAlignment srcAlign, tgtAlign;

        if (Math.Abs(dy) >= Math.Abs(dx))
        {
            // Mostly vertical: use top/bottom
            if (dy >= 0) { srcAlign = PortAlignment.Bottom; tgtAlign = PortAlignment.Top; }
            else          { srcAlign = PortAlignment.Top;    tgtAlign = PortAlignment.Bottom; }
        }
        else
        {
            // Mostly horizontal: use left/right
            if (dx >= 0) { srcAlign = PortAlignment.Right; tgtAlign = PortAlignment.Left; }
            else          { srcAlign = PortAlignment.Left;  tgtAlign = PortAlignment.Right; }
        }

        return (srcNode.GetPort(srcAlign), tgtNode.GetPort(tgtAlign));
    }

    // ───────────── View Mode Switching ─────────────

    private async Task SetViewMode(string mode)
    {
        if (_viewMode == mode) return;
        _viewMode = mode;

        if (mode == "Slide")
        {
            var procs = OrderedProcesses;
            if (procs.Any())
            {
                var idx = _slideProcessIndex >= 0 && _slideProcessIndex < procs.Count
                    ? _slideProcessIndex : 0;
                await SelectSlideProcess(idx);
            }
        }
        else if (mode == "Document")
        {
            await EnsureAllProcessDetailsLoaded();
        }
    }

    private async Task SelectSlideProcess(int index)
    {
        var procs = OrderedProcesses;
        if (index < 0 || index >= procs.Count) return;
        _slideProcessIndex = index;
        _slideProcess = procs[index];

        // Load process detail if not cached and not terminal
        if (_slideProcess.ProcessId.HasValue &&
            !_processDetailCache.ContainsKey(_slideProcess.ProcessId.Value))
        {
            var detail = await Api.GetProcessAsync(_slideProcess.ProcessId.Value);
            if (detail is not null)
            {
                _processDetailCache[detail.Id] = detail;

                // Also load step templates
                var templateIds = detail.Steps
                    .Select(s => s.StepTemplateId)
                    .Distinct()
                    .Where(id => !_stepTemplateCache.ContainsKey(id))
                    .ToList();
                var templateTasks = templateIds.Select(tid => Api.GetStepTemplateAsync(tid));
                var templates = await Task.WhenAll(templateTasks);
                foreach (var t in templates)
                {
                    if (t is not null)
                        _stepTemplateCache[t.Id] = t;
                }
            }
        }

        _slideProcessDetail = _slideProcess.ProcessId.HasValue &&
            _processDetailCache.TryGetValue(_slideProcess.ProcessId.Value, out var pd)
            ? pd : null;

        // Set _selectedNode so existing config methods (ToggleEntryPoint, etc.) work
        if (_nodeMap.TryGetValue(_slideProcess.Id, out var node))
        {
            _selectedNode = node;
        }
        _selectedLink = null;
        _selectedLinkData = null;
        _expandedStepIds.Clear();
        _selectedProcessDetail = _slideProcessDetail;
    }

    private async Task MoveSlideProcess(int index, int direction)
    {
        var procs = OrderedProcesses;
        int newIdx = index + direction;
        if (newIdx < 0 || newIdx >= procs.Count) return;

        var procA = procs[index];
        var procB = procs[newIdx];

        try
        {
            // Swap sort orders via API
            await Api.UpdateWorkflowProcessAsync(Id, procA.Id,
                new UpdateWorkflowProcessDto(SortOrder: procB.SortOrder));
            await Api.UpdateWorkflowProcessAsync(Id, procB.Id,
                new UpdateWorkflowProcessDto(SortOrder: procA.SortOrder));

            // Update node models
            if (_nodeMap.TryGetValue(procA.Id, out var nodeA))
                nodeA.SortOrder = procB.SortOrder;
            if (_nodeMap.TryGetValue(procB.Id, out var nodeB))
                nodeB.SortOrder = procA.SortOrder;

            // Reload workflow to get updated sort orders
            _wf = await Api.GetWorkflowAsync(Id);
            _slideProcessIndex = newIdx;
            await SelectSlideProcess(newIdx);
        }
        catch (HttpRequestException ex)
        {
            Toast.ShowError(ex.Message);
        }
    }

    private async Task SwitchToSlideProcess(int index)
    {
        _viewMode = "Slide";
        await SelectSlideProcess(index);
    }

    private async Task EnsureAllProcessDetailsLoaded()
    {
        _docLoading = true;
        StateHasChanged();

        try
        {
            var processIds = OrderedProcesses
                .Where(p => p.ProcessId.HasValue)
                .Select(p => p.ProcessId!.Value)
                .Distinct()
                .Where(pid => !_processDetailCache.ContainsKey(pid))
                .ToList();

            if (processIds.Any())
            {
                var tasks = processIds.Select(pid => Api.GetProcessAsync(pid));
                var results = await Task.WhenAll(tasks);
                foreach (var r in results)
                {
                    if (r is not null)
                        _processDetailCache[r.Id] = r;
                }

                // Also load any missing step templates
                var templateIds = _processDetailCache.Values
                    .SelectMany(p => p.Steps)
                    .Select(s => s.StepTemplateId)
                    .Distinct()
                    .Where(id => !_stepTemplateCache.ContainsKey(id))
                    .ToList();

                if (templateIds.Any())
                {
                    var templateTasks = templateIds.Select(tid => Api.GetStepTemplateAsync(tid));
                    var templates = await Task.WhenAll(templateTasks);
                    foreach (var t in templates)
                    {
                        if (t is not null)
                            _stepTemplateCache[t.Id] = t;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load process details: {ex.Message}");
        }
        finally
        {
            _docLoading = false;
        }
    }
