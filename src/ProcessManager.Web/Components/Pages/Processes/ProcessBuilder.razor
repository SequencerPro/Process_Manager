@page "/processes/builder"
@page "/processes/{Id:guid}/builder"
@rendermode InteractiveServer
@inject ApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ToastService Toast

<PageTitle>@(_name.Length > 0 ? $"Builder – {_name}" : "New Process")</PageTitle>

@* ── Top bar ── *@
<div class="d-flex justify-content-between align-items-center mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="processes">Processes</a></li>
            <li class="breadcrumb-item active">@(Id.HasValue ? "Process Builder" : "New Process")</li>
        </ol>
    </nav>
    <div class="d-flex gap-2">
        @if (Id.HasValue)
        {
            <button class="btn btn-outline-info btn-sm" @onclick="RunValidation">
                <i class="bi bi-check2-all me-1"></i>Validate
            </button>
        }
        <button class="btn btn-primary btn-sm" @onclick="Save" disabled="@_saving">
            @if (_saving)
            {
                <span class="spinner-border spinner-border-sm me-1"></span>
            }
            else
            {
                <i class="bi bi-floppy me-1"></i>
            }
            Save
        </button>
        <a href="@(Id.HasValue ? $"processes/{Id}" : "processes")" class="btn btn-outline-secondary btn-sm">
            Cancel
        </a>
    </div>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    @* ── Validation results ── *@
    @if (_validation is not null)
    {
        <div class="alert @(_validation.Errors.Any() ? "alert-danger" : _validation.Warnings.Any() ? "alert-warning" : "alert-success") alert-dismissible py-2 mb-2">
            @if (!_validation.Errors.Any() && !_validation.Warnings.Any())
            {
                <span><i class="bi bi-check-circle me-1"></i> Valid — no errors or warnings.</span>
            }
            @foreach (var e in _validation.Errors)
            {
                <div><i class="bi bi-x-circle text-danger me-1"></i>@e</div>
            }
            @foreach (var w in _validation.Warnings)
            {
                <div><i class="bi bi-exclamation-triangle text-warning me-1"></i>@w</div>
            }
            <button type="button" class="btn-close" @onclick="() => _validation = null"></button>
        </div>
    }

    @* ── Process metadata ── *@
    <div class="card mb-2">
        <div class="card-body py-2">
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label fw-semibold small mb-1">Code <span class="text-danger">*</span></label>
                    <input class="form-control form-control-sm" placeholder="e.g. WDG-FINISH-01" @bind="_code" disabled="@Id.HasValue" />
                    @if (Id.HasValue)
                    {
                        <div class="form-text" style="font-size:.7rem">Code cannot be changed after creation.</div>
                    }
                </div>
                <div class="col-md-5">
                    <label class="form-label fw-semibold small mb-1">Name <span class="text-danger">*</span></label>
                    <input class="form-control form-control-sm" placeholder="e.g. Widget Finishing Process" @bind="_name" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold small mb-1">Description</label>
                    <input class="form-control form-control-sm" placeholder="Optional description" @bind="_description" />
                </div>
            </div>
        </div>
    </div>

    @* ── Canvas + Sidebar ── *@
    <div class="d-flex" style="height: calc(100vh - 285px); min-height: 380px;">

        @* ── Diagram Canvas ── *@
        <div class="flex-grow-1 pb-canvas position-relative">
            <CascadingValue Value="_diagram" IsFixed="true">
                <DiagramCanvas></DiagramCanvas>
            </CascadingValue>
            @if (_steps.Count == 0)
            {
                <div class="position-absolute top-50 start-50 translate-middle text-center" style="pointer-events:none;">
                    <i class="bi bi-diagram-3 text-muted" style="font-size:3rem; opacity:.35"></i>
                    <p class="text-muted mt-2 mb-0" style="font-size:.85rem;">No steps yet.<br />Use <strong>Add Step</strong> in the panel on the right.</p>
                </div>
            }
        </div>

        @* ── Right Sidebar ── *@
        <div class="pb-sidebar d-flex flex-column">

            @* — Add Step — *@
            <div class="sidebar-section">
                <button class="btn btn-primary btn-sm w-100" @onclick="() => OpenStepPicker(_steps.Count)">
                    <i class="bi bi-plus-lg me-1"></i>Add Step
                </button>
            </div>

            @* — Selected Node — *@
            @if (_selectedNode is not null)
            {
                var selStep = _selectedNode.Step;
                var selIdx  = GetStepIndex(selStep);
                <div class="sidebar-section">
                    <h6>Step Configuration</h6>
                    <div class="mb-2">
                        <div class="fw-semibold small">@(selStep.NameOverride ?? selStep.Template?.Name)</div>
                        <div>
                            <code style="font-size:.72rem">@selStep.Template?.Code</code>
                            <span class="badge bg-light text-dark border ms-1" style="font-size:.6rem">@selStep.Template?.Pattern</span>
                        </div>
                    </div>
                    <div class="d-flex gap-1 mb-1">
                        <button class="btn btn-outline-secondary btn-sm py-0 px-2 flex-fill" style="font-size:.75rem"
                                disabled="@(selIdx == 0)" @onclick="MoveSelectedStepLeft">
                            <i class="bi bi-arrow-left me-1"></i>Earlier
                        </button>
                        <button class="btn btn-outline-secondary btn-sm py-0 px-2 flex-fill" style="font-size:.75rem"
                                disabled="@(selIdx == _steps.Count - 1)" @onclick="MoveSelectedStepRight">
                            Later<i class="bi bi-arrow-right ms-1"></i>
                        </button>
                    </div>
                    <div class="d-flex gap-1 mb-2">
                        <button class="btn btn-outline-primary btn-sm py-0 px-2 flex-fill" style="font-size:.75rem"
                                @onclick="() => OpenStepPicker(selIdx)">
                            <i class="bi bi-plus-lg me-1"></i>Before
                        </button>
                        <button class="btn btn-outline-primary btn-sm py-0 px-2 flex-fill" style="font-size:.75rem"
                                @onclick="() => OpenStepPicker(selIdx + 1)">
                            <i class="bi bi-plus-lg me-1"></i>After
                        </button>
                    </div>
                    <hr class="my-2" />
                    <button class="btn btn-outline-secondary btn-sm w-100 mb-1"
                            @onclick="() => ShowEditStep(selIdx)">
                        <i class="bi bi-pencil me-1"></i>Edit Work Instructions
                    </button>
                    <button class="btn btn-outline-danger btn-sm w-100" @onclick="RemoveSelectedStep">
                        <i class="bi bi-trash me-1"></i>Remove Step
                    </button>
                </div>
            }

            @* — Selected Link — *@
            @if (_selectedLink is not null)
            {
                <div class="sidebar-section">
                    <h6>Flow Connection</h6>
                    @if (_linkData.TryGetValue(_selectedLink, out var fl))
                    {
                        <div class="mb-2 small">
                            <div class="fw-semibold mb-1">@(fl.Source.Step.NameOverride ?? fl.Source.Step.Template?.Name)</div>
                            <div class="d-flex align-items-center gap-1 ms-2 mb-2">
                                <span class="pb-port pb-port-output d-inline-block" style="width:8px;height:8px;flex-shrink:0;"></span>
                                <span>@fl.SourcePort.PortData.Name</span>
                                <span class="text-muted" style="font-size:.65rem">(@PortInfo(fl.SourcePort.PortData))</span>
                            </div>
                            <div class="text-center text-muted my-1" style="font-size:.75rem"><i class="bi bi-arrow-down"></i></div>
                            <div class="fw-semibold mb-1">@(fl.Target.Step.NameOverride ?? fl.Target.Step.Template?.Name)</div>
                            <div class="d-flex align-items-center gap-1 ms-2">
                                <span class="pb-port pb-port-input d-inline-block" style="width:8px;height:8px;flex-shrink:0;"></span>
                                <span>@fl.TargetPort.PortData.Name</span>
                            </div>
                        </div>
                    }
                    <hr class="my-2" />
                    <button class="btn btn-outline-danger btn-sm w-100" @onclick="DeleteSelectedLink">
                        <i class="bi bi-trash me-1"></i>Delete Connection
                    </button>
                </div>
            }

            @* — Empty state / hints — *@
            @if (_selectedNode is null && _selectedLink is null)
            {
                <div class="sidebar-section text-muted small text-center flex-grow-1 d-flex align-items-center justify-content-center">
                    <div>
                        <i class="bi bi-diagram-2 d-block mb-2" style="font-size:1.5rem"></i>
                        Click a step to configure it.<br /><br />
                        Drag from an output port
                        <span class="pb-port pb-port-output d-inline-block" style="width:9px;height:9px;vertical-align:middle;"></span><br />
                        to an input port
                        <span class="pb-port pb-port-input d-inline-block" style="width:9px;height:9px;vertical-align:middle;"></span>
                        to connect steps.<br /><br />
                        Double-click a step to edit work instructions.<br /><br />
                        <kbd>Delete</kbd> removes a selected connection.
                    </div>
                </div>
            }
        </div>
    </div>
}

@* ══════════════════════════════════════════
   Step Picker — right-side slide panel
   ══════════════════════════════════════════ *@
@if (_showPicker)
{
    <div class="position-fixed top-0 start-0 w-100 h-100" style="background:rgba(0,0,0,.35);z-index:1050"
         @onclick="ClosePicker"></div>

    <div class="position-fixed top-0 end-0 h-100 bg-white shadow-lg border-start d-flex flex-column"
         style="width:400px;z-index:1051">
        <div class="d-flex justify-content-between align-items-center p-3 border-bottom">
            <h6 class="mb-0"><i class="bi bi-box-seam me-1"></i>Add Step</h6>
            <button class="btn-close" @onclick="ClosePicker"></button>
        </div>

        <div class="p-3 border-bottom">
            <input class="form-control" placeholder="Search step templates…"
                   value="@_pickerSearch"
                   @oninput="OnPickerSearch" />
        </div>

        <div class="flex-grow-1 overflow-auto p-3">
            @if (_pickerLoading)
            {
                <div class="text-center py-4">
                    <div class="spinner-border text-primary"></div>
                </div>
            }
            else if (_pickerTemplates is null || !_pickerTemplates.Items.Any())
            {
                <div class="text-center text-muted py-4">
                    <i class="bi bi-search d-block mb-2" style="font-size:1.8rem"></i>
                    No templates found.
                </div>
            }
            else
            {
                @foreach (var t in _pickerTemplates.Items)
                {
                    var tpl = t;
                    <div class="border rounded-2 p-3 mb-2 d-flex justify-content-between align-items-start"
                         style="cursor:pointer;transition:background .15s"
                         @onclick="() => AddStep(tpl)"
                         @onmouseenter="e => { }" @onmouseleave="e => { }">
                        <div class="flex-grow-1 pe-2">
                            <div class="fw-semibold">@t.Name</div>
                            <div class="text-muted small"><code>@t.Code</code> &bull; @t.Pattern</div>
                            <div class="mt-1 small">
                                <span class="text-success me-3">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>@t.Ports.Count(p => p.Direction == PortDirection.Input) input(s)
                                </span>
                                <span class="text-primary">
                                    <i class="bi bi-box-arrow-right me-1"></i>@t.Ports.Count(p => p.Direction == PortDirection.Output) output(s)
                                </span>
                            </div>
                            @if (t.Ports.Any())
                            {
                                <div class="mt-1">
                                    @foreach (var p in t.Ports.OrderBy(p => p.SortOrder).Take(4))
                                    {
                                        <span class="badge @(p.Direction == PortDirection.Input ? "bg-success-subtle text-success border border-success" : "bg-primary-subtle text-primary border border-primary") me-1 mb-1 small">
                                            @p.Name
                                        </span>
                                    }
                                    @if (t.Ports.Count > 4)
                                    {
                                        <span class="text-muted small">+@(t.Ports.Count - 4) more</span>
                                    }
                                </div>
                            }
                        </div>
                        <button class="btn btn-primary btn-sm ms-2 flex-shrink-0" @onclick:stopPropagation="true"
                                @onclick="() => AddStep(tpl)">
                            Add
                        </button>
                    </div>
                }
                @if (_pickerTemplates.TotalCount > _pickerTemplates.Items.Count)
                {
                    <div class="text-center text-muted small mt-2">
                        Showing @_pickerTemplates.Items.Count of @_pickerTemplates.TotalCount — refine search to narrow results.
                    </div>
                }
            }

            <hr />
            <div class="text-center">
                <p class="text-muted small mb-2">Need to create a new step template first?</p>
                <a href="step-templates" target="_blank" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-box-seam me-1"></i>Manage Step Templates
                    <i class="bi bi-box-arrow-up-right ms-1 small"></i>
                </a>
            </div>
        </div>
    </div>
}

@* ══════════════════════════════════════════
   Edit step modal
   ══════════════════════════════════════════ *@
@if (_showEditStepModal && _editStepIndex < _steps.Count)
{
    var editStep = _steps[_editStepIndex];
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.5);z-index:1060">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title mb-0">
                        <i class="bi bi-pencil me-2"></i>Edit Step
                        @if (editStep.Template is not null)
                        {
                            <span class="text-muted fw-normal ms-1 small">— @editStep.Template!.Name <code class="ms-1">@editStep.Template!.Code</code></span>
                        }
                    </h6>
                    <button class="btn-close" @onclick="CloseEditStepModal"></button>
                </div>
                <div class="modal-body" style="max-height:75vh;overflow-y:auto">

                    @* ── Identity fields ── *@
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Display Name <span class="text-muted fw-normal">(optional)</span></label>
                        <input class="form-control" @bind="_editNameValue"
                               placeholder="@(editStep.Template?.Name ?? "Step name")" />
                        <div class="form-text">Leave blank to use the template’s default name.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label small fw-semibold">Short Description <span class="text-muted fw-normal">(optional)</span></label>
                        <textarea class="form-control" rows="3" @bind="_editDescriptionValue"
                                  placeholder="Brief description or summary of this step’s purpose in this process…"></textarea>
                        <div class="form-text">Overrides the template’s default description.</div>
                    </div>

                    <hr class="my-3" />

                    @* ── Content Blocks ── *@
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <h6 class="mb-0">
                            <i class="bi bi-list-ul me-1 text-primary"></i>Work Instructions
                            <span class="badge bg-info text-dark ms-2 small fw-normal">saved immediately</span>
                        </h6>
                    </div>

                    @if (!editStep.ServerId.HasValue)
                    {
                        <div class="alert alert-info py-2 small mb-0">
                            <i class="bi bi-info-circle me-1"></i>
                            Save the process first to add content blocks to this step.
                        </div>
                    }
                    else
                    {
                        @if (_contentLoading)
                        {
                            <div class="text-center py-3">
                                <div class="spinner-border spinner-border-sm text-primary"></div>
                            </div>
                        }
                        else
                        {
                            @if (_contentError is not null)
                            {
                                <div class="alert alert-danger alert-dismissible py-2 small mb-2">
                                    @_contentError
                                    <button type="button" class="btn-close btn-sm" @onclick="() => _contentError = null"></button>
                                </div>
                            }

                            @* Block list *@
                            @if (!_contentBlocks.Any() && !_addingPromptBlock)
                            {
                                <div class="text-muted text-center small fst-italic py-2">No content blocks yet. Add text or images below.</div>
                            }
                            @for (int ci = 0; ci < _contentBlocks.Count; ci++)
                            {
                                var block = _contentBlocks[ci];
                                var blockIdx = ci;
                                <div class="border rounded-2 mb-2 p-2" @key="block.Id">
                                    <div class="d-flex justify-content-between align-items-start gap-2">
                                        <div class="flex-grow-1">
                                            @if (block.ContentType == "Text")
                                            {
                                                @if (_editingTextBlockId == block.Id)
                                                {
                                                    <textarea class="form-control form-control-sm" rows="5"
                                                              @bind="_editingTextBody"></textarea>
                                                    <div class="mt-1 d-flex gap-1">
                                                        <button class="btn btn-sm btn-primary" @onclick="SaveTextEdit">
                                                            <i class="bi bi-check-lg me-1"></i>Save
                                                        </button>
                                                        <button class="btn btn-sm btn-secondary" @onclick="() => _editingTextBlockId = null">Cancel</button>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="small" style="white-space:pre-wrap;word-break:break-word">@block.Body</div>
                                                }
                                            }
                                            else if (block.ContentType == "Image")
                                            {
                                                <img src="@Api.GetImageUrl(block.ImageUrl!)" alt="@block.OriginalFileName"
                                                     class="img-fluid rounded" style="max-height:200px;object-fit:contain" />
                                                <div class="text-muted small mt-1">@block.OriginalFileName</div>
                                            }
                                            else if (block.ContentType == "Prompt")
                                            {
                                                @if (_editingPromptBlockId == block.Id)
                                                {
                                                    <div class="mb-2">
                                                        <label class="form-label form-label-sm fw-semibold">Question / Label</label>
                                                        <input class="form-control form-control-sm" @bind="_editPromptLabel" />
                                                    </div>
                                                    @if (_editPromptType == "NumericEntry")
                                                    {
                                                        <div class="row g-2 mb-2">
                                                            <div class="col-4">
                                                                <label class="form-label form-label-sm">Min</label>
                                                                <input class="form-control form-control-sm" @bind="_editPromptMin" placeholder="no min" />
                                                            </div>
                                                            <div class="col-4">
                                                                <label class="form-label form-label-sm">Max</label>
                                                                <input class="form-control form-control-sm" @bind="_editPromptMax" placeholder="no max" />
                                                            </div>
                                                            <div class="col-4">
                                                                <label class="form-label form-label-sm">Units</label>
                                                                <input class="form-control form-control-sm" @bind="_editPromptUnits" placeholder="mm, rpm…" />
                                                            </div>
                                                        </div>
                                                    }
                                                    @if (_editPromptType == "MultipleChoice")
                                                    {
                                                        <div class="mb-2">
                                                            <label class="form-label form-label-sm">Choices <span class="text-muted">(one per line)</span></label>
                                                            <textarea class="form-control form-control-sm" rows="3" @bind="_editPromptChoicesRaw"></textarea>
                                                        </div>
                                                    }
                                                    <div class="form-check mb-2">
                                                        <input type="checkbox" class="form-check-input" @bind="_editPromptRequired" />
                                                        <label class="form-check-label small">Required</label>
                                                    </div>
                                                    <div class="d-flex gap-1">
                                                        <button class="btn btn-primary btn-sm" @onclick="SaveEditedPromptBlock">Save</button>
                                                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => _editingPromptBlockId = null">Cancel</button>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="d-flex align-items-start gap-2">
                                                        <i class="bi bi-input-cursor-text text-primary mt-1" style="font-size:1.1rem;flex-shrink:0"></i>
                                                        <div>
                                                            <div class="fw-semibold small">@block.Label</div>
                                                            <div class="d-flex flex-wrap gap-1 mt-1">
                                                                <span class="badge bg-info text-dark">@block.PromptType</span>
                                                                @if (block.IsRequired) { <span class="badge bg-warning text-dark">Required</span> }
                                                                @if (!string.IsNullOrEmpty(block.Units)) { <span class="badge bg-light text-dark border">@block.Units</span> }
                                                                @if (block.MinValue.HasValue || block.MaxValue.HasValue)
                                                                { <span class="badge bg-light text-dark border">@block.MinValue – @block.MaxValue</span> }
                                                            </div>
                                                        </div>
                                                    </div>
                                                }
                                            }
                                        </div>
                                        <div class="d-flex flex-column gap-1" style="flex-shrink:0">
                                            <button class="btn btn-outline-secondary btn-sm py-0 px-1" title="Move up"
                                                    disabled="@(blockIdx == 0)"
                                                    @onclick="() => MoveContentBlockAsync(block.Id, -1)">
                                                <i class="bi bi-arrow-up" style="font-size:.75rem"></i>
                                            </button>
                                            <button class="btn btn-outline-secondary btn-sm py-0 px-1" title="Move down"
                                                    disabled="@(blockIdx == _contentBlocks.Count - 1)"
                                                    @onclick="() => MoveContentBlockAsync(block.Id, 1)">
                                                <i class="bi bi-arrow-down" style="font-size:.75rem"></i>
                                            </button>
                                            @if (block.ContentType == "Text" && _editingTextBlockId != block.Id)
                                            {
                                                <button class="btn btn-outline-secondary btn-sm py-0 px-1" title="Edit text"
                                                        @onclick="() => StartEditText(block)">
                                                    <i class="bi bi-pencil" style="font-size:.75rem"></i>
                                                </button>
                                            }
                                            @if (block.ContentType == "Prompt" && _editingPromptBlockId != block.Id)
                                            {
                                                <button class="btn btn-outline-secondary btn-sm py-0 px-1" title="Edit prompt"
                                                        @onclick="() => StartEditPromptBlock(block)">
                                                    <i class="bi bi-pencil" style="font-size:.75rem"></i>
                                                </button>
                                            }
                                            <button class="btn btn-outline-danger btn-sm py-0 px-1" title="Delete block"
                                                    @onclick="() => DeleteContentBlockAsync(block.Id)">
                                                <i class="bi bi-trash" style="font-size:.75rem"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            }

                            @* Add text block *@
                            @if (_addingTextBlock)
                            {
                                <div class="border rounded-2 mb-2 p-2 border-primary">
                                    <label class="form-label small fw-semibold">New Text Block</label>
                                    <textarea class="form-control form-control-sm" rows="5"
                                              @bind="_newTextBody"
                                              placeholder="Enter instructions, notes, or any text for the operator…"></textarea>
                                    <div class="mt-2 d-flex gap-2">
                                        <button class="btn btn-sm btn-primary" @onclick="AddTextBlockAsync">
                                            <i class="bi bi-plus-lg me-1"></i>Add Block
                                        </button>
                                        <button class="btn btn-sm btn-secondary"
                                                @onclick="() => { _addingTextBlock = false; _newTextBody = string.Empty; }">
                                            Cancel
                                        </button>
                                    </div>
                                </div>
                            }

                            @* Add prompt block *@
                            @if (_addingPromptBlock)
                            {
                                <div class="border border-primary rounded-2 mb-2 p-2">
                                    <label class="form-label small fw-semibold mb-2"><i class="bi bi-input-cursor-text me-1 text-primary"></i>New Prompt Block</label>
                                    <div class="mb-2">
                                        <label class="form-label form-label-sm">Question / Label <span class="text-danger">*</span></label>
                                        <input class="form-control form-control-sm" @bind="_newPromptLabel" placeholder="e.g. Measure outer diameter at point A" />
                                    </div>
                                    <div class="mb-2">
                                        <label class="form-label form-label-sm">Prompt Type</label>
                                        <select class="form-select form-select-sm" @bind="_newPromptType">
                                            <option value="NumericEntry">Numeric Entry</option>
                                            <option value="PassFail">Pass / Fail</option>
                                            <option value="MultipleChoice">Multiple Choice</option>
                                            <option value="TextEntry">Text Entry (free form)</option>
                                            <option value="Checkbox">Checkbox</option>
                                            <option value="Scan">Scan (barcode / serial)</option>
                                        </select>
                                    </div>
                                    @if (_newPromptType == "NumericEntry")
                                    {
                                        <div class="row g-2 mb-2">
                                            <div class="col-4">
                                                <label class="form-label form-label-sm">Min</label>
                                                <input class="form-control form-control-sm" @bind="_newPromptMin" placeholder="no min" />
                                            </div>
                                            <div class="col-4">
                                                <label class="form-label form-label-sm">Max</label>
                                                <input class="form-control form-control-sm" @bind="_newPromptMax" placeholder="no max" />
                                            </div>
                                            <div class="col-4">
                                                <label class="form-label form-label-sm">Units</label>
                                                <input class="form-control form-control-sm" @bind="_newPromptUnits" placeholder="mm, rpm…" />
                                            </div>
                                        </div>
                                    }
                                    @if (_newPromptType == "MultipleChoice")
                                    {
                                        <div class="mb-2">
                                            <label class="form-label form-label-sm">Choices <span class="text-muted">(one per line)</span></label>
                                            <textarea class="form-control form-control-sm" rows="3" @bind="_newPromptChoicesRaw"
                                                      placeholder="Option A&#10;Option B&#10;Option C"></textarea>
                                        </div>
                                    }
                                    <div class="form-check mb-2">
                                        <input type="checkbox" class="form-check-input" @bind="_newPromptRequired" />
                                        <label class="form-check-label small">Required</label>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-sm btn-primary" @onclick="AddPromptBlockAsync">
                                            <i class="bi bi-plus-lg me-1"></i>Add Prompt
                                        </button>
                                        <button class="btn btn-sm btn-secondary" @onclick="() => _addingPromptBlock = false">Cancel</button>
                                    </div>
                                </div>
                            }

                            @* Add buttons *@
                            @if (!_addingTextBlock && !_addingPromptBlock)
                            {
                                <div class="d-flex gap-2 flex-wrap">
                                    <button class="btn btn-outline-secondary btn-sm"
                                            @onclick="() => { _addingTextBlock = true; _newTextBody = string.Empty; }">
                                        <i class="bi bi-text-paragraph me-1"></i>Add Text Block
                                    </button>
                                    <button class="btn btn-outline-primary btn-sm" @onclick="StartAddPromptBlock">
                                        <i class="bi bi-input-cursor-text me-1"></i>Add Prompt
                                    </button>
                                    <label class="btn btn-outline-secondary btn-sm mb-0" style="cursor:pointer">
                                        <i class="bi bi-image me-1"></i>Add Image
                                        <InputFile accept="image/*" style="display:none"
                                                   OnChange="UploadImageBlock" />
                                    </label>
                                </div>
                            }
                        }
                    }
                </div>
                <div class="modal-footer py-2">
                    <span class="text-muted small me-auto">Name &amp; description changes apply on Save.</span>
                    <button class="btn btn-secondary btn-sm" @onclick="CloseEditStepModal">Cancel</button>
                    <button class="btn btn-primary btn-sm" @onclick="ApplyStepEdit"><i class="bi bi-check-lg me-1"></i>Apply</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid? Id { get; set; }

    // ── Process metadata fields ──
    private string _code = "";
    private string _name = "";
    private string? _description;
    private ProcessResponseDto? _origProc;

    // ── Diagram ──
    private BlazorDiagram _diagram = null!;
    private ProcessStepNodeModel? _selectedNode;
    private LinkModel? _selectedLink;
    private Dictionary<LinkModel, FlowLink> _linkData = new();

    // ── Builder state ──
    private List<BuilderStep> _steps = new();

    // ── Page state ──
    private bool _loading = true;
    private bool _saving;
    private ProcessValidationResultDto? _validation;

    // ── Step picker ──
    private bool _showPicker;
    private int _insertAtIndex;
    private string _pickerSearch = "";
    private bool _pickerLoading;
    private PaginatedResponse<StepTemplateResponseDto>? _pickerTemplates;
    private System.Threading.CancellationTokenSource? _searchCts;

    // ── Edit step modal ──
    private bool _showEditStepModal;
    private int _editStepIndex;
    private string _editNameValue = "";
    private string _editDescriptionValue = "";
    // ── Edit step content blocks ──
    private bool _contentLoading;
    private string? _contentError;
    private List<ProcessStepContentResponseDto> _contentBlocks = new();
    private bool _addingTextBlock;
    private string _newTextBody = "";
    private Guid? _editingTextBlockId;
    private string _editingTextBody = "";
    // Prompt block state
    private bool _addingPromptBlock;
    private string _newPromptLabel = string.Empty;
    private string _newPromptType = "NumericEntry";
    private bool _newPromptRequired = true;
    private string _newPromptUnits = string.Empty;
    private string _newPromptMin = string.Empty;
    private string _newPromptMax = string.Empty;
    private string _newPromptChoicesRaw = string.Empty;
    private Guid? _editingPromptBlockId;
    private string _editPromptLabel = string.Empty;
    private string _editPromptType = "NumericEntry";
    private bool _editPromptRequired = true;
    private string _editPromptUnits = string.Empty;
    private string _editPromptMin = string.Empty;
    private string _editPromptMax = string.Empty;
    private string _editPromptChoicesRaw = string.Empty;

    // ──────────────────────────────────────────────
    // Initialization + Diagram setup
    // ──────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        SetupDiagram();
        if (Id.HasValue)
        {
            _origProc = await Api.GetProcessAsync(Id.Value);
            if (_origProc is not null)
            {
                _code = _origProc.Code;
                _name = _origProc.Name;
                _description = _origProc.Description;

                foreach (var s in _origProc.Steps.OrderBy(s => s.Sequence))
                {
                    _steps.Add(new BuilderStep
                    {
                        ServerId = s.Id,
                        Sequence = s.Sequence,
                        StepTemplateId = s.StepTemplateId,
                        NameOverride = s.NameOverride,
                        DescriptionOverride = s.DescriptionOverride
                    });
                }

                await Task.WhenAll(_steps.Select(async step =>
                    step.Template = await Api.GetStepTemplateAsync(step.StepTemplateId)));

                PopulateDiagram();
                RestoreFlowsFromOriginal();
            }
        }
        _loading = false;
    }

    private void SetupDiagram()
    {
        var options = new BlazorDiagramOptions();
        options.AllowMultiSelection = false;
        options.Zoom.Enabled = true;
        options.Zoom.Minimum = 0.25;
        options.Zoom.Maximum = 2.0;
        _diagram = new BlazorDiagram(options);
        _diagram.RegisterComponent<ProcessStepNodeModel, ProcessStepNode>();
        _diagram.SelectionChanged += OnSelectionChanged;
        _diagram.Links.Added += OnLinkAdded;
        _diagram.KeyDown += OnKeyDown;
        _diagram.PointerDoubleClick += OnDoubleClick;
    }

    private void PopulateDiagram()
    {
        _diagram.Nodes.Clear();
        _diagram.Links.Clear();
        _linkData.Clear();
        _selectedNode = null;
        _selectedLink = null;

        const double nodeWidth = 220;
        const double nodeGap   = 80;
        for (int i = 0; i < _steps.Count; i++)
        {
            var node = new ProcessStepNodeModel(_steps[i],
                new Blazor.Diagrams.Core.Geometry.Point(i * (nodeWidth + nodeGap), 80));
            _diagram.Nodes.Add(node);
        }
    }

    private void RestoreFlowsFromOriginal()
    {
        if (_origProc is null) return;
        var nodes = _diagram.Nodes.OfType<ProcessStepNodeModel>().ToList();
        foreach (var flow in _origProc.Flows)
        {
            var srcNode = nodes.FirstOrDefault(n => n.Step.ServerId == flow.SourceProcessStepId);
            var tgtNode = nodes.FirstOrDefault(n => n.Step.ServerId == flow.TargetProcessStepId);
            if (srcNode is null || tgtNode is null) continue;

            var srcPort = srcNode.OutputPorts.FirstOrDefault(p => p.PortData.Id == flow.SourcePortId);
            var tgtPort = tgtNode.InputPorts.FirstOrDefault(p => p.PortData.Id == flow.TargetPortId);
            if (srcPort is null || tgtPort is null) continue;

            var linkModel = new LinkModel(srcPort, tgtPort);
            _linkData[linkModel] = new FlowLink(srcNode, srcPort, tgtNode, tgtPort);
            _diagram.Links.Add(linkModel);
        }
    }

    private void TryAutoConnect(ProcessStepNodeModel src, ProcessStepNodeModel tgt)
    {
        var pairs = (from o   in src.OutputPorts
                     from inp in tgt.InputPorts
                     where o.PortData.PortType   == PortType.Material
                        && inp.PortData.PortType == PortType.Material
                        && o.PortData.KindId     == inp.PortData.KindId
                        && o.PortData.GradeId    == inp.PortData.GradeId
                     select (Out: o, In: inp)).ToList();

        if (pairs.Count == 1)
        {
            var linkModel = new LinkModel(pairs[0].Out, pairs[0].In);
            _linkData[linkModel] = new FlowLink(src, pairs[0].Out, tgt, pairs[0].In);
            _diagram.Links.Add(linkModel);
        }
    }

    // ──────────────────────────────────────────────
    // Diagram events
    // ──────────────────────────────────────────────

    private void OnSelectionChanged(SelectableModel model)
    {
        if (model is ProcessStepNodeModel node && model.Selected)
        {
            _selectedNode = node;
            _selectedLink = null;
        }
        else if (model is LinkModel link && model.Selected)
        {
            _selectedLink = link;
            _selectedNode = null;
        }
        else
        {
            _selectedNode = null;
            _selectedLink = null;
        }
        InvokeAsync(StateHasChanged);
    }

    private void OnLinkAdded(BaseLinkModel link)
    {
        if (link is LinkModel lm && !_linkData.ContainsKey(lm))
            link.TargetChanged += OnLinkTargetChanged;
    }

    private void OnLinkTargetChanged(BaseLinkModel link, Anchor oldTarget, Anchor newTarget)
    {
        link.TargetChanged -= OnLinkTargetChanged;
        if (link is not LinkModel lm) { _diagram.Links.Remove(link); return; }
        if (link.Source is not SinglePortAnchor srcAnchor || link.Target is not SinglePortAnchor tgtAnchor)
        { _diagram.Links.Remove(lm); return; }

        var srcPort = srcAnchor.Port as ProcessStepPortModel;
        var tgtPort = tgtAnchor.Port as ProcessStepPortModel;
        if (srcPort is null || tgtPort is null) { _diagram.Links.Remove(lm); return; }

        // Auto-swap if user dragged from input→output
        if (srcPort.Alignment == PortAlignment.Left && tgtPort.Alignment == PortAlignment.Right)
            (srcPort, tgtPort) = (tgtPort, srcPort);

        if (srcPort.PortData.PortType  != PortType.Material ||
            tgtPort.PortData.PortType  != PortType.Material ||
            srcPort.PortData.KindId    != tgtPort.PortData.KindId ||
            srcPort.PortData.GradeId   != tgtPort.PortData.GradeId)
        {
            _diagram.Links.Remove(lm);
            Toast.ShowError("Ports must be Material type with matching Kind and Grade.");
            InvokeAsync(StateHasChanged);
            return;
        }

        var srcNode = srcPort.Parent as ProcessStepNodeModel;
        var tgtNode = tgtPort.Parent as ProcessStepNodeModel;
        if (srcNode is null || tgtNode is null || srcNode == tgtNode)
        { _diagram.Links.Remove(lm); return; }

        _linkData[lm] = new FlowLink(srcNode, srcPort, tgtNode, tgtPort);
        InvokeAsync(StateHasChanged);
    }

    private void OnKeyDown(Blazor.Diagrams.Core.Events.KeyboardEventArgs e)
    {
        if (e.Key == "Delete" || e.Key == "Backspace")
            DeleteSelectedLink();
    }

    private void OnDoubleClick(Blazor.Diagrams.Core.Models.Base.Model? model,
        Blazor.Diagrams.Core.Events.PointerEventArgs e)
    {
        if (model is ProcessStepNodeModel node)
        {
            var idx = GetStepIndex(node.Step);
            if (idx >= 0) _ = ShowEditStep(idx);
        }
    }

    private void DeleteSelectedLink()
    {
        if (_selectedLink is null) return;
        _linkData.Remove(_selectedLink);
        _diagram.Links.Remove(_selectedLink);
        _selectedLink = null;
        InvokeAsync(StateHasChanged);
    }

    // ──────────────────────────────────────────────
    // Step canvas actions
    // ──────────────────────────────────────────────

    private void MoveSelectedStepLeft()
    {
        if (_selectedNode is null) return;
        var idx = GetStepIndex(_selectedNode.Step);
        if (idx <= 0) return;
        (_steps[idx], _steps[idx - 1]) = (_steps[idx - 1], _steps[idx]);
        for (int i = 0; i < _steps.Count; i++) _steps[i].Sequence = i + 1;
        _validation = null;
        RebuildDiagram();
    }

    private void MoveSelectedStepRight()
    {
        if (_selectedNode is null) return;
        var idx = GetStepIndex(_selectedNode.Step);
        if (idx < 0 || idx >= _steps.Count - 1) return;
        (_steps[idx], _steps[idx + 1]) = (_steps[idx + 1], _steps[idx]);
        for (int i = 0; i < _steps.Count; i++) _steps[i].Sequence = i + 1;
        _validation = null;
        RebuildDiagram();
    }

    private void RemoveSelectedStep()
    {
        if (_selectedNode is null) return;
        var idx = GetStepIndex(_selectedNode.Step);
        if (idx < 0) return;
        _steps.RemoveAt(idx);
        for (int i = 0; i < _steps.Count; i++) _steps[i].Sequence = i + 1;
        _validation = null;
        RebuildDiagram();
    }

    private void RebuildDiagram()
    {
        var existingLinks = _linkData.ToList();
        _selectedNode = null;
        _selectedLink = null;
        PopulateDiagram();
        var nodes = _diagram.Nodes.OfType<ProcessStepNodeModel>().ToList();
        foreach (var (_, fl) in existingLinks)
        {
            var srcNode = nodes.FirstOrDefault(n => n.Step == fl.Source.Step);
            var tgtNode = nodes.FirstOrDefault(n => n.Step == fl.Target.Step);
            if (srcNode is null || tgtNode is null) continue;

            var srcPort = srcNode.OutputPorts.FirstOrDefault(p => p.PortData.Id == fl.SourcePort.PortData.Id);
            var tgtPort = tgtNode.InputPorts.FirstOrDefault(p => p.PortData.Id == fl.TargetPort.PortData.Id);
            if (srcPort is null || tgtPort is null) continue;

            var newLink = new LinkModel(srcPort, tgtPort);
            _linkData[newLink] = new FlowLink(srcNode, srcPort, tgtNode, tgtPort);
            _diagram.Links.Add(newLink);
        }
    }

    private int GetStepIndex(BuilderStep step) => _steps.IndexOf(step);

    // ──────────────────────────────────────────────
    // Step manipulation
    // ──────────────────────────────────────────────

    private async Task OpenStepPicker(int insertAtIndex)
    {
        _insertAtIndex = insertAtIndex;
        _pickerSearch = "";
        _showPicker = true;
        await LoadPickerTemplates();
    }

    private void ClosePicker() => _showPicker = false;

    private async Task OnPickerSearch(ChangeEventArgs e)
    {
        _pickerSearch = e.Value?.ToString() ?? "";
        _searchCts?.Cancel();
        _searchCts = new System.Threading.CancellationTokenSource();
        var cts = _searchCts;
        await Task.Delay(300);
        if (!cts.IsCancellationRequested)
            await LoadPickerTemplates();
    }

    private async Task LoadPickerTemplates()
    {
        _pickerLoading = true;
        StateHasChanged();
        try
        {
            _pickerTemplates = await Api.GetStepTemplatesAsync(_pickerSearch, true, pageSize: 20);
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load templates: {ex.Message}");
        }
        finally
        {
            _pickerLoading = false;
        }
    }

    private void AddStep(StepTemplateResponseDto template)
    {
        _steps.Insert(_insertAtIndex, new BuilderStep
        {
            Sequence = _insertAtIndex + 1,
            StepTemplateId = template.Id,
            Template = template
        });
        for (int i = 0; i < _steps.Count; i++) _steps[i].Sequence = i + 1;
        _showPicker = false;
        _validation = null;
        RebuildDiagram();
    }

    private async Task ShowEditStep(int index)
    {
        _editStepIndex = index;
        _editNameValue = _steps[index].NameOverride ?? "";
        _editDescriptionValue = _steps[index].DescriptionOverride ?? "";
        _contentBlocks.Clear();
        _addingTextBlock = false;
        _editingTextBlockId = null;
        _addingPromptBlock = false;
        _editingPromptBlockId = null;
        _newTextBody = "";
        _editingTextBody = "";
        _contentError = null;
        _showEditStepModal = true;
        StateHasChanged();
        if (_steps[index].ServerId.HasValue && Id.HasValue)
            await LoadStepContent();
    }

    private void CloseEditStepModal()
    {
        _showEditStepModal = false;
        _addingTextBlock = false;
        _editingTextBlockId = null;
        _addingPromptBlock = false;
        _editingPromptBlockId = null;
        _contentError = null;
    }

    private void ApplyStepEdit()
    {
        _steps[_editStepIndex].NameOverride = string.IsNullOrWhiteSpace(_editNameValue) ? null : _editNameValue.Trim();
        _steps[_editStepIndex].DescriptionOverride = string.IsNullOrWhiteSpace(_editDescriptionValue) ? null : _editDescriptionValue.Trim();
        var node = _diagram.Nodes.OfType<ProcessStepNodeModel>()
            .FirstOrDefault(n => n.Step == _steps[_editStepIndex]);
        node?.Refresh();
        CloseEditStepModal();
    }

    private async Task LoadStepContent()
    {
        _contentLoading = true;
        _contentError = null;
        StateHasChanged();
        try
        {
            var blocks = await Api.GetStepContentAsync(
                Id!.Value, _steps[_editStepIndex].ServerId!.Value);
            _contentBlocks = blocks ?? new();
        }
        catch (Exception ex)
        {
            _contentError = ex.Message;
        }
        finally
        {
            _contentLoading = false;
        }
    }

    private async Task AddTextBlockAsync()
    {
        if (string.IsNullOrWhiteSpace(_newTextBody)) return;
        _contentError = null;
        try
        {
            var block = await Api.AddTextBlockAsync(
                Id!.Value, _steps[_editStepIndex].ServerId!.Value,
                new AddTextBlockDto(_newTextBody.Trim()));
            if (block is not null) _contentBlocks.Add(block);
            _newTextBody = "";
            _addingTextBlock = false;
        }
        catch (Exception ex)
        {
            _contentError = ex.Message;
        }
    }

    private async Task UploadImageBlock(InputFileChangeEventArgs e)
    {
        _contentError = null;
        try
        {
            var block = await Api.UploadStepContentImageAsync(
                Id!.Value, _steps[_editStepIndex].ServerId!.Value, e.File);
            if (block is not null) _contentBlocks.Add(block);
        }
        catch (Exception ex)
        {
            _contentError = ex.Message;
        }
    }

    private void StartEditText(ProcessStepContentResponseDto block)
    {
        _editingTextBlockId = block.Id;
        _editingTextBody = block.Body ?? "";
    }

    private async Task SaveTextEdit()
    {
        if (_editingTextBlockId is null) return;
        _contentError = null;
        try
        {
            var updated = await Api.UpdateTextBlockAsync(
                Id!.Value, _steps[_editStepIndex].ServerId!.Value,
                _editingTextBlockId.Value,
                new UpdateTextBlockDto(_editingTextBody.Trim()));
            if (updated is not null)
            {
                var idx = _contentBlocks.FindIndex(c => c.Id == updated.Id);
                if (idx >= 0) _contentBlocks[idx] = updated;
            }
            _editingTextBlockId = null;
        }
        catch (Exception ex)
        {
            _contentError = ex.Message;
        }
    }

    private async Task DeleteContentBlockAsync(Guid contentId)
    {
        _contentError = null;
        try
        {
            await Api.DeleteStepContentBlockAsync(
                Id!.Value, _steps[_editStepIndex].ServerId!.Value, contentId);
            _contentBlocks.RemoveAll(c => c.Id == contentId);
        }
        catch (Exception ex)
        {
            _contentError = ex.Message;
        }
    }

    private async Task MoveContentBlockAsync(Guid contentId, int direction)
    {
        var idx = _contentBlocks.FindIndex(c => c.Id == contentId);
        var newIdx = idx + direction;
        if (newIdx < 0 || newIdx >= _contentBlocks.Count) return;
        (_contentBlocks[idx], _contentBlocks[newIdx]) = (_contentBlocks[newIdx], _contentBlocks[idx]);
        _contentError = null;
        try
        {
            await Api.ReorderStepContentAsync(
                Id!.Value, _steps[_editStepIndex].ServerId!.Value,
                new ReorderContentBlocksDto(_contentBlocks.Select(c => c.Id).ToList()));
        }
        catch (Exception ex)
        {
            _contentError = ex.Message;
        }
    }

    // --- Prompt Blocks ---

    private void StartAddPromptBlock()
    {
        _addingPromptBlock = true;
        _newPromptLabel = string.Empty;
        _newPromptType = "NumericEntry";
        _newPromptRequired = true;
        _newPromptUnits = string.Empty;
        _newPromptMin = string.Empty;
        _newPromptMax = string.Empty;
        _newPromptChoicesRaw = string.Empty;
    }

    private async Task AddPromptBlockAsync()
    {
        if (string.IsNullOrWhiteSpace(_newPromptLabel)) return;
        _contentError = null;
        try
        {
            decimal? min = decimal.TryParse(_newPromptMin, out var mn) ? mn : null;
            decimal? max = decimal.TryParse(_newPromptMax, out var mx) ? mx : null;
            string? choices = _newPromptType == "MultipleChoice" ? SerializeChoices(_newPromptChoicesRaw) : null;
            var block = await Api.AddPromptBlockAsync(
                Id!.Value, _steps[_editStepIndex].ServerId!.Value,
                new AddPromptBlockDto(_newPromptLabel, _newPromptType, _newPromptRequired,
                    string.IsNullOrWhiteSpace(_newPromptUnits) ? null : _newPromptUnits, min, max, choices));
            if (block is not null) _contentBlocks.Add(block);
            _addingPromptBlock = false;
        }
        catch (Exception ex) { _contentError = ex.Message; }
    }

    private void StartEditPromptBlock(ProcessStepContentResponseDto block)
    {
        _editingPromptBlockId = block.Id;
        _editPromptLabel = block.Label ?? string.Empty;
        _editPromptType = block.PromptType ?? "NumericEntry";
        _editPromptRequired = block.IsRequired;
        _editPromptUnits = block.Units ?? string.Empty;
        _editPromptMin = block.MinValue?.ToString() ?? string.Empty;
        _editPromptMax = block.MaxValue?.ToString() ?? string.Empty;
        _editPromptChoicesRaw = DeserializeChoices(block.Choices);
    }

    private async Task SaveEditedPromptBlock()
    {
        if (_editingPromptBlockId is null) return;
        _contentError = null;
        try
        {
            decimal? min = decimal.TryParse(_editPromptMin, out var mn) ? mn : null;
            decimal? max = decimal.TryParse(_editPromptMax, out var mx) ? mx : null;
            string? choices = _editPromptType == "MultipleChoice" ? SerializeChoices(_editPromptChoicesRaw) : null;
            var updated = await Api.UpdatePromptBlockAsync(
                Id!.Value, _steps[_editStepIndex].ServerId!.Value, _editingPromptBlockId.Value,
                new UpdatePromptBlockDto(_editPromptLabel, _editPromptRequired,
                    string.IsNullOrWhiteSpace(_editPromptUnits) ? null : _editPromptUnits, min, max, choices));
            if (updated is not null)
            {
                var i = _contentBlocks.FindIndex(c => c.Id == updated.Id);
                if (i >= 0) _contentBlocks[i] = updated;
            }
            _editingPromptBlockId = null;
        }
        catch (Exception ex) { _contentError = ex.Message; }
    }

    private static string SerializeChoices(string raw) =>
        System.Text.Json.JsonSerializer.Serialize(
            raw.Split('\n', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries));

    private static string DeserializeChoices(string? json)
    {
        if (string.IsNullOrWhiteSpace(json)) return string.Empty;
        try
        {
            var arr = System.Text.Json.JsonSerializer.Deserialize<string[]>(json);
            return arr is null ? string.Empty : string.Join("\n", arr);
        }
        catch { return json; }
    }

    // ──────────────────────────────────────────────
    // Validate
    // ──────────────────────────────────────────────

    private async Task RunValidation()
    {
        if (!Id.HasValue) return;
        _validation = await Api.ValidateProcessAsync(Id.Value);
    }

    // ──────────────────────────────────────────────
    // Save
    // ──────────────────────────────────────────────

    private async Task Save()
    {
        if (string.IsNullOrWhiteSpace(_code)) { Toast.ShowError("Code is required."); return; }
        if (string.IsNullOrWhiteSpace(_name)) { Toast.ShowError("Name is required."); return; }

        _saving = true;
        try
        {
            Guid processId;

            if (!Id.HasValue)
            {
                var created = await Api.CreateProcessAsync(
                    new ProcessCreateDto(_code.Trim(), _name.Trim(), _description));
                if (created is null) { Toast.ShowError("Failed to create process."); return; }
                processId = created.Id;
            }
            else
            {
                processId = Id.Value;
                if (_name != _origProc!.Name || _description != _origProc.Description)
                    await Api.UpdateProcessAsync(processId,
                        new ProcessUpdateDto(_name.Trim(), _description, _origProc.IsActive));
            }

            var origStepIds = _origProc?.Steps.Select(s => s.Id).ToHashSet() ?? new HashSet<Guid>();
            var keptStepIds = _steps.Where(s => s.ServerId.HasValue).Select(s => s.ServerId!.Value).ToHashSet();
            foreach (var removedId in origStepIds.Except(keptStepIds))
                await Api.DeleteProcessStepAsync(processId, removedId);

            foreach (var step in _steps)
            {
                if (!step.ServerId.HasValue)
                {
                    var added = await Api.AddProcessStepAsync(processId,
                        new ProcessStepCreateDto(step.StepTemplateId, step.Sequence, step.NameOverride, step.DescriptionOverride));
                    if (added is not null) step.ServerId = added.Id;
                }
                else
                {
                    var orig = _origProc?.Steps.FirstOrDefault(s => s.Id == step.ServerId);
                    if (orig is not null && (orig.Sequence != step.Sequence || orig.NameOverride != step.NameOverride || orig.DescriptionOverride != step.DescriptionOverride))
                        await Api.UpdateProcessStepAsync(processId, step.ServerId.Value,
                            new ProcessStepUpdateDto(step.Sequence, step.NameOverride, step.DescriptionOverride));
                }
            }

            if (_origProc is not null)
                foreach (var flow in _origProc.Flows)
                    await Api.DeleteFlowAsync(processId, flow.Id);

            foreach (var (_, fl) in _linkData)
            {
                if (fl.Source.Step.ServerId.HasValue && fl.Target.Step.ServerId.HasValue)
                {
                    await Api.AddFlowAsync(processId, new FlowCreateDto(
                        fl.Source.Step.ServerId.Value, fl.SourcePort.PortData.Id,
                        fl.Target.Step.ServerId.Value, fl.TargetPort.PortData.Id));
                }
            }

            Nav.NavigateTo($"processes/{processId}/builder", forceLoad: true);
        }
        catch (HttpRequestException ex)
        {
            Toast.ShowError(ex.Message);
        }
        finally
        {
            _saving = false;
        }
    }

    // ──────────────────────────────────────────────
    // Inner types
    // ──────────────────────────────────────────────

    private sealed record FlowLink(
        ProcessStepNodeModel Source, ProcessStepPortModel SourcePort,
        ProcessStepNodeModel Target, ProcessStepPortModel TargetPort);

    private static string PortInfo(PortResponseDto p) => p.PortType switch
    {
        PortType.Material => $"{p.KindName} / {p.GradeName}",
        PortType.Parameter or PortType.Characteristic =>
            string.IsNullOrEmpty(p.Units) ? $"{p.DataType}" : $"{p.DataType} ({p.Units})",
        PortType.Condition => "Pass / Fail",
        _ => ""
    };

    private static string PortTypeBadge(PortType t) => t switch
    {
        PortType.Material => "bg-secondary",
        PortType.Parameter => "bg-warning text-dark",
        PortType.Characteristic => "bg-info text-dark",
        PortType.Condition => "bg-light text-dark border",
        _ => "bg-secondary"
    };
}
