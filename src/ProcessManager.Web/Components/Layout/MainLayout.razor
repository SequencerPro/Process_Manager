@inherits LayoutComponentBase
@using System.Security.Claims
@inject AuthenticationStateProvider AuthState
@inject ProcessManager.Web.Services.TokenService TokenSvc
@inject ProcessManager.Web.Services.VocabularyService Vocab
@inject ApiClient Api

<div class="d-flex vh-100 position-relative flex-column flex-lg-row">
    <header class="mobile-topbar d-flex d-lg-none align-items-center">
        <button class="btn btn-sm btn-outline-light border-0" @onclick="ToggleNav" aria-label="Open menu">
            <i class="bi bi-list fs-5"></i>
        </button>
        <span class="ms-2 fw-semibold text-white small">Process Manager</span>
    </header>

    @if (_navOpen)
    {
        <div class="sidebar-backdrop d-lg-none" @onclick="CloseNav"></div>
    }

    <NavMenu IsOpen="_navOpen" OnClose="CloseNav" />

    <main class="flex-grow-1 overflow-auto bg-light">
        <div class="container-fluid py-3 px-2 px-md-4">
            @Body
        </div>
    </main>
</div>

<ToastContainer />

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    private bool _navOpen;

    private void ToggleNav() => _navOpen = !_navOpen;
    private void CloseNav() => _navOpen = false;

    protected override async Task OnInitializedAsync()
    {
        // In Blazor Server, HTTP middleware populates TokenService for the
        // SSR pass but not for the interactive circuit scope.
        // Re-populate from the persistent AuthenticationState here so every
        // child component gets a valid bearer token on circuit reconnect.
        if (string.IsNullOrEmpty(TokenSvc.AccessToken))
        {
            var state = await AuthState.GetAuthenticationStateAsync();
            var user = state.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                TokenSvc.AccessToken  = user.FindFirst("access_token")?.Value;
                TokenSvc.UserName     = user.Identity.Name;
                TokenSvc.DisplayName  = user.FindFirst("display_name")?.Value;
                TokenSvc.Role         = user.FindFirst(ClaimTypes.Role)?.Value;
            }
        }

        if (!Vocab.IsLoaded)
        {
            await Vocab.LoadAsync(Api);
        }
    }
}
