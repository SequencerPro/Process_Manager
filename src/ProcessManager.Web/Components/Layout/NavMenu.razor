@rendermode InteractiveServer
@inject TokenService TokenService

<nav class="d-flex flex-column flex-shrink-0 p-3 text-white bg-dark sidebar" style="width: 250px;">
    <a href="/" class="d-flex align-items-center mb-3 text-white text-decoration-none">
        <i class="bi bi-gear-wide-connected me-2 fs-4"></i>
        <span class="fs-5 fw-semibold">Process Manager</span>
    </a>
    <hr />
    <ul class="nav nav-pills flex-column mb-auto">
        <li class="nav-item">
            <NavLink class="nav-link text-white" href="" Match="NavLinkMatch.All">
                <i class="bi bi-house-door me-2"></i> Home
            </NavLink>
        </li>

        <li class="nav-section-header mt-3 mb-1 ps-3 text-uppercase small text-secondary">Design</li>

        <li class="nav-item">
            <NavLink class="nav-link text-white" href="kinds">
                <i class="bi bi-box me-2"></i> Kinds & Grades
            </NavLink>
        </li>
        <li class="nav-item">
            <NavLink class="nav-link text-white" href="step-templates">
                <i class="bi bi-puzzle me-2"></i> Step Templates
            </NavLink>
        </li>
        <li class="nav-item">
            <NavLink class="nav-link text-white" href="processes">
                <i class="bi bi-diagram-3 me-2"></i> Processes
            </NavLink>
        </li>
        <li class="nav-item">
            <NavLink class="nav-link text-white" href="workflows">
                <i class="bi bi-share me-2"></i> Workflows
            </NavLink>
        </li>

        <li class="nav-section-header mt-3 mb-1 ps-3 text-uppercase small text-secondary">Execution</li>

        <li class="nav-item">
            <NavLink class="nav-link text-white" href="jobs">
                <i class="bi bi-clipboard-check me-2"></i> Jobs
            </NavLink>
        </li>
        <li class="nav-item">
            <NavLink class="nav-link text-white" href="items">
                <i class="bi bi-tag me-2"></i> Items
            </NavLink>
        </li>
        <li class="nav-item">
            <NavLink class="nav-link text-white" href="batches">
                <i class="bi bi-collection me-2"></i> Batches
            </NavLink>
        </li>
        <li class="nav-item">
            <NavLink class="nav-link text-white" href="step-executions">
                <i class="bi bi-play-circle me-2"></i> Step Executions
            </NavLink>
        </li>

        <li class="nav-section-header mt-3 mb-1 ps-3 text-uppercase small text-secondary">Config</li>

        <li class="nav-item">
            <NavLink class="nav-link text-white" href="vocabulary">
                <i class="bi bi-translate me-2"></i> Vocabulary
            </NavLink>
        </li>
    </ul>

    <hr class="mt-auto" />
    <div class="d-flex align-items-center text-white-50 small">
        <i class="bi bi-person-circle me-2 fs-5 text-white"></i>
        <div class="flex-grow-1 overflow-hidden">
            <div class="text-white fw-medium text-truncate">@(TokenService.DisplayName ?? TokenService.UserName)</div>
            <div class="text-white-50 small text-truncate">@TokenService.Role</div>
        </div>
        <a href="/account/logout" class="btn btn-sm btn-outline-light ms-2" title="Sign out">
            <i class="bi bi-box-arrow-right"></i>
        </a>
    </div>
</nav>
