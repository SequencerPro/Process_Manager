@page "/workorders/{Id:guid}"
@rendermode InteractiveServer
@inject ApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Workorder Detail</PageTitle>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_wo is null)
{
    <div class="alert alert-warning">Workorder not found.</div>
}
else
{
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="workorders">Workorders</a></li>
            <li class="breadcrumb-item active">@_wo.Name</li>
        </ol>
    </nav>

    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h4 class="mb-1">@_wo.Name</h4>
                    <span class="text-muted me-3"><code>@_wo.Code</code></span>
                    <StatusBadge Status="@_wo.Status" />
                    @if (_wo.Priority > 0)
                    {
                        <span class="badge bg-warning text-dark ms-1">Priority @_wo.Priority</span>
                    }
                    <span class="badge bg-dark ms-1">Workflow v@_wo.WorkflowVersion</span>
                </div>
                <div class="d-flex gap-1 flex-wrap">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="ShowEditForm">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </button>
                    @if (_wo.Status == "Created")
                    {
                        <button class="btn btn-success btn-sm" @onclick='() => Transition("start")'>
                            <i class="bi bi-play-fill me-1"></i>Start
                        </button>
                        <button class="btn btn-outline-danger btn-sm" @onclick='() => Transition("cancel")'>Cancel</button>
                    }
                    else if (_wo.Status == "InProgress")
                    {
                        <button class="btn btn-outline-danger btn-sm" @onclick='() => Transition("cancel")'>Cancel</button>
                    }
                    <button class="btn btn-outline-danger btn-sm" @onclick="DeleteWorkorder">
                        <i class="bi bi-trash me-1"></i>Delete
                    </button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_wo.Description))
            {
                <p class="mt-2 mb-2">@_wo.Description</p>
            }
            <div class="mt-2">
                <small class="text-muted">
                    Workflow: <strong>@_wo.WorkflowName</strong> &bull;
                    Created @_wo.CreatedAt.ToString("g")
                    @if (_wo.StartedAt.HasValue) { <text> &bull; Started @_wo.StartedAt.Value.ToString("g")</text> }
                    @if (_wo.CompletedAt.HasValue) { <text> &bull; Completed @_wo.CompletedAt.Value.ToString("g")</text> }
                </small>
            </div>
        </div>
    </div>

    <!-- Jobs Progress -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-list-check me-1"></i> Jobs (@(_wo.Jobs?.Count ?? 0))</span>
            @{
                var done  = _wo.Jobs?.Count(j => j.JobStatus == "Completed") ?? 0;
                var total = _wo.Jobs?.Count ?? 0;
                var pct   = total > 0 ? (int)((done / (double)total) * 100) : 0;
            }
            <small class="text-muted">@done / @total complete</small>
        </div>
        @if (_wo.Jobs?.Any() == true)
        {
            <div class="px-2 py-1">
                <div class="progress mb-0" style="height:4px;border-radius:0">
                    <div class="progress-bar bg-success" style="width:@pct%"></div>
                </div>
            </div>
            <div class="list-group list-group-flush">
                @foreach (var wj in _wo.Jobs)
                {
                    var (iconClass, badgeClass) = wj.JobStatus switch
                    {
                        "Completed"  => ("bi-check-circle-fill text-success",   "bg-success"),
                        "InProgress" => ("bi-play-circle-fill text-primary",    "bg-primary"),
                        "Cancelled"  => ("bi-x-circle-fill text-danger",        "bg-danger"),
                        "OnHold"     => ("bi-pause-circle-fill text-warning",   "bg-warning text-dark"),
                        _            => ("bi-circle text-secondary",            "bg-light text-dark border"),
                    };
                    <div class="list-group-item d-flex align-items-center gap-3 py-3">
                        <i class="bi @iconClass fs-5" style="flex-shrink:0"></i>
                        <div class="flex-grow-1">
                            <div class="fw-medium">@wj.ProcessName</div>
                            <div class="small text-muted">
                                <a href="jobs/@wj.JobId"><code>@wj.JobCode</code></a> — @wj.JobName
                            </div>
                        </div>
                        <div class="d-flex gap-2 align-items-center" style="flex-shrink:0">
                            <span class="badge @badgeClass">@wj.JobStatus</span>
                            @if (wj.CanStart && _wo.Status == "InProgress")
                            {
                                <button class="btn btn-sm btn-success" @onclick="() => StartJob(wj.JobId)">
                                    <i class="bi bi-play-fill me-1"></i>Start
                                </button>
                            }
                            else if (wj.CanStart)
                            {
                                <span class="badge bg-info text-dark">Ready</span>
                            }
                            <a href="jobs/@wj.JobId" class="btn btn-sm btn-outline-secondary">
                                <i class="bi bi-eye me-1"></i>View
                            </a>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="card-body text-muted small">No jobs created yet.</div>
        }
    </div>

    @* Edit Workorder Modal *@
    @if (_showEditForm)
    {
        <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Edit Workorder</h5>
                        <button type="button" class="btn-close" @onclick="CloseEditForm"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <input class="form-control" @bind="_editName" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" rows="3" @bind="_editDescription"></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Priority</label>
                            <input type="number" class="form-control" @bind="_editPriority" min="0" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="CloseEditForm">Cancel</button>
                        <button class="btn btn-primary" @onclick="SaveEdit">Update</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }

    private WorkorderResponseDto? _wo;
    private bool _loading = true;

    // Edit form
    private bool _showEditForm;
    private string _editName = "";
    private string? _editDescription;
    private int _editPriority;

    protected override async Task OnInitializedAsync() => await LoadAll();

    private async Task LoadAll()
    {
        _loading = true;
        try
        {
            _wo = await Api.GetWorkorderAsync(Id);
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task Transition(string action)
    {
        try
        {
            _wo = await Api.WorkorderTransitionAsync(Id, action);
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

    private async Task StartJob(Guid jobId)
    {
        try
        {
            await Api.JobTransitionAsync(jobId, "start");
            await LoadAll();
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

    // --- Edit ---
    private void ShowEditForm()
    {
        _editName = _wo!.Name;
        _editDescription = _wo.Description;
        _editPriority = _wo.Priority;
        _showEditForm = true;
    }

    private void CloseEditForm() { _showEditForm = false; }

    private async Task SaveEdit()
    {
        try
        {
            await Api.UpdateWorkorderAsync(Id, new UpdateWorkorderDto(_editName, _editDescription, _editPriority));
            _showEditForm = false;
            await LoadAll();
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

    private async Task DeleteWorkorder()
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this workorder? This cannot be undone.")) return;
        try { await Api.DeleteWorkorderAsync(Id); Nav.NavigateTo("workorders"); }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }
}
