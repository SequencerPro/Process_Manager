    private async Task RetireProcess()
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Retire process '{_proc!.Name}'? It will be archived.")) return;
        try { _proc = await Api.RetireProcessAsync(Id); }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

    private static string StatusBadgeClass(string? status) => status switch
    {
        "Draft"           => "bg-secondary",
        "PendingApproval" => "bg-warning text-dark",
        "Released"        => "bg-success",
        "Superseded"      => "bg-dark",
        "Retired"         => "bg-danger",
        _                 => "bg-light text-dark"
    };

    private MaturitySummaryDto? AggregateMaturity()    {
        if (_proc is null || !_proc.Steps.Any()) return null;
        var summaries = _proc.Steps
            .Select(s => s.StepTemplateMaturity)
            .Where(m => m is not null)
            .ToList();
        if (!summaries.Any()) return null;
        // Return the worst (lowest score) summary
        return summaries.MinBy(m => m!.Score);
    }

    private static string MaturityBadgeClass(MaturityLevel level) => level switch
    {
        MaturityLevel.Optimised  => "bg-success",
        MaturityLevel.Defined    => "bg-primary",
        MaturityLevel.Developing => "bg-warning text-dark",
        _                        => "bg-secondary"
    };
}
