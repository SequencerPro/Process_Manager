@page "/"

<PageTitle>Process Manager</PageTitle>

<div class="row mb-4">
    <div class="col">
        <h2>Process Manager</h2>
        <p class="text-muted">Manufacturing process design and execution management</p>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-box me-2"></i>Kinds & Grades</h5>
                <p class="card-text">Define material types with classifications and tracking rules.</p>
                <a href="kinds" class="btn btn-outline-primary btn-sm">Manage Kinds</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-puzzle me-2"></i>Step Templates</h5>
                <p class="card-text">Design reusable operations with typed input/output ports.</p>
                <a href="step-templates" class="btn btn-outline-primary btn-sm">Manage Templates</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-diagram-3 me-2"></i>Processes</h5>
                <p class="card-text">Compose steps into ordered process sequences with flows.</p>
                <a href="processes" class="btn btn-outline-primary btn-sm">Manage Processes</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-share me-2"></i>Workflows</h5>
                <p class="card-text">Connect processes into directed graphs with routing decisions.</p>
                <a href="workflows" class="btn btn-outline-primary btn-sm">Manage Workflows</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-clipboard-check me-2"></i>Jobs</h5>
                <p class="card-text">Create and track production jobs through processes.</p>
                <a href="jobs" class="btn btn-outline-primary btn-sm">Manage Jobs</a>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title"><i class="bi bi-tag me-2"></i>Items & Batches</h5>
                <p class="card-text">Track individual items and batches flowing through production.</p>
                <a href="items" class="btn btn-outline-primary btn-sm">View Items</a>
            </div>
        </div>
    </div>
</div>
