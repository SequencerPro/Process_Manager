    private async Task ConfirmNewLink()
    {
        Guid srcWpId, tgtWpId;
        WorkflowProcessNodeModel? srcNode, tgtNode;

        if (_isManualLinkCreation)
        {
            // Manual creation — get source/target from dropdowns
            if (!Guid.TryParse(_manualSourceId, out srcWpId) || !Guid.TryParse(_manualTargetId, out tgtWpId))
            {
                Toast.ShowError("Please select both source and target processes.");
                return;
            }
            if (srcWpId == tgtWpId)
            {
                Toast.ShowError("Source and target must be different.");
                return;
            }
            _nodeMap.TryGetValue(srcWpId, out srcNode);
            _nodeMap.TryGetValue(tgtWpId, out tgtNode);
        }
        else
        {
            // Port-dragged creation
            if (_pendingLink is null) return;
            var srcAnchor = _pendingLink.Source as SinglePortAnchor;
            var tgtAnchor = _pendingLink.Target as SinglePortAnchor;
            srcNode = srcAnchor?.Port?.Parent as WorkflowProcessNodeModel;
            tgtNode = tgtAnchor?.Port?.Parent as WorkflowProcessNodeModel;
            srcWpId = srcNode?.WorkflowProcessId ?? Guid.Empty;
            tgtWpId = tgtNode?.WorkflowProcessId ?? Guid.Empty;
        }

        if (srcNode is null || tgtNode is null) { CancelNewLink(); return; }

        if (_newLinkRoutingType == RoutingType.GradeBased && !_newLinkGradeIds.Any())
        {
            Toast.ShowError("GradeBased links must have at least one condition grade.");
            return;
        }

        try
        {
            var dto = new CreateWorkflowLinkDto(
                srcWpId,
                tgtWpId,
                _newLinkRoutingType,
                string.IsNullOrWhiteSpace(_newLinkName) ? null : _newLinkName,
                0,
                _newLinkRoutingType == RoutingType.GradeBased ? _newLinkGradeIds : null);

            var result = await Api.AddWorkflowLinkAsync(Id, dto);
            if (result is not null)
            {
                LinkModel diagramLink;

                if (_isManualLinkCreation)
                {
                    // Create diagram link for manual creation
                    var (srcPort, tgtPort) = GetBestPortPair(srcNode, tgtNode);
                    if (srcPort is null || tgtPort is null)
                    {
                        Toast.ShowError("Could not find ports to connect.");
                        return;
                    }
                    diagramLink = new LinkModel(srcPort, tgtPort);
                    _diagram.Links.Add(diagramLink);
                }
                else
                {
                    diagramLink = _pendingLink!;
                }

                _linkDataMap[diagramLink] = result;
                _linkShapeMap[diagramLink] = "straight";
                var newLabelParts = new List<string> { result.Name ?? result.RoutingType.ToString() };
                if (result.RoutingType == RoutingType.GradeBased && result.Conditions?.Any() == true)
                    newLabelParts.Add($"[{string.Join(", ", result.Conditions.Select(c => c.GradeCode))}]");
                diagramLink.Labels.Add(new LinkLabelModel(diagramLink, string.Join(" ", newLabelParts)));
                Toast.ShowSuccess("Link created.");
            }
        }
        catch (HttpRequestException ex)
        {
            Toast.ShowError(ex.Message);
            if (_pendingLink is not null)
                _diagram.Links.Remove(_pendingLink);
        }

        _showLinkModal = false;
        _pendingLink = null;
        _isManualLinkCreation = false;
    }

    private void CancelNewLink()
    {
        if (_pendingLink is not null)
        {
            _diagram.Links.Remove(_pendingLink);
        }
        _showLinkModal = false;
        _pendingLink = null;
        _isManualLinkCreation = false;
    }

