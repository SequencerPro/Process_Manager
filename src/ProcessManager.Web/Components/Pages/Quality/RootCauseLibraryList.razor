@page "/root-cause-library"
@rendermode InteractiveServer
@inject ApiClient Api
@inject IJSRuntime JS
@inject NavigationManager Nav
@attribute [Authorize]

<PageTitle>Root Cause Library — Process Manager</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-0"><i class="bi bi-diagram-3 me-2 text-secondary"></i>Root Cause Library</h3>
        <p class="text-muted small mb-0">Institutional catalogue of named causes — shared across all RCA tools</p>
    </div>
    @if (_activeTab == "entries")
    {
        <AuthorizeView Roles="Admin,Engineer">
            <Authorized>
                <button class="btn btn-primary btn-sm" @onclick="OpenCreate">
                    <i class="bi bi-plus-lg me-1"></i> New Entry
                </button>
            </Authorized>
        </AuthorizeView>
    }
</div>

<!-- Tabs -->
<ul class="nav nav-tabs mb-3">
    <li class="nav-item">
        <button class="nav-link @(_activeTab == "entries" ? "active" : "")" @onclick='() => SetTab("entries")'>
            <i class="bi bi-journal-text me-1"></i>Library Entries
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link @(_activeTab == "index" ? "active" : "")" @onclick='() => SetTab("index")'>
            <i class="bi bi-search me-1"></i>Analysis Index
        </button>
    </li>
</ul>

<!-- Library Entries tab -->
@if (_activeTab == "entries")
{
<!-- Filters -->
<div class="card mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-end">
            <div class="col-md-4">
                <label class="form-label small mb-1">Search</label>
                <input class="form-control form-control-sm" placeholder="Search title, tags…"
                       @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
            </div>
            <div class="col-md-3">
                <label class="form-label small mb-1">Category</label>
                <select class="form-select form-select-sm" @onchange="OnCategoryFilter">
                    <option value="">All categories</option>
                    @foreach (var cat in _categories)
                    {
                        <option value="@cat">@cat</option>
                    }
                </select>
            </div>
            <div class="col-auto">
                <button class="btn btn-outline-secondary btn-sm" @onclick="LoadData">
                    <i class="bi bi-arrow-clockwise me-1 @(_loading ? "spin" : "")"></i>Refresh
                </button>
            </div>
        </div>
    </div>
</div>

@if (_loading)
{
    <div class="text-center py-5 text-muted">
        <div class="spinner-border spinner-border-sm me-2"></div>Loading…
    </div>
}
else if (_data is null || !_data.Items.Any())
{
    <div class="card">
        <div class="card-body text-muted fst-italic small text-center py-4">
            <i class="bi bi-diagram-3 fs-2 d-block mb-2 text-secondary"></i>
            No root cause entries found. Add the first one to start building institutional knowledge.
        </div>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover table-sm mb-0 align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Tags</th>
                        <th>Corrective Action Template</th>
                        <th class="text-center">Usage</th>
                        <th style="width:100px"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var entry in _data.Items)
                    {
                        <tr>
                            <td>
                                <a class="fw-semibold text-decoration-none" href="/root-cause-library/@entry.Id">@entry.Title</a>
                                @if (!string.IsNullOrEmpty(entry.Description))
                                {
                                    <small class="text-muted d-block">@Truncate(entry.Description, 80)</small>
                                }
                            </td>
                            <td><span class="badge @CategoryBadgeClass(entry.Category)">@entry.Category</span></td>
                            <td>
                                @if (!string.IsNullOrEmpty(entry.Tags))
                                {
                                    @foreach (var tag in entry.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                                    {
                                        <span class="badge bg-light text-dark border me-1">@tag</span>
                                    }
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(entry.CorrectiveActionTemplate))
                                {
                                    <small class="text-muted">@Truncate(entry.CorrectiveActionTemplate, 80)</small>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-center">
                                @if (entry.UsageCount > 0)
                                {
                                    <span class="badge bg-info text-dark">@entry.UsageCount</span>
                                }
                                else
                                {
                                    <span class="text-muted small">0</span>
                                }
                            </td>
                            <td>
                                <AuthorizeView Roles="Admin,Engineer">
                                    <Authorized>
                                        <button class="btn btn-outline-secondary btn-sm py-0 px-2 me-1"
                                                @onclick="() => OpenEdit(entry)" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm py-0 px-2"
                                                @onclick="() => DeleteEntry(entry)" title="Delete">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </Authorized>
                                </AuthorizeView>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Pagination -->
    @if (_data.TotalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center mt-3">
            <small class="text-muted">
                @( (_data.Page - 1) * _data.PageSize + 1 )–@(Math.Min(_data.Page * _data.PageSize, _data.TotalCount)) of @_data.TotalCount entries
            </small>
            <div class="btn-group btn-group-sm">
                <button class="btn btn-outline-secondary" disabled="@(_data.Page <= 1)"
                        @onclick="() => ChangePage(_data.Page - 1)">
                    <i class="bi bi-chevron-left"></i>
                </button>
                <span class="btn btn-outline-secondary disabled">@_data.Page / @_data.TotalPages</span>
                <button class="btn btn-outline-secondary" disabled="@(_data.Page >= _data.TotalPages)"
                        @onclick="() => ChangePage(_data.Page + 1)">
                    <i class="bi bi-chevron-right"></i>
                </button>
            </div>
        </div>
    }
}
}

<!-- Analysis Index tab -->
@if (_activeTab == "index")
{
    <!-- Index filters -->
    <div class="card mb-3">
        <div class="card-body py-2">
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="form-label small mb-1">Search</label>
                    <input class="form-control form-control-sm" placeholder="Search title, problem statement…"
                           @bind="_idxSearch" @bind:event="oninput" @onkeyup="OnIdxSearchKeyUp" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Type</label>
                    <select class="form-select form-select-sm" @onchange="OnIdxTypeFilter">
                        <option value="">All types</option>
                        <option value="FiveWhys">5 Whys</option>
                        <option value="Ishikawa">Ishikawa</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small mb-1">Status</label>
                    <select class="form-select form-select-sm" @onchange="OnIdxStatusFilter">
                        <option value="">All statuses</option>
                        <option value="Open">Open</option>
                        <option value="Closed">Closed</option>
                    </select>
                </div>
                <div class="col-auto">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="LoadIndex">
                        <i class="bi bi-arrow-clockwise me-1 @(_idxLoading ? "spin" : "")"></i>Refresh
                    </button>
                </div>
            </div>
        </div>
    </div>

    @if (_idxLoading)
    {
        <div class="text-center py-5 text-muted">
            <div class="spinner-border spinner-border-sm me-2"></div>Loading…
        </div>
    }
    else if (_idxData is null || !_idxData.Items.Any())
    {
        <div class="card">
            <div class="card-body text-muted fst-italic small text-center py-4">
                <i class="bi bi-search fs-2 d-block mb-2 text-secondary"></i>
                No analyses found. Create a 5 Whys or Ishikawa analysis to populate this index.
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="table-responsive">
                <table class="table table-hover table-sm mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Type</th>
                            <th>Title</th>
                            <th>Problem / Defect</th>
                            <th class="text-center">Nodes</th>
                            <th class="text-center">Root Causes</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th style="width:60px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in _idxData.Items)
                        {
                            <tr>
                                <td>
                                    @if (item.AnalysisType == "FiveWhys")
                                    {
                                        <span class="badge bg-primary">5 Whys</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Ishikawa</span>
                                    }
                                </td>
                                <td class="fw-semibold">@item.Title</td>
                                <td><small class="text-muted">@Truncate(item.ProblemStatement, 70)</small></td>
                                <td class="text-center">@item.TotalNodes</td>
                                <td class="text-center">
                                    @if (item.ConfirmedRootCauses > 0)
                                    {
                                        <span class="badge bg-success">@item.ConfirmedRootCauses</span>
                                    }
                                    else { <span class="text-muted small">0</span> }
                                </td>
                                <td>
                                    <span class="badge @(item.Status == "Open" ? "bg-warning text-dark" : "bg-secondary")">
                                        @item.Status
                                    </span>
                                </td>
                                <td><small class="text-muted">@item.CreatedAt.ToString("dd MMM yyyy")</small></td>
                                <td>
                                    <a href="@IdxAnalysisUrl(item)" class="btn btn-outline-secondary btn-sm py-0 px-2" title="Open">
                                        <i class="bi bi-box-arrow-up-right"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Pagination -->
        @if (_idxData.TotalPages > 1)
        {
            <div class="d-flex justify-content-between align-items-center mt-3">
                <small class="text-muted">
                    @( (_idxData.Page - 1) * _idxData.PageSize + 1 )–@(Math.Min(_idxData.Page * _idxData.PageSize, _idxData.TotalCount)) of @_idxData.TotalCount analyses
                </small>
                <div class="btn-group btn-group-sm">
                    <button class="btn btn-outline-secondary" disabled="@(_idxData.Page <= 1)"
                            @onclick="() => ChangeIdxPage(_idxData.Page - 1)">
                        <i class="bi bi-chevron-left"></i>
                    </button>
                    <span class="btn btn-outline-secondary disabled">@_idxData.Page / @_idxData.TotalPages</span>
                    <button class="btn btn-outline-secondary" disabled="@(_idxData.Page >= _idxData.TotalPages)"
                            @onclick="() => ChangeIdxPage(_idxData.Page + 1)">
                        <i class="bi bi-chevron-right"></i>
                    </button>
                </div>
            </div>
        }
    }
}
<!-- Create / Edit Modal -->
@if (_showModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.4)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">
                        @(_editId is null ? "New Root Cause Entry" : "Edit Root Cause Entry")
                    </h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Title <span class="text-danger">*</span></label>
                        <input class="form-control" @bind="_form.Title" placeholder="e.g. Fixture wear" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Category <span class="text-danger">*</span></label>
                        <select class="form-select" @bind="_form.Category">
                            <option value="">— Select category —</option>
                            @foreach (var cat in _categories)
                            {
                                <option value="@cat">@cat</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea class="form-control" rows="3" @bind="_form.Description"
                                  placeholder="How this cause manifests and how to detect it"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Tags</label>
                        <input class="form-control" @bind="_form.Tags"
                               placeholder="Comma-separated, e.g. tooling, setup, wear" />
                        <div class="form-text">Used for cross-cutting retrieval in analysis tools.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Corrective Action Template</label>
                        <textarea class="form-control" rows="3" @bind="_form.CorrectiveActionTemplate"
                                  placeholder="Suggested corrective action — pre-populated into investigations"></textarea>
                    </div>
                    @if (!string.IsNullOrEmpty(_modalError))
                    {
                        <div class="alert alert-danger py-2">@_modalError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary btn-sm" @onclick="CloseModal">Cancel</button>
                    <button class="btn btn-primary btn-sm" @onclick="SaveEntry" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        @(_editId is null ? "Create" : "Save Changes")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private static readonly string[] _categories =
        ["Machine", "Method", "Material", "People", "Measurement", "Environment", "Management"];

    // ── Library Entries tab ──
    private string _activeTab = "entries";
    private PaginatedResponse<RootCauseEntryResponseDto>? _data;
    private bool _loading;
    private string _search = "";
    private string _category = "";
    private int _page = 1;
    private const int PageSize = 25;

    // ── Analysis Index tab ──
    private PaginatedResponse<RcaAnalysisIndexItemDto>? _idxData;
    private bool _idxLoading;
    private string _idxSearch = "";
    private string _idxType = "";
    private string _idxStatus = "";
    private int _idxPage = 1;
    private const int IdxPageSize = 25;

    // Modal
    private bool _showModal;
    private bool _saving;
    private Guid? _editId;
    private string _modalError = "";
    private FormModel _form = new();

    private class FormModel
    {
        public string Title { get; set; } = "";
        public string Category { get; set; } = "";
        public string? Description { get; set; }
        public string? Tags { get; set; }
        public string? CorrectiveActionTemplate { get; set; }
    }

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task SetTab(string tab)
    {
        _activeTab = tab;
        if (tab == "index" && _idxData is null)
            await LoadIndex();
    }

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _data = await Api.GetRootCauseEntriesAsync(_search, _category, _page, PageSize);
        }
        finally { _loading = false; }
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { _page = 1; await LoadData(); }
    }

    private async Task OnCategoryFilter(ChangeEventArgs e)
    {
        _category = e.Value?.ToString() ?? "";
        _page = 1;
        await LoadData();
    }

    private async Task ChangePage(int page) { _page = page; await LoadData(); }

    // ── Analysis Index ──

    private async Task LoadIndex()
    {
        _idxLoading = true;
        try
        {
            _idxData = await Api.GetRcaAnalysisIndexAsync(_idxSearch, _idxType, _idxStatus, _idxPage, IdxPageSize);
        }
        finally { _idxLoading = false; }
    }

    private async Task OnIdxSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { _idxPage = 1; await LoadIndex(); }
    }

    private async Task OnIdxTypeFilter(ChangeEventArgs e)
    {
        _idxType = e.Value?.ToString() ?? "";
        _idxPage = 1;
        await LoadIndex();
    }

    private async Task OnIdxStatusFilter(ChangeEventArgs e)
    {
        _idxStatus = e.Value?.ToString() ?? "";
        _idxPage = 1;
        await LoadIndex();
    }

    private async Task ChangeIdxPage(int page) { _idxPage = page; await LoadIndex(); }

    private static string IdxAnalysisUrl(RcaAnalysisIndexItemDto item) =>
        item.AnalysisType == "FiveWhys" ? $"/five-whys/{item.Id}" : $"/ishikawa/{item.Id}";

    // ── Modal ──

    private void OpenCreate()
    {
        _editId = null;
        _form = new();
        _modalError = "";
        _showModal = true;
    }

    private void OpenEdit(RootCauseEntryResponseDto entry)
    {
        _editId = entry.Id;
        _form = new FormModel
        {
            Title                    = entry.Title,
            Category                 = entry.Category,
            Description              = entry.Description,
            Tags                     = entry.Tags,
            CorrectiveActionTemplate = entry.CorrectiveActionTemplate
        };
        _modalError = "";
        _showModal = true;
    }

    private void CloseModal() => _showModal = false;

    private async Task SaveEntry()
    {
        if (string.IsNullOrWhiteSpace(_form.Title))   { _modalError = "Title is required."; return; }
        if (string.IsNullOrWhiteSpace(_form.Category)) { _modalError = "Category is required."; return; }

        _saving = true;
        _modalError = "";
        try
        {
            if (_editId is null)
            {
                await Api.CreateRootCauseEntryAsync(new RootCauseEntryCreateDto(
                    _form.Title, _form.Description, _form.Category, _form.Tags, _form.CorrectiveActionTemplate));
            }
            else
            {
                await Api.UpdateRootCauseEntryAsync(_editId.Value, new RootCauseEntryUpdateDto(
                    _form.Title, _form.Description, _form.Category, _form.Tags, _form.CorrectiveActionTemplate));
            }
            _showModal = false;
            await LoadData();
        }
        catch (Exception ex)
        {
            _modalError = ex.Message;
        }
        finally { _saving = false; }
    }

    private async Task DeleteEntry(RootCauseEntryResponseDto entry)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Delete '{entry.Title}'? This cannot be undone."))
            return;
        try
        {
            await Api.DeleteRootCauseEntryAsync(entry.Id);
            await LoadData();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Delete failed: {ex.Message}");
        }
    }

    // ── Helpers ──

    private static string CategoryBadgeClass(string category) => category switch
    {
        "Machine"     => "bg-primary",
        "Method"      => "bg-success",
        "Material"    => "bg-warning text-dark",
        "People"      => "bg-info text-dark",
        "Measurement" => "bg-secondary",
        "Environment" => "bg-dark",
        "Management"  => "bg-danger",
        _             => "bg-light text-dark border"
    };

    private static string Truncate(string? s, int max) =>
        s is null ? "" : s.Length <= max ? s : s[..max] + "…";
}
