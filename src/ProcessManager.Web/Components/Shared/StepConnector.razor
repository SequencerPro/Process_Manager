@* Arrow connector between sequential process builder tiles *@
<div class="step-connector">
    @if (Status == StepConnectionStatus.Connected)
    {
        <span class="badge rounded-pill bg-success-subtle text-success border border-success px-3 py-1">
            <i class="bi bi-check-circle me-1"></i>
            @SourcePortName
            <i class="bi bi-arrow-right mx-1"></i>
            @TargetPortName
            @if (!string.IsNullOrEmpty(PortInfoText))
            {
                <span class="ms-1 opacity-75 small">(@PortInfoText)</span>
            }
        </span>
    }
    else if (Status == StepConnectionStatus.Ambiguous)
    {
        <div class="d-flex align-items-center gap-2" style="background:#fff;padding:2px 8px;border-radius:4px;">
            <i class="bi bi-exclamation-triangle-fill text-warning"></i>
            <span class="text-warning small">Multiple possible connections — select one:</span>
            @ChildContent
        </div>
    }
    else
    {
        <span class="badge rounded-pill bg-danger-subtle text-danger border border-danger px-3 py-1">
            <i class="bi bi-x-circle me-1"></i>No compatible connection — output types don't match input types
        </span>
    }

    @if (OnInsertClick.HasDelegate)
    {
        <button class="btn btn-outline-primary btn-sm py-0 px-2" style="font-size:.75rem"
                @onclick="OnInsertClick">
            <i class="bi bi-plus-lg me-1"></i>Insert Step Here
        </button>
    }
</div>

@code {
    [Parameter] public StepConnectionStatus Status { get; set; } = StepConnectionStatus.Incompatible;
    [Parameter] public string? SourcePortName { get; set; }
    [Parameter] public string? TargetPortName { get; set; }
    [Parameter] public string? PortInfoText { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnInsertClick { get; set; }
}
