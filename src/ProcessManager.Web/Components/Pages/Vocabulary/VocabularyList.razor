@page "/vocabulary"
@attribute [Authorize(Roles = "Admin,Engineer")]
@rendermode InteractiveServer
@inject ApiClient Api
@inject IJSRuntime JS
@inject VocabularyService Vocab
@implements IDisposable

<PageTitle>Domain Vocabulary</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Domain Vocabulary</h3>
    <button class="btn btn-primary btn-sm" @onclick="ShowCreate">
        <i class="bi bi-plus-lg me-1"></i> New Vocabulary
    </button>
</div>

@if (Vocab.ActiveName is not null)
{
    <div class="alert alert-success d-flex align-items-center py-2 mb-3">
        <i class="bi bi-check-circle-fill me-2"></i>
        <span>Active vocabulary: <strong>@Vocab.ActiveName</strong></span>
    </div>
}

<div class="mb-3">
    <SearchBox Value="@_search" ValueChanged="OnSearch" Placeholder="Search vocabularies..." />
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_data is not null)
{
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Active</th>
                    <th>Kind</th>
                    <th>Grade</th>
                    <th>Item</th>
                    <th>Batch</th>
                    <th>Job</th>
                    <th>Workorder</th>
                    <th>Process</th>
                    <th>Step</th>
                    <th style="width:160px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!_data.Items.Any())
                {
                    <tr><td colspan="11" class="text-center text-muted py-3">No vocabularies found.</td></tr>
                }
                else
                {
                @foreach (var v in _data.Items)
                {
                    <tr class="@(v.IsActive ? "table-success" : "")">
                        <td><strong>@v.Name</strong></td>
                        <td>
                            @if (v.IsActive)
                            {
                                <span class="badge bg-success"><i class="bi bi-check-lg"></i> Active</span>
                            }
                        </td>
                        <td>@v.TermKind</td>
                        <td>@v.TermGrade</td>
                        <td>@v.TermItem</td>
                        <td>@v.TermBatch</td>
                        <td>@v.TermJob</td>
                        <td>@v.TermWorkorder</td>
                        <td>@v.TermProcess</td>
                        <td>@v.TermStep</td>
                        <td>
                            <button class="btn @(v.IsActive ? "btn-success" : "btn-outline-success") btn-sm me-1"
                                    @onclick="() => ToggleActive(v)"
                                    title="@(v.IsActive ? "Deactivate" : "Activate")">
                                <i class="bi @(v.IsActive ? "bi-toggle-on" : "bi-toggle-off")"></i>
                            </button>
                            <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => ShowEdit(v)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(v.Id)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
                }
            </tbody>
        </table>
    </div>

    <Pager Page="_page" PageSize="_pageSize" TotalCount="_data.TotalCount"
           OnPageChanged="OnPageChanged" />
}

@if (_showForm)
{
    <div class="modal show d-block pm-modal" tabindex="-1" style="background: rgba(0,0,0,.45)">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <div class="pm-modal-icon pm-modal-icon-purple">
                        <i class="bi bi-translate"></i>
                    </div>
                    <div>
                        <h5 class="modal-title">@(_editId.HasValue ? "Edit" : "New") Vocabulary</h5>
                        <div class="pm-modal-subtitle">@(_editId.HasValue ? "Update vocabulary term definitions" : "Define terminology mappings for your organization")</div>
                    </div>
                    <button type="button" class="btn-close ms-auto" @onclick="CloseForm"></button>
                </div>
                <div class="modal-body">
                    <div class="pm-input-group">
                        <label><i class="bi bi-type"></i> Name</label>
                        <input class="form-control" @bind="_formName" />
                    </div>
                    <div class="pm-modal-divider">Terms</div>
                    <div class="row g-3">
                        <div class="col-md-4 pm-input-group">
                            <label><i class="bi bi-tag"></i> Kind</label>
                            <input class="form-control" @bind="_formTermKind" />
                        </div>
                        <div class="col-md-4 pm-input-group">
                            <label><i class="bi bi-tag"></i> Kind Code</label>
                            <input class="form-control" @bind="_formTermKindCode" />
                        </div>
                        <div class="col-md-4 pm-input-group">
                            <label><i class="bi bi-tag"></i> Grade</label>
                            <input class="form-control" @bind="_formTermGrade" />
                        </div>
                        <div class="col-md-4 pm-input-group">
                            <label><i class="bi bi-tag"></i> Item</label>
                            <input class="form-control" @bind="_formTermItem" />
                        </div>
                        <div class="col-md-4 pm-input-group">
                            <label><i class="bi bi-tag"></i> Item ID</label>
                            <input class="form-control" @bind="_formTermItemId" />
                        </div>
                        <div class="col-md-4 pm-input-group">
                            <label><i class="bi bi-tag"></i> Batch</label>
                            <input class="form-control" @bind="_formTermBatch" />
                        </div>
                        <div class="col-md-4 pm-input-group">
                            <label><i class="bi bi-tag"></i> Batch ID</label>
                            <input class="form-control" @bind="_formTermBatchId" />
                        </div>
                        <div class="col-md-4 pm-input-group">
                            <label><i class="bi bi-tag"></i> Job</label>
                            <input class="form-control" @bind="_formTermJob" />
                        </div>
                        <div class="col-md-4 pm-input-group">
                            <label><i class="bi bi-tag"></i> Workorder</label>
                            <input class="form-control" @bind="_formTermWorkorder" />
                        </div>
                        <div class="col-md-4 pm-input-group">
                            <label><i class="bi bi-tag"></i> Workflow</label>
                            <input class="form-control" @bind="_formTermWorkflow" />
                        </div>
                        <div class="col-md-4 pm-input-group">
                            <label><i class="bi bi-tag"></i> Process</label>
                            <input class="form-control" @bind="_formTermProcess" />
                        </div>
                        <div class="col-md-4 pm-input-group">
                            <label><i class="bi bi-tag"></i> Step</label>
                            <input class="form-control" @bind="_formTermStep" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                    <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Save
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PaginatedResponse<DomainVocabularyResponseDto>? _data;
    private bool _loading = true;
    private string _search = "";
    private int _page = 1;
    private int _pageSize = 25;

    // Form
    private bool _showForm;
    private bool _saving;
    private Guid? _editId;
    private string _formName = "";
    private string _formTermKind = "Kind";
    private string _formTermKindCode = "Kind Code";
    private string _formTermGrade = "Grade";
    private string _formTermItem = "Item";
    private string _formTermItemId = "Serial Number";
    private string _formTermBatch = "Batch";
    private string _formTermBatchId = "Batch Code";
    private string _formTermJob = "Job";
    private string _formTermWorkorder = "Workorder";
    private string _formTermWorkflow = "Workflow";
    private string _formTermProcess = "Process";
    private string _formTermStep = "Step";

    protected override void OnInitialized() => Vocab.OnChange += OnVocabChanged;
    protected override async Task OnInitializedAsync() => await LoadData();
    private void OnVocabChanged() => InvokeAsync(StateHasChanged);
    public void Dispose() => Vocab.OnChange -= OnVocabChanged;

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _data = await Api.GetVocabulariesAsync(_search, _page, _pageSize);
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearch(string v) { _search = v; _page = 1; await LoadData(); }
    private async Task OnPageChanged(int p) { _page = p; await LoadData(); }

    private void ShowCreate()
    {
        _editId = null;
        _formName = "";
        _formTermKind = "Kind"; _formTermKindCode = "Kind Code"; _formTermGrade = "Grade";
        _formTermItem = "Item"; _formTermItemId = "Serial Number";
        _formTermBatch = "Batch"; _formTermBatchId = "Batch Code";
        _formTermJob = "Job"; _formTermWorkorder = "Workorder"; _formTermWorkflow = "Workflow";
        _formTermProcess = "Process"; _formTermStep = "Step";
        _showForm = true;
    }

    private void ShowEdit(DomainVocabularyResponseDto v)
    {
        _editId = v.Id; _formName = v.Name;
        _formTermKind = v.TermKind; _formTermKindCode = v.TermKindCode; _formTermGrade = v.TermGrade;
        _formTermItem = v.TermItem; _formTermItemId = v.TermItemId;
        _formTermBatch = v.TermBatch; _formTermBatchId = v.TermBatchId;
        _formTermJob = v.TermJob; _formTermWorkorder = v.TermWorkorder; _formTermWorkflow = v.TermWorkflow;
        _formTermProcess = v.TermProcess; _formTermStep = v.TermStep;
        _showForm = true;
    }

    private void CloseForm() { _showForm = false; }

    private async Task Save()
    {
        _saving = true;
        try
        {
            if (_editId.HasValue)
                await Api.UpdateVocabularyAsync(_editId.Value, new DomainVocabularyUpdateDto(
                    _formName, _formTermKind, _formTermKindCode, _formTermGrade,
                    _formTermItem, _formTermItemId, _formTermBatch, _formTermBatchId,
                    _formTermJob, _formTermWorkflow, _formTermProcess, _formTermStep, _formTermWorkorder));
            else
                await Api.CreateVocabularyAsync(new DomainVocabularyCreateDto(
                    _formName, _formTermKind, _formTermKindCode, _formTermGrade,
                    _formTermItem, _formTermItemId, _formTermBatch, _formTermBatchId,
                    _formTermJob, _formTermWorkflow, _formTermProcess, _formTermStep, _formTermWorkorder));
            _showForm = false;
            await LoadData();
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
        finally { _saving = false; }
    }

    private async Task ToggleActive(DomainVocabularyResponseDto v)
    {
        try
        {
            if (v.IsActive)
            {
                await Api.DeactivateVocabularyAsync(v.Id);
                Vocab.SetVocabulary(null);
            }
            else
            {
                var activated = await Api.ActivateVocabularyAsync(v.Id);
                Vocab.SetVocabulary(activated);
            }
            await LoadData();
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

    private async Task Delete(Guid id)
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Delete this vocabulary entry?")) return;
        try { await Api.DeleteVocabularyAsync(id); await LoadData(); }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }
}
