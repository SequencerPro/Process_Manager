    private void FilterProcesses()
    {
        if (_allProcesses is null) { _filteredProcesses = null; return; }

        var search = _pickerSearch.Trim().ToLowerInvariant();
        _filteredProcesses = string.IsNullOrEmpty(search)
            ? _allProcesses
            : _allProcesses.Where(p =>
                p.Name.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                p.Code.Contains(search, StringComparison.OrdinalIgnoreCase)).ToList();
    }

    private async Task AddProcessToCanvas(ProcessSummaryResponseDto process)
    {
        // Calculate position for the new node (grid offset by count)
        int count = _diagram.Nodes.Count;
        double x = 80 + (count % 3) * 280;
        double y = 80 + (count / 3) * 200;

        try
        {
            var dto = new AddWorkflowProcessDto(process.Id, false, count, x, y);
            var result = await Api.AddWorkflowProcessAsync(Id, dto);
            if (result is not null)
            {
                var node = new WorkflowProcessNodeModel(new Point(x, y))
                {
                    WorkflowProcessId = result.Id,
                    ProcessId = result.ProcessId,
                    ProcessName = result.ProcessName,
                    ProcessCode = result.ProcessCode,
                    IsEntryPoint = result.IsEntryPoint,
                    SortOrder = result.SortOrder,
                    Color = result.Color
                };

                node.AddPort(PortAlignment.Top);
                node.AddPort(PortAlignment.Bottom);
                node.AddPort(PortAlignment.Left);
                node.AddPort(PortAlignment.Right);

                _diagram.Nodes.Add(node);
                _nodeMap[result.Id] = node;
                Toast.ShowSuccess($"Added '{process.Name}' to workflow.");
            }
        }
        catch (HttpRequestException ex)
        {
            Toast.ShowError(ex.Message);
        }
    }

