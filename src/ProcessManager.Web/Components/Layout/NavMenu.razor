@rendermode InteractiveServer
@inject TokenService TokenService
@inject AuthenticationStateProvider AuthState
@inject ApiClient Api
@inject NavigationManager Nav
@inject VocabularyService Vocab
@inject FeatureFlagService Flags
@implements IDisposable
@using System.Security.Claims

<header class="mobile-topbar d-flex d-lg-none align-items-center">
    <button class="btn btn-sm btn-outline-light border-0" @onclick="ToggleOpen" aria-label="Open menu">
        <i class="bi bi-list fs-5"></i>
    </button>
    <span class="ms-2 fw-semibold text-white small">Process Manager</span>
</header>

@if (_isOpen)
{
    <div class="sidebar-backdrop d-lg-none" @onclick="CloseNav"></div>
}

<nav class="d-flex flex-column flex-shrink-0 p-3 pm-sidebar @(_isOpen ? "sidebar-open" : "") @(_openSection is not null ? "pm-drilled" : "")" style="overflow: hidden; background: #141414; color: #c0c0c0;">
    <a href="/" class="pm-sidebar-brand d-flex align-items-center mb-3 text-decoration-none">
        <i class="bi bi-gear-wide-connected me-2 fs-4"></i>
        <span class="fs-5 fw-semibold">Process Manager</span>
    </a>
    <hr />
    <ul class="nav nav-pills flex-column mb-auto" style="overflow-y: auto; flex: 1 1 0; min-height: 0;">
        @if (_openSection is not null)
        {
            <li class="nav-item pm-nav-back">
                <button type="button" class="nav-link text-white w-100 text-start d-flex align-items-center"
                        @onclick="() => _openSection = null">
                    <i class="bi bi-arrow-left me-2"></i>
                    <span class="fw-semibold">@SectionLabel(_openSection)</span>
                </button>
            </li>
            <li><hr class="my-1" style="border-color:#262626;opacity:1"/></li>
        }
        <li class="nav-item pm-nav-root-item">
            <NavLink class="nav-link text-white" href="" Match="NavLinkMatch.All">
                <i class="bi bi-house-door me-2"></i> Home
            </NavLink>
        </li>
        <li class="nav-item pm-nav-root-item">
            <NavLink class="nav-link text-white" href="dashboard">
                <i class="bi bi-speedometer2 me-2"></i> Dashboard
            </NavLink>
        </li>
        <li class="nav-item pm-nav-root-item">
            <NavLink class="nav-link text-white" href="my-work">
                <i class="bi bi-person-workspace me-2"></i> My Work
            </NavLink>
        </li>
        <AuthorizeView Roles="Admin,Engineer">
            <Authorized>
                <li class="nav-item pm-nav-root-item">
                    <NavLink class="nav-link text-white d-flex align-items-center justify-content-between" href="alerts">
                        <span><i class="bi bi-bell me-2"></i> Alerts</span>
                        @if (_alertCount > 0)
                        {
                            <span class="badge bg-danger rounded-pill" style="font-size:.68rem">@(_alertCount > 99 ? "99+" : _alertCount.ToString())</span>
                        }
                    </NavLink>
                </li>
                <li class="nav-item pm-nav-root-item">
                    <NavLink class="nav-link text-white" href="analytics">
                        <i class="bi bi-graph-up-arrow me-2"></i> Analytics
                    </NavLink>
                </li>

                @* ── Design ── *@
                <li class="mt-2 pm-nav-root-item">
                    <button type="button"
                            class="nav-section-toggle d-flex justify-content-between align-items-center w-100 text-start"
                            @onclick='() => ToggleSection("design")'>
                        <span>Design</span>
                        <span class="d-flex align-items-center gap-2">
                            @if (_pendingCount > 0 && _openSection != "design")
                            {
                                <span class="badge bg-warning text-dark rounded-pill" style="font-size:.6rem" title="Pending approvals">@(_pendingCount > 99 ? "99+" : _pendingCount.ToString())</span>
                            }
                            <i class='bi @(_openSection == "design" ? "bi-chevron-down" : "bi-chevron-right")' style="font-size:.65rem"></i>
                        </span>
                    </button>
                </li>
                @if (_openSection == "design")
                {
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="kinds">
                            <i class="bi bi-box me-2"></i> @Vocab.KindsAndGrades
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="step-templates">
                            <i class="bi bi-puzzle me-2"></i> @Vocab.StepTemplates
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="processes">
                            <i class="bi bi-diagram-3 me-2"></i> @Vocab.Processes
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4 d-flex align-items-center justify-content-between" href="approval-queue">
                            <span><i class="bi bi-clipboard2-check me-2"></i> Approval Queue</span>
                            @if (_pendingCount > 0)
                            {
                                <span class="badge bg-warning text-dark rounded-pill" style="font-size:.68rem">@(_pendingCount > 99 ? "99+" : _pendingCount.ToString())</span>
                            }
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="workflows">
                            <i class="bi bi-share me-2"></i> @Vocab.Workflows
                        </NavLink>
                    </li>
                }

                @* ── Execution ── *@
                <li class="mt-2 pm-nav-root-item">
                    <button type="button"
                            class="nav-section-toggle d-flex justify-content-between align-items-center w-100 text-start"
                            @onclick='() => ToggleSection("execution")'>
                        <span>Execution</span>
                        <i class='bi @(_openSection == "execution" ? "bi-chevron-down" : "bi-chevron-right")' style="font-size:.65rem"></i>
                    </button>
                </li>
                @if (_openSection == "execution")
                {
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="workorders">
                            <i class="bi bi-kanban me-2"></i> @Vocab.Workorders
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="jobs">
                            <i class="bi bi-clipboard-check me-2"></i> @Vocab.Jobs
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="items">
                            <i class="bi bi-tag me-2"></i> @Vocab.Items
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="batches">
                            <i class="bi bi-collection me-2"></i> @Vocab.Batches
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="step-executions">
                            <i class="bi bi-play-circle me-2"></i> @Vocab.StepExecutions
                        </NavLink>
                    </li>
                }

                @* ── Config ── *@
                <li class="mt-2 pm-nav-root-item">
                    <button type="button"
                            class="nav-section-toggle d-flex justify-content-between align-items-center w-100 text-start"
                            @onclick='() => ToggleSection("config")'>
                        <span>Config</span>
                        <i class='bi @(_openSection == "config" ? "bi-chevron-down" : "bi-chevron-right")' style="font-size:.65rem"></i>
                    </button>
                </li>
                @if (_openSection == "config")
                {
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="vocabulary">
                            <i class="bi bi-translate me-2"></i> Vocabulary
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="orgunits">
                            <i class="bi bi-building me-2"></i> Org Units
                        </NavLink>
                    </li>
                }

                @* ── Quality ── *@
                @if (Flags.ShowQualityTools)
                {
                <li class="mt-2 pm-nav-root-item">
                    <button type="button"
                            class="nav-section-toggle d-flex justify-content-between align-items-center w-100 text-start"
                            @onclick='() => ToggleSection("quality")'>
                        <span>Quality</span>
                        <i class='bi @(_openSection == "quality" ? "bi-chevron-down" : "bi-chevron-right")' style="font-size:.65rem"></i>
                    </button>
                </li>
                }
                @if (Flags.ShowQualityTools && _openSection == "quality")
                {
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="pfmeas">
                            <i class="bi bi-shield-exclamation me-2"></i> PFMEAs
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="ce-matrices">
                            <i class="bi bi-grid-3x3 me-2"></i> C&amp;E Matrices
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="control-plans">
                            <i class="bi bi-clipboard-check me-2"></i> Control Plans
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="non-conformances">
                            <i class="bi bi-exclamation-triangle me-2"></i> Non-Conformances
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="root-cause-library">
                            <i class="bi bi-diagram-3 me-2"></i> Root Cause Library
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="ishikawa">
                            <i class="bi bi-fish me-2"></i> Ishikawa Diagrams
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="five-whys">
                            <i class="bi bi-question-circle me-2"></i> 5 Whys
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="mrb">
                            <i class="bi bi-clipboard2-x me-2"></i> Material Review Board
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="spc">
                            <i class="bi bi-graph-up me-2"></i> SPC Charts
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="suppliers">
                            <i class="bi bi-building me-2"></i> Suppliers
                        </NavLink>
                    </li>
                }

                @* ── Document Library ── *@
                <li class="mt-2 pm-nav-root-item">
                    <button type="button"
                            class="nav-section-toggle d-flex justify-content-between align-items-center w-100 text-start"
                            @onclick='() => ToggleSection("documents")'>
                        <span>Document Library</span>
                        <i class='bi @(_openSection == "documents" ? "bi-chevron-down" : "bi-chevron-right")' style="font-size:.65rem"></i>
                    </button>
                </li>
                @if (_openSection == "documents")
                {
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="documents" Match="NavLinkMatch.All">
                            <i class="bi bi-files me-2"></i> All Documents
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="documents?type=QmsDocument">
                            <i class="bi bi-journal-text me-2"></i> QMS Documents
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="documents?type=WorkInstruction">
                            <i class="bi bi-list-check me-2"></i> Work Instructions
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="documents?type=Training">
                            <i class="bi bi-mortarboard me-2"></i> Training
                        </NavLink>
                    </li>
                }
            </Authorized>
        </AuthorizeView>

        @* ── Accountability ── *@
        <li class="mt-2 pm-nav-root-item">
            <button type="button"
                    class="nav-section-toggle d-flex justify-content-between align-items-center w-100 text-start"
                    @onclick='() => ToggleSection("accountability")'>
                <span>Accountability</span>
                @if (_overdueActionCount > 0 && _openSection != "accountability")
                {
                    <span class="badge bg-danger rounded-pill" style="font-size:.68rem">@(_overdueActionCount > 99 ? "99+" : _overdueActionCount.ToString())</span>
                }
                <i class='bi @(_openSection == "accountability" ? "bi-chevron-down" : "bi-chevron-right")' style="font-size:.65rem"></i>
            </button>
        </li>
        @if (_openSection == "accountability")
        {
            <li class="nav-item">
                <NavLink class="nav-link text-white ps-4" href="my-actions">
                    <i class="bi bi-person-check me-2"></i> My Actions
                    @if (_overdueActionCount > 0)
                    {
                        <span class="badge bg-danger rounded-pill ms-1" style="font-size:.65rem">@_overdueActionCount</span>
                    }
                </NavLink>
            </li>
            <AuthorizeView Roles="Admin,Engineer">
                <Authorized>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="team-actions">
                            <i class="bi bi-people me-2"></i> Team Actions
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="quality-scorecard">
                            <i class="bi bi-clipboard2-data me-2"></i> Quality Scorecard
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="management-reviews">
                            <i class="bi bi-journal-check me-2"></i> Management Reviews
                        </NavLink>
                    </li>
                </Authorized>
            </AuthorizeView>
        }

        @* ── Conformance ── *@
        @if (Flags.ShowQualityTools)
        {
        <AuthorizeView Roles="Admin,Engineer">
            <Authorized>
                <li class="mt-2 pm-nav-root-item">
                    <button type="button"
                            class="nav-section-toggle d-flex justify-content-between align-items-center w-100 text-start"
                            @onclick='() => ToggleSection("conformance")'>
                        <span>Conformance</span>
                        <i class='bi @(_openSection == "conformance" ? "bi-chevron-down" : "bi-chevron-right")' style="font-size:.65rem"></i>
                    </button>
                </li>
            </Authorized>
        </AuthorizeView>
        }
        @if (Flags.ShowQualityTools && _openSection == "conformance")
        {
            <AuthorizeView Roles="Admin,Engineer">
                <Authorized>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="conformance">
                            <i class="bi bi-shield-check me-2"></i> Dashboard
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="conformance/clauses">
                            <i class="bi bi-list-check me-2"></i> Clause Browser
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="audit-programs">
                            <i class="bi bi-clipboard2-check me-2"></i> Audit Programs
                        </NavLink>
                    </li>
                </Authorized>
            </AuthorizeView>
        }

        @* ── Training ── *@
        @if (Flags.ShowTrainingTools)
        {
        <li class="mt-2 pm-nav-root-item">
            <button type="button"
                    class="nav-section-toggle d-flex justify-content-between align-items-center w-100 text-start"
                    @onclick='() => ToggleSection("training")'>
                <span>Training</span>
                <i class='bi @(_openSection == "training" ? "bi-chevron-down" : "bi-chevron-right")' style="font-size:.65rem"></i>
            </button>
        </li>
        }
        @if (Flags.ShowTrainingTools && _openSection == "training")
        {
            <li class="nav-item">
                <NavLink class="nav-link text-white ps-4" href="training">
                    <i class="bi bi-mortarboard me-2"></i> Training Catalogue
                </NavLink>
            </li>
            <AuthorizeView Roles="Admin,Engineer">
                <Authorized>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="competency-matrix">
                            <i class="bi bi-table me-2"></i> Competency Matrix
                        </NavLink>
                    </li>
                </Authorized>
            </AuthorizeView>
        }

        <AuthorizeView Roles="Admin,Engineer">
            <Authorized>
                @* ── Production ── *@
                @if (Flags.ShowProductionTools)
                {
                <li class="mt-2 pm-nav-root-item">
                    <button type="button"
                            class="nav-section-toggle d-flex justify-content-between align-items-center w-100 text-start"
                            @onclick='() => ToggleSection("production")'>
                        <span>Production</span>
                        @if (_overdueCount > 0 && _openSection != "production")
                        {
                            <span class="badge bg-warning text-dark ms-1" style="font-size:.65rem">@_overdueCount</span>
                        }
                        <i class='bi @(_openSection == "production" ? "bi-chevron-down" : "bi-chevron-right")' style="font-size:.65rem"></i>
                    </button>
                </li>
                }
                @if (Flags.ShowProductionTools && _openSection == "production")
                {
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="production">
                            <i class="bi bi-speedometer me-2"></i> Production Dashboard
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="equipment">
                            <i class="bi bi-gear-wide me-2"></i> Equipment
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="maintenance">
                            <i class="bi bi-tools me-2"></i> Maintenance Tasks
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="factory-design">
                            <i class="bi bi-bounding-box me-2"></i> Factory Design
                        </NavLink>
                    </li>
                }

                @* ── Warehouse ── *@
                @if (Flags.ShowWarehouseTools)
                {
                <li class="mt-2 pm-nav-root-item">
                    <button type="button"
                            class="nav-section-toggle d-flex justify-content-between align-items-center w-100 text-start"
                            @onclick='() => ToggleSection("warehouse")'>
                        <span>Warehouse</span>
                        <i class='bi @(_openSection == "warehouse" ? "bi-chevron-down" : "bi-chevron-right")' style="font-size:.65rem"></i>
                    </button>
                </li>
                }
                @if (Flags.ShowWarehouseTools && _openSection == "warehouse")
                {
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="warehouse" Match="NavLinkMatch.All">
                            <i class="bi bi-box-seam me-2"></i> Dashboard
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="warehouse/locations">
                            <i class="bi bi-geo-alt me-2"></i> Locations
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="picklists">
                            <i class="bi bi-card-checklist me-2"></i> Pick Lists
                        </NavLink>
                    </li>
                }

                @* ── Reports ── *@
                @if (Flags.ShowAdvancedModules)
                {
                <li class="mt-2 pm-nav-root-item">
                    <button type="button"
                            class="nav-section-toggle d-flex justify-content-between align-items-center w-100 text-start"
                            @onclick='() => ToggleSection("reports")'>
                        <span>Reports</span>
                        <i class='bi @(_openSection == "reports" ? "bi-chevron-down" : "bi-chevron-right")' style="font-size:.65rem"></i>
                    </button>
                </li>
                }
                @if (Flags.ShowAdvancedModules && _openSection == "reports")
                {
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="reports">
                            <i class="bi bi-bar-chart-line me-2"></i> Reports
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="reports/process-timing">
                            <i class="bi bi-stopwatch me-2"></i> Process Timing
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="powerbi-dashboards">
                            <i class="bi bi-bar-chart-steps me-2"></i> Power BI
                        </NavLink>
                    </li>
                }
            </Authorized>
        </AuthorizeView>

        @* ── Admin (role-gated) ── *@
        <AuthorizeView Roles="Admin">
            <Authorized>
                <li class="mt-2 pm-nav-root-item">
                    <button type="button"
                            class="nav-section-toggle d-flex justify-content-between align-items-center w-100 text-start"
                            @onclick='() => ToggleSection("admin")'>
                        <span>Admin</span>
                        <i class='bi @(_openSection == "admin" ? "bi-chevron-down" : "bi-chevron-right")' style="font-size:.65rem"></i>
                    </button>
                </li>
                @if (_openSection == "admin")
                {
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="admin/users">
                            <i class="bi bi-people me-2"></i> Users
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="settings/modules">
                            <i class="bi bi-sliders2 me-2"></i> Modules
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="ai-audit">
                            <i class="bi bi-robot me-2"></i> AI Audit Log
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="admin/workstations">
                            <i class="bi bi-pc-display me-2"></i> Workstations
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="webhooks">
                            <i class="bi bi-broadcast me-2"></i> Webhooks
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="settings/billing">
                            <i class="bi bi-credit-card me-2"></i> Billing
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link text-white ps-4" href="settings/branding">
                            <i class="bi bi-palette me-2"></i> Branding
                        </NavLink>
                    </li>
                }
            </Authorized>
        </AuthorizeView>

    </ul>

    <hr class="mt-auto" />
    <div class="d-flex align-items-center text-white-50 small">
        <i class="bi bi-person-circle me-2 fs-5 text-white"></i>
        <div class="flex-grow-1 overflow-hidden">
            <div class="text-white fw-medium text-truncate">@(_displayName)</div>
            <div class="text-white-50 small text-truncate">@(_role)</div>
        </div>
        <a href="/account/profile" class="btn btn-sm btn-outline-light ms-1" title="Edit profile">
            <i class="bi bi-person-gear"></i>
        </a>
        <a href="/account/change-password" class="btn btn-sm btn-outline-light ms-1" title="Change password">
            <i class="bi bi-key"></i>
        </a>
        <a href="/account/logout" class="btn btn-sm btn-outline-light ms-1" title="Sign out">
            <i class="bi bi-box-arrow-right"></i>
        </a>
    </div>
</nav>

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private bool _isOpen;

    private void ToggleOpen() => _isOpen = !_isOpen;
    private void CloseNav() => _isOpen = false;

    private string? _displayName;
    private string? _role;
    private int _alertCount;
    private int _pendingCount;
    private int _overdueActionCount;
    private int _overdueCount;
    private string? _openSection;

    private static readonly Dictionary<string, string[]> _sectionPaths = new()
    {
        ["design"]    = ["kinds", "step-templates", "processes", "approval-queue", "workflows"],
        ["execution"] = ["workorders", "jobs", "items", "batches", "step-executions"],
        ["config"]    = ["vocabulary", "orgunits"],
        ["quality"]   = ["pfmeas", "ce-matrices", "control-plans", "non-conformances", "root-cause-library", "ishikawa", "five-whys", "mrb", "spc", "suppliers"],
        ["documents"]  = ["documents"],
        ["accountability"] = ["my-actions", "team-actions", "quality-scorecard", "management-reviews"],
        ["conformance"] = ["conformance", "conformance/clauses", "audit-programs"],
        ["production"] = ["production", "equipment", "maintenance", "factory-design"],
        ["warehouse"]  = ["warehouse", "picklists"],
        ["admin"]     = ["admin", "ai-audit", "webhooks", "settings/modules", "settings/billing", "settings/branding", "admin/workstations"],
        ["reports"]   = ["reports", "reports/process-timing", "powerbi-dashboards"],
    };

    protected override void OnInitialized()
    {
        _openSection = GetSectionForUrl(Nav.Uri);
        Nav.LocationChanged += OnLocationChanged;
        Vocab.OnChange += OnVocabChanged;
        Flags.OnChange += OnVocabChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        var user  = state.User;
        _displayName = user.FindFirst("display_name")?.Value
                       ?? user.Identity?.Name;
        _role        = user.FindFirst(ClaimTypes.Role)?.Value;

        if (_role is "Admin" or "Engineer")
        {
            try
            {
                var result = await Api.GetOutOfRangeAlertCountAsync(days: 7);
                _alertCount = result?.Count ?? 0;
            }
            catch { /* badge is best-effort — never break the nav */ }

            try
            {
                var pending = await Api.GetApprovalRecordsAsync(decision: "Pending", pageSize: 1);
                _pendingCount = pending?.TotalCount ?? 0;
            }
            catch { /* badge is best-effort */ }

            try
            {
                var overdueMaint = await Api.GetAllMaintenanceTasksAsync(status: "Overdue", pageSize: 1);
                _overdueCount = (overdueMaint?.TotalCount ?? 0);
                var dueMaint = await Api.GetAllMaintenanceTasksAsync(status: "Due", pageSize: 1);
                _overdueCount += (dueMaint?.TotalCount ?? 0);
            }
            catch { /* badge is best-effort */ }
        }

        try
        {
            var overdue = await Api.GetActionItemsAsync(assignedToMe: true, overdue: true, pageSize: 1);
            _overdueActionCount = overdue?.TotalCount ?? 0;
        }
        catch { /* badge is best-effort */ }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        var section = GetSectionForUrl(e.Location);
        _isOpen = false;
        if (section is not null && section != _openSection)
        {
            _openSection = section;
        }
        InvokeAsync(StateHasChanged);
    }

    private void ToggleSection(string key) =>
        _openSection = _openSection == key ? null : key;

    private static string SectionLabel(string? key) => key switch
    {
        "design"         => "Design",
        "execution"      => "Execution",
        "config"         => "Config",
        "quality"        => "Quality",
        "documents"      => "Document Library",
        "accountability" => "Accountability",
        "training"       => "Training",
        "production"     => "Production",
        "warehouse"      => "Warehouse",
        "reports"        => "Reports",
        "admin"          => "Admin",
        _                => ""
    };

    private static string? GetSectionForUrl(string url)
    {
        var path = new Uri(url).AbsolutePath.TrimStart('/').ToLowerInvariant();
        foreach (var (section, prefixes) in _sectionPaths)
            if (prefixes.Any(p => path == p || path.StartsWith(p + "/")))
                return section;
        return null;
    }

    private void OnVocabChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
        Vocab.OnChange -= OnVocabChanged;
        Flags.OnChange -= OnVocabChanged;
    }
}
