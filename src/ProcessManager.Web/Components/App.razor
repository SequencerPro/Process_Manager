<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="_content/Z.Blazor.Diagrams/style.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="ProcessManager.Web.styles.css" />
    <HeadOutlet />
</head>

<body>
    <Routes />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="_content/Z.Blazor.Diagrams/script.min.js"></script>

    <!-- Three.js for 3D model viewer -->
    <script type="importmap">
    {
        "imports": {
            "three": "https://cdn.jsdelivr.net/npm/three@0.170.0/build/three.module.js",
            "three/addons/": "https://cdn.jsdelivr.net/npm/three@0.170.0/examples/jsm/"
        }
    }
    </script>
    <!-- OpenCascade WASM for STEP/IGES parsing (lazy-loaded by model-viewer.js) -->
    <script src="https://cdn.jsdelivr.net/npm/occt-import-js@0.0.23/dist/occt-import-js.js" defer></script>
    <script type="module" src="js/model-viewer.js?v=10"></script>

    <!-- Helper: wait for the ES module to finish loading before Blazor calls it -->
    <script>
        window.waitForModelViewer = function (timeoutMs) {
            return new Promise(function (resolve, reject) {
                if (window.ModelViewer) { resolve(); return; }
                var start = Date.now();
                var check = setInterval(function () {
                    if (window.ModelViewer) { clearInterval(check); resolve(); }
                    else if (Date.now() - start > timeoutMs) {
                        clearInterval(check);
                        reject('ModelViewer module did not load within ' + timeoutMs + 'ms');
                    }
                }, 100);
            });
        };
    </script>

    <!-- Operator execution: offline sync, barcode, photo, signature -->
    <script src="js/operator-sync.js?v=1"></script>
    <script src="js/barcode-scanner.js?v=1"></script>
    <script src="js/photo-capture.js?v=1"></script>
    <script src="js/signature-pad.js?v=1"></script>

    <!-- Service worker registration -->
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.register('/operator-sw.js').catch(function () { });
        }
    </script>

    <script src="_framework/blazor.web.js" defer></script>
</body>

</html>
