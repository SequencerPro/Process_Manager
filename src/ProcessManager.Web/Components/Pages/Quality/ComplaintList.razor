@page "/complaints"
@attribute [Authorize(Roles = "Admin,Engineer")]
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Authorization
@using ProcessManager.Api.DTOs
@inject ApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Customer Complaints — Process Manager</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4 page-heading-row">
    <div>
        <h3 class="mb-0"><i class="bi bi-chat-left-dots me-2 text-primary"></i>Customer Complaints</h3>
        <p class="text-muted small mb-0 d-none d-md-block">Track, investigate, and resolve customer complaints</p>
    </div>
    <button class="btn btn-primary" @onclick="OpenCreateModal">
        <i class="bi bi-plus-lg me-1"></i> New Complaint
    </button>
</div>

@* ── KPI cards ── *@
@if (_dashboard is not null)
{
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="card shadow-sm text-center p-3">
                <div class="fs-3 fw-bold text-primary">@_dashboard.TotalOpen</div>
                <div class="small text-muted">Open</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm text-center p-3">
                <div class="fs-3 fw-bold text-danger">@_dashboard.TotalOverdue</div>
                <div class="small text-muted">Overdue</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm text-center p-3">
                <div class="fs-3 fw-bold text-info">@_dashboard.AvgDaysToClose d</div>
                <div class="small text-muted">Avg Days to Close</div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card shadow-sm text-center p-3">
                <div class="fs-3 fw-bold text-success">@(_dashboard.CustomerSatisfactionRate.ToString("F0"))%</div>
                <div class="small text-muted">Satisfaction Rate</div>
            </div>
        </div>
    </div>
}

@* ── Filters ── *@
<div class="row g-2 mb-3">
    <div class="col-md-3">
        <div class="input-group input-group-sm">
            <span class="input-group-text"><i class="bi bi-search"></i></span>
            <input type="text" class="form-control" placeholder="Search by code, customer, description…"
                   @bind="_search" @bind:event="oninput" @onkeyup="OnSearchKeyUp" />
        </div>
    </div>
    <div class="col-md-2">
        <select class="form-select form-select-sm" @bind="_statusFilter" @bind:after="LoadData">
            <option value="">All statuses</option>
            <option value="New">New</option>
            <option value="UnderInvestigation">Under Investigation</option>
            <option value="ContainmentInPlace">Containment In Place</option>
            <option value="RootCauseIdentified">Root Cause Identified</option>
            <option value="CorrectiveActionImplemented">Corrective Action</option>
            <option value="ResponseSent">Response Sent</option>
            <option value="Closed">Closed</option>
        </select>
    </div>
    <div class="col-md-2">
        <select class="form-select form-select-sm" @bind="_categoryFilter" @bind:after="LoadData">
            <option value="">All categories</option>
            <option value="ProductDefect">Product Defect</option>
            <option value="Packaging">Packaging</option>
            <option value="Delivery">Delivery</option>
            <option value="Documentation">Documentation</option>
            <option value="Service">Service</option>
            <option value="Regulatory">Regulatory</option>
        </select>
    </div>
    <div class="col-md-2">
        <select class="form-select form-select-sm" @bind="_severityFilter" @bind:after="LoadData">
            <option value="">All severities</option>
            <option value="Cosmetic">Cosmetic</option>
            <option value="Minor">Minor</option>
            <option value="Major">Major</option>
            <option value="Critical">Critical</option>
        </select>
    </div>
</div>

@* ── Table ── *@
<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Code</th>
                    <th>Customer</th>
                    <th class="col-hide-mobile">Description</th>
                    <th class="text-center">Category</th>
                    <th class="text-center">Severity</th>
                    <th class="text-center">Status</th>
                    <th class="col-hide-mobile">Owner</th>
                    <th class="text-end" style="width:140px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (_loading)
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">
                        <div class="spinner-border spinner-border-sm me-2"></div>Loading…
                    </td></tr>
                }
                else if (_result is null || !_result.Items.Any())
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">No complaints found.</td></tr>
                }
                else
                {
                    @foreach (var cc in _result.Items)
                    {
                        <tr>
                            <td class="align-middle"><code>@cc.Code</code></td>
                            <td class="align-middle">@cc.CustomerName</td>
                            <td class="align-middle col-hide-mobile">
                                <span class="d-inline-block text-truncate" style="max-width: 250px;">
                                    @cc.Description
                                </span>
                            </td>
                            <td class="align-middle text-center">
                                <span class="badge bg-outline-secondary">@FormatCategory(cc.Category)</span>
                            </td>
                            <td class="align-middle text-center">
                                <span class="badge @SeverityBadge(cc.Severity)">@cc.Severity</span>
                            </td>
                            <td class="align-middle text-center">
                                <span class="badge @ComplaintStatusBadge(cc.Status)">@FormatStatus(cc.Status)</span>
                            </td>
                            <td class="align-middle col-hide-mobile small">@cc.OwnerDisplayName</td>
                            <td class="align-middle text-end">
                                @if (cc.Status == "New")
                                {
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteComplaint(cc)" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@* ── Pager ── *@
@if (_result is not null && _result.TotalPages > 1)
{
    <nav class="mt-3 d-flex justify-content-center">
        <ul class="pagination pagination-sm">
            <li class="page-item @(!_result.HasPreviousPage ? "disabled" : "")">
                <button class="page-link" @onclick="() => GoToPage(_page - 1)">&laquo;</button>
            </li>
            @for (var p = 1; p <= _result.TotalPages; p++)
            {
                var pg = p;
                <li class="page-item @(pg == _page ? "active" : "")">
                    <button class="page-link" @onclick="() => GoToPage(pg)">@pg</button>
                </li>
            }
            <li class="page-item @(!_result.HasNextPage ? "disabled" : "")">
                <button class="page-link" @onclick="() => GoToPage(_page + 1)">&raquo;</button>
            </li>
        </ul>
    </nav>
}

@* ── Create modal ── *@
@if (_showCreateModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">New Customer Complaint</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(_error))
                    {
                        <div class="alert alert-danger py-2 small">@_error</div>
                    }
                    <div class="row g-2">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Customer Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="_createCustomerName" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Customer Reference</label>
                            <input type="text" class="form-control" @bind="_createCustomerRef" placeholder="Customer's own reference #" />
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description <span class="text-danger">*</span></label>
                        <textarea class="form-control" rows="3" @bind="_createDescription"
                                  placeholder="Describe the complaint…"></textarea>
                    </div>
                    <div class="row g-2">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Category <span class="text-danger">*</span></label>
                            <select class="form-select" @bind="_createCategory">
                                <option value="ProductDefect">Product Defect</option>
                                <option value="Packaging">Packaging</option>
                                <option value="Delivery">Delivery</option>
                                <option value="Documentation">Documentation</option>
                                <option value="Service">Service</option>
                                <option value="Regulatory">Regulatory</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Severity <span class="text-danger">*</span></label>
                            <select class="form-select" @bind="_createSeverity">
                                <option value="Cosmetic">Cosmetic</option>
                                <option value="Minor">Minor</option>
                                <option value="Major">Major</option>
                                <option value="Critical">Critical</option>
                            </select>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Qty Affected</label>
                            <input type="number" class="form-control" @bind="_createQty" min="0" />
                        </div>
                    </div>
                    <div class="row g-2">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Lot Number</label>
                            <input type="text" class="form-control" @bind="_createLotNumber" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Response Due Date</label>
                            <input type="date" class="form-control" @bind="_createResponseDue" />
                        </div>
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Complaint Date</label>
                            <input type="date" class="form-control" @bind="_createComplaintDate" />
                        </div>
                    </div>
                    <div class="row g-2">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Owner Name <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="_createOwnerName" placeholder="Display name" />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Owner User ID <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" @bind="_createOwnerUserId" placeholder="User ID" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button class="btn btn-primary" @onclick="SubmitCreate" disabled="@_saving">
                        @if (_saving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Create
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PaginatedResponse<CustomerComplaintSummaryDto>? _result;
    private ComplaintDashboardDto? _dashboard;
    private bool _loading = true;
    private string _search = "";
    private string _statusFilter = "";
    private string _categoryFilter = "";
    private string _severityFilter = "";
    private int _page = 1;

    // Create modal
    private bool _showCreateModal;
    private bool _saving;
    private string? _error;
    private string _createCustomerName = "";
    private string? _createCustomerRef;
    private string _createDescription = "";
    private string _createCategory = "ProductDefect";
    private string _createSeverity = "Minor";
    private int _createQty;
    private string? _createLotNumber;
    private DateTime? _createResponseDue;
    private DateTime? _createComplaintDate;
    private string _createOwnerName = "";
    private string _createOwnerUserId = "";

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        StateHasChanged();

        try
        {
            var searchParam = string.IsNullOrWhiteSpace(_search) ? null : _search;
            var statusParam = string.IsNullOrEmpty(_statusFilter) ? null : _statusFilter;
            var categoryParam = string.IsNullOrEmpty(_categoryFilter) ? null : _categoryFilter;
            var severityParam = string.IsNullOrEmpty(_severityFilter) ? null : _severityFilter;

            _result = await Api.GetComplaintsAsync(searchParam, statusParam, categoryParam, severityParam, _page);
            _dashboard = await Api.GetComplaintDashboardAsync();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs e) { if (e.Key == "Enter") { _page = 1; await LoadData(); } }
    private async Task GoToPage(int p) { _page = p; await LoadData(); }

    private void OpenCreateModal()
    {
        _showCreateModal = true;
        _error = null;
        _createCustomerName = "";
        _createCustomerRef = null;
        _createDescription = "";
        _createCategory = "ProductDefect";
        _createSeverity = "Minor";
        _createQty = 0;
        _createLotNumber = null;
        _createResponseDue = null;
        _createComplaintDate = null;
        _createOwnerName = "";
        _createOwnerUserId = "";
    }

    private void CloseModal() => _showCreateModal = false;

    private async Task SubmitCreate()
    {
        if (string.IsNullOrWhiteSpace(_createCustomerName) || string.IsNullOrWhiteSpace(_createDescription)
            || string.IsNullOrWhiteSpace(_createOwnerUserId) || string.IsNullOrWhiteSpace(_createOwnerName))
        {
            _error = "Customer name, description, owner name, and owner user ID are required.";
            return;
        }

        _saving = true;
        _error = null;

        try
        {
            var dto = new CreateCustomerComplaintDto
            {
                CustomerName = _createCustomerName,
                CustomerReference = _createCustomerRef,
                Description = _createDescription,
                Category = _createCategory,
                Severity = _createSeverity,
                QuantityAffected = _createQty,
                LotNumber = _createLotNumber,
                ComplaintDate = _createComplaintDate,
                ResponseDueDate = _createResponseDue,
                OwnerUserId = _createOwnerUserId,
                OwnerDisplayName = _createOwnerName
            };
            await Api.CreateComplaintAsync(dto);
            _showCreateModal = false;
            await LoadData();
        }
        catch (HttpRequestException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task DeleteComplaint(CustomerComplaintSummaryDto cc)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Delete complaint '{cc.Code}'?"))
            return;
        try
        {
            await Api.DeleteComplaintAsync(cc.Id);
            await LoadData();
        }
        catch (HttpRequestException ex)
        {
            await JS.InvokeVoidAsync("alert", $"Delete failed: {ex.Message}");
        }
    }

    private static string ComplaintStatusBadge(string status) => status switch
    {
        "New" => "bg-info text-dark",
        "UnderInvestigation" => "bg-warning text-dark",
        "ContainmentInPlace" => "bg-orange text-dark",
        "RootCauseIdentified" => "bg-primary",
        "CorrectiveActionImplemented" => "bg-purple",
        "ResponseSent" => "bg-secondary",
        "Closed" => "bg-success",
        _ => "bg-secondary"
    };

    private static string SeverityBadge(string severity) => severity switch
    {
        "Critical" => "bg-danger",
        "Major" => "bg-warning text-dark",
        "Minor" => "bg-info text-dark",
        "Cosmetic" => "bg-secondary",
        _ => "bg-secondary"
    };

    private static string FormatStatus(string status) => status switch
    {
        "UnderInvestigation" => "Investigating",
        "ContainmentInPlace" => "Containment",
        "RootCauseIdentified" => "Root Cause",
        "CorrectiveActionImplemented" => "Corrective Action",
        "ResponseSent" => "Response Sent",
        _ => status
    };

    private static string FormatCategory(string category) => category switch
    {
        "ProductDefect" => "Product Defect",
        _ => category
    };
}
