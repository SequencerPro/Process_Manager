    private async Task ShowBomForm()
    {
        _editingBomLineId = null;
        _selectedComponentKind = null;
        _componentPickerSearch = "";
        // Auto-increment line number
        var nextLine = (_kind?.BomLines?.Any() == true)
            ? _kind.BomLines.Max(b => b.LineNumber) + 1
            : 1;
        _bomForm = new() { LineNumber = nextLine, Quantity = 1 };
        // Load available kinds for the picker
        await LoadAvailableKinds();
        _showBomForm = true;
    }

    private async Task ShowEditBomLine(BomLineResponseDto line)
    {
        _editingBomLineId = line.Id;
        _selectedComponentKind = new KindResponseDto(
            line.ComponentKindId, line.ComponentCode, line.ComponentName, null,
            false, false, "", line.ComponentUnitOfMeasure, line.ComponentCost, null,
            null, null, null, null, null, null, null, null, null, null, null,
            null, null, null, DateTime.MinValue, DateTime.MinValue,
            new List<GradeResponseDto>(), new List<KindDocumentResponseDto>(), new List<BomLineResponseDto>());
        _bomForm = new()
        {
            LineNumber = line.LineNumber,
            Quantity = line.Quantity,
            UnitOfMeasure = line.UnitOfMeasure ?? "",
            Notes = line.Notes ?? ""
        };
        await LoadAvailableKinds();
        _showBomForm = true;
    }

    private void CloseBomForm() { _showBomForm = false; _showComponentPicker = false; }

    private void SelectComponent(KindResponseDto kind)
    {
        _selectedComponentKind = kind;
        _showComponentPicker = false;
    }

    private async Task LoadAvailableKinds()
    {
        try
        {
            var result = await Api.GetKindsAsync(pageSize: 10000);
            _availableKinds = result?.Items ?? Enumerable.Empty<KindResponseDto>();
        }
        catch { _availableKinds = Enumerable.Empty<KindResponseDto>(); }
    }

    private async Task SaveBomLine()
    {
        try
        {
            if (_editingBomLineId.HasValue)
            {
                await Api.UpdateBomLineAsync(Id, _editingBomLineId.Value,
                    new BomLineUpdateDto(
                        _bomForm.LineNumber,
                        _bomForm.Quantity,
                        string.IsNullOrWhiteSpace(_bomForm.UnitOfMeasure) ? null : _bomForm.UnitOfMeasure,
                        string.IsNullOrWhiteSpace(_bomForm.Notes) ? null : _bomForm.Notes,
                        _bomForm.SortOrder));
            }
            else
            {
                if (_selectedComponentKind is null) return;
                await Api.CreateBomLineAsync(Id,
                    new BomLineCreateDto(
                        _selectedComponentKind.Id,
                        _bomForm.LineNumber,
                        _bomForm.Quantity,
                        string.IsNullOrWhiteSpace(_bomForm.UnitOfMeasure) ? null : _bomForm.UnitOfMeasure,
                        string.IsNullOrWhiteSpace(_bomForm.Notes) ? null : _bomForm.Notes,
                        _bomForm.SortOrder));
            }

            _showBomForm = false;
            _showComponentPicker = false;
            await LoadData();
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

    private async Task DeleteBomLine(BomLineResponseDto line)
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Remove component '{line.ComponentCode}' from BoM?")) return;
        try
        {
            await Api.DeleteBomLineAsync(Id, line.Id);
            await LoadData();
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

