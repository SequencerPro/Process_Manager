@page "/processes/builder"
@page "/processes/{Id:guid}/builder"
@rendermode InteractiveServer
@inject ApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>@(_name.Length > 0 ? $"Builder – {_name}" : "New Process")</PageTitle>

@* ── Top bar ── *@
<div class="d-flex justify-content-between align-items-center mb-3">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="processes">Processes</a></li>
            <li class="breadcrumb-item active">@(Id.HasValue ? "Process Builder" : "New Process")</li>
        </ol>
    </nav>
    <div class="d-flex gap-2">
        @if (Id.HasValue)
        {
            <button class="btn btn-outline-info btn-sm" @onclick="RunValidation">
                <i class="bi bi-check2-all me-1"></i>Validate
            </button>
        }
        <button class="btn btn-primary btn-sm" @onclick="Save" disabled="@_saving">
            @if (_saving)
            {
                <span class="spinner-border spinner-border-sm me-1"></span>
            }
            else
            {
                <i class="bi bi-floppy me-1"></i>
            }
            Save
        </button>
        <a href="@(Id.HasValue ? $"processes/{Id}" : "processes")" class="btn btn-outline-secondary btn-sm">
            Cancel
        </a>
    </div>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else
{
    @* ── Error banner ── *@
    @if (_error is not null)
    {
        <div class="alert alert-danger alert-dismissible py-2 mb-3">
            <i class="bi bi-exclamation-triangle-fill me-1"></i>@_error
            <button type="button" class="btn-close" @onclick="() => _error = null"></button>
        </div>
    }

    @* ── Validation results ── *@
    @if (_validation is not null)
    {
        <div class="alert @(_validation.Errors.Any() ? "alert-danger" : _validation.Warnings.Any() ? "alert-warning" : "alert-success") alert-dismissible py-2 mb-3">
            @if (!_validation.Errors.Any() && !_validation.Warnings.Any())
            {
                <span><i class="bi bi-check-circle me-1"></i> Valid — no errors or warnings.</span>
            }
            @foreach (var e in _validation.Errors)
            {
                <div><i class="bi bi-x-circle text-danger me-1"></i>@e</div>
            }
            @foreach (var w in _validation.Warnings)
            {
                <div><i class="bi bi-exclamation-triangle text-warning me-1"></i>@w</div>
            }
            <button type="button" class="btn-close" @onclick="() => _validation = null"></button>
        </div>
    }

    @* ── Process metadata ── *@
    <div class="card mb-4">
        <div class="card-header py-2">
            <strong><i class="bi bi-info-circle me-1"></i>Process Details</strong>
        </div>
        <div class="card-body py-3">
            <div class="row g-3">
                <div class="col-md-3">
                    <label class="form-label fw-semibold">Code <span class="text-danger">*</span></label>
                    <input class="form-control" placeholder="e.g. WDG-FINISH-01" @bind="_code" disabled="@Id.HasValue" />
                    @if (Id.HasValue)
                    {
                        <div class="form-text">Code cannot be changed after creation.</div>
                    }
                </div>
                <div class="col-md-5">
                    <label class="form-label fw-semibold">Name <span class="text-danger">*</span></label>
                    <input class="form-control" placeholder="e.g. Widget Finishing Process" @bind="_name" />
                </div>
                <div class="col-md-4">
                    <label class="form-label fw-semibold">Description</label>
                    <input class="form-control" placeholder="Optional description" @bind="_description" />
                </div>
            </div>
        </div>
    </div>

    @* ── Step canvas ── *@
    @if (_steps.Count == 0)
    {
        <div class="text-center py-5 border rounded-3 bg-light">
            <i class="bi bi-diagram-3 text-muted" style="font-size:3rem"></i>
            <p class="text-muted mt-2 mb-3">No steps yet. Add your first step to begin building the process.</p>
            <button class="btn btn-primary" @onclick="() => OpenStepPicker(0)">
                <i class="bi bi-plus-lg me-1"></i>Add First Step
            </button>
        </div>
    }
    else
    {
        @for (int i = 0; i < _steps.Count; i++)
        {
            var step = _steps[i];
            var stepIdx = i;

            @* Add step button ABOVE first step *@
            @if (i == 0)
            {
                <div class="text-center mb-2">
                    <button class="btn btn-outline-primary btn-sm" @onclick="() => OpenStepPicker(0)">
                        <i class="bi bi-plus-lg me-1"></i>Insert Step Here
                    </button>
                </div>
            }

            @* ── Step card ── *@
            <div class="card border-2 mb-0" style="border-color: #0d6efd !important;" @key="step.LocalId">
                <div class="card-header py-2 d-flex justify-content-between align-items-center" style="background:#f0f5ff">
                    <div class="d-flex align-items-center gap-2">
                        <span class="badge bg-primary rounded-pill">@(stepIdx + 1)</span>
                        @if (step.Template is not null)
                        {
                            <strong class="me-1">@(step.NameOverride ?? step.Template.Name)</strong>
                            <code class="text-muted small">@step.Template.Code</code>
                            <span class="badge bg-light text-dark border small">@step.Template.Pattern</span>
                        }
                        else
                        {
                            <span class="text-muted fst-italic small">Loading template…</span>
                        }
                    </div>
                    <div class="d-flex gap-1">
                        <button class="btn btn-outline-secondary btn-sm py-0 px-2" title="Move up"
                                disabled="@(stepIdx == 0)"
                                @onclick="() => MoveStep(stepIdx, -1)">
                            <i class="bi bi-arrow-up"></i>
                        </button>
                        <button class="btn btn-outline-secondary btn-sm py-0 px-2" title="Move down"
                                disabled="@(stepIdx == _steps.Count - 1)"
                                @onclick="() => MoveStep(stepIdx, 1)">
                            <i class="bi bi-arrow-down"></i>
                        </button>
                        <button class="btn btn-outline-secondary btn-sm py-0 px-2" title="Rename / override step name"
                                @onclick="() => ShowRenameStep(stepIdx)">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <button class="btn btn-outline-danger btn-sm py-0 px-2" title="Remove step"
                                @onclick="() => RemoveStep(stepIdx)">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </div>

                @if (step.Template is not null)
                {
                    <div class="card-body py-2">
                        <div class="row g-0">
                            <div class="col-md-6 pe-3">
                                <div class="text-uppercase text-muted fw-semibold mb-2" style="font-size:.7rem">
                                    <i class="bi bi-box-arrow-in-right text-success me-1"></i>Inputs
                                </div>
                                @{
                                    var inputs = step.Template.Ports
                                        .Where(p => p.Direction == PortDirection.Input)
                                        .OrderBy(p => p.SortOrder).ToList();
                                }
                                @if (!inputs.Any())
                                {
                                    <div class="text-muted small fst-italic">No inputs</div>
                                }
                                @foreach (var p in inputs)
                                {
                                    <div class="d-flex align-items-center gap-2 mb-1 small">
                                        <i class="bi bi-circle-fill text-success" style="font-size:.45rem;flex-shrink:0"></i>
                                        <span>
                                            <strong>@p.Name</strong>
                                            <span class="badge @PortTypeBadge(p.PortType) ms-1" style="font-size:.65rem">@p.PortType</span>
                                            <span class="text-muted ms-1">@PortInfo(p)</span>
                                        </span>
                                    </div>
                                }
                            </div>
                            <div class="col-md-6 ps-3 border-start">
                                <div class="text-uppercase text-muted fw-semibold mb-2" style="font-size:.7rem">
                                    <i class="bi bi-box-arrow-right text-primary me-1"></i>Outputs
                                </div>
                                @{
                                    var outputs = step.Template.Ports
                                        .Where(p => p.Direction == PortDirection.Output)
                                        .OrderBy(p => p.SortOrder).ToList();
                                }
                                @if (!outputs.Any())
                                {
                                    <div class="text-muted small fst-italic">No outputs</div>
                                }
                                @foreach (var p in outputs)
                                {
                                    <div class="d-flex align-items-center justify-content-end gap-2 mb-1 small">
                                        <span>
                                            <strong>@p.Name</strong>
                                            <span class="badge @PortTypeBadge(p.PortType) ms-1" style="font-size:.65rem">@p.PortType</span>
                                            <span class="text-muted ms-1">@PortInfo(p)</span>
                                        </span>
                                        <i class="bi bi-circle-fill text-primary" style="font-size:.45rem;flex-shrink:0"></i>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            @* ── Connection row between this step and the next ── *@
            @if (stepIdx < _steps.Count - 1)
            {
                var conn = GetConnection(stepIdx);
                <div class="d-flex flex-column align-items-center py-2 gap-1" @key="@($"conn-{stepIdx}")">
                    <i class="bi bi-arrow-down text-muted"></i>
                    @if (conn.Status == ConnectionStatus.AutoMatched || conn.Status == ConnectionStatus.UserSelected)
                    {
                        <span class="badge rounded-pill bg-success-subtle text-success border border-success px-3 py-1">
                            <i class="bi bi-check-circle me-1"></i>
                            @conn.SourcePort!.Name
                            <i class="bi bi-arrow-right mx-1"></i>
                            @conn.TargetPort!.Name
                            <span class="ms-1 opacity-75 small">(@PortInfo(conn.SourcePort))</span>
                        </span>
                    }
                    else if (conn.Status == ConnectionStatus.Ambiguous)
                    {
                        <div class="d-flex align-items-center gap-2">
                            <i class="bi bi-exclamation-triangle-fill text-warning"></i>
                            <span class="text-warning small">Multiple possible connections — select one:</span>
                            <select class="form-select form-select-sm" style="width:auto;min-width:280px"
                                    @onchange="e => SetConnection(stepIdx, e.Value?.ToString())">
                                <option value="">Select connection…</option>
                                @foreach (var opt in conn.Options)
                                {
                                    <option value="@($"{opt.Out.Id}|{opt.In.Id}")">
                                        @opt.Out.Name → @opt.In.Name (@PortInfo(opt.Out))
                                    </option>
                                }
                            </select>
                        </div>
                    }
                    else
                    {
                        <span class="badge rounded-pill bg-danger-subtle text-danger border border-danger px-3 py-1">
                            <i class="bi bi-x-circle me-1"></i>No compatible connection — output types don't match input types
                        </span>
                    }
                    <i class="bi bi-arrow-down text-muted"></i>
                </div>

                @* Add step between these two steps *@
                <div class="text-center mb-0">
                    <button class="btn btn-outline-primary btn-sm py-0 px-2" style="font-size:.75rem"
                            @onclick="() => OpenStepPicker(stepIdx + 1)">
                        <i class="bi bi-plus-lg me-1"></i>Insert Step Here
                    </button>
                </div>
            }
        }

        @* ── Add step at end ── *@
        <div class="text-center mt-3">
            <button class="btn btn-outline-primary" @onclick="() => OpenStepPicker(_steps.Count)">
                <i class="bi bi-plus-lg me-1"></i>Add Step
            </button>
        </div>
    }
}

@* ══════════════════════════════════════════
   Step Picker — right-side slide panel
   ══════════════════════════════════════════ *@
@if (_showPicker)
{
    <div class="position-fixed top-0 start-0 w-100 h-100" style="background:rgba(0,0,0,.35);z-index:1050"
         @onclick="ClosePicker"></div>

    <div class="position-fixed top-0 end-0 h-100 bg-white shadow-lg border-start d-flex flex-column"
         style="width:400px;z-index:1051">
        <div class="d-flex justify-content-between align-items-center p-3 border-bottom">
            <h6 class="mb-0"><i class="bi bi-box-seam me-1"></i>Add Step</h6>
            <button class="btn-close" @onclick="ClosePicker"></button>
        </div>

        <div class="p-3 border-bottom">
            <input class="form-control" placeholder="Search step templates…"
                   value="@_pickerSearch"
                   @oninput="OnPickerSearch" />
        </div>

        <div class="flex-grow-1 overflow-auto p-3">
            @if (_pickerLoading)
            {
                <div class="text-center py-4">
                    <div class="spinner-border text-primary"></div>
                </div>
            }
            else if (_pickerTemplates is null || !_pickerTemplates.Items.Any())
            {
                <div class="text-center text-muted py-4">
                    <i class="bi bi-search d-block mb-2" style="font-size:1.8rem"></i>
                    No templates found.
                </div>
            }
            else
            {
                @foreach (var t in _pickerTemplates.Items)
                {
                    var tpl = t;
                    <div class="border rounded-2 p-3 mb-2 d-flex justify-content-between align-items-start"
                         style="cursor:pointer;transition:background .15s"
                         @onclick="() => AddStep(tpl)"
                         @onmouseenter="e => { }" @onmouseleave="e => { }">
                        <div class="flex-grow-1 pe-2">
                            <div class="fw-semibold">@t.Name</div>
                            <div class="text-muted small"><code>@t.Code</code> &bull; @t.Pattern</div>
                            <div class="mt-1 small">
                                <span class="text-success me-3">
                                    <i class="bi bi-box-arrow-in-right me-1"></i>@t.Ports.Count(p => p.Direction == PortDirection.Input) input(s)
                                </span>
                                <span class="text-primary">
                                    <i class="bi bi-box-arrow-right me-1"></i>@t.Ports.Count(p => p.Direction == PortDirection.Output) output(s)
                                </span>
                            </div>
                            @if (t.Ports.Any())
                            {
                                <div class="mt-1">
                                    @foreach (var p in t.Ports.OrderBy(p => p.SortOrder).Take(4))
                                    {
                                        <span class="badge @(p.Direction == PortDirection.Input ? "bg-success-subtle text-success border border-success" : "bg-primary-subtle text-primary border border-primary") me-1 mb-1 small">
                                            @p.Name
                                        </span>
                                    }
                                    @if (t.Ports.Count > 4)
                                    {
                                        <span class="text-muted small">+@(t.Ports.Count - 4) more</span>
                                    }
                                </div>
                            }
                        </div>
                        <button class="btn btn-primary btn-sm ms-2 flex-shrink-0" @onclick:stopPropagation="true"
                                @onclick="() => AddStep(tpl)">
                            Add
                        </button>
                    </div>
                }
                @if (_pickerTemplates.TotalCount > _pickerTemplates.Items.Count)
                {
                    <div class="text-center text-muted small mt-2">
                        Showing @_pickerTemplates.Items.Count of @_pickerTemplates.TotalCount — refine search to narrow results.
                    </div>
                }
            }

            <hr />
            <div class="text-center">
                <p class="text-muted small mb-2">Need to create a new step template first?</p>
                <a href="step-templates" target="_blank" class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-box-seam me-1"></i>Manage Step Templates
                    <i class="bi bi-box-arrow-up-right ms-1 small"></i>
                </a>
            </div>
        </div>
    </div>
}

@* ══════════════════════════════════════════
   Rename step modal
   ══════════════════════════════════════════ *@
@if (_showRenameModal && _renameIndex < _steps.Count)
{
    <div class="modal show d-block" tabindex="-1" style="background:rgba(0,0,0,.5);z-index:1060">
        <div class="modal-dialog modal-sm">
            <div class="modal-content">
                <div class="modal-header py-2">
                    <h6 class="modal-title mb-0">Override Step Name</h6>
                    <button class="btn-close" @onclick="() => _showRenameModal = false"></button>
                </div>
                <div class="modal-body">
                    <label class="form-label small fw-semibold">Display Name</label>
                    <input class="form-control" @bind="_renameValue"
                           placeholder="@(_steps[_renameIndex].Template?.Name ?? "Step name")" />
                    <div class="form-text">Leave blank to use the template's default name.</div>
                </div>
                <div class="modal-footer py-2">
                    <button class="btn btn-secondary btn-sm" @onclick="() => _showRenameModal = false">Cancel</button>
                    <button class="btn btn-primary btn-sm" @onclick="ApplyRename">Apply</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid? Id { get; set; }

    // ── Process metadata fields ──
    private string _code = "";
    private string _name = "";
    private string? _description;
    private ProcessResponseDto? _origProc;

    // ── Builder state ──
    private List<BuilderStep> _steps = new();
    private Dictionary<int, Connection> _connCache = new();

    // ── Page state ──
    private bool _loading = true;
    private bool _saving;
    private string? _error;
    private ProcessValidationResultDto? _validation;

    // ── Step picker ──
    private bool _showPicker;
    private int _insertAtIndex;
    private string _pickerSearch = "";
    private bool _pickerLoading;
    private PaginatedResponse<StepTemplateResponseDto>? _pickerTemplates;
    private System.Threading.CancellationTokenSource? _searchCts;

    // ── Rename modal ──
    private bool _showRenameModal;
    private int _renameIndex;
    private string _renameValue = "";

    // ──────────────────────────────────────────────
    // Initialization
    // ──────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        if (Id.HasValue)
        {
            _origProc = await Api.GetProcessAsync(Id.Value);
            if (_origProc is not null)
            {
                _code = _origProc.Code;
                _name = _origProc.Name;
                _description = _origProc.Description;

                foreach (var s in _origProc.Steps.OrderBy(s => s.Sequence))
                {
                    _steps.Add(new BuilderStep
                    {
                        ServerId = s.Id,
                        Sequence = s.Sequence,
                        StepTemplateId = s.StepTemplateId,
                        NameOverride = s.NameOverride
                    });
                }

                // Load all step templates in parallel
                await Task.WhenAll(_steps.Select(async step =>
                    step.Template = await Api.GetStepTemplateAsync(step.StepTemplateId)));

                RecomputeConnections();
                RestoreFlowsFromOriginal();
            }
        }
        _loading = false;
    }

    private void RestoreFlowsFromOriginal()
    {
        if (_origProc is null) return;
        foreach (var flow in _origProc.Flows)
        {
            int srcIdx = _steps.FindIndex(s => s.ServerId == flow.SourceProcessStepId);
            if (srcIdx < 0 || !_connCache.ContainsKey(srcIdx)) continue;
            var conn = _connCache[srcIdx];
            var srcPort = conn.Source.Template?.Ports.FirstOrDefault(p => p.Id == flow.SourcePortId);
            var tgtPort = conn.Target.Template?.Ports.FirstOrDefault(p => p.Id == flow.TargetPortId);
            if (srcPort is not null && tgtPort is not null)
            {
                conn.SourcePort = srcPort;
                conn.TargetPort = tgtPort;
                conn.Status = ConnectionStatus.UserSelected;
            }
        }
    }

    // ──────────────────────────────────────────────
    // Connection logic
    // ──────────────────────────────────────────────

    private void RecomputeConnections()
    {
        _connCache.Clear();
        for (int i = 0; i < _steps.Count - 1; i++)
        {
            var src = _steps[i];
            var tgt = _steps[i + 1];
            var conn = new Connection { Source = src, Target = tgt };

            if (src.Template is null || tgt.Template is null)
            {
                conn.Status = ConnectionStatus.Incompatible;
                _connCache[i] = conn;
                continue;
            }

            var outs = src.Template.Ports.Where(p => p.Direction == PortDirection.Output && p.PortType == PortType.Material).ToList();
            var ins  = tgt.Template.Ports.Where(p => p.Direction == PortDirection.Input && p.PortType == PortType.Material).ToList();

            var pairs = (from o in outs
                         from inp in ins
                         where o.KindId == inp.KindId && o.GradeId == inp.GradeId
                         select (Out: o, In: inp)).ToList();

            if (pairs.Count == 0)
            {
                conn.Status = ConnectionStatus.Incompatible;
            }
            else if (pairs.Count == 1)
            {
                conn.SourcePort = pairs[0].Out;
                conn.TargetPort = pairs[0].In;
                conn.Status = ConnectionStatus.AutoMatched;
            }
            else
            {
                conn.Options = pairs;
                conn.Status = ConnectionStatus.Ambiguous;
            }

            _connCache[i] = conn;
        }
    }

    private Connection GetConnection(int index)
    {
        if (_connCache.TryGetValue(index, out var c)) return c;
        RecomputeConnections();
        return _connCache.TryGetValue(index, out var c2)
            ? c2
            : new Connection { Source = _steps[index], Target = _steps[index + 1], Status = ConnectionStatus.Incompatible };
    }

    private void SetConnection(int index, string? value)
    {
        if (string.IsNullOrEmpty(value) || !_connCache.ContainsKey(index)) return;
        var parts = value.Split('|');
        if (parts.Length != 2) return;
        if (!Guid.TryParse(parts[0], out var outId) || !Guid.TryParse(parts[1], out var inId)) return;
        var conn = _connCache[index];
        var sp = conn.Source.Template?.Ports.FirstOrDefault(p => p.Id == outId);
        var tp = conn.Target.Template?.Ports.FirstOrDefault(p => p.Id == inId);
        if (sp is null || tp is null) return;
        conn.SourcePort = sp;
        conn.TargetPort = tp;
        conn.Status = ConnectionStatus.UserSelected;
    }

    // ──────────────────────────────────────────────
    // Step manipulation
    // ──────────────────────────────────────────────

    private async Task OpenStepPicker(int insertAtIndex)
    {
        _insertAtIndex = insertAtIndex;
        _pickerSearch = "";
        _showPicker = true;
        await LoadPickerTemplates();
    }

    private void ClosePicker() => _showPicker = false;

    private async Task OnPickerSearch(ChangeEventArgs e)
    {
        _pickerSearch = e.Value?.ToString() ?? "";
        _searchCts?.Cancel();
        _searchCts = new System.Threading.CancellationTokenSource();
        var cts = _searchCts;
        await Task.Delay(300);
        if (!cts.IsCancellationRequested)
            await LoadPickerTemplates();
    }

    private async Task LoadPickerTemplates()
    {
        _pickerLoading = true;
        StateHasChanged();
        _pickerTemplates = await Api.GetStepTemplatesAsync(_pickerSearch, true, 1, 20);
        _pickerLoading = false;
    }

    private void AddStep(StepTemplateResponseDto template)
    {
        _steps.Insert(_insertAtIndex, new BuilderStep
        {
            Sequence = _insertAtIndex + 1,
            StepTemplateId = template.Id,
            Template = template
        });
        for (int i = 0; i < _steps.Count; i++) _steps[i].Sequence = i + 1;
        RecomputeConnections();
        _showPicker = false;
        _validation = null;
    }

    private void MoveStep(int index, int direction)
    {
        int newIdx = index + direction;
        if (newIdx < 0 || newIdx >= _steps.Count) return;
        (_steps[index], _steps[newIdx]) = (_steps[newIdx], _steps[index]);
        for (int i = 0; i < _steps.Count; i++) _steps[i].Sequence = i + 1;
        RecomputeConnections();
        _validation = null;
    }

    private void RemoveStep(int index)
    {
        _steps.RemoveAt(index);
        for (int i = 0; i < _steps.Count; i++) _steps[i].Sequence = i + 1;
        RecomputeConnections();
        _validation = null;
    }

    private void ShowRenameStep(int index)
    {
        _renameIndex = index;
        _renameValue = _steps[index].NameOverride ?? "";
        _showRenameModal = true;
    }

    private void ApplyRename()
    {
        _steps[_renameIndex].NameOverride = string.IsNullOrWhiteSpace(_renameValue) ? null : _renameValue.Trim();
        _showRenameModal = false;
    }

    // ──────────────────────────────────────────────
    // Validate
    // ──────────────────────────────────────────────

    private async Task RunValidation()
    {
        if (!Id.HasValue) return;
        _validation = await Api.ValidateProcessAsync(Id.Value);
    }

    // ──────────────────────────────────────────────
    // Save
    // ──────────────────────────────────────────────

    private async Task Save()
    {
        _error = null;
        if (string.IsNullOrWhiteSpace(_code)) { _error = "Code is required."; return; }
        if (string.IsNullOrWhiteSpace(_name)) { _error = "Name is required."; return; }

        _saving = true;
        try
        {
            Guid processId;

            // 1. Create or update the process header
            if (!Id.HasValue)
            {
                var created = await Api.CreateProcessAsync(
                    new ProcessCreateDto(_code.Trim(), _name.Trim(), _description));
                if (created is null) { _error = "Failed to create process."; return; }
                processId = created.Id;
            }
            else
            {
                processId = Id.Value;
                if (_name != _origProc!.Name || _description != _origProc.Description)
                    await Api.UpdateProcessAsync(processId,
                        new ProcessUpdateDto(_name.Trim(), _description, _origProc.IsActive));
            }

            // 2. Remove steps that were deleted
            var origStepIds = _origProc?.Steps.Select(s => s.Id).ToHashSet() ?? new HashSet<Guid>();
            var keptStepIds = _steps.Where(s => s.ServerId.HasValue).Select(s => s.ServerId!.Value).ToHashSet();
            foreach (var removedId in origStepIds.Except(keptStepIds))
                await Api.DeleteProcessStepAsync(processId, removedId);

            // 3. Add new steps / update changed existing steps
            foreach (var step in _steps)
            {
                if (!step.ServerId.HasValue)
                {
                    var added = await Api.AddProcessStepAsync(processId,
                        new ProcessStepCreateDto(step.StepTemplateId, step.Sequence, step.NameOverride, null));
                    if (added is not null) step.ServerId = added.Id;
                }
                else
                {
                    var orig = _origProc?.Steps.FirstOrDefault(s => s.Id == step.ServerId);
                    if (orig is not null && (orig.Sequence != step.Sequence || orig.NameOverride != step.NameOverride))
                        await Api.UpdateProcessStepAsync(processId, step.ServerId.Value,
                            new ProcessStepUpdateDto(step.Sequence, step.NameOverride, orig.DescriptionOverride));
                }
            }

            // 4. Rebuild all flows: delete originals, create from current connections
            if (_origProc is not null)
                foreach (var flow in _origProc.Flows)
                    await Api.DeleteFlowAsync(processId, flow.Id);

            for (int i = 0; i < _steps.Count - 1; i++)
            {
                var conn = GetConnection(i);
                if ((conn.Status == ConnectionStatus.AutoMatched || conn.Status == ConnectionStatus.UserSelected)
                    && conn.SourcePort is not null && conn.TargetPort is not null
                    && conn.Source.ServerId.HasValue && conn.Target.ServerId.HasValue)
                {
                    await Api.AddFlowAsync(processId, new FlowCreateDto(
                        conn.Source.ServerId.Value, conn.SourcePort.Id,
                        conn.Target.ServerId.Value, conn.TargetPort.Id));
                }
            }

            // Navigate to builder URL for the (possibly new) process
            Nav.NavigateTo($"processes/{processId}/builder", forceLoad: true);
        }
        catch (HttpRequestException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    // ──────────────────────────────────────────────
    // Inner types
    // ──────────────────────────────────────────────

    private sealed class BuilderStep
    {
        public Guid LocalId { get; } = Guid.NewGuid();
        public Guid? ServerId { get; set; }
        public int Sequence { get; set; }
        public Guid StepTemplateId { get; set; }
        public StepTemplateResponseDto? Template { get; set; }
        public string? NameOverride { get; set; }
    }

    private sealed class Connection
    {
        public BuilderStep Source { get; set; } = null!;
        public BuilderStep Target { get; set; } = null!;
        public PortResponseDto? SourcePort { get; set; }
        public PortResponseDto? TargetPort { get; set; }
        public ConnectionStatus Status { get; set; } = ConnectionStatus.Incompatible;
        public List<(PortResponseDto Out, PortResponseDto In)> Options { get; set; } = new();
    }

    private enum ConnectionStatus { AutoMatched, Ambiguous, UserSelected, Incompatible }

    private static string PortInfo(PortResponseDto p) => p.PortType switch
    {
        PortType.Material => $"{p.KindName} / {p.GradeName}",
        PortType.Parameter or PortType.Characteristic =>
            string.IsNullOrEmpty(p.Units) ? $"{p.DataType}" : $"{p.DataType} ({p.Units})",
        PortType.Condition => "Pass / Fail",
        _ => ""
    };

    private static string PortTypeBadge(PortType t) => t switch
    {
        PortType.Material => "bg-secondary",
        PortType.Parameter => "bg-warning text-dark",
        PortType.Characteristic => "bg-info text-dark",
        PortType.Condition => "bg-light text-dark border",
        _ => "bg-secondary"
    };
}
