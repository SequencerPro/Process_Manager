@rendermode InteractiveServer
@implements IDisposable
@inject PlanEnforcementNotifier Enforcer
@inject ApiClient Api
@inject NavigationManager Nav

@if (_show)
{
    <div class="modal show d-block pm-modal" tabindex="-1" style="background: rgba(0,0,0,.55); z-index: 1060">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <div class="pm-modal-icon pm-modal-icon-orange">
                        <i class="bi bi-lock-fill"></i>
                    </div>
                    <div>
                        <h5 class="modal-title">Plan Limit Reached</h5>
                        <span class="pm-modal-subtitle">@_message</span>
                    </div>
                    <button type="button" class="btn-close ms-auto" @onclick="Dismiss"></button>
                </div>
                <div class="modal-body">
                    @if (_loadingPlans)
                    {
                        <div class="text-center py-4">
                            <div class="spinner-border spinner-border-sm me-2 text-primary"></div>
                            Loading plans…
                        </div>
                    }
                    else if (_loadError is not null)
                    {
                        <div class="alert alert-danger">
                            @_loadError
                            <a href="/settings/billing" class="alert-link ms-2">Go to Billing page</a>
                        </div>
                    }
                    else if (_plans is not null)
                    {
                        <p class="text-muted small mb-3">Upgrade your plan to continue. Your data is safe.</p>
                        <div class="row g-3">
                            @foreach (var plan in _plans.Where(p => p.Plan != SubscriptionPlan.Trial))
                            {
                                var isSuggested = plan.Plan.ToString() == _suggestedUpgradeName;
                                var isCurrent = plan.IsCurrent;
                                <div class="col-md-4">
                                    <div class="card h-100 @(isSuggested ? "border-warning" : isCurrent ? "border-success" : "")">
                                        <div class="card-body d-flex flex-column">
                                            <div class="d-flex justify-content-between align-items-start mb-2">
                                                <h6 class="card-title fw-bold mb-0">@plan.Name</h6>
                                                @if (isCurrent)
                                                {
                                                    <span class="badge bg-success">Current</span>
                                                }
                                                else if (isSuggested)
                                                {
                                                    <span class="badge bg-warning text-dark">Suggested</span>
                                                }
                                            </div>
                                            <div class="text-primary fw-semibold mb-3">@plan.PriceLabel</div>
                                            <ul class="list-unstyled small text-muted flex-grow-1 mb-3">
                                                <li><i class="bi bi-people me-1"></i>
                                                    @(plan.MaxUsers.HasValue ? $"Up to {plan.MaxUsers} users" : "Unlimited users")
                                                </li>
                                                <li><i class="bi bi-diagram-3 me-1"></i>
                                                    @(plan.MaxProcesses.HasValue ? $"Up to {plan.MaxProcesses} processes" : "Unlimited processes")
                                                </li>
                                                <li><i class="bi bi-play-circle me-1"></i>
                                                    @(plan.MaxMonthlyExecutions.HasValue ? $"{plan.MaxMonthlyExecutions} executions/mo" : "Unlimited executions")
                                                </li>
                                                <li>
                                                    @if (plan.AdvancedModulesEnabled)
                                                    {
                                                        <i class="bi bi-check-circle-fill text-success me-1"></i><span class="text-success">Advanced modules</span>
                                                    }
                                                    else
                                                    {
                                                        <i class="bi bi-x-circle text-muted me-1"></i><span>Advanced modules</span>
                                                    }
                                                </li>
                                            </ul>
                                            @if (isCurrent)
                                            {
                                                <button class="btn btn-outline-success btn-sm w-100" disabled>Current Plan</button>
                                            }
                                            else if (plan.Plan == SubscriptionPlan.Enterprise)
                                            {
                                                <a href="mailto:sales@processmanager.app" class="btn btn-outline-secondary btn-sm w-100">Contact Sales</a>
                                            }
                                            else
                                            {
                                                <button class="btn @(isSuggested ? "btn-warning" : "btn-primary") btn-sm w-100"
                                                        @onclick="() => HandleUpgradeAsync(plan.Plan)"
                                                        disabled="@_redirecting">
                                                    @if (_redirecting && _targetPlan == plan.Plan)
                                                    {
                                                        <span class="spinner-border spinner-border-sm me-1"></span>
                                                    }
                                                    Upgrade to @plan.Name
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <a href="/settings/billing" class="btn btn-link btn-sm text-muted">View Billing Details</a>
                    <button type="button" class="btn btn-secondary" @onclick="Dismiss">Maybe Later</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool _show;
    private string? _message;
    private string? _suggestedUpgradeName;
    private List<PlanComparisonDto>? _plans;
    private bool _loadingPlans;
    private string? _loadError;
    private bool _redirecting;
    private SubscriptionPlan? _targetPlan;

    protected override void OnInitialized()
    {
        Enforcer.OnPlanLimitHit += HandlePlanLimitHit;
    }

    private void HandlePlanLimitHit(string message, string? suggestedUpgrade, string? resource)
    {
        _message = message;
        _suggestedUpgradeName = suggestedUpgrade;
        _show = true;
        InvokeAsync(async () =>
        {
            StateHasChanged();
            if (_plans is null)
                await LoadPlansAsync();
        });
    }

    private async Task LoadPlansAsync()
    {
        _loadingPlans = true;
        StateHasChanged();
        try
        {
            _plans = await Api.GetPlanComparisonAsync();
        }
        catch
        {
            _loadError = "Could not load plan details.";
        }
        finally
        {
            _loadingPlans = false;
            StateHasChanged();
        }
    }

    private async Task HandleUpgradeAsync(SubscriptionPlan plan)
    {
        _redirecting = true;
        _targetPlan = plan;
        StateHasChanged();
        try
        {
            var successUrl = Nav.BaseUri.TrimEnd('/') + "/settings/billing?upgraded=true";
            var cancelUrl = Nav.BaseUri.TrimEnd('/') + "/settings/billing";
            var result = await Api.CreateCheckoutSessionAsync(
                new CreateCheckoutSessionDto(plan, successUrl, cancelUrl, null));
            if (result?.Url is not null)
                Nav.NavigateTo(result.Url, forceLoad: true);
            else
                _loadError = "Could not create checkout session. Please visit the Billing page.";
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            _redirecting = false;
            StateHasChanged();
        }
    }

    private void Dismiss()
    {
        _show = false;
        _loadError = null;
    }

    public void Dispose()
    {
        Enforcer.OnPlanLimitHit -= HandlePlanLimitHit;
    }
}
