@page "/kinds/{Id:guid}"
@attribute [Authorize(Roles = "Admin,Engineer")]
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject ApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IConfiguration Config

<PageTitle>Kind Detail</PageTitle>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_kind is null)
{
    <div class="alert alert-warning">Kind not found.</div>
}
else
{
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="kinds">Kinds</a></li>
            <li class="breadcrumb-item active">@_kind.Code</li>
        </ol>
    </nav>

    <div class="row mb-4">
        <div class="col-md-8">
            <h3>@_kind.Name <code class="ms-2 fs-6">@_kind.Code</code></h3>
            @if (!string.IsNullOrEmpty(_kind.Description))
            {
                <p class="text-muted d-none d-md-block">@_kind.Description</p>
            }
            <div class="d-flex gap-2 flex-wrap mb-3">
                <span class="badge @SourceBadgeClass(_kind.SourceType)">@FormatSourceType(_kind.SourceType)</span>
                <span class="badge @(_kind.IsSerialized ? "bg-primary" : "bg-secondary")">
                    @(_kind.IsSerialized ? "Serialized" : "Not Serialized")
                </span>
                <span class="badge @(_kind.IsBatchable ? "bg-primary" : "bg-secondary")">
                    @(_kind.IsBatchable ? "Batchable" : "Not Batchable")
                </span>
                @if (!string.IsNullOrEmpty(_kind.RohsStatus))
                {
                    <span class="badge @(_kind.RohsStatus == "Compliant" ? "bg-success" : _kind.RohsStatus == "Non-Compliant" ? "bg-danger" : "bg-warning text-dark")">
                        RoHS: @_kind.RohsStatus
                    </span>
                }
            </div>
            <small class="text-muted">Created @_kind.CreatedAt.ToString("g") &middot; Updated @_kind.UpdatedAt.ToString("g")</small>
        </div>
    </div>

    @* ──── Extended Properties Card ──── *@
    @if (HasExtendedProperties())
    {
        <div class="card mb-4">
            <div class="card-header"><i class="bi bi-info-circle me-1"></i> Extended Properties</div>
            <div class="card-body">
                <div class="row g-3">
                    @if (!string.IsNullOrEmpty(_kind.UnitOfMeasure))
                    {
                        <div class="col-md-3">
                            <div class="text-muted small">Unit of Measure</div>
                            <div class="fw-semibold">@_kind.UnitOfMeasure</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(_kind.Revision))
                    {
                        <div class="col-md-3">
                            <div class="text-muted small">Revision</div>
                            <div class="fw-semibold">@_kind.Revision</div>
                        </div>
                    }
                    @if (_kind.LeadTimeDays.HasValue)
                    {
                        <div class="col-md-3">
                            <div class="text-muted small">Lead Time</div>
                            <div class="fw-semibold">@_kind.LeadTimeDays days</div>
                        </div>
                    }
                    @if (_kind.Cost.HasValue)
                    {
                        <div class="col-md-3">
                            <div class="text-muted small">Cost</div>
                            <div class="fw-semibold">@_kind.Cost.Value.ToString("C")</div>
                        </div>
                    }
                    @if (_kind.Price.HasValue)
                    {
                        <div class="col-md-3">
                            <div class="text-muted small">Price</div>
                            <div class="fw-semibold">@_kind.Price.Value.ToString("C")</div>
                        </div>
                    }
                    @if (_kind.Weight.HasValue)
                    {
                        <div class="col-md-3">
                            <div class="text-muted small">Weight</div>
                            <div class="fw-semibold">@_kind.Weight.Value @_kind.WeightUnit</div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(_kind.CountryOfOrigin))
                    {
                        <div class="col-md-3">
                            <div class="text-muted small">Country of Origin</div>
                            <div class="fw-semibold">@_kind.CountryOfOrigin</div>
                        </div>
                    }
                </div>

                @if (!string.IsNullOrEmpty(_kind.VendorName) || !string.IsNullOrEmpty(_kind.VendorPartNumber))
                {
                    <hr />
                    <h6 class="text-muted mb-2"><i class="bi bi-truck me-1"></i> Vendor Information</h6>
                    <div class="row g-3">
                        @if (!string.IsNullOrEmpty(_kind.VendorName))
                        {
                            <div class="col-md-4">
                                <div class="text-muted small">Vendor Name</div>
                                <div class="fw-semibold">@_kind.VendorName</div>
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(_kind.VendorPartNumber))
                        {
                            <div class="col-md-4">
                                <div class="text-muted small">Vendor Part Number</div>
                                <div class="fw-semibold"><code>@_kind.VendorPartNumber</code></div>
                            </div>
                        }
                    </div>
                }

                @if (!string.IsNullOrEmpty(_kind.Notes))
                {
                    <hr />
                    <h6 class="text-muted mb-2"><i class="bi bi-journal-text me-1"></i> Notes</h6>
                    <p class="mb-0" style="white-space: pre-wrap">@_kind.Notes</p>
                }
            </div>
        </div>
    }

    @* ──── 3D Model + Documents Row ──── *@
    <div class="row mb-4">
        @* ──── 3D Model Viewer ──── *@
        <div class="@(HasModel() ? "col-md-6" : "col-12") mb-3 mb-md-0">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-box me-1"></i> 3D Model</span>
                    <div class="d-flex gap-2">
                        @if (HasModel())
                        {
                            <a href="@ApiBaseUrl/api/kinds/@_kind.Id/model/download" class="btn btn-outline-secondary btn-sm" target="_blank">
                                <i class="bi bi-download"></i>
                            </a>
                            <button class="btn btn-outline-danger btn-sm" @onclick="DeleteModel">
                                <i class="bi bi-trash"></i>
                            </button>
                        }
                        <label class="btn btn-primary btn-sm mb-0">
                            <i class="bi bi-upload me-1"></i> @(HasModel() ? "Replace" : "Upload")
                            <InputFile OnChange="OnModelSelected" accept=".stl,.obj,.glb,.gltf,.step,.stp,.iges,.igs" style="display:none" />
                        </label>
                    </div>
                </div>
                <div class="card-body p-0">
                    @if (HasModel())
                    {
                        <div id="model-viewer-container" style="width:100%; height:400px; position:relative;">
                            @if (!string.IsNullOrEmpty(_modelViewerStatus))
                            {
                                <div class="text-center text-muted py-5">
                                    <div class="spinner-border spinner-border-sm text-primary mb-2"></div><br />
                                    <small>@_modelViewerStatus</small>
                                </div>
                            }
                        </div>
                        <div class="text-center py-1 border-top" style="background: #f8f9fa">
                            <small class="text-muted">
                                <i class="bi bi-file-earmark-binary me-1"></i>@_kind.ModelOriginalFileName
                                &mdash; Drag to orbit, scroll to zoom, right-click to pan
                            </small>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-5">
                            <i class="bi bi-box d-block mb-2" style="font-size: 2rem; opacity: 0.3"></i>
                            No 3D model attached.<br />
                            <small>Supports STL, OBJ, GLB, GLTF, STEP, IGES formats</small>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* ──── Documents Card ──── *@
        <div class="@(HasModel() ? "col-md-6" : "col-12")">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-paperclip me-1"></i> Documents (@(_kind.Documents?.Count ?? 0))</span>
                    <label class="btn btn-primary btn-sm mb-0">
                        <i class="bi bi-upload me-1"></i> Upload
                        <InputFile OnChange="OnFileSelected" style="display:none" />
                    </label>
                </div>
                <div class="card-body">
                    @if (_kind.Documents?.Any() == true)
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var doc in _kind.Documents)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <i class="bi @FileIcon(doc.MimeType) me-2"></i>
                                        <a href="@ApiBaseUrl/api/kinds/@_kind.Id/documents/@doc.Id/download" target="_blank">
                                            @(string.IsNullOrEmpty(doc.Title) ? doc.OriginalFileName : doc.Title)
                                        </a>
                                        <span class="text-muted small ms-2">@doc.OriginalFileName</span>
                                    </div>
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteDocument(doc)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-3">No documents attached yet.</div>
                    }
                </div>
            </div>
        </div>
    </div>

    @* ──── Grades ──── *@
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">Grades</h5>
        <button class="btn btn-primary btn-sm" @onclick="ShowGradeForm">
            <i class="bi bi-plus-lg me-1"></i> Add Grade
        </button>
    </div>

    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th class="col-hide-mobile">Description</th>
                    <th class="col-hide-mobile">Default</th>
                    <th class="col-hide-mobile">Sort</th>
                    <th style="width:120px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var grade in _kind.Grades)
                {
                    <tr>
                        <td><code>@grade.Code</code></td>
                        <td>@grade.Name</td>
                        <td class="col-hide-mobile text-muted small">@grade.Description</td>
                        <td class="col-hide-mobile">
                            @if (grade.IsDefault)
                            {
                                <i class="bi bi-check-circle-fill text-success"></i>
                            }
                        </td>
                        <td class="col-hide-mobile">@grade.SortOrder</td>
                        <td>
                            <button class="btn btn-outline-secondary btn-sm me-1"
                                    @onclick="() => ShowEditGrade(grade)">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-outline-danger btn-sm"
                                    @onclick="() => DeleteGrade(grade)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
                @if (!_kind.Grades.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-3">No grades defined yet.</td></tr>
                }
            </tbody>
        </table>
    </div>

    @* ──── Bill of Materials ──── *@
    <div class="d-flex justify-content-between align-items-center mb-3 mt-4">
        <h5 class="mb-0"><i class="bi bi-diagram-3 me-1"></i> Bill of Materials (@(_kind.BomLines?.Count ?? 0) lines)</h5>
        <button class="btn btn-primary btn-sm" @onclick="ShowBomForm">
            <i class="bi bi-plus-lg me-1"></i> Add Component
        </button>
    </div>

    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th class="col-hide-mobile">Line #</th>
                    <th>Code</th>
                    <th>Component</th>
                    <th class="text-end">Qty</th>
                    <th class="col-hide-mobile">UoM</th>
                    <th class="col-hide-mobile">Notes</th>
                    <th class="col-hide-mobile text-end">Line Cost</th>
                    <th style="width:120px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (_kind.BomLines?.Any() == true)
                {
                    @foreach (var line in _kind.BomLines.OrderBy(b => b.SortOrder).ThenBy(b => b.LineNumber))
                    {
                        <tr>
                            <td class="col-hide-mobile">@line.LineNumber</td>
                            <td><code>@line.ComponentCode</code></td>
                            <td>@line.ComponentName</td>
                            <td class="text-end">@line.Quantity.ToString("G")</td>
                            <td class="col-hide-mobile">@(line.UnitOfMeasure ?? line.ComponentUnitOfMeasure ?? "—")</td>
                            <td class="col-hide-mobile text-muted small">@line.Notes</td>
                            <td class="col-hide-mobile text-end">
                                @if (line.ComponentCost.HasValue)
                                {
                                    @((line.Quantity * line.ComponentCost.Value).ToString("C"))
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                <button class="btn btn-outline-secondary btn-sm me-1"
                                        @onclick="() => ShowEditBomLine(line)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <button class="btn btn-outline-danger btn-sm"
                                        @onclick="() => DeleteBomLine(line)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </td>
                        </tr>
                    }
                    @if (GetBomTotalCost() > 0)
                    {
                        <tr class="table-light fw-semibold">
                            <td colspan="6" class="text-end">Total BoM Cost</td>
                            <td class="text-end">@GetBomTotalCost().ToString("C")</td>
                            <td></td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="8" class="text-center text-muted py-3">No components defined.</td></tr>
                }
            </tbody>
        </table>
    </div>
}

@if (_showGradeForm)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editingGradeId.HasValue ? "Edit Grade" : "Add Grade")</h5>
                    <button type="button" class="btn-close" @onclick="CloseGradeForm"></button>
                </div>
                <EditForm Model="_gradeForm" OnValidSubmit="SaveGrade">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Code</label>
                            <InputText class="form-control" @bind-Value="_gradeForm.Code"
                                       disabled="@_editingGradeId.HasValue" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <InputText class="form-control" @bind-Value="_gradeForm.Name" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <InputTextArea class="form-control" @bind-Value="_gradeForm.Description" rows="2" />
                        </div>
                        <div class="form-check mb-2">
                            <InputCheckbox class="form-check-input" @bind-Value="_gradeForm.IsDefault" />
                            <label class="form-check-label">Default Grade</label>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Sort Order</label>
                            <InputNumber class="form-control" @bind-Value="_gradeForm.SortOrder" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseGradeForm">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@if (_showBomForm)
{
    <div class="modal show d-block pm-modal" tabindex="-1" style="background: rgba(0,0,0,.45)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <div>
                        <div class="pm-modal-icon @(_editingBomLineId.HasValue ? "pm-modal-icon-blue" : "pm-modal-icon-green")">
                            <i class="bi @(_editingBomLineId.HasValue ? "bi-pencil" : "bi-diagram-3")"></i>
                        </div>
                        <h5 class="modal-title">@(_editingBomLineId.HasValue ? "Edit Component" : "Add Component")</h5>
                        <div class="pm-modal-subtitle">@(_editingBomLineId.HasValue ? "Update component line details" : "Add a component to this Kind's Bill of Materials")</div>
                    </div>
                    <button type="button" class="btn-close" @onclick="CloseBomForm"></button>
                </div>
                <EditForm Model="_bomForm" OnValidSubmit="SaveBomLine">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="pm-modal-divider">Component</div>
                        @if (_editingBomLineId.HasValue)
                        {
                            <div class="pm-input-group">
                                <label class="form-label"><i class="bi bi-box me-1"></i> Component</label>
                                <div class="form-control-plaintext fw-semibold">
                                    <code>@_selectedComponentKind?.Code</code> @_selectedComponentKind?.Name
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="pm-input-group">
                                <label class="form-label"><i class="bi bi-box me-1"></i> Component Kind</label>
                                @if (_selectedComponentKind is not null)
                                {
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="fw-semibold"><code>@_selectedComponentKind.Code</code> @_selectedComponentKind.Name</span>
                                        <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="() => _showComponentPicker = true">
                                            <i class="bi bi-arrow-repeat"></i> Change
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <button type="button" class="btn btn-outline-primary" @onclick="() => _showComponentPicker = true">
                                        <i class="bi bi-search me-1"></i> Select Component Kind
                                    </button>
                                }
                            </div>
                        }

                        <div class="pm-modal-divider">Line Details</div>
                        <div class="pm-input-group">
                            <label class="form-label"><i class="bi bi-hash me-1"></i> Line Number</label>
                            <InputNumber class="form-control" @bind-Value="_bomForm.LineNumber" />
                        </div>
                        <div class="pm-input-group">
                            <label class="form-label"><i class="bi bi-123 me-1"></i> Quantity</label>
                            <InputNumber class="form-control" @bind-Value="_bomForm.Quantity" />
                        </div>
                        <div class="pm-input-group">
                            <label class="form-label"><i class="bi bi-rulers me-1"></i> Unit of Measure (override)</label>
                            <InputText class="form-control" @bind-Value="_bomForm.UnitOfMeasure" placeholder="Leave blank to use component default" />
                        </div>
                        <div class="pm-input-group">
                            <label class="form-label"><i class="bi bi-chat-left-text me-1"></i> Notes</label>
                            <InputTextArea class="form-control" @bind-Value="_bomForm.Notes" rows="2" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseBomForm">Cancel</button>
                        <button type="submit" class="btn btn-primary" disabled="@(_selectedComponentKind is null && !_editingBomLineId.HasValue)">Save</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@if (_showComponentPicker)
{
    <div class="modal show d-block pm-modal" tabindex="-1" style="background: rgba(0,0,0,.55); z-index: 1060">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <div>
                        <div class="pm-modal-icon pm-modal-icon-green">
                            <i class="bi bi-box"></i>
                        </div>
                        <h5 class="modal-title">Select Component Kind</h5>
                        <div class="pm-modal-subtitle">Choose a Kind to add as a component</div>
                    </div>
                    <button type="button" class="btn-close" @onclick="() => _showComponentPicker = false"></button>
                </div>
                <div class="modal-body p-0">
                    <div class="p-3 border-bottom">
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-search"></i></span>
                            <input type="text" class="form-control" placeholder="Search by code or name..."
                                   @bind="_componentPickerSearch" @bind:event="oninput" />
                        </div>
                    </div>
                    <div style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-hover table-sm align-middle mb-0">
                            <thead class="table-light sticky-top">
                                <tr>
                                    <th>Code</th>
                                    <th>Name</th>
                                    <th class="col-hide-mobile">Source</th>
                                    <th class="col-hide-mobile">UoM</th>
                                    <th class="col-hide-mobile text-end">Cost</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var existingComponentIds = new HashSet<Guid>(
                                        _kind?.BomLines?.Select(b => b.ComponentKindId) ?? Enumerable.Empty<Guid>());
                                    var filteredKinds = (_availableKinds ?? Enumerable.Empty<KindResponseDto>())
                                        .Where(k => k.Id != Id && !existingComponentIds.Contains(k.Id))
                                        .Where(k => string.IsNullOrWhiteSpace(_componentPickerSearch)
                                            || k.Code.Contains(_componentPickerSearch, StringComparison.OrdinalIgnoreCase)
                                            || k.Name.Contains(_componentPickerSearch, StringComparison.OrdinalIgnoreCase))
                                        .OrderBy(k => k.Code)
                                        .Take(100);
                                }
                                @foreach (var k in filteredKinds)
                                {
                                    <tr class="cursor-pointer" style="cursor: pointer;" @onclick="() => SelectComponent(k)">
                                        <td><code>@k.Code</code></td>
                                        <td>@k.Name</td>
                                        <td class="col-hide-mobile"><span class="badge @SourceBadgeClass(k.SourceType)">@FormatSourceType(k.SourceType)</span></td>
                                        <td class="col-hide-mobile text-muted small">@(k.UnitOfMeasure ?? "—")</td>
                                        <td class="col-hide-mobile text-end">@(k.Cost.HasValue ? k.Cost.Value.ToString("C") : "—")</td>
                                    </tr>
                                }
                                @if (!filteredKinds.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">
                                            <i class="bi bi-inbox d-block fs-3 mb-2"></i>
                                            No available kinds found.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private KindResponseDto? _kind;
    private bool _loading = true;
    private string ApiBaseUrl = "";
    private bool _modelViewerInitialized;
    private bool _modelViewerInitializing; // re-entrancy guard
    private string? _modelViewerStatus;

    // Grade form
    private bool _showGradeForm;
    private Guid? _editingGradeId;
    private GradeFormModel _gradeForm = new();

    // BoM form
    private bool _showBomForm;
    private Guid? _editingBomLineId;
    private BomFormModel _bomForm = new();
    private KindResponseDto? _selectedComponentKind;
    private bool _showComponentPicker;
    private string _componentPickerSearch = "";
    private IEnumerable<KindResponseDto>? _availableKinds;

    protected override async Task OnInitializedAsync()
    {
        // Use configured API base URL (same one used by ApiClient)
        ApiBaseUrl = (Config["ApiBaseUrl"] ?? "http://localhost:5183").TrimEnd('/');
        await LoadData();
    }

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        // Init viewer whenever the component has rendered with a model but the viewer isn't active.
        // This covers: first page load, navigating away and back (DOM destroyed/recreated),
        // and enhanced navigation re-renders.
        // Fire-and-forget so the render pipeline is never blocked — users can interact
        // with the rest of the page while the 3D model loads in the background.
        if (_kind is not null && HasModel() && !_modelViewerInitialized && !_modelViewerInitializing)
        {
            Console.WriteLine($"[ModelViewer] OnAfterRenderAsync: firstRender={firstRender}, HasModel=true, file={_kind.ModelOriginalFileName}");
            _ = InitModelViewerAsync();
        }
        return Task.CompletedTask;
    }

    private async Task InitModelViewerAsync()
    {
        if (_modelViewerInitialized || _modelViewerInitializing)
        {
            Console.WriteLine($"[ModelViewer] InitModelViewer skipped: initialized={_modelViewerInitialized}, initializing={_modelViewerInitializing}");
            return;
        }
        _modelViewerInitializing = true;

        try
        {
            var ext = Path.GetExtension(_kind!.ModelOriginalFileName ?? "");
            var modelUrl = $"{ApiBaseUrl}/api/kinds/{_kind.Id}/model/download";
            Console.WriteLine($"[ModelViewer] InitModelViewer: ext={ext}, url={modelUrl}, HasModel={HasModel()}");

            // Ensure the DOM has been updated (model-viewer-container div must exist)
            _modelViewerStatus = "Initializing 3D viewer...";
            StateHasChanged();
            await Task.Delay(300);

            // Retry up to 3 times with increasing delay
            for (int attempt = 1; attempt <= 3; attempt++)
            {
                try
                {
                    Console.WriteLine($"[ModelViewer] JS init attempt {attempt}...");
                    await JS.InvokeVoidAsync("ModelViewer.init", "model-viewer-container", modelUrl, ext);
                    Console.WriteLine($"[ModelViewer] JS init attempt {attempt} succeeded!");
                    _modelViewerInitialized = true;
                    _modelViewerStatus = null;
                    StateHasChanged();
                    return;
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"[ModelViewer] JS init attempt {attempt} failed: {ex.Message}");
                    if (attempt < 3)
                        await Task.Delay(attempt * 500);
                }
            }

            _modelViewerStatus = "Failed to initialize 3D viewer after 3 attempts.";
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ModelViewer] InitModelViewer error: {ex.Message}");
            _modelViewerStatus = $"Viewer error: {ex.Message}";
            StateHasChanged();
        }
        finally
        {
            _modelViewerInitializing = false;
        }
    }

    private async Task LoadData()
    {
        _loading = true;
        // Reset viewer state so it re-initialises after data loads
        // (covers navigating away and back, enhanced navigation, etc.)
        _modelViewerInitialized = false;
        _modelViewerInitializing = false;
        try
        {
            _kind = await Api.GetKindAsync(Id);
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private bool HasModel() => _kind is not null && !string.IsNullOrEmpty(_kind.ModelFileName);

    private bool HasExtendedProperties() => _kind is not null && (
        !string.IsNullOrEmpty(_kind.UnitOfMeasure) ||
        !string.IsNullOrEmpty(_kind.Revision) ||
        _kind.LeadTimeDays.HasValue ||
        _kind.Cost.HasValue || _kind.Price.HasValue ||
        _kind.Weight.HasValue ||
        !string.IsNullOrEmpty(_kind.CountryOfOrigin) ||
        !string.IsNullOrEmpty(_kind.VendorName) ||
        !string.IsNullOrEmpty(_kind.VendorPartNumber) ||
        !string.IsNullOrEmpty(_kind.Notes)
    );

    // ──── 3D Model ────

    private async Task OnModelSelected(InputFileChangeEventArgs e)
    {
        Console.WriteLine($"[ModelViewer] OnModelSelected: file={e.File.Name}, size={e.File.Size}");
        try
        {
            // Destroy existing viewer
            try { await JS.InvokeVoidAsync("ModelViewer.destroy", "model-viewer-container"); } catch { }
            _modelViewerInitialized = false;
            _modelViewerInitializing = false;
            _modelViewerStatus = "Uploading model...";
            StateHasChanged();

            Console.WriteLine("[ModelViewer] Uploading model to API...");
            _kind = await Api.UploadKindModelAsync(Id, e.File);
            Console.WriteLine($"[ModelViewer] Upload complete. kind is null={_kind is null}, HasModel={_kind is not null && !string.IsNullOrEmpty(_kind.ModelFileName)}, OriginalFileName={_kind?.ModelOriginalFileName}");

            if (_kind is null)
            {
                Toast.ShowError("Upload returned no data. Please try again.");
                _modelViewerStatus = null;
                return;
            }

            _modelViewerStatus = "Preparing 3D viewer...";
            StateHasChanged();
            // Yield to let Blazor render the model-viewer-container div
            await Task.Yield();

            // Fire-and-forget so the upload handler returns immediately
            // and the user can interact with the rest of the page
            _ = InitModelViewerAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[ModelViewer] OnModelSelected error: {ex.GetType().Name}: {ex.Message}");
            Console.WriteLine($"[ModelViewer] Stack trace: {ex.StackTrace}");
            _modelViewerStatus = null;
            _modelViewerInitializing = false;
            Toast.ShowError($"Model upload failed: {ex.Message}");
        }
    }

    private async Task DeleteModel()
    {
        if (!await JS.InvokeAsync<bool>("confirm", "Remove 3D model?")) return;
        try
        {
            try { await JS.InvokeVoidAsync("ModelViewer.destroy", "model-viewer-container"); } catch { }
            _modelViewerInitialized = false;
            await Api.DeleteKindModelAsync(Id);
            await LoadData();
        }
        catch (Exception ex) { Toast.ShowError(ex.Message); }
    }

