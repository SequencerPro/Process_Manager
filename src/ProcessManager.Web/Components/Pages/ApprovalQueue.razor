@page "/approval-queue"
@rendermode InteractiveServer
@inject ApiClient Api

<PageTitle>Approval Queue</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Approval Queue</h3>
</div>

<div class="d-flex gap-3 mb-3 flex-wrap">
    <select class="form-select form-select-sm" style="width:auto" @onchange="OnTypeFilter">
        <option value="">All Types</option>
        <option value="Process">Processes</option>
        <option value="StepTemplate">Step Templates</option>
    </select>
    <select class="form-select form-select-sm" style="width:auto" @onchange="OnDecisionFilter">
        <option value="Pending" selected>Pending</option>
        <option value="">All Decisions</option>
        <option value="Approved">Approved</option>
        <option value="Rejected">Rejected</option>
    </select>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_data is not null)
{
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>Type</th>
                    <th>Entity</th>
                    <th>Version</th>
                    <th>Submitted By</th>
                    <th>Submitted At</th>
                    <th>Decision</th>
                    <th style="width:160px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!_data.Items.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-3">No items found.</td></tr>
                }
                else
                {
                    @foreach (var ar in _data.Items)
                    {
                        <tr>
                            <td><span class="badge bg-secondary">@ar.EntityType</span></td>
                            <td>
                                @if (ar.EntityType == "Process")
                                {
                                    <a href="processes/@ar.EntityId">@ar.EntityId.ToString()[..8]…</a>
                                }
                                else
                                {
                                    <a href="step-templates/@ar.EntityId">@ar.EntityId.ToString()[..8]…</a>
                                }
                            </td>
                            <td>v@ar.EntityVersion</td>
                            <td>@ar.SubmittedBy</td>
                            <td>@ar.SubmittedAt.ToString("g")</td>
                            <td>
                                <span class="badge @DecisionBadgeClass(ar.Decision)">@ar.Decision</span>
                            </td>
                            <td>
                                @if (ar.Decision == "Pending")
                                {
                                    <button class="btn btn-success btn-sm me-1"
                                            @onclick="() => OpenApproveModal(ar)">
                                        <i class="bi bi-check-circle me-1"></i>Approve
                                    </button>
                                    <button class="btn btn-warning btn-sm"
                                            @onclick="() => OpenRejectModal(ar)">
                                        <i class="bi bi-x-circle me-1"></i>Reject
                                    </button>
                                }
                                else
                                {
                                    <span class="text-muted small">@ar.ReviewedBy @ar.ReviewedAt?.ToString("g")</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <Pager Page="_page" PageSize="_pageSize" TotalCount="_data.TotalCount"
           OnPageChanged="OnPageChanged" />
}

@* Approve Modal *@
@if (_showApproveModal && _selected is not null)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Approve @_selected.EntityType</h5>
                    <button type="button" class="btn-close" @onclick="() => _showApproveModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Approved By</label>
                        <input class="form-control" @bind="_actionUser" placeholder="Your name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Notes (optional)</label>
                        <textarea class="form-control" rows="2" @bind="_actionNotes"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _showApproveModal = false">Cancel</button>
                    <button class="btn btn-success" @onclick="DoApprove">Approve</button>
                </div>
            </div>
        </div>
    </div>
}

@* Reject Modal *@
@if (_showRejectModal && _selected is not null)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Reject @_selected.EntityType</h5>
                    <button type="button" class="btn-close" @onclick="() => _showRejectModal = false"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Rejected By</label>
                        <input class="form-control" @bind="_actionUser" placeholder="Your name" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Rejection Reason</label>
                        <textarea class="form-control" rows="2" @bind="_actionNotes"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => _showRejectModal = false">Cancel</button>
                    <button class="btn btn-warning" @onclick="DoReject">Reject</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PaginatedResponse<ApprovalRecordResponseDto>? _data;
    private bool _loading = true;
    private string? _entityType;
    private string? _decision = "Pending";
    private int _page = 1;
    private int _pageSize = 25;

    // Modal state
    private bool _showApproveModal;
    private bool _showRejectModal;
    private ApprovalRecordResponseDto? _selected;
    private string _actionUser = "";
    private string _actionNotes = "";

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _data = await Api.GetApprovalRecordsAsync(_entityType, null, _decision, _page, _pageSize);
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task OnTypeFilter(ChangeEventArgs e)
    {
        _entityType = string.IsNullOrEmpty(e.Value?.ToString()) ? null : e.Value.ToString();
        _page = 1;
        await LoadData();
    }

    private async Task OnDecisionFilter(ChangeEventArgs e)
    {
        _decision = string.IsNullOrEmpty(e.Value?.ToString()) ? null : e.Value.ToString();
        _page = 1;
        await LoadData();
    }

    private async Task OnPageChanged(int p) { _page = p; await LoadData(); }

    private void OpenApproveModal(ApprovalRecordResponseDto ar)
    {
        _selected = ar; _actionUser = ""; _actionNotes = ""; _showApproveModal = true;
    }

    private void OpenRejectModal(ApprovalRecordResponseDto ar)
    {
        _selected = ar; _actionUser = ""; _actionNotes = ""; _showRejectModal = true;
    }

    private async Task DoApprove()
    {
        if (_selected is null || string.IsNullOrWhiteSpace(_actionUser)) { Toast.ShowError("Approved By is required."); return; }
        try
        {
            if (_selected.EntityType == "Process")
                await Api.ApproveProcessAsync(_selected.EntityId, new ApproveDto(_actionUser, _actionNotes));
            else
                await Api.ApproveStepTemplateAsync(_selected.EntityId, new ApproveDto(_actionUser, _actionNotes));
            _showApproveModal = false;
            await LoadData();
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

    private async Task DoReject()
    {
        if (_selected is null || string.IsNullOrWhiteSpace(_actionUser)) { Toast.ShowError("Rejected By is required."); return; }
        try
        {
            if (_selected.EntityType == "Process")
                await Api.RejectProcessAsync(_selected.EntityId, new RejectDto(_actionUser, _actionNotes ?? ""));
            else
                await Api.RejectStepTemplateAsync(_selected.EntityId, new RejectDto(_actionUser, _actionNotes ?? ""));
            _showRejectModal = false;
            await LoadData();
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

    private static string DecisionBadgeClass(string? decision) => decision switch
    {
        "Pending"  => "bg-warning text-dark",
        "Approved" => "bg-success",
        "Rejected" => "bg-danger",
        _          => "bg-secondary"
    };
}
