@page "/processes/{Id:guid}"
@page "/documents/{Id:guid}"
@rendermode InteractiveServer
@inject ApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>@(_proc is null ? "Detail" : IsDocumentContext ? $"Document — {_proc.Name}" : $"Process — {_proc.Name}")</PageTitle>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_proc is null)
{
    <div class="alert alert-warning">Process not found.</div>
}
else
{
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0">
            @if (IsDocumentContext)
            {
                <li class="breadcrumb-item"><a href="documents">Document Library</a></li>
            }
            else
            {
                <li class="breadcrumb-item"><a href="processes">Processes</a></li>
            }
            <li class="breadcrumb-item active">@_proc.Name</li>
        </ol>
    </nav>

    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <div>
                    <h4 class="mb-1">@_proc.Name</h4>
                    <span class="text-muted me-3"><code>@_proc.Code</code></span>
                    <span class="badge me-1 @(_proc.IsActive ? "bg-success" : "bg-secondary")">@(_proc.IsActive ? "Active" : "Inactive")</span>
                    <span class="badge bg-dark">v@_proc.Version</span>
                    <span class="badge @StatusBadgeClass(_proc.Status) ms-1">@_proc.Status</span>
                    @{ var aggMaturity = AggregateMaturity(); }
                    @if (aggMaturity is not null)
                    {
                        <span class="badge @MaturityBadgeClass(aggMaturity.Level) ms-1" title="Lowest step-template maturity (Score @aggMaturity.Score/100)">
                            <i class="bi bi-bar-chart-fill me-1"></i>@aggMaturity.Level
                        </span>
                        @if (aggMaturity.HasBlockingErrors)
                        {
                            <span class="badge bg-danger ms-1" title="One or more steps have blocking maturity errors"><i class="bi bi-exclamation-triangle-fill"></i></span>
                        }
                    }
                </div>
                <div>
                    <a href="@(IsDocumentContext ? $"documents/{Id}/builder" : $"processes/{Id}/builder")" class="btn btn-outline-primary btn-sm me-1">
                        <i class="bi bi-diagram-3 me-1"></i>Builder
                    </a>
                    <button class="btn btn-outline-secondary btn-sm me-1" @onclick="ShowEditForm">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </button>
                    <button class="btn btn-outline-info btn-sm me-1" @onclick="Validate">
                        <i class="bi bi-check2-all me-1"></i>Validate
                    </button>
                    @if (_proc.Status == "Draft")
                    {
                        <button class="btn btn-outline-primary btn-sm me-1" @onclick="() => _showSubmitModal = true">
                            <i class="bi bi-send me-1"></i>Submit
                        </button>
                    }
                    else if (_proc.Status == "PendingApproval")
                    {
                        <button class="btn btn-success btn-sm me-1" @onclick="() => _showApproveModal = true">
                            <i class="bi bi-check-circle me-1"></i>Approve
                        </button>
                        <button class="btn btn-warning btn-sm me-1" @onclick="() => _showRejectModal = true">
                            <i class="bi bi-x-circle me-1"></i>Reject
                        </button>
                    }
                    else if (_proc.Status == "Released")
                    {
                        <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => _showNewRevisionModal = true">
                            <i class="bi bi-arrow-clockwise me-1"></i>New Revision
                        </button>
                        <button class="btn btn-outline-danger btn-sm me-1" @onclick="RetireProcess">
                            <i class="bi bi-archive me-1"></i>Retire
                        </button>
                    }
                    <button class="btn btn-outline-danger btn-sm" @onclick="Delete">
                        <i class="bi bi-trash me-1"></i>Delete
                    </button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_proc.Description))
            {
                <p class="mb-2">@_proc.Description</p>
            }
            <small class="text-muted">Created @_proc.CreatedAt.ToString("g") &bull; Updated @_proc.UpdatedAt.ToString("g")</small>
        </div>
    </div>

    @if (_validation is not null)
    {
        <div class="alert @(_validation.Errors.Any() ? "alert-danger" : "alert-success") py-2">
            @if (!_validation.Errors.Any() && !_validation.Warnings.Any())
            {
                <span><i class="bi bi-check-circle me-1"></i> Valid &mdash; no errors found.</span>
            }
            @foreach (var e in _validation.Errors) { <div><i class="bi bi-x-circle text-danger me-1"></i> @e</div> }
            @foreach (var w in _validation.Warnings) { <div><i class="bi bi-exclamation-triangle text-warning me-1"></i> @w</div> }
        </div>
    }

    <!-- Steps -->
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-list-ol me-1"></i> Steps (@_proc.Steps.Count)</span>
            <a href="@(IsDocumentContext ? $"documents/{Id}/builder" : $"processes/{Id}/builder")" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-diagram-3 me-1"></i>Edit in Builder
            </a>
        </div>
        @if (_proc.Steps.Any())
        {
            <div class="table-responsive">
                <table class="table table-sm mb-0 align-middle">
                    <thead class="table-light">
                        <tr><th>#</th><th>Template</th><th>Name Override</th><th>Desc. Override</th><th>Maturity</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var s in _proc.Steps.OrderBy(s => s.Sequence))
                        {
                            <tr>
                                <td>@s.Sequence</td>
                                <td>
                                    <a href="step-templates/@s.StepTemplateId" title="Open step template editor">
                                        <code>@s.StepTemplateCode</code>
                                    </a>
                                    — @s.StepTemplateName
                                </td>
                                <td>@(s.NameOverride ?? "—")</td>
                                <td class="small text-truncate" style="max-width:200px">@(s.DescriptionOverride ?? "—")</td>
                                <td>
                                    @if (s.StepTemplateMaturity is not null)
                                    {
                                        <span class="badge @MaturityBadgeClass(s.StepTemplateMaturity.Level)" title="Score @s.StepTemplateMaturity.Score/100">
                                            @s.StepTemplateMaturity.Level
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="card-body text-muted small">No steps defined. Use the Builder to add steps.</div>
        }
    </div>

    <!-- Flows -->
    <div class="card mb-4">
        <div class="card-header">
            <span><i class="bi bi-arrow-left-right me-1"></i> Flows (@_proc.Flows.Count)</span>
        </div>
        @if (_proc.Flows.Any())
        {
            <div class="table-responsive">
                <table class="table table-sm mb-0 align-middle">
                    <thead class="table-light">
                        <tr><th>Source Step</th><th>Source Port</th><th></th><th>Target Step</th><th>Target Port</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var f in _proc.Flows)
                        {
                            var srcStep = _proc.Steps.FirstOrDefault(s => s.Id == f.SourceProcessStepId);
                            var tgtStep = _proc.Steps.FirstOrDefault(s => s.Id == f.TargetProcessStepId);
                            <tr>
                                <td>@(srcStep?.NameOverride ?? srcStep?.StepTemplateName ?? "?")</td>
                                <td><code>@f.SourcePortName</code></td>
                                <td class="text-center"><i class="bi bi-arrow-right"></i></td>
                                <td>@(tgtStep?.NameOverride ?? tgtStep?.StepTemplateName ?? "?")</td>
                                <td><code>@f.TargetPortName</code></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="card-body text-muted small">No flows defined. Use the Builder to connect steps.</div>
        }
    </div>

    @* Training Requirements *@
    @if (_proc.ProcessRole != "Training" && _proc.ProcessRole != "ApprovalProcess")
    {
        <div class="card mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span><i class="bi bi-mortarboard me-1"></i> Training Requirements (@(_trainingRequirements?.Count ?? 0))</span>
                <AuthorizeView Roles="Admin,Engineer">
                    <Authorized>
                        <button class="btn btn-sm btn-outline-primary" @onclick="OpenAddRequirement">
                            <i class="bi bi-plus-lg me-1"></i>Add Requirement
                        </button>
                    </Authorized>
                </AuthorizeView>
            </div>
            @if (_trainingRequirements is null)
            {
                <div class="card-body text-muted small text-center py-3">
                    <div class="spinner-border spinner-border-sm"></div>
                </div>
            }
            else if (!_trainingRequirements.Any())
            {
                <div class="card-body text-muted small">No training requirements defined for this process.</div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Training Course</th>
                                <th>Competency</th>
                                <th>Enforcement</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var req in _trainingRequirements)
                            {
                                <tr>
                                    <td><code>@req.TrainingProcessCode</code> — @req.TrainingProcessName</td>
                                    <td class="small text-muted">@(req.CompetencyTitle ?? req.TrainingProcessName)</td>
                                    <td>
                                        @if (req.IsEnforced)
                                        {
                                            <span class="badge bg-danger">Enforced</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Advisory</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <AuthorizeView Roles="Admin,Engineer">
                                            <Authorized>
                                                <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveRequirement(req.Id)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </Authorized>
                                        </AuthorizeView>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    }

    @* Add Training Requirement Modal *@
    @if (_showAddReqModal)
    {
        <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title"><i class="bi bi-mortarboard me-2"></i>Add Training Requirement</h5>
                        <button type="button" class="btn-close" @onclick="() => _showAddReqModal = false"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Training Course <span class="text-danger">*</span></label>
                            <select class="form-select" @bind="_reqTrainingProcessId">
                                <option value="">Select a training course…</option>
                                @if (_availableTrainingProcesses is not null)
                                {
                                    @foreach (var tp in _availableTrainingProcesses.Items)
                                    {
                                        <option value="@tp.Id">@(tp.CompetencyTitle ?? tp.Name) (@tp.Code)</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="reqEnforced" @bind="_reqIsEnforced" />
                            <label class="form-check-label" for="reqEnforced">
                                Enforced (blocks job creation if prerequisite not met)
                            </label>
                        </div>
                        @if (_reqError is not null)
                        {
                            <div class="alert alert-danger py-1 small mt-2">@_reqError</div>
                        }
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="() => _showAddReqModal = false">Cancel</button>
                        <button class="btn btn-primary" @onclick="SubmitAddRequirement" disabled="@_reqSaving">
                            @if (_reqSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Add
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @* Edit Process Modal *@
    @if (_showEditForm)
    {
        <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Edit Process</h5>
                        <button type="button" class="btn-close" @onclick="() => _showEditForm = false"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <input class="form-control" @bind="_editName" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" rows="3" @bind="_editDescription"></textarea>
                        </div>
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="procIsActive" @bind="_editIsActive" />
                            <label class="form-check-label" for="procIsActive">Active</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="() => _showEditForm = false">Cancel</button>
                        <button class="btn btn-primary" @onclick="SaveEdit">Update</button>
                    </div>
                </div>
            </div>
        </div>
    }

    @* Submit Modal *@
    @if (_showSubmitModal)
    {
        <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Submit for Approval</h5>
                        <button type="button" class="btn-close" @onclick="() => _showSubmitModal = false"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Submitted By</label>
                            <input class="form-control" @bind="_lifecycleUser" placeholder="Your name" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notes (optional)</label>
                            <textarea class="form-control" rows="2" @bind="_lifecycleNotes"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="() => _showSubmitModal = false">Cancel</button>
                        <button class="btn btn-primary" @onclick="SubmitForApproval">Submit</button>
                    </div>
                </div>
            </div>
        </div>
    }

    @* Approve Modal *@
    @if (_showApproveModal)
    {
        <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Approve Process</h5>
                        <button type="button" class="btn-close" @onclick="() => _showApproveModal = false"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Approved By</label>
                            <input class="form-control" @bind="_lifecycleUser" placeholder="Your name" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notes (optional)</label>
                            <textarea class="form-control" rows="2" @bind="_lifecycleNotes"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="() => _showApproveModal = false">Cancel</button>
                        <button class="btn btn-success" @onclick="ApproveProcess">Approve</button>
                    </div>
                </div>
            </div>
        </div>
    }

    @* Reject Modal *@
    @if (_showRejectModal)
    {
        <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Reject Process</h5>
                        <button type="button" class="btn-close" @onclick="() => _showRejectModal = false"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Rejected By</label>
                            <input class="form-control" @bind="_lifecycleUser" placeholder="Your name" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Rejection Reason</label>
                            <textarea class="form-control" rows="2" @bind="_lifecycleNotes"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="() => _showRejectModal = false">Cancel</button>
                        <button class="btn btn-warning" @onclick="RejectProcess">Reject</button>
                    </div>
                </div>
            </div>
        </div>
    }

    @* New Revision Modal *@
    @if (_showNewRevisionModal)
    {
        <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Create New Revision</h5>
                        <button type="button" class="btn-close" @onclick="() => _showNewRevisionModal = false"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted small">A new <strong>Draft</strong> copy of this process will be created at v@(_proc!.Version + 1). The current Release remains active.</p>
                        <div class="mb-3">
                            <label class="form-label">Requested By</label>
                            <input class="form-control" @bind="_lifecycleUser" placeholder="Your name" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="() => _showNewRevisionModal = false">Cancel</button>
                        <button class="btn btn-primary" @onclick="NewRevision">Create Revision</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }

    private bool IsDocumentContext => _proc?.ProcessRole is "QmsDocument" or "WorkInstruction"
        || Nav.Uri.Contains("/documents/");

    private ProcessResponseDto? _proc;
    private ProcessValidationResultDto? _validation;
    private bool _loading = true;

    // Edit form
    private bool _showEditForm;
    private string _editName = "";
    private string? _editDescription;
    private bool _editIsActive;

    // Lifecycle modals
    private bool _showSubmitModal;
    private bool _showApproveModal;
    private bool _showRejectModal;
    private bool _showNewRevisionModal;
    private string _lifecycleUser = "";
    private string _lifecycleNotes = "";

    // Training requirements
    private List<ProcessTrainingRequirementDto>? _trainingRequirements;
    private PaginatedResponse<ProcessSummaryResponseDto>? _availableTrainingProcesses;
    private bool _showAddReqModal;
    private string _reqTrainingProcessId = "";
    private bool   _reqIsEnforced = true;
    private string? _reqError;
    private bool    _reqSaving;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _proc = await Api.GetProcessAsync(Id);
            if (_proc is not null && _proc.ProcessRole != "Training" && _proc.ProcessRole != "ApprovalProcess")
                _trainingRequirements = await Api.GetTrainingRequirementsAsync("Process", Id);
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task Validate()
    {
        _validation = await Api.ValidateProcessAsync(Id);
    }

    private async Task Delete()
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Delete '{_proc!.Name}'? This cannot be undone.")) return;
        try
        {
            await Api.DeleteProcessAsync(Id);
            Nav.NavigateTo(IsDocumentContext ? "documents" : "processes");
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

    // --- Edit Process ---
    private void ShowEditForm()
    {
        _editName = _proc!.Name;
        _editDescription = _proc.Description;
        _editIsActive = _proc.IsActive;
        _showEditForm = true;
    }

    private async Task SaveEdit()
    {
        try
        {
            await Api.UpdateProcessAsync(Id, new ProcessUpdateDto(_editName, _editDescription, _editIsActive));
            _showEditForm = false;
            await LoadData();
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

    private async Task SubmitForApproval()
    {
        if (string.IsNullOrWhiteSpace(_lifecycleUser)) { Toast.ShowError("Submitted By is required."); return; }
        try
        {
            _proc = await Api.SubmitProcessForApprovalAsync(Id, new SubmitForApprovalDto(_lifecycleUser, _lifecycleNotes));
            _showSubmitModal = false; _lifecycleUser = ""; _lifecycleNotes = "";
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

    private async Task ApproveProcess()
    {
        if (string.IsNullOrWhiteSpace(_lifecycleUser)) { Toast.ShowError("Approved By is required."); return; }
        try
        {
            _proc = await Api.ApproveProcessAsync(Id, new ApproveDto(_lifecycleUser, _lifecycleNotes));
            _showApproveModal = false; _lifecycleUser = ""; _lifecycleNotes = "";
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

    private async Task RejectProcess()
    {
        if (string.IsNullOrWhiteSpace(_lifecycleUser)) { Toast.ShowError("Rejected By is required."); return; }
        try
        {
            _proc = await Api.RejectProcessAsync(Id, new RejectDto(_lifecycleUser, _lifecycleNotes ?? ""));
            _showRejectModal = false; _lifecycleUser = ""; _lifecycleNotes = "";
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

    private async Task NewRevision()
    {
        if (string.IsNullOrWhiteSpace(_lifecycleUser)) { Toast.ShowError("Requested By is required."); return; }
        try
        {
            var newProc = await Api.NewProcessRevisionAsync(Id, new NewRevisionDto(_lifecycleUser));
            _showNewRevisionModal = false;
            if (newProc is not null) Nav.NavigateTo(IsDocumentContext ? $"documents/{newProc.Id}" : $"processes/{newProc.Id}");
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

    private async Task RetireProcess()
    {
        if (!await JS.InvokeAsync<bool>("confirm", $"Retire process '{_proc!.Name}'? It will be archived.")) return;
        try { _proc = await Api.RetireProcessAsync(Id); }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

    private static string StatusBadgeClass(string? status) => status switch
    {
        "Draft"           => "bg-secondary",
        "PendingApproval" => "bg-warning text-dark",
        "Released"        => "bg-success",
        "Superseded"      => "bg-dark",
        "Retired"         => "bg-danger",
        _                 => "bg-light text-dark"
    };

    private MaturitySummaryDto? AggregateMaturity()    {
        if (_proc is null || !_proc.Steps.Any()) return null;
        var summaries = _proc.Steps
            .Select(s => s.StepTemplateMaturity)
            .Where(m => m is not null)
            .ToList();
        if (!summaries.Any()) return null;
        // Return the worst (lowest score) summary
        return summaries.MinBy(m => m!.Score);
    }

    private static string MaturityBadgeClass(MaturityLevel level) => level switch
    {
        MaturityLevel.Optimised  => "bg-success",
        MaturityLevel.Defined    => "bg-primary",
        MaturityLevel.Developing => "bg-warning text-dark",
        _                        => "bg-secondary"
    };

    // --- Training Requirements ---
    private async Task OpenAddRequirement()
    {
        _reqTrainingProcessId = "";
        _reqIsEnforced = true;
        _reqError = null;
        if (_availableTrainingProcesses is null)
            _availableTrainingProcesses = await Api.GetProcessesAsync(processRole: "Training", active: true, pageSize: 200);
        _showAddReqModal = true;
    }

    private async Task SubmitAddRequirement()
    {
        if (!Guid.TryParse(_reqTrainingProcessId, out var tpId)) { _reqError = "Please select a training course."; return; }
        _reqSaving = true; _reqError = null;
        try
        {
            await Api.AddTrainingRequirementAsync(new AddTrainingRequirementDto("Process", Id, tpId, _reqIsEnforced));
            _trainingRequirements = await Api.GetTrainingRequirementsAsync("Process", Id);
            _showAddReqModal = false;
        }
        catch (Exception ex) { _reqError = ex.Message; }
        finally { _reqSaving = false; }
    }

    private async Task RemoveRequirement(Guid reqId)
    {
        try
        {
            await Api.DeleteTrainingRequirementAsync(reqId);
            _trainingRequirements = await Api.GetTrainingRequirementsAsync("Process", Id);
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }
}
