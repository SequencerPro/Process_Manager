@using Blazor.Diagrams.Components.Renderers
@using ProcessManager.Web.Components.Pages.Workflows

<div style="min-width:@(Node.IsTerminalNode ? "120px" : "180px"); max-width:260px;">
    <div style="position:relative;">
        @if (Node.IsTerminalNode)
        {
            @* Terminal "End" node — distinct red-themed stop tile *@
            <div style="background:#fff; border:2px solid @BorderColor; border-radius:2rem;
                         box-shadow: @(Node.Selected ? "0 0 0 3px rgba(220,53,69,.3)" : "0 2px 8px rgba(0,0,0,.12)");
                         pointer-events:none; text-align:center;">
                <div style="padding:0.6rem 1rem; background:@HeaderBg; border-radius:2rem;">
                    <i class="bi bi-stop-circle-fill" style="font-size:1.1rem; color:#dc3545; vertical-align:middle;"></i>
                    <span style="font-weight:700; font-size:0.9rem; color:#dc3545; margin-left:0.3rem; vertical-align:middle;">END</span>
                </div>
            </div>
        }
        else
        {
            @* Regular process card — pointer-events:none so drag events pass through to library wrapper *@
            <div style="background:#fff; border:2px solid @BorderColor; border-radius:0.5rem;
                         box-shadow: @(Node.Selected ? "0 0 0 3px rgba(13,110,253,.3)" : "0 2px 8px rgba(0,0,0,.12)");
                         pointer-events:none;">
                <div style="padding:0.5rem 0.75rem; font-weight:600; font-size:0.85rem;
                             border-bottom:1px solid #e9ecef; background:@HeaderBg;
                             border-radius:0.375rem 0.375rem 0 0;"
                     class="d-flex align-items-center gap-1">
                    @if (Node.IsEntryPoint)
                    {
                        <i class="bi bi-flag-fill" style="font-size:.7rem; color:#198754;"></i>
                    }
                    <span class="text-truncate">@Node.ProcessName</span>
                </div>
                <div style="padding:0.4rem 0.75rem; font-size:0.75rem; color:#6c757d;">
                    <code>@Node.ProcessCode</code>
                </div>
                @if (Node.DetailLoaded)
                {
                    <div style="padding:0.15rem 0.75rem 0.3rem; font-size:0.65rem; display:flex; gap:0.35rem; flex-wrap:wrap;">
                        <span style="background:#e9ecef; border-radius:3px; padding:1px 5px;" title="Steps">
                            <i class="bi bi-layers" style="font-size:0.55rem;"></i> @Node.StepCount
                        </span>
                        <span style="background:#d1ecf1; border-radius:3px; padding:1px 5px;" title="Input ports">
                            <i class="bi bi-box-arrow-in-right" style="font-size:0.55rem;"></i> @Node.InputPortCount
                        </span>
                        <span style="background:#d4edda; border-radius:3px; padding:1px 5px;" title="Output ports">
                            <i class="bi bi-box-arrow-right" style="font-size:0.55rem;"></i> @Node.OutputPortCount
                        </span>
                    </div>
                    @if (Node.MaterialFlows.Any())
                    {
                        <div style="padding:0 0.75rem 0.3rem; font-size:0.58rem; display:flex; gap:2px; flex-wrap:wrap; max-height:2.5rem; overflow:hidden;">
                            @foreach (var mf in Node.MaterialFlows.Take(4))
                            {
                                <span style="background:@(mf.Direction == "IN" ? "#fff3cd" : "#cfe2ff");
                                             border-radius:2px; padding:0 3px; white-space:nowrap;"
                                      title="@mf.Direction: @mf.KindName / @mf.GradeName">
                                    @mf.Direction @mf.KindName/@mf.GradeName
                                </span>
                            }
                            @if (Node.MaterialFlows.Count > 4)
                            {
                                <span style="color:#6c757d;">+@(Node.MaterialFlows.Count - 4)</span>
                            }
                        </div>
                    }
                }
                else
                {
                    <div style="padding:0.15rem 0.75rem 0.3rem; font-size:0.6rem; color:#adb5bd;">
                        <span class="spinner-border spinner-border-sm" style="width:0.6rem; height:0.6rem;"></span>
                    </div>
                }
            </div>
        }

        @* Ports — absolutely positioned at card edges with pointer-events restored *@
        @foreach (var port in Node.Ports)
        {
            <div style="@GetPortStyle(port.Alignment) pointer-events:all;">
                <PortRenderer Port="port" Class="workflow-port" />
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public WorkflowProcessNodeModel Node { get; set; } = null!;

    private string BorderColor =>
        Node.IsTerminalNode ? "#dc3545"
        : !string.IsNullOrEmpty(Node.Color) ? Node.Color
        : Node.IsEntryPoint ? "#198754"
        : "#0d6efd";

    private string HeaderBg
    {
        get
        {
            if (Node.IsTerminalNode)
                return "#f8d7da"; // light red

            if (!string.IsNullOrEmpty(Node.Color))
            {
                // Lighten custom color for header background
                return Node.Color + "1A"; // 10% opacity via hex alpha
            }
            return Node.IsEntryPoint ? "#d1e7dd" : "#f0f5ff";
        }
    }

    private string GetPortStyle(PortAlignment alignment) => alignment switch
    {
        PortAlignment.Top    => "position:absolute; top:-7px; left:50%; transform:translateX(-50%); z-index:5;",
        PortAlignment.Bottom => "position:absolute; bottom:-7px; left:50%; transform:translateX(-50%); z-index:5;",
        PortAlignment.Left   => "position:absolute; left:-7px; top:50%; transform:translateY(-50%); z-index:5;",
        PortAlignment.Right  => "position:absolute; right:-7px; top:50%; transform:translateY(-50%); z-index:5;",
        _                    => ""
    };
}
