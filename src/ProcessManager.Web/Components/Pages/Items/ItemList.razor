@page "/items"
@rendermode InteractiveServer
@inject ApiClient Api

<PageTitle>Items</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Items</h3>
</div>

<div class="d-flex gap-3 mb-3 flex-wrap">
    <SearchBox Value="@_search" ValueChanged="OnSearch" Placeholder="Search by serial..." />
    <select class="form-select form-select-sm" style="width:auto" @onchange="OnStatusFilter">
        <option value="">All Statuses</option>
        <option value="Available">Available</option>
        <option value="InProcess">In Process</option>
        <option value="Consumed">Consumed</option>
        <option value="Scrapped">Scrapped</option>
    </select>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_data is not null)
{
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>Serial Number</th>
                    <th>Kind</th>
                    <th>Grade</th>
                    <th>Status</th>
                    <th>Job</th>
                    <th>Batch</th>
                    <th>Created</th>
                    <th style="width:80px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var i in _data.Items)
                {
                    <tr>
                        <td><a href="items/@i.Id"><code>@(i.SerialNumber ?? "—")</code></a></td>
                        <td>@i.KindName</td>
                        <td>@i.GradeName</td>
                        <td><StatusBadge Status="@i.Status" /></td>
                        <td><a href="jobs/@i.JobId">View</a></td>
                        <td>
                            @if (i.BatchId.HasValue)
                            {
                                <a href="batches/@i.BatchId.Value">@i.BatchId.Value.ToString()[..8]</a>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>@i.CreatedAt.ToString("g")</td>
                        <td>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(i.Id)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <Pager Page="_page" PageSize="_pageSize" TotalCount="_data.TotalCount"
           OnPageChanged="OnPageChanged" />
}

@if (_error is not null)
{
    <div class="alert alert-danger mt-3 py-2">@_error</div>
}

@code {
    private PaginatedResponse<ItemResponseDto>? _data;
    private bool _loading = true;
    private string _search = "";
    private string? _status;
    private int _page = 1;
    private int _pageSize = 25;
    private string? _error;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true; _error = null;
        _data = await Api.GetItemsAsync(_search, status: _status, page: _page, pageSize: _pageSize);
        _loading = false;
    }

    private async Task OnSearch(string v) { _search = v; _page = 1; await LoadData(); }
    private async Task OnPageChanged(int p) { _page = p; await LoadData(); }

    private async Task OnStatusFilter(ChangeEventArgs e)
    {
        _status = string.IsNullOrEmpty(e.Value?.ToString()) ? null : e.Value.ToString();
        _page = 1; await LoadData();
    }

    private async Task Delete(Guid id)
    {
        try { await Api.DeleteItemAsync(id); await LoadData(); }
        catch (HttpRequestException ex) { _error = ex.Message; }
    }
}
