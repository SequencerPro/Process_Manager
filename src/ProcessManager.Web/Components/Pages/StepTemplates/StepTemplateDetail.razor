    private void ClosePortForm() => _showPortForm = false;

    private async Task SavePort()
    {
        try
        {
            Guid? kindId = Guid.TryParse(_portKindId, out var k) ? k : null;
            Guid? gradeId = Guid.TryParse(_portGradeId, out var g) ? g : null;

            if (_portType == PortType.Material && (kindId is null || gradeId is null))
            {
                Toast.ShowError("Please select both a Kind and a Grade for Material ports.");
                return;
            }

            DataValueType? dataType = _portType is PortType.Parameter or PortType.Characteristic
                ? _portDataType : null;
            string? units = _portType is PortType.Parameter or PortType.Characteristic
                ? (string.IsNullOrEmpty(_portUnits) ? null : _portUnits) : null;
            string? nominal = _portType is PortType.Parameter or PortType.Characteristic
                ? (string.IsNullOrEmpty(_portNominalValue) ? null : _portNominalValue) : null;
            string? lower = _portType is PortType.Parameter or PortType.Characteristic
                ? (string.IsNullOrEmpty(_portLowerTolerance) ? null : _portLowerTolerance) : null;
            string? upper = _portType is PortType.Parameter or PortType.Characteristic
                ? (string.IsNullOrEmpty(_portUpperTolerance) ? null : _portUpperTolerance) : null;
            QuantityRuleMode? qtyMode = _portType == PortType.Material ? _portQtyMode : null;

            // Resolve qty rule numeric fields based on mode
            int? qtyN   = qtyMode is QuantityRuleMode.Exactly or QuantityRuleMode.ZeroOrN ? _portQtyRuleN : null;
            int? qtyMin = qtyMode is QuantityRuleMode.Range or QuantityRuleMode.Unbounded ? _portQtyRuleMin : null;
            int? qtyMax = qtyMode == QuantityRuleMode.Range ? _portQtyRuleMax : null;

            if (_editPortId.HasValue)
            {
                var dto = new PortUpdateDto(_portName, _portType,
                    kindId, gradeId, qtyMode, qtyN, qtyMin, qtyMax,
                    dataType, units, nominal, lower, upper, _portSortOrder);
                await Api.UpdatePortAsync(Id, _editPortId.Value, dto);
            }
            else
            {
                var dto = new PortCreateDto(_portName, _portDirection, _portType,
                    kindId, gradeId, qtyMode, qtyN, qtyMin, qtyMax,
                    dataType, units, nominal, lower, upper, _portSortOrder);
                await Api.CreatePortAsync(Id, dto);
            }
            _showPortForm = false;
            await LoadData();
        }
        catch (HttpRequestException ex) { Toast.ShowError(ex.Message); }
    }

