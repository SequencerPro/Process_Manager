@page "/items"
@rendermode InteractiveServer
@inject ApiClient Api

<PageTitle>Items</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">Items</h3>
    <button class="btn btn-primary btn-sm" @onclick="ShowCreateForm">
        <i class="bi bi-plus-lg me-1"></i> New Item
    </button>
</div>

<div class="d-flex gap-3 mb-3 flex-wrap">
    <SearchBox Value="@_search" ValueChanged="OnSearch" Placeholder="Search by serial..." />
    <select class="form-select form-select-sm" style="width:auto" @onchange="OnStatusFilter">
        <option value="">All Statuses</option>
        <option value="Available">Available</option>
        <option value="InProcess">In Process</option>
        <option value="Consumed">Consumed</option>
        <option value="Scrapped">Scrapped</option>
    </select>
</div>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_data is not null)
{
    <div class="table-responsive">
        <table class="table table-hover table-sm align-middle">
            <thead class="table-light">
                <tr>
                    <th>Serial Number</th>
                    <th>Kind</th>
                    <th>Grade</th>
                    <th>Status</th>
                    <th>Job</th>
                    <th>Batch</th>
                    <th>Created</th>
                    <th style="width:80px">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var i in _data.Items)
                {
                    <tr>
                        <td><a href="items/@i.Id"><code>@(i.SerialNumber ?? "—")</code></a></td>
                        <td>@i.KindName</td>
                        <td>@i.GradeName</td>
                        <td><StatusBadge Status="@i.Status" /></td>
                        <td><a href="jobs/@i.JobId">View</a></td>
                        <td>
                            @if (i.BatchId.HasValue)
                            {
                                <a href="batches/@i.BatchId.Value">@i.BatchId.Value.ToString()[..8]</a>
                            }
                            else
                            {
                                <span class="text-muted">—</span>
                            }
                        </td>
                        <td>@i.CreatedAt.ToString("g")</td>
                        <td>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(i.Id)">
                                <i class="bi bi-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <Pager Page="_page" PageSize="_pageSize" TotalCount="_data.TotalCount"
           OnPageChanged="OnPageChanged" />
}

@if (_error is not null)
{
    <div class="alert alert-danger mt-3 py-2">@_error</div>
}

@* Create Item Modal *@
@if (_showForm)
{
    <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">New Item</h5>
                    <button type="button" class="btn-close" @onclick="CloseForm"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Serial Number</label>
                        <input class="form-control" @bind="_formSerial" placeholder="Optional" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Job</label>
                        <select class="form-select" @bind="_formJobId">
                            <option value="">Select job...</option>
                            @if (_jobs is not null)
                            {
                                @foreach (var j in _jobs.Items)
                                {
                                    <option value="@j.Id">@j.Name (@j.Code)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Kind</label>
                        <select class="form-select" @bind="_formKindId" @bind:after="OnFormKindChanged">
                            <option value="">Select kind...</option>
                            @if (_kinds is not null)
                            {
                                @foreach (var k in _kinds.Items)
                                {
                                    <option value="@k.Id">@k.Name (@k.Code)</option>
                                }
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Grade</label>
                        <select class="form-select" @bind="_formGradeId">
                            <option value="">Select grade...</option>
                            @if (_formGrades is not null)
                            {
                                @foreach (var g in _formGrades)
                                {
                                    <option value="@g.Id">@g.Name (@g.Code)</option>
                                }
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CloseForm">Cancel</button>
                    <button class="btn btn-primary" @onclick="SaveForm">Create</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private PaginatedResponse<ItemResponseDto>? _data;
    private bool _loading = true;
    private string _search = "";
    private string? _status;
    private int _page = 1;
    private int _pageSize = 25;
    private string? _error;

    // Create form
    private bool _showForm;
    private string _formSerial = "";
    private string _formJobId = "";
    private string _formKindId = "";
    private string _formGradeId = "";
    private PaginatedResponse<JobResponseDto>? _jobs;
    private PaginatedResponse<KindResponseDto>? _kinds;
    private List<GradeResponseDto>? _formGrades;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true; _error = null;
        _data = await Api.GetItemsAsync(_search, status: _status, page: _page, pageSize: _pageSize);
        _loading = false;
    }

    private async Task OnSearch(string v) { _search = v; _page = 1; await LoadData(); }
    private async Task OnPageChanged(int p) { _page = p; await LoadData(); }

    private async Task OnStatusFilter(ChangeEventArgs e)
    {
        _status = string.IsNullOrEmpty(e.Value?.ToString()) ? null : e.Value.ToString();
        _page = 1; await LoadData();
    }

    private async Task ShowCreateForm()
    {
        _formSerial = ""; _formJobId = ""; _formKindId = ""; _formGradeId = "";
        _formGrades = null;
        _showForm = true;
        _jobs = await Api.GetJobsAsync(page: 1, pageSize: 100);
        _kinds = await Api.GetKindsAsync("", 1, 100);
        StateHasChanged();
    }

    private void CloseForm() => _showForm = false;

    private async Task OnFormKindChanged()
    {
        _formGrades = null; _formGradeId = "";
        if (Guid.TryParse(_formKindId, out var kindId))
        {
            var kind = await Api.GetKindAsync(kindId);
            _formGrades = kind?.Grades?.ToList();
        }
    }

    private async Task SaveForm()
    {
        try
        {
            if (!Guid.TryParse(_formJobId, out var jobId)) { _error = "Select a job."; return; }
            if (!Guid.TryParse(_formKindId, out var kindId)) { _error = "Select a kind."; return; }
            if (!Guid.TryParse(_formGradeId, out var gradeId)) { _error = "Select a grade."; return; }
            var serial = string.IsNullOrWhiteSpace(_formSerial) ? null : _formSerial.Trim();
            await Api.CreateItemAsync(new CreateItemDto(kindId, gradeId, jobId, serial));
            _showForm = false; _error = null;
            await LoadData();
        }
        catch (HttpRequestException ex) { _error = ex.Message; }
    }

    private async Task Delete(Guid id)
    {
        try { await Api.DeleteItemAsync(id); await LoadData(); }
        catch (HttpRequestException ex) { _error = ex.Message; }
    }
}
