@page "/admin/users"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin")]
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using ProcessManager.Api.DTOs
@inject ApiClient Api
@inject TokenService TokenService

<PageTitle>Users — Process Manager</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="mb-0"><i class="bi bi-people me-2 text-primary"></i>Users</h3>
        <p class="text-muted small mb-0">Manage who can access Process Manager</p>
    </div>
    <button class="btn btn-primary" @onclick="() => ShowAddModal = true">
        <i class="bi bi-person-plus me-1"></i> Add User
    </button>
</div>

@if (ErrorMessage is not null)
{
    <div class="alert alert-danger alert-dismissible">
        <i class="bi bi-exclamation-triangle me-2"></i>@ErrorMessage
        <button type="button" class="btn-close" @onclick="() => ErrorMessage = null"></button>
    </div>
}
@if (SuccessMessage is not null)
{
    <div class="alert alert-success alert-dismissible">
        <i class="bi bi-check-circle me-2"></i>@SuccessMessage
        <button type="button" class="btn-close" @onclick="() => SuccessMessage = null"></button>
    </div>
}

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Display Name</th>
                    <th>Role</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Users is null)
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">
                        <div class="spinner-border spinner-border-sm me-2"></div>Loading…
                    </td></tr>
                }
                else if (!Users.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">No users found.</td></tr>
                }
                else
                {
                    @foreach (var user in Users)
                    {
                        <tr>
                            <td class="align-middle fw-medium">
                                <i class="bi bi-person-circle me-1 text-secondary"></i>
                                @user.UserName
                                @if (user.UserName == TokenService.UserName)
                                {
                                    <span class="badge bg-secondary ms-1">you</span>
                                }
                            </td>
                            <td class="align-middle text-muted">@user.Email</td>
                            <td class="align-middle text-muted">@(user.DisplayName ?? "—")</td>
                            <td class="align-middle">
                                <span class="badge @(user.Role == "Admin" ? "bg-danger" : "bg-primary")">
                                    @user.Role
                                </span>
                            </td>
                            <td class="align-middle text-end">
                                @if (user.UserName != TokenService.UserName)
                                {
                                    <button class="btn btn-sm btn-outline-danger"
                                            @onclick="() => ConfirmDelete(user)">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@* ── Add User Modal ─────────────────────────────────────────────────────── *@
@if (ShowAddModal)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-person-plus me-2"></i>Add User</h5>
                    <button type="button" class="btn-close" @onclick="CloseAddModal"></button>
                </div>
                <EditForm Model="NewUser" OnValidSubmit="HandleAddUser">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        @if (AddError is not null)
                        {
                            <div class="alert alert-danger py-2">@AddError</div>
                        }
                        <div class="mb-3">
                        <label class="form-label fw-medium">Username <span class="text-danger">*</span></label>
                        <InputText class="form-control" @bind-Value="NewUser.UserName" />
                        <ValidationMessage For="() => NewUser.UserName" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Email <span class="text-danger">*</span></label>
                        <InputText type="email" class="form-control" @bind-Value="NewUser.Email" />
                        <ValidationMessage For="() => NewUser.Email" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Password <span class="text-danger">*</span></label>
                        <InputText type="password" class="form-control" @bind-Value="NewUser.Password" />
                        <ValidationMessage For="() => NewUser.Password" />
                        <div class="form-text">Minimum 8 characters.</div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-medium">Role <span class="text-danger">*</span></label>
                        <InputSelect class="form-select" @bind-Value="NewUser.Role">
                            <option value="Engineer">Engineer</option>
                            <option value="Admin">Admin</option>
                        </InputSelect>
                    </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="CloseAddModal">Cancel</button>
                        <button type="submit" class="btn btn-primary" disabled="@AddSaving">
                            @if (AddSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                            Create User
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@* ── Delete Confirm Modal ───────────────────────────────────────────────── *@
@if (UserToDelete is not null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background:rgba(0,0,0,.5)">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header border-0">
                    <h5 class="modal-title text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Delete User</h5>
                    <button type="button" class="btn-close" @onclick="() => UserToDelete = null"></button>
                </div>
                <div class="modal-body">
                    Are you sure you want to delete <strong>@UserToDelete.UserName</strong>?
                    This cannot be undone.
                </div>
                <div class="modal-footer border-0">
                    <button class="btn btn-secondary" @onclick="() => UserToDelete = null">Cancel</button>
                    <button class="btn btn-danger" @onclick="HandleDeleteUser" disabled="@DeleteSaving">
                        @if (DeleteSaving) { <span class="spinner-border spinner-border-sm me-1"></span> }
                        Delete
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    // ── Mutable form model (records are init-only; Blazor bind needs setters) ──
    private class NewUserModel
    {
        [Required][StringLength(50)] public string UserName { get; set; } = "";
        [Required][EmailAddress]     public string Email    { get; set; } = "";
        [Required][StringLength(100, MinimumLength = 8)] public string Password { get; set; } = "";
        [Required]                   public string Role     { get; set; } = "Engineer";
    }

    private List<UserResponseDto>? Users;
    private string? ErrorMessage;
    private string? SuccessMessage;

    // Add modal
    private bool ShowAddModal;
    private bool AddSaving;
    private string? AddError;
    private NewUserModel NewUser = new();

    // Delete modal
    private UserResponseDto? UserToDelete;
    private bool DeleteSaving;

    protected override async Task OnInitializedAsync() => await LoadUsers();

    private async Task LoadUsers()
    {
        try { Users = await Api.GetUsersAsync(); }
        catch (Exception ex) { ErrorMessage = $"Failed to load users: {ex.Message}"; }
    }

    private void ConfirmDelete(UserResponseDto user) { UserToDelete = user; }

    private async Task HandleDeleteUser()
    {
        if (UserToDelete is null) return;
        DeleteSaving = true;
        try
        {
            await Api.DeleteUserAsync(UserToDelete.Id);
            SuccessMessage = $"User '{UserToDelete.UserName}' deleted.";
            UserToDelete = null;
            await LoadUsers();
        }
        catch (Exception ex) { ErrorMessage = $"Delete failed: {ex.Message}"; }
        finally { DeleteSaving = false; }
    }

    private void CloseAddModal()
    {
        ShowAddModal = false;
        AddError = null;
        NewUser = new();
    }

    private async Task HandleAddUser()
    {
        AddSaving = true;
        AddError = null;
        try
        {
            var dto = new RegisterRequestDto(NewUser.UserName, NewUser.Email, NewUser.Password, NewUser.Role);
            await Api.RegisterUserAsync(dto);
            SuccessMessage = $"User '{NewUser.UserName}' created.";
            CloseAddModal();
            await LoadUsers();
        }
        catch (HttpRequestException ex) { AddError = $"Failed to create user: {ex.Message}"; }
        catch (Exception ex) { AddError = ex.Message; }
        finally { AddSaving = false; }
    }
}
