@page "/warehouse"
@rendermode InteractiveServer
@attribute [Authorize(Roles = "Admin,Engineer")]
@inject ApiClient Api
@inject NavigationManager Nav
@inject TokenService TokenService
@using Microsoft.AspNetCore.Authorization
@using ProcessManager.Api.DTOs
@using ProcessManager.Web.Services

<PageTitle>Warehouse Dashboard</PageTitle>

<h3 class="mb-4"><i class="bi bi-box-seam me-2"></i>Warehouse Dashboard</h3>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border" role="status"><span class="visually-hidden">Loading...</span></div></div>
}
else if (_dashboard is null)
{
    <div class="alert alert-danger">Failed to load warehouse dashboard.</div>
}
else
{
    @* ── KPI Cards ── *@
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card text-bg-primary h-100">
                <div class="card-body">
                    <h6 class="card-title text-uppercase small opacity-75">Total Locations</h6>
                    <h2 class="mb-0">@_dashboard.TotalLocations</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-success h-100">
                <div class="card-body">
                    <h6 class="card-title text-uppercase small opacity-75">Items On Hand</h6>
                    <h2 class="mb-0">@_dashboard.TotalItemsOnHand</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-warning h-100">
                <div class="card-body">
                    <h6 class="card-title text-uppercase small opacity-75">Low Stock Kinds</h6>
                    <h2 class="mb-0">@_dashboard.LowStockKindCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-bg-info h-100">
                <div class="card-body">
                    <h6 class="card-title text-uppercase small opacity-75">Pending Pick Lists</h6>
                    <h2 class="mb-0">@_dashboard.PendingPickLists</h2>
                </div>
            </div>
        </div>
    </div>

    @* ── Low Stock Table ── *@
    <div class="card mb-4">
        <div class="card-header"><i class="bi bi-exclamation-triangle me-2"></i>Low Stock</div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Kind Code</th>
                            <th>Kind Name</th>
                            <th>On Hand</th>
                            <th>Reorder Threshold</th>
                            <th>Reorder Qty</th>
                            <th>UoM</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_dashboard.LowStockKinds is { Count: > 0 })
                        {
                            @foreach (var item in _dashboard.LowStockKinds)
                            {
                                <tr>
                                    <td>@item.KindCode</td>
                                    <td>@item.KindName</td>
                                    <td>@item.OnHand</td>
                                    <td>@item.ReorderThreshold</td>
                                    <td>@item.ReorderQuantity</td>
                                    <td>@item.UnitOfMeasure</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="6" class="text-muted text-center py-3">No low-stock items.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* ── Recent Transactions Table ── *@
    <div class="card">
        <div class="card-header"><i class="bi bi-arrow-left-right me-2"></i>Recent Transactions</div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-striped table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Type</th>
                            <th>Kind Code</th>
                            <th>Serial #</th>
                            <th>From</th>
                            <th>To</th>
                            <th>Quantity</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (_dashboard.RecentTransactions is { Count: > 0 })
                        {
                            @foreach (var tx in _dashboard.RecentTransactions)
                            {
                                <tr>
                                    <td><span class="badge bg-secondary">@tx.TransactionType</span></td>
                                    <td>@tx.KindCode</td>
                                    <td>@tx.ItemSerialNumber</td>
                                    <td>@tx.FromLocationCode</td>
                                    <td>@tx.ToLocationCode</td>
                                    <td>@tx.Quantity</td>
                                    <td>@tx.TransactedAt.ToString("g")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="7" class="text-muted text-center py-3">No recent transactions.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private bool _loading = true;
    private WarehouseDashboardDto? _dashboard;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _dashboard = await Api.GetWarehouseDashboardAsync();
        }
        catch { /* handled by null check */ }
        finally
        {
            _loading = false;
        }
    }
}
