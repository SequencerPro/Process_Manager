@page "/step-templates/{Id:guid}"
@rendermode InteractiveServer
@inject ApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Step Template Detail</PageTitle>

@if (_loading)
{
    <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
}
else if (_st is null)
{
    <div class="alert alert-warning">Step template not found.</div>
}
else
{
    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a href="step-templates">Step Templates</a></li>
            <li class="breadcrumb-item active">@_st.Name</li>
        </ol>
    </nav>

    <div class="card mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <div>
                    <h4 class="mb-1">@_st.Name</h4>
                    <span class="text-muted me-3"><code>@_st.Code</code></span>
                    <span class="badge bg-info text-dark me-1">@_st.Pattern</span>
                    <span class="badge me-1 @(_st.IsActive ? "bg-success" : "bg-secondary")">@(_st.IsActive ? "Active" : "Inactive")</span>
                    <span class="badge bg-dark">v@_st.Version</span>
                    <span class="badge @StatusBadgeClass(_st.Status) ms-1">@_st.Status</span>
                    @if (_st.Maturity is not null)
                    {
                        <span class="badge @MaturityBadgeClass(_st.Maturity.Level) ms-1" title="Maturity score @_st.Maturity.Score/100">
                            <i class="bi bi-clipboard-check me-1"></i>@_st.Maturity.Level (@_st.Maturity.Score)
                        </span>
                    }
                </div>
                <div class="d-flex gap-1">
                    <button class="btn btn-outline-secondary btn-sm" @onclick="ShowEditForm">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </button>
                    @if (_st.Status == "Draft")
                    {
                        <button class="btn btn-outline-primary btn-sm" @onclick="() => _showSubmitModal = true">
                            <i class="bi bi-send me-1"></i>Submit
                        </button>
                    }
                    else if (_st.Status == "PendingApproval")
                    {
                        <button class="btn btn-success btn-sm" @onclick="() => _showApproveModal = true">
                            <i class="bi bi-check-circle me-1"></i>Approve
                        </button>
                        <button class="btn btn-warning btn-sm" @onclick="() => _showRejectModal = true">
                            <i class="bi bi-x-circle me-1"></i>Reject
                        </button>
                    }
                    else if (_st.Status == "Released")
                    {
                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => _showNewRevisionModal = true">
                            <i class="bi bi-arrow-clockwise me-1"></i>New Revision
                        </button>
                    }
                    <button class="btn btn-outline-danger btn-sm" @onclick="Delete">
                        <i class="bi bi-trash me-1"></i>Delete
                    </button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_st.Description))
            {
                <p class="mb-2">@_st.Description</p>
            }
            <small class="text-muted">Created @_st.CreatedAt.ToString("g") &bull; Updated @_st.UpdatedAt.ToString("g")</small>
        </div>
    </div>

    @* Maturity Panel *@
    @if (_st.Maturity is not null)
    {
        <div class="d-flex align-items-center gap-3 flex-wrap mb-3 px-1">
            <span class="fw-semibold small text-muted">MATURITY</span>
            <div class="progress flex-grow-1" style="height:8px;max-width:220px">
                <div class="progress-bar @MaturityProgressBarClass(_st.Maturity.Level)"
                     role="progressbar" style="width:@(_st.Maturity.Score)%"></div>
            </div>
            <span class="small">@_st.Maturity.Score / 100</span>
            @if (_st.Maturity.HasBlockingErrors)
            {
                <span class="badge bg-danger"><i class="bi bi-exclamation-triangle me-1"></i>Errors present</span>
            }
            <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleMaturityPanel">
                @(_showMaturityPanel ? "Hide Report" : "Maturity Report")
            </button>
        </div>

        @if (_showMaturityPanel)
        {
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center py-2">
                    <span><i class="bi bi-clipboard-check me-1"></i>Maturity Rules</span>
                    @if (_maturityLoading) { <span class="spinner-border spinner-border-sm text-secondary"></span> }
                </div>
                <div class="card-body p-0">
                    @if (_maturityReport is not null)
                    {
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr><th style="width:36px"></th><th>Rule</th><th class="d-none d-md-table-cell">Remediation</th></tr>
                            </thead>
                            <tbody>
                                @foreach (var rule in _maturityReport.Rules)
                                {
                                    <tr class="@(rule.Outcome == MaturityRuleOutcome.Fail ? "table-danger" : rule.Outcome == MaturityRuleOutcome.Warn ? "table-warning" : "")">
                                        <td class="text-center">
                                            @if (rule.Outcome == MaturityRuleOutcome.Pass)
                                            { <i class="bi bi-check-circle-fill text-success"></i> }
                                            else if (rule.Outcome == MaturityRuleOutcome.Warn)
                                            { <i class="bi bi-exclamation-circle-fill text-warning"></i> }
                                            else
                                            { <i class="bi bi-x-circle-fill text-danger"></i> }
                                        </td>
                                        <td><small>@rule.Description</small></td>
                                        <td class="d-none d-md-table-cell"><small class="text-muted">@rule.RemediationHint</small></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        }
    }

    <!-- Input Ports -->

    <div class="row">
        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-box-arrow-in-right text-success me-1"></i> Input Ports (@InputPorts.Count)</span>
                    <button class="btn btn-success btn-sm" @onclick='() => ShowPortForm(PortDirection.Input)'>
                        <i class="bi bi-plus-lg"></i>
                    </button>
                </div>
                @if (InputPorts.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr><th>Name</th><th>Type</th><th>Details</th><th></th></tr>
                            </thead>
                            <tbody>
                                @foreach (var p in InputPorts)
                                {
                                    <tr>
                                        <td>@p.Name</td>
                                        <td><span class="badge @PortTypeBadgeClass(p.PortType)">@p.PortType</span></td>
                                        <td>
                                            @PortDetails(p)
                                            @if (p.PortType == PortType.Material)
                                            {
                                                <span class="text-muted ms-1 small">(@FormatQtyRule(p))</span>
                                            }
                                        </td>
                                        <td>
                                            <button class="btn btn-outline-secondary btn-sm py-0 px-1 me-1" @onclick="() => ShowEditPort(p)" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-outline-danger btn-sm py-0 px-1" @onclick="() => DeletePort(p)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="card-body text-muted small">No input ports defined.</div>
                }
            </div>
        </div>

        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-box-arrow-right text-primary me-1"></i> Output Ports (@OutputPorts.Count)</span>
                    <button class="btn btn-primary btn-sm" @onclick='() => ShowPortForm(PortDirection.Output)'>
                        <i class="bi bi-plus-lg"></i>
                    </button>
                </div>
                @if (OutputPorts.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm mb-0">
                            <thead class="table-light">
                                <tr><th>Name</th><th>Type</th><th>Details</th><th></th></tr>
                            </thead>
                            <tbody>
                                @foreach (var p in OutputPorts)
                                {
                                    <tr>
                                        <td>@p.Name</td>
                                        <td><span class="badge @PortTypeBadgeClass(p.PortType)">@p.PortType</span></td>
                                        <td>
                                            @PortDetails(p)
                                            @if (p.PortType == PortType.Material)
                                            {
                                                <span class="text-muted ms-1 small">(@FormatQtyRule(p))</span>
                                            }
                                        </td>
                                        <td>
                                            <button class="btn btn-outline-secondary btn-sm py-0 px-1 me-1" @onclick="() => ShowEditPort(p)" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-outline-danger btn-sm py-0 px-1" @onclick="() => DeletePort(p)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="card-body text-muted small">No output ports defined.</div>
                }
            </div>
        </div>
    </div>

    @* Work Instructions *@
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-card-text me-1"></i> Work Instructions (@_contentBlocks.Count)</span>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-secondary btn-sm" @onclick="StartAddTextBlock"
                        disabled="@(_addingTextBlock || _addingPromptBlock)">
                    <i class="bi bi-text-paragraph me-1"></i>Add Text
                </button>
                <button class="btn btn-outline-primary btn-sm" @onclick="StartAddPromptBlock"
                        disabled="@(_addingTextBlock || _addingPromptBlock)">
                    <i class="bi bi-input-cursor-text me-1"></i>Add Prompt
                </button>
                <label class="btn btn-outline-secondary btn-sm mb-0" style="cursor:pointer" title="Add image block">
                    <i class="bi bi-image me-1"></i>Add Image
                    <InputFile OnChange="AddImageBlock" accept="image/*" class="d-none" />
                </label>
            </div>
        </div>

        <div class="card-body">
            @if (_contentLoading)
            {
                <div class="text-center py-3"><span class="spinner-border spinner-border-sm text-secondary me-2"></span>Loading…</div>
            }
            else
            {
                @if (_contentError is not null)
                {
                    <div class="alert alert-danger py-2 mb-3">@_contentError
                        <button type="button" class="btn-close float-end py-0" @onclick='() => _contentError = null'></button>
                    </div>
                }

                @if (_contentBlocks.Count == 0 && !_addingTextBlock && !_addingPromptBlock)
                {
                    <p class="text-muted small mb-0">No instructions added yet. Use the buttons above to add text or image blocks.</p>
                }

                @foreach (var block in _contentBlocks.OrderBy(b => b.SortOrder))
                {
                    var isFirst = block.SortOrder == _contentBlocks.Min(b => b.SortOrder);
                    var isLast = block.SortOrder == _contentBlocks.Max(b => b.SortOrder);

                    <div class="border rounded p-2 mb-2 bg-white">
                        <div class="d-flex align-items-start gap-2">
                            <div class="flex-grow-1">
                                @if (block.ContentType == "Text")
                                {
                                    @if (_editingTextBlockId == block.Id)
                                    {
                                        <textarea class="form-control form-control-sm mb-1" rows="4"
                                                  @bind="_editingTextBody"></textarea>
                                        <div class="mb-1">
                                            <label class="form-label form-label-sm">Category</label>
                                            <select class="form-select form-select-sm" @bind="_editTextCategory">
                                                <option value="">None</option>
                                                <option value="Setup">Setup</option>
                                                <option value="Safety">Safety</option>
                                                <option value="Inspection">Inspection</option>
                                                <option value="Reference">Reference</option>
                                                <option value="Note">Note</option>
                                            </select>
                                        </div>
                                        <div class="d-flex gap-1">
                                            <button class="btn btn-primary btn-sm" @onclick="SaveEditedTextBlock">Save</button>
                                            <button class="btn btn-outline-secondary btn-sm" @onclick="CancelEditTextBlock">Cancel</button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-start gap-2 flex-wrap">
                                            @if (!string.IsNullOrEmpty(block.ContentCategory))
                                            {
                                                <span class="badge @ContentCategoryBadgeClass(block.ContentCategory) flex-shrink-0">@block.ContentCategory</span>
                                            }
                                            @if (block.AcknowledgmentRequired)
                                            {
                                                <span class="badge bg-warning text-dark flex-shrink-0"><i class="bi bi-hand-index me-1"></i>Ack</span>
                                            }
                                        </div>
                                        <p class="mb-0 mt-1" style="white-space: pre-wrap">@block.Body</p>
                                    }
                                }
                                else if (block.ContentType == "Image")
                                {
                                    <div class="d-flex align-items-center gap-2 flex-wrap">
                                        <img src="@Api.GetImageUrl(block.ImageUrl!)"
                                             style="height:64px;width:auto;object-fit:cover;border-radius:4px"
                                             alt="@block.OriginalFileName" />
                                        <div>
                                            <span class="text-muted small text-truncate d-block" style="max-width:200px"
                                                  title="@block.OriginalFileName">@block.OriginalFileName</span>
                                            @if (!string.IsNullOrEmpty(block.ContentCategory))
                                            {
                                                <span class="badge @ContentCategoryBadgeClass(block.ContentCategory) mt-1">@block.ContentCategory</span>
                                            }
                                        </div>
                                    </div>
                                }
                                else if (block.ContentType == "Prompt")
                                {
                                    @if (_editingPromptBlockId == block.Id)
                                    {
                                        <div class="mb-2">
                                            <label class="form-label form-label-sm fw-semibold">Question / Label</label>
                                            <input class="form-control form-control-sm" @bind="_editPromptLabel" />
                                        </div>
                                        @if (_editPromptType == "NumericEntry")
                                        {
                                            <div class="row g-2 mb-2">
                                                <div class="col-3">
                                                    <label class="form-label form-label-sm">LSL (Min)</label>
                                                    <input class="form-control form-control-sm" @bind="_editPromptMin" placeholder="no min" />
                                                </div>
                                                <div class="col-3">
                                                    <label class="form-label form-label-sm">Nominal</label>
                                                    <input class="form-control form-control-sm" @bind="_editPromptNominal" placeholder="target" />
                                                </div>
                                                <div class="col-3">
                                                    <label class="form-label form-label-sm">USL (Max)</label>
                                                    <input class="form-control form-control-sm" @bind="_editPromptMax" placeholder="no max" />
                                                </div>
                                                <div class="col-3">
                                                    <label class="form-label form-label-sm">Units</label>
                                                    <input class="form-control form-control-sm" @bind="_editPromptUnits" placeholder="mm, rpm…" />
                                                </div>
                                            </div>
                                            <div class="form-check mb-2">
                                                <input type="checkbox" class="form-check-input" id="editHardLimit" @bind="_editPromptIsHardLimit" />
                                                <label class="form-check-label small" for="editHardLimit">
                                                    <span class="badge bg-danger me-1">Hard Limit</span> Block sign-off on out-of-spec response
                                                </label>
                                            </div>
                                        }
                                        @if (_editPromptType == "MultipleChoice")
                                        {
                                            <div class="mb-2">
                                                <label class="form-label form-label-sm">Choices <span class="text-muted">(one per line)</span></label>
                                                <textarea class="form-control form-control-sm" rows="3" @bind="_editPromptChoicesRaw"></textarea>
                                            </div>
                                        }
                                        <div class="mb-2">
                                            <label class="form-label form-label-sm">Category</label>
                                            <select class="form-select form-select-sm" @bind="_editPromptCategory">
                                                <option value="">None</option>
                                                <option value="Setup">Setup</option>
                                                <option value="Safety">Safety (requires acknowledgment)</option>
                                                <option value="Inspection">Inspection</option>
                                                <option value="Reference">Reference</option>
                                                <option value="Note">Note</option>
                                            </select>
                                        </div>
                                        <div class="form-check mb-2">
                                            <input type="checkbox" class="form-check-input" @bind="_editPromptRequired" />
                                            <label class="form-check-label small">Required</label>
                                        </div>
                                        <div class="d-flex gap-1">
                                            <button class="btn btn-primary btn-sm" @onclick="SaveEditedPromptBlock">Save</button>
                                            <button class="btn btn-outline-secondary btn-sm" @onclick="CancelEditPromptBlock">Cancel</button>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-start gap-2">
                                            <i class="bi bi-input-cursor-text text-primary mt-1" style="font-size:1.1rem;flex-shrink:0"></i>
                                            <div>
                                                <div class="fw-semibold">@block.Label</div>
                                                <div class="d-flex flex-wrap gap-1 mt-1">
                                                    <span class="badge bg-info text-dark">@block.PromptType</span>
                                                    @if (block.IsRequired)
                                                    {
                                                        <span class="badge bg-warning text-dark">Required</span>
                                                    }
                                                    @if (!string.IsNullOrEmpty(block.Units))
                                                    {
                                                        <span class="badge bg-light text-dark border">@block.Units</span>
                                                    }
                                                    @if (block.MinValue.HasValue || block.MaxValue.HasValue)
                                                    {
                                                        <span class="badge bg-light text-dark border">LSL @block.MinValue – USL @block.MaxValue</span>
                                                    }
                                                    @if (block.NominalValue.HasValue)
                                                    {
                                                        <span class="badge bg-success text-white">Nom @block.NominalValue</span>
                                                    }
                                                    @if (block.IsHardLimit)
                                                    {
                                                        <span class="badge bg-danger">Hard Limit</span>
                                                    }
                                                    @if (!string.IsNullOrEmpty(block.ContentCategory))
                                                    {
                                                        <span class="badge @ContentCategoryBadgeClass(block.ContentCategory)">@block.ContentCategory</span>
                                                    }
                                                    @if (block.AcknowledgmentRequired)
                                                    {
                                                        <span class="badge bg-warning text-dark"><i class="bi bi-hand-index me-1"></i>Ack</span>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                            <div class="d-flex flex-column gap-1 ms-2 flex-shrink-0">
                                @if (block.ContentType == "Text" && _editingTextBlockId != block.Id)
                                {
                                    <button class="btn btn-outline-secondary btn-sm py-0 px-1" title="Edit"
                                            @onclick="() => StartEditTextBlock(block)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                }
                                @if (block.ContentType == "Prompt" && _editingPromptBlockId != block.Id)
                                {
                                    <button class="btn btn-outline-secondary btn-sm py-0 px-1" title="Edit prompt"
                                            @onclick="() => StartEditPromptBlock(block)">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                }
                                <button class="btn btn-outline-secondary btn-sm py-0 px-1" title="Move up"
                                        disabled="@isFirst"
                                        @onclick="() => MoveBlock(block, -1)">
                                    <i class="bi bi-arrow-up"></i>
                                </button>
                                <button class="btn btn-outline-secondary btn-sm py-0 px-1" title="Move down"
                                        disabled="@isLast"
                                        @onclick="() => MoveBlock(block, 1)">
                                    <i class="bi bi-arrow-down"></i>
                                </button>
                                <button class="btn btn-outline-danger btn-sm py-0 px-1" title="Delete"
                                        @onclick="() => DeleteContentBlock(block)">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                }

                @if (_addingTextBlock)
                {
                    <div class="border rounded p-2 bg-light mt-2">
                        <label class="form-label small fw-semibold mb-1">New Text Block</label>
                        <textarea class="form-control form-control-sm mb-2" rows="4"
                                  @bind="_newTextBody" placeholder="Enter instructions…"></textarea>
                        <div class="mb-2">
                            <label class="form-label small fw-semibold mb-1">Category</label>
                            <select class="form-select form-select-sm" @bind="_newTextCategory">
                                <option value="">None</option>
                                <option value="Setup">Setup — preparation before work begins</option>
                                <option value="Safety">Safety — hazards; PPE; stop conditions</option>
                                <option value="Inspection">Inspection — visual or measurement checks</option>
                                <option value="Reference">Reference — background information; diagrams</option>
                                <option value="Note">Note — engineering notes and caveats</option>
                            </select>
                        </div>
                        <div class="d-flex gap-1">
                            <button class="btn btn-primary btn-sm" @onclick="SaveNewTextBlock">Add Block</button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => { _addingTextBlock = false; _newTextBody = string.Empty; _newTextCategory = string.Empty; }">Cancel</button>
                        </div>
                    </div>
                }

                @if (_addingPromptBlock)
                {
                    <div class="border border-primary rounded p-2 bg-light mt-2">
                        <label class="form-label small fw-semibold mb-2"><i class="bi bi-input-cursor-text me-1 text-primary"></i>New Prompt Block</label>
                        <div class="mb-2">
                            <label class="form-label form-label-sm">Question / Label <span class="text-danger">*</span></label>
                            <input class="form-control form-control-sm" @bind="_newPromptLabel" placeholder="e.g. Measure outer diameter at point A" />
                        </div>
                        <div class="mb-2">
                            <label class="form-label form-label-sm">Prompt Type</label>
                            <select class="form-select form-select-sm" @bind="_newPromptType">
                                <option value="NumericEntry">Numeric Entry (number + optional bounds)</option>
                                <option value="PassFail">Pass / Fail</option>
                                <option value="MultipleChoice">Multiple Choice</option>
                                <option value="TextEntry">Text Entry (free form)</option>
                                <option value="Checkbox">Checkbox (tick)</option>
                                <option value="Scan">Scan (barcode / serial)</option>
                            </select>
                        </div>
                        @if (_newPromptType == "NumericEntry")
                        {
                            <div class="row g-2 mb-2">
                                <div class="col-3">
                                    <label class="form-label form-label-sm">LSL (Min)</label>
                                    <input class="form-control form-control-sm" @bind="_newPromptMin" placeholder="no min" />
                                </div>
                                <div class="col-3">
                                    <label class="form-label form-label-sm">Nominal</label>
                                    <input class="form-control form-control-sm" @bind="_newPromptNominal" placeholder="target" />
                                </div>
                                <div class="col-3">
                                    <label class="form-label form-label-sm">USL (Max)</label>
                                    <input class="form-control form-control-sm" @bind="_newPromptMax" placeholder="no max" />
                                </div>
                                <div class="col-3">
                                    <label class="form-label form-label-sm">Units</label>
                                    <input class="form-control form-control-sm" @bind="_newPromptUnits" placeholder="mm, rpm…" />
                                </div>
                            </div>
                            <div class="form-check mb-2">
                                <input type="checkbox" class="form-check-input" id="newHardLimit" @bind="_newPromptIsHardLimit" />
                                <label class="form-check-label small" for="newHardLimit">
                                    <span class="badge bg-danger me-1">Hard Limit</span> Out-of-spec response blocks sign-off and triggers non-conformance disposition
                                </label>
                            </div>
                        }
                        @if (_newPromptType == "MultipleChoice")
                        {
                            <div class="mb-2">
                                <label class="form-label form-label-sm">Choices <span class="text-muted">(one per line)</span></label>
                                <textarea class="form-control form-control-sm" rows="3" @bind="_newPromptChoicesRaw"
                                          placeholder="Option A&#10;Option B&#10;Option C"></textarea>
                            </div>
                        }
                        <div class="mb-2">
                            <label class="form-label form-label-sm">Category</label>
                            <select class="form-select form-select-sm" @bind="_newPromptCategory">
                                <option value="">None</option>
                                <option value="Setup">Setup</option>
                                <option value="Safety">Safety (requires acknowledgment)</option>
                                <option value="Inspection">Inspection</option>
                                <option value="Reference">Reference</option>
                                <option value="Note">Note</option>
                            </select>
                        </div>
                        <div class="form-check mb-2">
                            <input type="checkbox" class="form-check-input" @bind="_newPromptRequired" />
                            <label class="form-check-label small">Required (operator must answer before completing step)</label>
                        </div>
                        <div class="d-flex gap-1">
                            <button class="btn btn-primary btn-sm" @onclick="SaveNewPromptBlock">Add Prompt</button>
                            <button class="btn btn-outline-secondary btn-sm" @onclick="() => _addingPromptBlock = false">Cancel</button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    @* Run Charts *@
    <div class="card mb-4">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="bi bi-graph-up me-1"></i> Run Charts (@_runChartWidgets.Count)</span>
            <button class="btn btn-outline-primary btn-sm" @onclick="ShowAddChartPicker">
                <i class="bi bi-plus-lg"></i>
            </button>
        </div>
        <div class="card-body">
            @if (_chartsLoading)
            {
                <div class="text-center py-3"><span class="spinner-border spinner-border-sm"></span></div>
            }
            else if (_runChartWidgets.Count == 0)
            {
                <p class="text-muted small mb-0">No run charts configured. Add one so operators can see trend data from any numeric prompt during step execution — including data collected in a different step or process.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Label</th>
                                <th>Source</th>
                                <th>Window</th>
                                <th>Spec Limits</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var w in _runChartWidgets)
                            {
                                <tr>
                                    <td><strong>@w.Label</strong></td>
                                    <td>
                                        <span class="small">
                                            <code>@w.SourceStepTemplateCode</code> — @w.SourceStepTemplateName
                                            <br /><span class="text-muted">@w.SourcePromptLabel @(!string.IsNullOrEmpty(w.SourceUnits) ? $"({w.SourceUnits})" : "")</span>
                                        </span>
                                    </td>
                                    <td>@w.ChartWindowSize</td>
                                    <td>
                                        @if (w.SpecMin.HasValue || w.SpecMax.HasValue)
                                        {
                                            <span>@(w.SpecMin?.ToString() ?? "—") – @(w.SpecMax?.ToString() ?? "—")</span>
                                        }
                                        else if (w.SourceSpecMin.HasValue || w.SourceSpecMax.HasValue)
                                        {
                                            <span class="text-muted small">@(w.SourceSpecMin?.ToString() ?? "—") – @(w.SourceSpecMax?.ToString() ?? "—") <em>(inherited)</em></span>
                                        }
                                        else { <span class="text-muted">—</span> }
                                    </td>
                                    <td>
                                        <button class="btn btn-outline-secondary btn-sm py-0 px-1 me-1"
                                                @onclick="() => ShowEditChart(w)" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm py-0 px-1"
                                                @onclick="() => DeleteChart(w)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>

    @* Add / Edit Port Modal *@
    @if (_showPortForm)
    {
        <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">@(_editPortId.HasValue ? "Edit" : "Add @_portDirection") Port</h5>
                        <button type="button" class="btn-close" @onclick="ClosePortForm"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <input class="form-control" @bind="_portName" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Port Type</label>
                            <select class="form-select" @bind="_portType">
                                @foreach (var t in Enum.GetValues<PortType>())
                                {
                                    <option value="@t">@t</option>
                                }
                            </select>
                        </div>

                        @if (_portType == PortType.Material)
                        {
                            <div class="row mb-3">
                                <div class="col-6">
                                    <label class="form-label">Kind</label>
                                    <select class="form-select" @bind="_portKindId">
                                        <option value="">Select...</option>
                                        @if (_kinds is not null)
                                        {
                                            @foreach (var k in _kinds.Items)
                                            {
                                                <option value="@k.Id">@k.Name (@k.Code)</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Grade</label>
                                    <select class="form-select" @bind="_portGradeId">
                                        <option value="">Select...</option>
                                        @if (_grades is not null)
                                        {
                                            @foreach (var g in _grades)
                                            {
                                                <option value="@g.Id">@g.Name (@g.Code)</option>
                                            }
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Qty Rule Mode</label>
                                <select class="form-select" @bind="_portQtyMode">
                                    @foreach (var m in Enum.GetValues<QuantityRuleMode>())
                                    {
                                        <option value="@m">@m</option>
                                    }
                                </select>
                            </div>
                            @if (_portQtyMode is QuantityRuleMode.Exactly or QuantityRuleMode.ZeroOrN)
                            {
                                <div class="mb-3">
                                    <label class="form-label">N <span class="text-muted small">(@(_portQtyMode == QuantityRuleMode.Exactly ? "must be exactly N" : "zero or N"))</span></label>
                                    <input type="number" class="form-control" min="1" @bind="_portQtyRuleN" placeholder="1" />
                                </div>
                            }
                            @if (_portQtyMode is QuantityRuleMode.Range or QuantityRuleMode.Unbounded)
                            {
                                <div class="row mb-3">
                                    <div class="col-6">
                                        <label class="form-label">Min</label>
                                        <input type="number" class="form-control" min="0" @bind="_portQtyRuleMin" placeholder="0" />
                                    </div>
                                    @if (_portQtyMode == QuantityRuleMode.Range)
                                    {
                                        <div class="col-6">
                                            <label class="form-label">Max</label>
                                            <input type="number" class="form-control" min="1" @bind="_portQtyRuleMax" placeholder="e.g. 10" />
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="col-6">
                                            <label class="form-label text-muted">Max</label>
                                            <input class="form-control" disabled value="unlimited" />
                                        </div>
                                    }
                                </div>
                            }
                        }

                        @if (_portType is PortType.Parameter or PortType.Characteristic)
                        {
                            <div class="row mb-3">
                                <div class="col-6">
                                    <label class="form-label">Data Type</label>
                                    <select class="form-select" @bind="_portDataType">
                                        @foreach (var dt in Enum.GetValues<DataValueType>())
                                        {
                                            <option value="@dt">@dt</option>
                                        }
                                    </select>
                                </div>
                                <div class="col-6">
                                    <label class="form-label">Units</label>
                                    <input class="form-control" @bind="_portUnits" placeholder="e.g. RPM, °C, mm" />
                                </div>
                            </div>
                            <div class="row mb-3">
                                <div class="col-4">
                                    <label class="form-label">Nominal</label>
                                    <input class="form-control" @bind="_portNominalValue" placeholder="Target value" />
                                </div>
                                <div class="col-4">
                                    <label class="form-label">Lower Tolerance</label>
                                    <input class="form-control" @bind="_portLowerTolerance" placeholder="e.g. -0.05" />
                                </div>
                                <div class="col-4">
                                    <label class="form-label">Upper Tolerance</label>
                                    <input class="form-control" @bind="_portUpperTolerance" placeholder="e.g. +0.05" />
                                </div>
                            </div>
                        }

                        @if (_portType == PortType.Condition)
                        {
                            <div class="alert alert-light border small mb-0">
                                <i class="bi bi-info-circle me-1"></i>Condition ports are binary pass/fail checkpoints. No additional metadata is required.
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label">Sort Order</label>
                            <input type="number" class="form-control" @bind="_portSortOrder" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" @onclick="ClosePortForm">Cancel</button>
                        <button type="button" class="btn btn-primary" @onclick="SavePort">
                            @(_editPortId.HasValue ? "Update" : "Save Port")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @* Edit Template Modal *@
    @if (_showEditForm)
    {
        <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Edit Step Template</h5>
                        <button type="button" class="btn-close" @onclick="() => _showEditForm = false"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Name</label>
                            <input class="form-control" @bind="_editName" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Description</label>
                            <textarea class="form-control" rows="3" @bind="_editDescription"></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Pattern</label>
                            <select class="form-select" @bind="_editPattern">
                                @foreach (var p in Enum.GetValues<StepPattern>())
                                {
                                    <option value="@p">@p</option>
                                }
                            </select>
                        </div>
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" id="editIsActive" @bind="_editIsActive" />
                            <label class="form-check-label" for="editIsActive">Active</label>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="() => _showEditForm = false">Cancel</button>
                        <button class="btn btn-primary" @onclick="SaveEdit">Update</button>
                    </div>
                </div>
            </div>
        </div>
    }
    @* Add / Edit Run Chart Modal *@
    @if (_showChartForm)
    {
        <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">@(_editChartId.HasValue ? "Edit Run Chart" : "Add Run Chart")</h5>
                        <button type="button" class="btn-close" @onclick="CloseChartForm"></button>
                    </div>
                    <div class="modal-body">
                        @if (!_editChartId.HasValue)
                        {
                            <h6 class="fw-semibold mb-3"><span class="badge bg-secondary me-2">1</span>Select source prompt</h6>
                            <div class="mb-3">
                                <label class="form-label">Process</label>
                                @if (_pickerProcesses is null)
                                {
                                    <div class="text-muted small"><span class="spinner-border spinner-border-sm me-1"></span>Loading processes…</div>
                                }
                                else
                                {
                                    <select class="form-select" @bind="_pickerProcessId" @bind:after="OnPickerProcessChanged">
                                        <option value="">Select a process…</option>
                                        @foreach (var p in _pickerProcesses)
                                        {
                                            <option value="@p.Id">@p.Code — @p.Name</option>
                                        }
                                    </select>
                                }
                            </div>
                            @if (_pickerSteps is not null)
                            {
                                <div class="mb-3">
                                    <label class="form-label">Step (step template)</label>
                                    <select class="form-select" @bind="_pickerStepTemplateId" @bind:after="OnPickerStepChanged">
                                        <option value="">Select a step…</option>
                                        @foreach (var s in _pickerSteps)
                                        {
                                            <option value="@s.StepTemplateId">@s.Sequence. [@s.StepTemplateCode] @s.StepTemplateName</option>
                                        }
                                    </select>
                                </div>
                            }
                            @if (_pickerPrompts is not null)
                            {
                                @if (_pickerPrompts.Count == 0)
                                {
                                    <div class="alert alert-warning py-2 small">This step has no NumericEntry prompts.</div>
                                }
                                else
                                {
                                    <div class="mb-3">
                                        <label class="form-label">Numeric Prompt</label>
                                        <select class="form-select" @bind="_pickerContentId" @bind:after="OnPickerPromptChanged">
                                            <option value="">Select a prompt…</option>
                                            @foreach (var pt in _pickerPrompts)
                                            {
                                                <option value="@pt.Id">@pt.Label @(!string.IsNullOrEmpty(pt.Units) ? $"({pt.Units})" : "")</option>
                                            }
                                        </select>
                                    </div>
                                }
                            }
                            <hr class="my-3" />
                        }
                        <h6 class="fw-semibold mb-3"><span class="badge bg-secondary me-2">@(_editChartId.HasValue ? "" : "2")</span>Chart settings</h6>
                        <div class="mb-3">
                            <label class="form-label">Chart label <span class="text-danger">*</span></label>
                            <input class="form-control" @bind="_chartLabel" placeholder="e.g. DI Water Resistivity" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Window size <span class="text-muted small fw-normal">(last N observations shown)</span></label>
                            <input type="number" class="form-control" @bind="_chartWindowSize" min="5" max="500" />
                        </div>
                        <div class="row">
                            <div class="col-6">
                                <label class="form-label">Spec Lower Limit (LSL)</label>
                                <input type="number" step="any" class="form-control" @bind="_chartSpecMin"
                                       placeholder="inherit from prompt" />
                            </div>
                            <div class="col-6">
                                <label class="form-label">Spec Upper Limit (USL)</label>
                                <input type="number" step="any" class="form-control" @bind="_chartSpecMax"
                                       placeholder="inherit from prompt" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="CloseChartForm">Cancel</button>
                        <button class="btn btn-primary" @onclick="SaveChart">
                            @(_editChartId.HasValue ? "Update" : "Add Chart")
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

    @* Lifecycle Modals *@
    @if (_showSubmitModal)
    {
        <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Submit for Approval</h5>
                        <button type="button" class="btn-close" @onclick="() => _showSubmitModal = false"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Submitted By</label>
                            <input class="form-control" @bind="_lifecycleUser" placeholder="Your name" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notes (optional)</label>
                            <textarea class="form-control" rows="2" @bind="_lifecycleNotes"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="() => _showSubmitModal = false">Cancel</button>
                        <button class="btn btn-primary" @onclick="SubmitForApproval">Submit</button>
                    </div>
                </div>
            </div>
        </div>
    }
    @if (_showApproveModal)
    {
        <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Approve Step Template</h5>
                        <button type="button" class="btn-close" @onclick="() => _showApproveModal = false"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Approved By</label>
                            <input class="form-control" @bind="_lifecycleUser" placeholder="Your name" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Notes (optional)</label>
                            <textarea class="form-control" rows="2" @bind="_lifecycleNotes"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="() => _showApproveModal = false">Cancel</button>
                        <button class="btn btn-success" @onclick="ApproveTemplate">Approve</button>
                    </div>
                </div>
            </div>
        </div>
    }
    @if (_showRejectModal)
    {
        <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Reject Step Template</h5>
                        <button type="button" class="btn-close" @onclick="() => _showRejectModal = false"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Rejected By</label>
                            <input class="form-control" @bind="_lifecycleUser" placeholder="Your name" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Rejection Reason</label>
                            <textarea class="form-control" rows="2" @bind="_lifecycleNotes"></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="() => _showRejectModal = false">Cancel</button>
                        <button class="btn btn-warning" @onclick="RejectTemplate">Reject</button>
                    </div>
                </div>
            </div>
        </div>
    }
    @if (_showNewRevisionModal)
    {
        <div class="modal show d-block" tabindex="-1" style="background: rgba(0,0,0,.5)">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">Create New Revision</h5>
                        <button type="button" class="btn-close" @onclick="() => _showNewRevisionModal = false"></button>
                    </div>
                    <div class="modal-body">
                        <p class="text-muted small">A new <strong>Draft</strong> copy of this step template will be created at v@(_st!.Version + 1).</p>
                        <div class="mb-3">
                            <label class="form-label">Requested By</label>
                            <input class="form-control" @bind="_lifecycleUser" placeholder="Your name" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="() => _showNewRevisionModal = false">Cancel</button>
                        <button class="btn btn-primary" @onclick="NewRevision">Create Revision</button>
                    </div>
                </div>
            </div>
        </div>
    }
}

@code {
    [Parameter] public Guid Id { get; set; }

    private StepTemplateResponseDto? _st;
    private bool _loading = true;

    private List<PortResponseDto> InputPorts =>
        _st?.Ports?.Where(p => p.Direction == PortDirection.Input).OrderBy(p => p.SortOrder).ToList() ?? new();
    private List<PortResponseDto> OutputPorts =>
        _st?.Ports?.Where(p => p.Direction == PortDirection.Output).OrderBy(p => p.SortOrder).ToList() ?? new();

    // Port form state
    private bool _showPortForm;
    private Guid? _editPortId;
    private PortDirection _portDirection;
    private string _portName = "";
    private PortType _portType = PortType.Material;
    // Material fields
    private string _portKindId = "";
    private string _portGradeId = "";
    private QuantityRuleMode _portQtyMode = QuantityRuleMode.Exactly;
    private int? _portQtyRuleN;
    private int? _portQtyRuleMin;
    private int? _portQtyRuleMax;
    // Parameter / Characteristic fields
    private DataValueType _portDataType = DataValueType.Decimal;
    private string _portUnits = "";
    private string _portNominalValue = "";
    private string _portLowerTolerance = "";
    private string _portUpperTolerance = "";
    private int _portSortOrder;

    // Edit template form state
    // Edit form
    private bool _showEditForm;
    private string _editName = "";

    // Lifecycle modals
    private bool _showSubmitModal;
    private bool _showApproveModal;
    private bool _showRejectModal;
    private bool _showNewRevisionModal;
    private string _lifecycleUser = "";
    private string _lifecycleNotes = "";
    private string? _editDescription;
    private StepPattern _editPattern;
    private bool _editIsActive;

    // Content block state
    private bool _contentLoading;
    private string? _contentError;
    private List<StepTemplateContentResponseDto> _contentBlocks = new();
    private bool _addingTextBlock;
    private string _newTextBody = string.Empty;
    private Guid? _editingTextBlockId;
    private string _editingTextBody = string.Empty;

    // Prompt block state
    private bool _addingPromptBlock;
    private string _newPromptLabel = string.Empty;
    private string _newPromptType = "NumericEntry";
    private bool _newPromptRequired = true;
    private string _newPromptUnits = string.Empty;
    private string _newPromptMin = string.Empty;
    private string _newPromptMax = string.Empty;
    private string _newPromptChoicesRaw = string.Empty;
    private Guid? _editingPromptBlockId;
    private string _editPromptLabel = string.Empty;
    private string _editPromptType = "NumericEntry";
    private bool _editPromptRequired = true;
    private string _editPromptUnits = string.Empty;
    private string _editPromptMin = string.Empty;
    private string _editPromptMax = string.Empty;
    private string _editPromptChoicesRaw = string.Empty;

    // Phase 8a — content categorisation + spec enrichment
    private string _newTextCategory = "";
    private string _editTextCategory = "";
    private string _newPromptCategory = "";
    private string _editPromptCategory = "";
    private string _newPromptNominal = string.Empty;
    private string _editPromptNominal = string.Empty;
    private bool _newPromptIsHardLimit;
    private bool _editPromptIsHardLimit;
    // Maturity state
    private MaturityReportDto? _maturityReport;
    private bool _showMaturityPanel;
    private bool _maturityLoading;

    // Run chart widget state
    private bool _chartsLoading;
    private List<RunChartWidgetResponseDto> _runChartWidgets = new();
    private bool _showChartForm;
    private Guid? _editChartId;
    private string _chartLabel = "";
    private int _chartWindowSize = 30;
    private decimal? _chartSpecMin;
    private decimal? _chartSpecMax;
    // Picker state
    private List<ProcessSummaryResponseDto>? _pickerProcesses;
    private string _pickerProcessId = "";
    private List<ProcessStepResponseDto>? _pickerSteps;
    private string _pickerStepTemplateId = "";
    private List<StepTemplateContentResponseDto>? _pickerPrompts;
    private string _pickerContentId = "";

    // Lookup data
    private PaginatedResponse<KindResponseDto>? _kinds;
    private List<GradeResponseDto>? _grades = new();

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        _loading = true;
        try
        {
            _st = await Api.GetStepTemplateAsync(Id);
        }
        catch (Exception ex)
        {
            Toast.ShowError($"Failed to load data: {ex.Message}");
        }
        finally
        {
            _loading = false;
        }
        _ = LoadContent();
        _ = LoadCharts();
    }

    private async Task LoadContent()
    {
        _contentLoading = true;
        _contentError = null;
        try
